---
import '../styles/global.css';
import { LOCALES, DEFAULT_LOCALE, dir, localePath, type Locale } from '../lib/i18n';
import { seo, ui } from '../lib/content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Display = Oswald variable (500–700), self-hosted. Latin-ext carries the Turkish
// glyphs (ğ ş İ ı); cyrillic carries RU display natively (no more Plex fallback).
import oswaldLatin from '../assets/fonts/oswald-latin.woff2?url';
import oswaldLatinExt from '../assets/fonts/oswald-latin-ext.woff2?url';
import oswaldCyrillic from '../assets/fonts/oswald-cyrillic.woff2?url';
import sansCyrillic from '@fontsource/ibm-plex-sans/files/ibm-plex-sans-cyrillic-600-normal.woff2?url';
import arabicBold from '@fontsource/ibm-plex-sans-arabic/files/ibm-plex-sans-arabic-arabic-700-normal.woff2?url';
import arabicRegular from '@fontsource/ibm-plex-sans-arabic/files/ibm-plex-sans-arabic-arabic-400-normal.woff2?url';

interface Props {
  locale: Locale;
  /** seo.<loc>.json pages key */
  page: string;
  /** route path without locale prefix, e.g. '/kurumsal' */
  path: string;
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { locale, page, path, title, description, noindex = false } = Astro.props;
const s = seo(locale);
const t = ui(locale);
const pageSeo = s.pages[page] ?? s.pages.home;
const docTitle = title ?? pageSeo.title;
const docDescription = description ?? pageSeo.description;
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = site + localePath(locale, path);
const ogImage = site + import.meta.env.BASE_URL.replace(/\/$/, '') + '/og-default.jpg';

const PRELOADS: Record<Locale, string[]> = {
  tr: [oswaldLatin, oswaldLatinExt],
  en: [oswaldLatin],
  ru: [oswaldCyrillic, sansCyrillic],
  ar: [arabicBold, arabicRegular],
};

const OG_LOCALES: Record<Locale, string> = {
  tr: 'tr_TR',
  en: 'en_US',
  ru: 'ru_RU',
  ar: 'ar_AR',
};
---

<!doctype html>
<html lang={locale} dir={dir(locale)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{docTitle}</title>
    <meta name="description" content={docDescription} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={l} href={site + localePath(l, path)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={site + localePath(DEFAULT_LOCALE, path)} />
    <link rel="icon" type="image/png" href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/favicon.png'} />
    <link rel="apple-touch-icon" href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/apple-touch-icon.png'} />
    <meta name="theme-color" content="#f4f4f2" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={s.siteName} />
    <meta property="og:title" content={docTitle} />
    <meta property="og:description" content={docDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={OG_LOCALES[locale]} />
    {PRELOADS[locale].map((href) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body class="bg-concrete-050 text-graphite-600 t-body min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-mey-red focus:text-white focus:px-4 focus:py-2"
    >
      {t.a11y.skipToContent}
    </a>
    <Header locale={locale} path={path} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} path={path} />

    <!-- Inline on purpose: reveals must not wait for a module fetch on slow networks -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.reveal');
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              });
            },
            { rootMargin: '0px 0px -10% 0px' }
          );
          els.forEach(function (el) { io.observe(el); });
        } else {
          els.forEach(function (el) { el.classList.add('is-visible'); });
        }
      })();
    </script>
  </body>
</html>
