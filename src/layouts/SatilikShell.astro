---
/*
  SATILIK DAİRELER vitrini için yalın kabuk: site Header/Footer'ı YOK — her tasarım
  yönü kendi navigasyonunu kurar (Base.astro bu yüzden kullanılmıyor). Global token
  ve tip sistemi global.css'ten gelir; sayfalar TR ve daima noindex'tir.
*/
import '../styles/global.css';
import oswaldLatin from '../assets/fonts/oswald-latin.woff2?url';
import oswaldLatinExt from '../assets/fonts/oswald-latin-ext.woff2?url';

interface Props {
  title: string;
  description: string;
  /** gövdeye tema sınıfı (örn. 'sv-album') */
  bodyClass?: string;
}

const { title, description, bodyClass = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="tr" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href={base + '/favicon.png'} />
    <meta name="theme-color" content="#f4f4f2" />
    <link rel="preload" href={oswaldLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={oswaldLatinExt} as="font" type="font/woff2" crossorigin />
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body class:list={['bg-concrete-050 text-graphite-600 t-body min-h-screen flex flex-col', bodyClass]}>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-mey-red focus:text-white focus:px-4 focus:py-2"
    >
      İçeriğe geç
    </a>
    <slot />

    <!-- Sessiz kaydırma-görünümü (Base ile aynı sözleşme: içerik JS'siz de görünür) -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.reveal');
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              });
            },
            { rootMargin: '0px 0px -10% 0px' }
          );
          els.forEach(function (el) { io.observe(el); });
        } else {
          els.forEach(function (el) { el.classList.add('is-visible'); });
        }
      })();
    </script>
  </body>
</html>
