---
import Base from '../layouts/Base.astro';
import PlaceholderChip from '../components/PlaceholderChip.astro';
import { type Locale } from '../lib/i18n';
import { ui, pageContent } from '../lib/content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui(locale);
const fm = pageContent('hizmetler', locale)?.frontmatter ?? {};

const photos = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/photos/*.webp',
  { eager: true }
);
const photo = (name: string) =>
  photos[`../assets/photos/${name}.webp`]!.default;
---

<Base locale={locale} page="services" path="/hizmetler">
  <section class="container-site section-pad">
    <div class="guide-line-v ps-6 sm:ps-10">
      <p class="t-tech text-mey-red mb-4">{t.nav.services.toUpperCase()}</p>
      <h1 class="t-display-xl">{fm.title}</h1>
      <p class="t-body-l mt-6 max-w-2xl">{fm.intro}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 mt-14">
      {(fm.services ?? []).map((svc: any) => (
        <div class:list={['card p-6', !svc.confirmed && 'border-dashed']}>
          {!svc.confirmed && (
            <p class="mb-3"><PlaceholderChip locale={locale} /></p>
          )}
          <h2 class="t-heading-m">{svc.name}</h2>
          <p class="t-body mt-3">{svc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-concrete-100 border-y border-line">
    <div class="container-site section-pad">
      <h2 class="t-display-l reveal">{fm.process?.title}</h2>
      <ol class="grid gap-px sm:grid-cols-2 lg:grid-cols-4 bg-line border border-line rounded-brand overflow-hidden mt-10 reveal">
        {(fm.process?.steps ?? []).map((step: any, i: number) => (
          <li class="bg-white p-5">
            <p class="t-tech text-mey-red">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="t-heading-s mt-3">{step.name}</h3>
            <p class="t-caption mt-2">{step.desc}</p>
          </li>
        ))}
      </ol>

      <div class="grid gap-4 sm:grid-cols-2 mt-10">
        {['planning-design-desk', 'materials-finish-palette'].map((name) => (
          <figure class="card overflow-hidden reveal">
            <Image
              src={photo(name)}
              alt={t.placeholder.representativeImage}
              widths={[640, 1024, 1600]}
              sizes="(min-width: 1024px) 640px, 100vw"
              class="w-full aspect-[4/3] object-cover"
            />
            <figcaption class="t-tech text-graphite-400 px-4 py-2 border-t border-line bg-white">
              {t.placeholder.representativeImage}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>
