---
import Base from '../layouts/Base.astro';
import { breadcrumbLd } from '../lib/schema';
import ContactRouteBoard from '../components/contact/ContactRouteBoard.astro';
import { type Locale } from '../lib/i18n';
import { ui } from '../lib/content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui(locale);
const jsonLd = breadcrumbLd(Astro.site, locale, [
  { name: t.nav.home, path: '/' },
  { name: t.nav.contact },
]);
---

<Base locale={locale} page="contact" path="/iletisim" jsonLd={jsonLd}>
  <ContactRouteBoard locale={locale} />
</Base>
