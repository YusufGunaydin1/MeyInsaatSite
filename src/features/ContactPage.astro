---
import Base from '../layouts/Base.astro';
import ContactRouteBoard from '../components/contact/ContactRouteBoard.astro';
import { type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Base locale={locale} page="contact" path="/iletisim">
  <ContactRouteBoard locale={locale} />
</Base>
