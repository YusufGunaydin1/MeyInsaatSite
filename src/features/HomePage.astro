---
import Base from '../layouts/Base.astro';
import HomeHero from '../components/HomeHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollToBuild from '../components/ScrollToBuild.astro';
import ConstructionJourney from '../components/ConstructionJourney.astro';
import MaterialsMood from '../components/MaterialsMood.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import WhyMey from '../components/WhyMey.astro';
import ContactCta from '../components/ContactCta.astro';
import ProjectTile from '../components/ProjectTile.astro';
import { localePath, type Locale } from '../lib/i18n';
import { ui, pageContent, projects } from '../lib/content';
import type { ImageMetadata } from 'astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui(locale);
const page = pageContent('home', locale);
const fm = page?.frontmatter ?? {};

const covers = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/projects/*.webp',
  { eager: true }
);
const cover = (name: string) =>
  covers[`../assets/projects/${name}.webp`]!.default;
const xrayOf = (name: string) =>
  covers[`../assets/projects/${name}-xray.webp`]?.default;
const projectList = projects(locale);
---

<Base locale={locale} page="home" path="/">
  <!-- HERO — dark cinematic cover that fuses with the dark header: a real
       delivered building, the friendly headline (the page's one h1) + CTAs.
       The scroll-to-build signature is the immediate second beat. -->
  <HomeHero locale={locale} />

  <!-- SIGNATURE — scroll-to-build (the one spectacular gesture) -->
  <ScrollToBuild locale={locale} />

  <!-- 01 — PROJECTS PREVIEW: the real portfolio, same tiles as /projeler -->
  <section class="container-site section-pad">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <SectionHeading
        eyebrow={fm.sections?.projects?.eyebrow}
        title={fm.sections?.projects?.title}
        intro={fm.sections?.projects?.intro}
      />
      <a href={localePath(locale, '/projeler')} class="btn-ghost reveal">{t.cta.allProjects}</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mt-10">
      {projectList.map((p, i) => (
        <div class="reveal" style={`transition-delay: ${i * 70}ms`}>
          <ProjectTile
            index={String(i + 1).padStart(2, '0')}
            title={p.md?.frontmatter?.name ?? p.slug}
            caption={p.md?.frontmatter?.summary}
            image={cover(p.data.cover)}
            xray={xrayOf(p.data.cover)}
            alt={p.md?.frontmatter?.name ?? p.slug}
            href={localePath(locale, `/projeler/${p.slug}`)}
            portrait
          />
        </div>
      ))}
    </div>
  </section>

  <!-- 02 — ON SITE (real construction stages) -->
  <ConstructionJourney locale={locale} />

  <!-- 03 — SERVICES / CAPABILITIES -->
  <section class="bg-concrete-100 border-y border-line">
    <div class="container-site section-pad">
      <SectionHeading
        eyebrow={fm.sections?.services?.eyebrow}
        title={fm.sections?.services?.title}
        intro={fm.sections?.services?.intro}
      />
      <div class="mt-12">
        <ProcessSteps
          steps={pageContent('hizmetler', locale)?.frontmatter?.process?.steps ?? []}
        />
      </div>
      <div class="mt-8">
        <a href={localePath(locale, '/hizmetler')} class="btn-ghost">{t.nav.services}</a>
      </div>
    </div>
  </section>

  <!-- 04 — MATERIALS & TEXTURE -->
  <MaterialsMood locale={locale} />

  <!-- 05 — WHY MEY (real numbers + promises, replaces the old stats grid) -->
  <WhyMey locale={locale} />

  <!-- 06 — CONTACT CTA (closing gesture) -->
  <ContactCta locale={locale} />
</Base>
