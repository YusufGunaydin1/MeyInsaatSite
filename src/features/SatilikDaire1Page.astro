---
/*
  DAİRE DETAY — D-11 / Daire 1 (canlı; tasarım: daire-detay-ref-a mock).
  Başlık+satış durumu → galeri | künye → çapa sekmeleri → matris + genel bakış
  → konum → satış durumu + SSS → benzer daireler; sağda yapışkan ray.
  NOINDEX (bilerek): daire SATILDI + m²/kat İÇ TAHMİN; Google'a gönderilmez
  (sitemap'ten de dışlanır). Arayüzde temsilî ibaresi YOK.
*/
import Base from '../layouts/Base.astro';
import Icon from '../components/showcase/satilik/kompakt/Icon.astro';
import Breadcrumb from '../components/showcase/satilik/kompakt/Breadcrumb.astro';
import SpecGrid from '../components/showcase/satilik/kompakt/SpecGrid.astro';
import AvailabilityMatrix from '../components/showcase/satilik/kompakt/AvailabilityMatrix.astro';
import MapPanel from '../components/showcase/satilik/kompakt/MapPanel.astro';
import FaqList from '../components/showcase/satilik/kompakt/FaqList.astro';
import SimilarUnits from '../components/showcase/satilik/kompakt/SimilarUnits.astro';
import StickyRail from '../components/showcase/satilik/kompakt/StickyRail.astro';
import SoonDialog from '../components/showcase/satilik/kompakt/SoonDialog.astro';
import Carousel from '../components/showcase/satilik/kompakt/Carousel.tsx';
import { carouselItems } from '../components/showcase/satilik/kompakt/assets.ts';
import { detay, specsD1, proje, RECENTLY_SOLD_LABEL } from '../components/showcase/satilik/kompakt/data.ts';
import { localePath, type Locale } from '../lib/i18n';
import { ui } from '../lib/content';
import '../components/showcase/satilik/kompakt/kompakt.css';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui(locale);
const basePrefix = localePath(locale, '/').replace(/\/$/, '');
const root = basePrefix + '/satilik-daireler';

const d = detay['daire-1'];
const items = await carouselItems([...d.galeri]);

const sekmeler = [
  { id: 'genel', label: 'Genel Bilgiler' },
  { id: 'konum-secimi', label: 'Daire Konumu' },
  { id: 'konum', label: 'Konum' },
  { id: 'durum', label: 'Satış Durumu' },
  { id: 'sss', label: 'SSS' },
  { id: 'benzer', label: 'Benzer Daireler' },
];

const projeDetay = [
  { label: 'Proje Adı', value: proje.ad },
  { label: 'Yapımcı / Satıcı', value: 'Mey İnşaat' },
  { label: 'Blok / Kat', value: `${proje.blok} blok · ${proje.kat} kat` },
  { label: 'Toplam Daire', value: String(proje.toplamDaire) },
  { label: 'Proje Durumu', value: proje.durum },
  { label: 'Teslim', value: proje.teslim },
];
---

<Base
  locale={locale}
  page="satilik"
  path="/satilik-daireler/daire-1"
  title={d.baslik + ' — MEY İnşaat'}
  description="El Ele Apartmanı D-11: yakın zamanda satılan deniz manzaralı 3+2 dubleks — galeri ve künye."
  noindex
>
  <div class="container-site kcd-crumbwrap">
    <Breadcrumb items={[
      { label: t.nav.home, href: localePath(locale, '/') },
      { label: t.nav.forSale, href: root },
      { label: proje.ad, href: root },
      { label: '3+2 Dubleks · D-11' },
    ]} />
  </div>

  <!-- BAŞLIK + SATIŞ DURUMU -->
  <header class="container-site kcd-head">
    <div class="kcd-head-main">
      <h1 class="kcd-title">{d.baslik}</h1>
      <p class="kcd-chips">
        <span class="t-tech kcd-chip is-red" data-testid="kc-sold-status">{RECENTLY_SOLD_LABEL}</span>
        <span class="t-tech kcd-chip">DUBLEKS</span>
        <span class="t-tech kcd-meta"><Icon name="pin" size={13} /> {proje.lokasyon}</span>
        <span class="t-tech kcd-meta">{d.unit.kat} · {d.unit.no} · Brüt {d.unit.brut} m² / Net {d.unit.net} m²</span>
      </p>
    </div>
    <div class="kcd-head-price">
      <p class="t-caption kcd-sold-summary">Satış işlemi tamamlandı</p>
    </div>
    <div class="kcd-head-actions">
      <a class="kcd-mini" href={root + '/daire-2'} data-testid="kc-compare"><Icon name="compare" size={15} /> Satıştaki D-12’yi İncele</a>
    </div>
  </header>

  <!-- GÖVDE: sol içerik + sağ ray -->
  <div class="container-site kcd-layout">
    <div class="kcd-main">
      <section class="kcg" id="genel" data-gallery aria-label="Galeri ve künye">
        <Carousel client:load items={items} label={d.baslik + ' fotoğrafları'} />
        <div class="kcg-specside card">
          <h2 class="t-heading-s">Künye</h2>
          <SpecGrid items={specsD1} columns={1} testid="kc-specs-d1" />
        </div>
      </section>

      <nav class="kcd-tabs" aria-label="Sayfa bölümleri">
        {sekmeler.map((s) => <a href={'#' + s.id}>{s.label}</a>)}
      </nav>

      <section class="kcd-block" aria-label="Proje detayları">
        <div class="kcd-two">
          <div class="card kcd-card">
            <h2 class="t-heading-s">Proje Detayları</h2>
            <SpecGrid items={projeDetay} columns={1} testid="kc-specs-proje" />
          </div>
          <div class="card kcd-card">
            <h2 class="t-heading-s">Daireye Genel Bakış</h2>
            <ul class="kcd-checklist" data-testid="kc-genel-bakis">
              {d.genelBakis.map((g) => (
                <li><Icon name="check" size={16} /> {g}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="kcd-block" id="konum-secimi" aria-label="Blok, kat ve daire konumu">
        <AvailabilityMatrix />
      </section>

      <section class="kcd-block" id="konum" aria-label="Konum ve yakın çevre">
        <MapPanel title="Yakın Çevre" locale={locale} />
      </section>

      <section class="kcd-block" id="durum" aria-label="Satış durumu ve sorular">
        <div class="kcd-two">
          <div class="card kcd-card kcd-sold-card" data-testid="kc-sold-detail">
            <p class="t-tech kcd-sold-kicker">{RECENTLY_SOLD_LABEL}</p>
            <h2 class="t-heading-s kcd-sold-title">Bu dairenin satış işlemi tamamlandı.</h2>
            <p class="t-caption kcd-sold-text">D-11 arşiv ve galeri bilgileri için yayında kalır. Satıştaki D-12 dairesini inceleyebilirsiniz.</p>
            <a class="kcd-sold-next" href={root + '/daire-2'} data-testid="kc-sold-next">13.750.000 TL fiyatlı D-12’yi incele <Icon name="arrow-right" size={15} /></a>
          </div>
          <div class="card kcd-card" id="sss"><FaqList /></div>
        </div>
      </section>

      <section class="kcd-block" id="benzer">
        <SimilarUnits current="daire-1" base={basePrefix} />
      </section>
    </div>

    <StickyRail konu="D-11 (satıldı) · benzer daireler" base={basePrefix} />
  </div>

  <SoonDialog />
</Base>

<style>
  .kcd-crumbwrap { padding-block: 0.9rem 0.4rem; }
  .kcd-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.4rem 1.5rem;
    align-items: start;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--color-line);
  }
  .kcd-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    line-height: 1.15;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--color-graphite-900);
  }
  .kcd-chips { display: flex; align-items: center; gap: 0.5rem 0.8rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .kcd-chip { padding: 0.2rem 0.5rem; border-radius: var(--radius-brand); border: 1px solid var(--color-line); color: var(--color-graphite-600); }
  .kcd-chip.is-red { background: var(--color-mey-red); border-color: var(--color-mey-red); color: #fff; }
  .kcd-chip.is-teal { border-color: var(--color-mey-teal-700); color: var(--color-mey-teal-700); }
  .kcd-meta { display: inline-flex; align-items: center; gap: 0.3rem; color: var(--color-graphite-400); }
  .kcd-head-price { text-align: end; display: flex; flex-direction: column; align-items: flex-end; gap: 0.2rem; }
  .kcd-sold-summary { color: var(--color-mey-red); font-weight: 600; }
  .kcd-head-actions { grid-column: 1 / -1; display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.2rem; }
  .kcd-mini {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-graphite-600);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .kcd-mini:hover { color: var(--color-mey-red); }

  .kcd-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 1.5rem;
    padding-block: 1.25rem 2.25rem;
    align-items: start;
  }
  .kcd-main { display: flex; flex-direction: column; gap: 1.25rem; min-width: 0; }
  .kcd-tabs {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    border-bottom: 2px solid var(--color-line);
  }
  .kcd-tabs a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-graphite-600);
    padding: 0.5rem 0.8rem;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
  }
  .kcd-tabs a:hover { color: var(--color-mey-red); border-color: var(--color-mey-red); }
  .kcd-two { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; align-items: start; }
  .kcd-card { padding: 1rem 1.1rem 1.1rem; }
  .kcd-checklist { margin-top: 0.6rem; display: flex; flex-direction: column; gap: 0.45rem; }
  .kcd-checklist li { display: flex; align-items: baseline; gap: 0.5rem; font-size: 0.875rem; }
  .kcd-checklist :global(svg) { color: var(--color-mey-teal-700); flex-shrink: 0; transform: translateY(2px); }
  .kcd-sold-card { border-inline-start: 3px solid var(--color-mey-red); }
  .kcd-sold-kicker { color: var(--color-mey-red); font-weight: 600; }
  .kcd-sold-title { margin-top: 0.35rem; }
  .kcd-sold-text { margin-top: 0.45rem; color: var(--color-graphite-600); }
  .kcd-sold-next {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.8rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-mey-red);
  }
  .kcd-sold-next:hover { color: var(--color-mey-red-700); text-decoration: underline; }

  @media (max-width: 1023px) {
    .kcd-layout { grid-template-columns: minmax(0, 1fr); }
    .kcd-head { grid-template-columns: minmax(0, 1fr); }
    .kcd-head-price { text-align: start; align-items: flex-start; }
    .kcd-two { grid-template-columns: minmax(0, 1fr); }
  }

  @media (max-width: 640px) {
    .kcd-crumbwrap { padding-block: 0.55rem 0.25rem; }
    .kcd-crumbwrap :global(.kc-crumb ol) {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.15rem;
      scrollbar-width: none;
    }
    .kcd-crumbwrap :global(.kc-crumb li) { flex-shrink: 0; font-size: 0.7rem; }
    .kcd-head { gap: 0.3rem; padding-bottom: 0.4rem; }
    .kcd-title { font-size: 1.15rem; line-height: 1.12; }
    .kcd-chips { gap: 0.35rem 0.45rem; margin-top: 0.35rem; }
    .kcd-chip { padding: 0.15rem 0.35rem; font-size: 0.625rem; }
    .kcd-meta { font-size: 0.625rem; }
    .kcd-head-price {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.25rem 0.45rem;
      text-align: start;
    }
    .kcd-head-price :global(.kc-mock) { margin-inline-start: auto; padding: 0.2rem 0.4rem; font-size: 0.6rem; }
    .kcd-head-actions { display: grid; grid-template-columns: minmax(0, 1fr); gap: 0.45rem; margin-top: 0; }
    .kcd-mini {
      justify-content: center;
      min-height: 40px;
      padding: 0.35rem 0.45rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-brand);
      font-size: 0.7rem;
      text-align: center;
    }
    .kcd-layout { gap: 1rem; padding-block: 0.75rem 1.5rem; }
    .kcd-main { gap: 1rem; }
    .kcd-tabs { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; }
    .kcd-tabs a { flex-shrink: 0; padding: 0.45rem 0.6rem; font-size: 0.75rem; }
    .kcd-card { padding: 0.8rem; }
  }
</style>
