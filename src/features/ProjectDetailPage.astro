---
import Base from '../layouts/Base.astro';
import PlaceholderChip from '../components/PlaceholderChip.astro';
import ProjectStory from '../components/ProjectStory.astro';
import XrayReveal from '../components/XrayReveal.astro';
import DetailStage from '../components/projectDetail/DetailStage.astro';
import { localePath, type Locale } from '../lib/i18n';
import { ui, seo, project, projectDetailOverride, mergeDeep } from '../lib/content';
import { breadcrumbLd, buildingLd } from '../lib/schema';
import { listingProjeler, listing, DETAY_SLUG, tl } from '../components/showcase/satilik/kompakt/data.ts';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const t = ui(locale);
const entry = project(slug, locale);
if (!entry) throw new Error(`Unknown project slug: ${slug}`);
const { data } = entry;
const fm = entry.md?.frontmatter ?? {};
const Content = entry.md?.Content;

const imgs = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/projects/*.webp',
  { eager: true }
);
const img = (name: string) => imgs[`../assets/projects/${name}.webp`]?.default;
const cover = img(data.cover);
// Pixel-aligned cutaway twin (facade removed): powers the x-ray hover lens.
const coverXray = img(`${data.cover}-xray`);
const gallery = (data.gallery ?? []).map(img).filter(Boolean) as ImageMetadata[];
const stages: string[] = data.stages ?? [];

// DetailStage metni: paylaşımlı varsayılan + (varsa) bu projenin kendi metni.
// Override yoksa (Maşuk) sonuç varsayılana birebir eşittir.
const detail = mergeDeep(t.projects.detail, projectDetailOverride(slug, locale));

const specs = [
  { label: t.projects.specs.location, value: data.location },
  { label: t.projects.specs.type, value: t.projects.types?.[data.type] ?? data.type },
  { label: t.projects.specs.status, value: t.projects.status[data.status] ?? data.status },
  { label: t.projects.specs.year, value: data.year },
  { label: t.projects.specs.units, value: data.units },
];

// Yatay detay sahnesi: galeri seti TAM olan projelerde (bugün üç bina da).
// Eksik setli projeler dürüst basit hero'da kalır — asla temsilî dolgu yok.
const stageImgs = {
  salon: img(`${slug}-salon`)!,
  mutfak: img(`${slug}-mutfak`)!,
  cephe: img(`${slug}-cephe-cizim`)!,
  izometrik: img(`${slug}-izometrik`)!,
  vaziyet: img(`${slug}-vaziyet`)!,
  malzeme: img(`${slug}-malzeme`)!,
  dokular: ['beton', 'tugla', 'cam', 'metal'].map((d) => img(`${slug}-doku-${d}`)!),
};
const hasStage =
  !!cover &&
  Object.values(stageImgs).every(Boolean) &&
  stageImgs.dokular.every(Boolean);
const typeLabel = String(t.projects.types?.[data.type] ?? data.type).toLocaleUpperCase(locale);
const statusLabel = String(t.projects.status[data.status] ?? data.status).toLocaleUpperCase(locale);
/* Bu binada CANLI satılık daire var mı? Varsa sayfadan ilana bağlamsal bir
   bağlantı çıkar: satış sayfasına giden tek yol menüdeki "Satılık" değil, bu.
   Kaynak satılık verisinin kendisi — bina adı burada elle yazılmaz. */
// Satılık bölümü henüz yalnız Türkçe (bkz. SatilikPage trOnly) → bağlantı da TR'de.
const projeKarti = locale === 'tr' ? listingProjeler.find((lp) => lp.slug === slug) : undefined;
const canliDaire = projeKarti && !projeKarti.sold
  ? listing.find((u) => u.projeKey === projeKarti.projeKey && u.durum === 'musait')
  : undefined;
const canliDaireHref = canliDaire
  ? localePath(locale, `/satilik-daireler/${DETAY_SLUG[canliDaire.detay!]}`)
  : null;

const seoTpl = seo(locale).pages.projectDetail ?? {};
const fill = (tpl: string | undefined, fallback: string) =>
  (tpl ?? fallback)
    .replace('{name}', fm.name ?? slug)
    .replace('{district}', data.district ?? 'Pendik')
    .replace('{summary}', fm.summary ?? '')
    .replace('{location}', data.location ?? '');
const detailTitle = fill(seoTpl.titleTemplate, '{name} — MEY İnşaat');
const detailDescription = fill(seoTpl.descriptionTemplate, '{summary}');
const jsonLd = [
  breadcrumbLd(Astro.site, locale, [
    { name: t.nav.home, path: '/' },
    { name: t.nav.projects, path: '/projeler' },
    { name: fm.name ?? slug },
  ]),
  buildingLd(Astro.site, locale, data as any, fm.name ?? slug, fm.summary),
];
---

<Base
  locale={locale}
  page="projects"
  path={`/projeler/${slug}`}
  title={detailTitle}
  description={detailDescription}
  jsonLd={jsonLd}
>
  <!-- Geri bağlantısı — her iki hero varyantının üstünde ortak -->
  <div class="container-site pd-back-pad">
    <a href={localePath(locale, '/projeler')} class="t-tech pd-back">
      <span aria-hidden="true" class="rtl:-scale-x-100 inline-block">←</span> {t.cta.allProjects}
    </a>
  </div>

  {canliDaire && canliDaireHref && (
    <div class="container-site pd-sale-pad">
      <a href={canliDaireHref} class="pd-sale" data-testid="pd-sale-link">
        <span class="pd-sale-tag t-tech">SATILIK</span>
        <span class="pd-sale-text">
          Bu binada satılık {canliDaire.baslik.toLocaleLowerCase('tr')} var —
          {' '}{canliDaire.brut} m² brüt, {canliDaire.kat}
          {canliDaire.fiyat !== null && <>, {tl(canliDaire.fiyat)}</>}
        </span>
        <span class="pd-sale-go" aria-hidden="true">→</span>
      </a>
    </div>
  )}

  {/* Yatay detay sahnesi: foto sabit solda, sağ pencere scroll ile üç kareyi tarar.
      Galeri seti eksikse dürüst basit hero (aşağıdaki) kalır. */}
  {hasStage && cover ? (
    <DetailStage
      locale={locale}
      name={fm.name ?? slug}
      typeLabel={typeLabel}
      statusLabel={statusLabel}
      cover={cover}
      coverXray={coverXray}
      imgs={stageImgs}
      detail={detail}
      mapQuery={data.location}
      mapCoordinates={data.coordinates}
    />
  ) : (
    <section class="container-site pd-hero-pad">
      <div class="pd-hero">
        <figure class="pd-hero-media reveal">
          {cover && coverXray ? (
            <XrayReveal
              base={cover}
              xray={coverXray}
              alt={fm.name ?? slug}
              widths={[600, 900, 1200]}
              sizes="(min-width: 900px) 44vw, 100vw"
              radius={85}
              eager
            />
          ) : cover ? (
            <Image
              src={cover}
              alt={fm.name ?? slug}
              widths={[600, 900, 1200]}
              sizes="(min-width: 900px) 44vw, 100vw"
              loading="eager"
              class="pd-hero-img"
            />
          ) : null}
        </figure>

        <div class="pd-hero-info guide-line-v reveal">
          <p class="t-tech text-mey-red mb-3">{t.nav.projects.toUpperCase()}</p>
          <h1 class="t-display-l">{fm.name}</h1>
          <p class="t-body-l mt-4">{fm.summary}</p>

          <dl class="pd-specs mt-8">
            {specs.map((s) => (
              <div class="pd-spec">
                <dt class="t-tech text-graphite-400">{s.label}</dt>
                <dd class="t-heading-s mt-1 tabular-nums">
                  {s.value ?? <PlaceholderChip locale={locale} />}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>
  )}

  <!-- CONSTRUCTION STORY — this building's real time-lapse (skipped if no frames) -->
  {stages.length > 0 && <ProjectStory locale={locale} stages={stages} />}

  <!-- GALLERY — only when real extra photos exist (none yet; forward-compatible) -->
  {gallery.length > 0 && (
    <section class="container-site section-pad">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {gallery.map((g) => (
          <figure class="card overflow-hidden reveal">
            <Image src={g} alt={fm.name ?? slug} widths={[480, 800, 1200]} sizes="(min-width:1024px) 420px, 100vw" class="w-full aspect-[4/3] object-cover" />
          </figure>
        ))}
      </div>
    </section>
  )}

  <!-- STORY / PROSE -->
  {Content && (
    <section class="container-site pd-prose-pad">
      <article class="max-w-3xl t-body guide-line-v ps-6 sm:ps-10 reveal">
        <Content />
      </article>
    </section>
  )}
</Base>

<style>
  .pd-sale-pad { padding-block: 0 1.25rem; }
  .pd-sale {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-line);
    border-inline-start: 3px solid var(--color-mey-red);
    border-radius: var(--radius-brand);
    background: #fff;
    color: var(--color-graphite-900);
    text-decoration: none;
  }
  .pd-sale:hover { border-color: var(--color-graphite-400); }
  .pd-sale-tag {
    color: var(--color-mey-red);
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }
  .pd-sale-text { font-size: 0.9375rem; line-height: 1.4; }
  .pd-sale-go { margin-inline-start: auto; color: var(--color-mey-red); }

  .pd-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-graphite-400);
  }
  .pd-back:hover { color: var(--color-mey-red); }
  .pd-back-pad { padding-block-start: clamp(2.5rem, 6vh, 4rem); }
  .pd-hero-pad { padding-block: 1.5rem clamp(4rem, 10vh, 8rem); }

  .pd-hero { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) {
    .pd-hero { grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr); gap: 3.5rem; align-items: start; }
  }
  .pd-hero-media {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
  }
  .pd-hero-img { width: 100%; height: auto; display: block; aspect-ratio: 3 / 4; object-fit: cover; }
  .pd-hero-info { padding-inline-start: 1.5rem; }
  @media (min-width: 900px) { .pd-hero-info { position: sticky; top: 6rem; } }

  .pd-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    overflow: hidden;
  }
  @media (min-width: 480px) { .pd-specs { grid-template-columns: repeat(3, 1fr); } }
  .pd-spec { background: #fff; padding: 1rem; }

  .pd-prose-pad { padding-block: clamp(2.5rem, 6vh, 4.5rem) clamp(4rem, 10vh, 8rem); }
</style>
