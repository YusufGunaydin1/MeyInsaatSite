---
/*
  DAİRE DETAY — D-12 / Daire 2 (canlı). Üst bölge 2026-07-16'da D-11'in
  varsayılanına eşitlendi: galeri | künye (.kcg, ortak); eski ref-b geniş karusel
  artık galeri adasındaki ⟷ anahtarıyla SEÇMELİ geniş görünüm. Sayfanın geri
  kalanı ref-b kimliğini korur: özellik çipleri, oda ölçüleri, genel bakış +
  proje + konum üçlüsü, kendi benzer sırası.
  İNDEKSLENİR: veriler gerçek (sahibinden ilan 1317631166) — noindex kaldırıldı.
*/
import { Image, getImage } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Icon from '../components/showcase/satilik/kompakt/Icon.astro';
import Breadcrumb from '../components/showcase/satilik/kompakt/Breadcrumb.astro';
import SpecGrid from '../components/showcase/satilik/kompakt/SpecGrid.astro';
import MapPanel from '../components/showcase/satilik/kompakt/MapPanel.astro';
import FaqList from '../components/showcase/satilik/kompakt/FaqList.astro';
import SimilarUnits from '../components/showcase/satilik/kompakt/SimilarUnits.astro';
import StickyRail from '../components/showcase/satilik/kompakt/StickyRail.astro';
import MobileSaleBar from '../components/showcase/satilik/kompakt/MobileSaleBar.astro';
import Carousel from '../components/showcase/satilik/kompakt/Carousel.tsx';
import { carouselItems } from '../components/showcase/satilik/kompakt/assets.ts';
import { detay, specsD2, odaOlculeriD2, tl, proje, sss, DETAY_SLUG } from '../components/showcase/satilik/kompakt/data.ts';
import { building } from '../components/showcase/satilik/data.ts';
import { publicAsset, entry } from '../components/showcase/satilik/media.ts';
import { localePath, type Locale } from '../lib/i18n';
import { ui } from '../lib/content';
import '../components/showcase/satilik/kompakt/kompakt.css';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui(locale);
const basePrefix = localePath(locale, '/').replace(/\/$/, '');
const root = localePath(locale, '/satilik-daireler');

const d = detay['daire-2'];
const items = await carouselItems([...d.galeri]);

const binaKey = 'daire-1/bina-dis.png';
const bina = { img: publicAsset(binaKey), alt: entry(binaKey).alt };

/* Özellik çipleri — fotoğrafların desteklediği + oda ölçüleri modülünden gelen değerler */
const ozellikler = [
  { icon: 'sea', title: 'Çatı Terası', sub: '~20 m²' },
  { icon: 'stairs', title: 'Dubleks', sub: 'İki katlı yaşam' },
  { icon: 'cart', title: 'İkinci Mutfak', sub: 'Üst kat nişi' },
  { icon: 'car', title: 'Kapalı Otopark', sub: 'Bina içinde' },
  { icon: 'expand', title: 'Dam Pencereleri', sub: 'Üç çatı odası' },
  { icon: 'shield', title: '2 Banyo', sub: 'Siyah profil duş' },
];

/* ─── SEO: yayın slug'u, kanonik yol, OG görseli (gerçek daire), JSON-LD ─── */
const slug = DETAY_SLUG['daire-2'];
const detailPath = `/satilik-daireler/${slug}`;
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://meyinsaat.com';
const detailUrl = siteUrl + localePath(locale, detailPath);
const abs = (s: string) => (s.startsWith('http') ? s : siteUrl + s);

// Paylaşım/reklam önizlemesi = gerçek dairenin salonu (1200×630); şema için de birkaç gerçek kare.
const ogHero = await getImage({ src: publicAsset('daire-2/d2-salon-ust-1.png'), width: 1200, height: 630, fit: 'cover', format: 'jpeg', quality: 72 });
const ogTeras = await getImage({ src: publicAsset('daire-2/d2-teras.png'), width: 1200, format: 'webp', quality: 74 });
const ogBina = await getImage({ src: publicAsset(binaKey), width: 1200, format: 'webp', quality: 74 });
const schemaImages = [abs(ogHero.src), abs(ogTeras.src), abs(ogBina.src)];

const metaTitle = 'Pendik Satılık 3+2 Çatı Dubleksi — El Ele Apartmanı D-12';
const metaDesc =
  "Pendik El Ele Apartmanı'nda sıfır 3+2 çatı dubleksi (D-12): 160/135 m², 5. kat, çatı terası, 2 banyo, kapalı otopark. 13.750.000 TL — yerinde gezin.";
const h1 = 'Pendik Satılık 3+2 Çatı Dubleksi — El Ele Apartmanı';

// og:type=product için fiyat meta'ları (scraper'lar fiyatı önizlemede göstersin)
const extraMeta = [
  { property: 'product:price:amount', content: '13750000' },
  { property: 'product:price:currency', content: 'TRY' },
  { property: 'og:availability', content: 'instock' },
];

/* JSON-LD @graph — YALNIZ doğrulanmış D-12 değerleri (sahibinden 1317631166).
   Tahminler (oda m², mesafeler) ŞEMAYA GİRMEZ. */
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Product', 'Residence'],
      '@id': detailUrl + '#unit',
      name: 'El Ele Apartmanı — Çatı Avlulu 3+2 Dubleks (D-12)',
      description:
        "Pendik Batı Mah. sıfır El Ele Apartmanı'nda 5. kat çatı dubleksi: 160 m² brüt / 135 m² net, 3+2, 2 banyo, çatı terası, kapalı otopark.",
      url: detailUrl,
      image: schemaImages,
      brand: { '@type': 'Organization', name: 'MEY İnşaat' },
      category: 'Satılık Daire',
      numberOfRooms: 5,
      numberOfBedrooms: 3,
      numberOfBathroomsTotal: 2,
      floorSize: { '@type': 'QuantitativeValue', value: 160, unitCode: 'MTK' },
      floorLevel: '5',
      numberOfFloors: 2,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Batı Mah. Çiğdem Sok. No:6',
        addressLocality: 'Pendik',
        addressRegion: 'İstanbul',
        addressCountry: 'TR',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 40.875102, longitude: 29.227424 },
      offers: {
        '@type': 'Offer',
        price: 13750000,
        priceCurrency: 'TRY',
        availability: 'https://schema.org/InStock',
        priceValidUntil: '2026-12-31',
        url: detailUrl,
        seller: { '@id': siteUrl + '/#org' },
      },
    },
    {
      '@type': 'RealEstateListing',
      '@id': detailUrl + '#listing',
      url: detailUrl,
      name: 'El Ele Apartmanı 3+2 Dubleks — Satılık (D-12)',
      datePosted: '2026-07-21',
      mainEntity: { '@id': detailUrl + '#unit' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t.nav.home, item: siteUrl + localePath(locale, '/') },
        { '@type': 'ListItem', position: 2, name: t.nav.forSale, item: siteUrl + localePath(locale, '/satilik-daireler') },
        { '@type': 'ListItem', position: 3, name: '3+2 Dubleks · D-12' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: sss.map((q) => ({
        '@type': 'Question',
        name: q.soru,
        acceptedAnswer: { '@type': 'Answer', text: q.cevap },
      })),
    },
  ],
};
/* EN/RU/AR satılık sayfaları gövde metnini HENÜZ çevirmiyor (künye, oda adları,
   açıklamalar TR). Çeviri gelene kadar bu üç dil noindex ve hreflang kümesi
   dışında: aynı Türkçe metni "İngilizce sayfa" diye ilan etmek yeni bir alan
   adında kopya içerik sinyalidir. TR sayfa etkilenmez. */
const trOnly = locale !== 'tr';
---

<Base
  locale={locale}
  page="satilik"
  path={detailPath}
  title={metaTitle}
  description={metaDesc}
  ogType="product"
  ogImage={ogHero.src}
  ogImageAlt="El Ele Apartmanı D-12 — çatı avlulu 3+2 dubleks üst kat salonu, Pendik"
  jsonLd={jsonLd}
  extraMeta={extraMeta}
  noindex={trOnly}
  hreflangLocales={[locale]}
>
  <div class="container-site kce-crumbwrap">
    <Breadcrumb items={[
      { label: t.nav.home, href: localePath(locale, '/') },
      { label: t.nav.forSale, href: root },
      { label: proje.ad, href: root },
      { label: '3+2 Dubleks · D-12' },
    ]} />
  </div>

  <!-- BAŞLIK ŞERİDİ -->
  <header class="container-site kce-head">
    <div>
      <h1 class="kce-title">{h1}</h1>
      <p class="kce-meta">
        <span class="t-tech"><Icon name="pin" size={13} /> {proje.lokasyon}</span>
        <span class="t-tech">{proje.ad}</span>
        <span class="t-tech">3+2 Dubleks</span>
        <span class="t-tech">{d.unit.brut} m² / {d.unit.net} m²</span>
        <span class="t-tech">{d.unit.kat}</span>
        <span class="t-tech">No: {d.unit.no}</span>
      </p>
    </div>
    <div class="kce-price-box">
      <p class="kce-price tabular-nums" data-testid="kc-price">{tl(d.unit.fiyat!)}</p>
      <p class="t-caption kce-kdv">KDV Dahil</p>
    </div>
  </header>

  <!-- GÖVDE -->
  <div class="container-site kce-layout">
    <div class="kce-main">
      <section class="kcg kcg-hasmap" data-gallery aria-label="Galeri, konum ve künye">
        <div class="kcg-media">
          <Carousel client:load items={items} label={d.baslik + ' fotoğrafları'} />
          <MapPanel mode="map" locale={locale} />
        </div>
        <div class="kcg-specside card">
          <h2 class="t-heading-s">Künye</h2>
          <SpecGrid items={specsD2} columns={1} testid="kc-specs-d2" />
        </div>
      </section>

      <ul class="kce-chips card" data-testid="kc-ozellik-chips">
        {ozellikler.map((o) => (
          <li>
            <span class="kce-chip-ic"><Icon name={o.icon} size={19} /></span>
            <p class="kce-chip-title">{o.title}</p>
            <p class="kce-chip-sub">{o.sub}</p>
          </li>
        ))}
      </ul>

      <section aria-label="Oda ölçüleri">
        <div class="card kce-card" data-testid="kc-oda-olculeri">
          <h2 class="t-heading-s">Yaklaşık Oda Ölçüleri</h2>
          <p class="t-caption kce-plan-note">Toplam 160 m² brüt / 135 m² net kesindir (sahibinden ilanı). Oda bazındaki değerler yaklaşıktır; kesin ölçüler yerinde teyit edilir.</p>
          <div class="kce-oda-cols">
            {odaOlculeriD2.map((g) => (
              <div class="kce-oda-grup">
                <p class="t-tech kce-oda-grup-ad">{g.grup}</p>
                <SpecGrid items={g.odalar} columns={1} testid={`kc-oda-${g.grup === 'Alt kat' ? 'alt' : 'ust'}`} />
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="kce-three" aria-label="Genel bakış, proje ve konum">
        <div class="card kce-card">
          <h2 class="t-heading-s">Daireye Genel Bakış</h2>
          <ul class="kce-checklist" data-testid="kc-genel-bakis">
            {d.genelBakis.map((g) => (
              <li><Icon name="check" size={16} /> {g}</li>
            ))}
          </ul>
        </div>
        <div class="card kce-card kce-proje">
          <h2 class="t-heading-s">Proje Hakkında</h2>
          <Image
            src={bina.img}
            alt={bina.alt}
            widths={[360, 640]}
            sizes="(min-width: 1024px) 300px, calc(100vw - 3rem)"
            quality={74}
            loading="lazy"
            decoding="async"
            class="kce-proje-img"
          />
          <p class="t-caption kce-proje-text">{building.positioning} — {building.builder} yapımı, {proje.kat} katlı, {proje.toplamDaire} daireli bina.</p>
          <a class="kce-proje-link" href={localePath(locale, '/projeler/el-ele-apartmani')}>Projeyi İncele <Icon name="arrow-right" size={14} /></a>
        </div>
        <MapPanel mode="info" title="Pendik Batı Mah. — Yakın Çevre" locale={locale} />
      </section>

      <section id="sss" aria-label="Sıkça sorulan sorular">
        <div class="card kce-card"><FaqList /></div>
      </section>

      <section id="benzer">
        <SimilarUnits current="daire-2" base={basePrefix} />
      </section>
    </div>

    <StickyRail konu="D-12 · 3+2 Dubleks" base={basePrefix} />
  </div>

  <MobileSaleBar fiyat={tl(d.unit.fiyat!)} etiket="Son daire · D-12" />
</Base>

<style>
  .kce-crumbwrap { padding-block: 0.9rem 0.4rem; }
  .kce-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--color-line);
  }
  .kce-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    line-height: 1.15;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--color-graphite-900);
  }
  .kce-meta { display: flex; gap: 0.9rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .kce-meta span { display: inline-flex; align-items: center; gap: 0.3rem; color: var(--color-graphite-400); }
  .kce-price-box { text-align: end; display: flex; flex-direction: column; align-items: flex-end; gap: 0.2rem; }
  .kce-price {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    color: var(--color-graphite-900);
    line-height: 1.05;
  }
  .kce-kdv { color: var(--color-graphite-400); }

  .kce-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 1.5rem;
    padding-block: 1.25rem 2.25rem;
    align-items: start;
  }
  .kce-main { display: flex; flex-direction: column; gap: 1.25rem; min-width: 0; }

  .kce-chips {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(125px, 1fr));
    gap: 0.9rem;
    padding: 0.9rem 1.1rem;
  }
  .kce-chip-ic { color: var(--color-mey-red); display: inline-flex; }
  .kce-chip-title { font-weight: 600; font-size: 0.8125rem; color: var(--color-graphite-900); margin-top: 0.25rem; line-height: 1.25; }
  .kce-chip-sub { font-size: 0.75rem; color: var(--color-graphite-400); }

  .kce-card { padding: 1rem 1.1rem 1.1rem; }
  .kce-plan-note { color: var(--color-graphite-400); margin-top: 0.2rem; }
  .kce-oda-cols { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 2rem; align-items: start; }
  .kce-oda-grup { margin-top: 0.7rem; }
  .kce-oda-grup-ad { color: var(--color-mey-teal-700); margin-bottom: 0.2rem; }

  .kce-three { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; align-items: start; }
  .kce-checklist { margin-top: 0.6rem; display: flex; flex-direction: column; gap: 0.45rem; }
  .kce-checklist li { display: flex; align-items: baseline; gap: 0.5rem; font-size: 0.875rem; }
  .kce-checklist :global(svg) { color: var(--color-mey-teal-700); flex-shrink: 0; transform: translateY(2px); }
  .kce-proje-img { width: 100%; height: 110px; object-fit: cover; border-radius: var(--radius-brand); margin-top: 0.6rem; }
  .kce-proje-text { margin-top: 0.5rem; }
  .kce-proje-link { display: inline-flex; align-items: center; gap: 0.35rem; margin-top: 0.5rem; font-size: 0.8125rem; font-weight: 500; color: var(--color-mey-red); }
  .kce-proje-link:hover { color: var(--color-mey-red-700); }

  @media (max-width: 1023px) {
    .kce-layout { grid-template-columns: minmax(0, 1fr); }
    .kce-three { grid-template-columns: minmax(0, 1fr); }
  }
  @media (max-width: 760px) {
    .kce-oda-cols { grid-template-columns: minmax(0, 1fr); }
  }
  @media (max-width: 640px) {
    .kce-crumbwrap { padding-block: 0.55rem 0.25rem; }
    .kce-crumbwrap :global(.kc-crumb ol) {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.15rem;
      scrollbar-width: none;
    }
    .kce-crumbwrap :global(.kc-crumb li) { flex-shrink: 0; font-size: 0.7rem; }
    .kce-head { gap: 0.45rem; padding-bottom: 0.65rem; }
    .kce-title { font-size: 1.15rem; line-height: 1.12; }
    .kce-meta { gap: 0.35rem 0.55rem; margin-top: 0.35rem; }
    .kce-meta span { font-size: 0.625rem; }
    .kce-price-box {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.25rem 0.45rem;
      text-align: start;
    }
    .kce-price { font-size: 1.3rem; }
    .kce-price-box :global(.kc-mock) { margin-inline-start: auto; padding: 0.2rem 0.4rem; font-size: 0.6rem; }
    .kce-layout { gap: 1rem; padding-block: 0.75rem 1.5rem; }
    .kce-main { gap: 1rem; }
    .kce-chips { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.65rem; padding: 0.75rem 0.8rem; }
    .kce-card { padding: 0.8rem; }
  }
</style>
