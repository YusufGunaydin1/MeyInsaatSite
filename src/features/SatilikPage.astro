---
/*
  SATILIK DAİRELER — canlı listeleme sayfası. Koyu hero (başlık + 3 stat + yardım
  kartı) → sekme/filtre/sıralama + kart ızgarası + hızlı iletişim rayı → kat
  planları → CTA. TR + [lang] rotaları bu bileşeni sarar; sayfa içeriği şimdilik TR.

  İNDEKSLENİR: D-12 gerçek satış verisiyle canlıya alındı (sahibinden ilanı) →
  noindex kaldırıldı, sitemap istisnası da kaldırıldı (astro.config.mjs — yalnız
  daire-1 sitemap dışı, çünkü satıldı).
*/
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../layouts/Base.astro';
import Icon from '../components/showcase/satilik/kompakt/Icon.astro';
import Breadcrumb from '../components/showcase/satilik/kompakt/Breadcrumb.astro';
import CtaBand from '../components/showcase/satilik/kompakt/CtaBand.astro';
import MobileSaleBar from '../components/showcase/satilik/kompakt/MobileSaleBar.astro';
import SaleListing, { type ListingCard, type ListingImage } from '../components/showcase/satilik/kompakt/SaleListing.tsx';
import { cardImage } from '../components/showcase/satilik/kompakt/assets.ts';
import { listing, listingProjeler, satistakiDaireSayisi, tl, DETAY_SLUG } from '../components/showcase/satilik/kompakt/data.ts';
import { publicAsset, entry } from '../components/showcase/satilik/media.ts';
import { localePath, type Locale } from '../lib/i18n';
import { ui, company } from '../lib/content';
import { contactNumber, telHref, whatsappHref } from '../lib/contact';
import elEleImg from '../assets/projects/el-ele-apartmani.webp';
import masukImg from '../assets/projects/masuk-apartmani.webp';
import camogluImg from '../assets/projects/camoglu-apartmani.webp';
import elEleData from '../../content/projects/el-ele-apartmani/data.json';
import masukData from '../../content/projects/masuk-apartmani/data.json';
import camogluData from '../../content/projects/camoglu-apartmani/data.json';
import '../components/showcase/satilik/kompakt/kompakt.css';
import '../components/showcase/satilik-mobile/mobile-sale-compact.css';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui(locale);

/** yerel dil öneki dahil kök ('' | '/en' | ...) — bileşenlerin base'i */
const basePrefix = localePath(locale, '/').replace(/\/$/, '');
const root = localePath(locale, '/satilik-daireler');
const salesPhone = contactNumber(company.salesContact.phone);
const salesWhatsapp = contactNumber(company.salesContact.whatsapp);

const heroKey = 'daire-1/bina-dis.png';
const hero = publicAsset(heroKey);
const heroAlt = entry(heroKey).alt;

/* Paylaşım/reklam önizlemesi: jenerik og-default yerine binanın kendisi (1200×630). */
const ogHero = await getImage({ src: hero, width: 1200, height: 630, fit: 'cover', format: 'jpeg', quality: 72 });

/* Kırıntı yapısal verisi (BreadcrumbList) — görünür Breadcrumb ile aynı kaynak. */
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://meyinsaat.com';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.nav.home, item: siteUrl + localePath(locale, '/') },
    { '@type': 'ListItem', position: 2, name: t.nav.forSale, item: siteUrl + localePath(locale, '/satilik-daireler') },
  ],
};

/* Proje dış cepheleri proje kartlarının görseli olur */
async function assetImage(src: ImageMetadata, alt: string): Promise<ListingImage> {
  const a = await getImage({ src, width: 400, format: 'webp', quality: 74 });
  const b = await getImage({ src, width: 720, format: 'webp', quality: 74 });
  return { src: a.src, srcset: `${a.src} 400w, ${b.src} 720w`, width: src.width, height: src.height, alt };
}
const projeGorsel: Record<string, ImageMetadata> = {
  'el-ele': elEleImg,
  masuk: masukImg,
  camoglu: camogluImg,
};

/* Harita görünümü için proje/bina koordinatları (tek kaynak: content/projects) */
const projeCoords: Record<string, { lat: number; lng: number }> = {
  'el-ele': elEleData.coordinates,
  masuk: masukData.coordinates,
  camoglu: camogluData.coordinates,
};

const ilanlar: ListingCard[] = await Promise.all(
  listing.map(async (u): Promise<ListingCard> => ({
    kind: 'ilan',
    id: u.id,
    tip: u.tip,
    baslik: u.baslik,
    proje: u.proje,
    projeKey: u.projeKey,
    blokKat: u.blokKat,
    oda: u.oda,
    brut: u.brut,
    banyo: u.banyo,
    balkon: u.balkon,
    kat: u.kat,
    katKey: u.katKey,
    fiyat: u.fiyat,
    fiyatText: u.fiyat === null ? null : tl(u.fiyat),
    durum: u.durum,
    badge: u.badge,
    href: `${root}${DETAY_SLUG[u.detay!]}/`,
    img: await cardImage(u.imgKey!),
    lat: projeCoords[u.projeKey]?.lat,
    lng: projeCoords[u.projeKey]?.lng,
  }))
);

const projeKartlari: ListingCard[] = await Promise.all(
  listingProjeler.map(async (p): Promise<ListingCard> => ({
    kind: 'proje',
    id: p.id,
    ad: p.ad,
    projeKey: p.projeKey,
    konum: p.konum,
    sold: p.sold,
    not: p.not,
    rozet: p.rozet,
    href: localePath(locale, `/projeler/${p.slug}`),
    img: await assetImage(projeGorsel[p.projeKey], `${p.ad} dış cephe`),
    lat: projeCoords[p.projeKey]?.lat,
    lng: projeCoords[p.projeKey]?.lng,
  }))
);

const items: ListingCard[] = [...ilanlar, ...projeKartlari];

const projeler = [
  { key: 'el-ele', ad: 'El Ele Apartmanı' },
  { key: 'masuk', ad: 'Maşuk Apartmanı' },
  { key: 'camoglu', ad: 'Çamoğlu Apartmanı' },
];

const stats = [
  { icon: 'building', deger: '160 m²', alt: 'Brüt alan' },
  { icon: 'stairs', deger: '3+2 Dubleks', alt: 'Çatı katı · 5. kat' },
  { icon: 'key', deger: tl(13_750_000), alt: 'Müteahhitten sıfır' },
];
/* EN/RU/AR satılık sayfaları gövde metnini HENÜZ çevirmiyor (künye, oda adları,
   açıklamalar TR). Çeviri gelene kadar bu üç dil noindex ve hreflang kümesi
   dışında: aynı Türkçe metni "İngilizce sayfa" diye ilan etmek yeni bir alan
   adında kopya içerik sinyalidir. TR sayfa etkilenmez. */
const trOnly = locale !== 'tr';
---

<Base
  locale={locale}
  page="satilik"
  path="/satilik-daireler"
  ogImage={ogHero.src}
  ogImageAlt="El Ele Apartmanı — Pendik Batı Mahallesi'nde müteahhitten sıfır 3+2 dubleks daireli bina"
  jsonLd={breadcrumbLd}
  noindex={trOnly}
  hreflangLocales={[locale]}
>
  <!-- HERO -->
  <section class="ks-hero theatre ksm-hero" data-testid="ksm-hero">
    <Image
      src={hero}
      alt={heroAlt}
      widths={[480, 880, 1440]}
      sizes="100vw"
      quality={74}
      class="ks-hero-img"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="ks-hero-scrim" aria-hidden="true"></div>
    <div class="container-site ks-hero-in">
      <div class="ks-hero-left">
        <div class="ks-hero-crumb">
          <Breadcrumb items={[{ label: t.nav.home, href: localePath(locale, '/') }, { label: t.nav.forSale }]} />
        </div>
        <h1 class="ks-hero-title">Pendik Satılık Daireler</h1>
        <p class="ks-hero-sub">
          El Ele Apartmanı’nda satılık son daire: 3+2 çatı dubleksi, 160 m² brüt, 5. kat.
          Müteahhitten sıfır, aracısız — {tl(13_750_000)}.
        </p>
        <ul class="ks-hero-stats">
          {stats.map((s) => (
            <li>
              <span class="ks-stat-ic"><Icon name={s.icon} size={20} /></span>
              <div><p class="ks-stat-deger">{s.deger}</p><p class="ks-stat-alt">{s.alt}</p></div>
            </li>
          ))}
        </ul>
        <div class="ks-hero-cta" aria-label="Satış danışmanı">
          <a class="ks-hero-cta-call" href={telHref(company.salesContact.phone) ?? '#'} data-testid="ks-hero-call">
            <Icon name="phone" size={17} /> Ara · {salesPhone?.display ?? ''}
          </a>
          <a class="ks-hero-cta-wa" href={whatsappHref(company.salesContact.whatsapp) ?? '#'} data-testid="ks-hero-whatsapp">
            <Icon name="chat" size={17} /> WhatsApp
          </a>
        </div>
      </div>
      <aside class="ks-hero-help">
        <span class="ks-help-ic"><Icon name="chat" size={22} /></span>
        <p class="ks-help-title">Size yardımcı olalım</p>
        <p class="ks-help-sub">Size en uygun daireyi bulmanızda ekibimiz yardımcı olsun.</p>
        <a
          class="btn-ghost ks-help-cta"
          href={whatsappHref(company.salesContact.whatsapp, 'Merhaba, Pendik’teki satılık daire hakkında bilgi almak istiyorum.') ?? '#'}
          data-testid="ks-help-whatsapp"
        >Bize Ulaşın</a>
      </aside>

      <div class="ksm-mobile-hero" data-testid="ksm-mobile-hero">
          <p class="ksm-mobile-status"><span aria-hidden="true"></span>{satistakiDaireSayisi} DAİRE SATIŞTA</p>
          <!-- Gerçek h1: masaüstü başlığı bu genişlikte display:none, yani mobil
               tarayan Googlebot yalnız bunu görür. Metin masaüstüyle aynı olmalı. -->
          <h1 class="ksm-mobile-h1">Pendik Satılık Daireler</h1>
          <p class="ksm-mobile-sub">El Ele Apartmanı · Son 3+2 dubleks</p>
          <div class="ksm-mobile-actions" aria-label="Satış danışmanı">
            <a href={telHref(company.salesContact.phone) ?? '#'} aria-label={`Satış danışmanını ara: ${salesPhone?.display ?? ''}`} data-testid="ksm-call">
              <Icon name="phone" size={16} /> Ara
            </a>
            <a href={whatsappHref(company.salesContact.whatsapp) ?? '#'} aria-label={`WhatsApp: ${salesWhatsapp?.display ?? ''}`} data-testid="ksm-whatsapp">
              <Icon name="chat" size={16} /> WhatsApp
            </a>
          </div>
      </div>
    </div>
  </section>

  <!-- LİSTE + RAY (ada) -->
  <section class="container-site ks-listing ksm-listing" aria-label="Satılık daire listesi">
    <h2 class="kc-h2 ks-listing-h2">Satıştaki ve Tamamlanan Daireler</h2>
    <SaleListing
      client:load
      items={items}
      projeler={projeler}
      salesPhone={salesPhone?.display ?? ''}
      salesPhoneHref={telHref(company.salesContact.phone) ?? ''}
      salesWhatsapp={salesWhatsapp?.display ?? ''}
      salesWhatsappHref={whatsappHref(company.salesContact.whatsapp) ?? ''}
      formAccessKey={company.contact.formAccessKey ?? ''}
    />
  </section>

  <!-- TANITIM / indekslenebilir metin (konum + yatırım) -->
  <section class="container-site ks-intro" aria-label="El Ele Apartmanı hakkında">
    <h2 class="kc-h2">Pendik’te Müteahhitten Sıfır 3+2 Çatı Dubleksi</h2>
    <div class="ks-intro-cols">
      <p>
        El Ele Apartmanı, Mey İnşaat’ın Pendik Batı Mahallesi’nde tamamladığı, kat mülkiyetli
        sıfır bir konut binasıdır. Bina teslime hazırdır; şu an yalnızca 5. kattaki 3+2 çatı
        dubleksi (D-12) satılıktır ve aracısız, doğrudan binayı yapan Mey İnşaat’tan satın alınır.
      </p>
      <p>
        Bina; sahil parkı, market, eczane ve ilkokulun yürüme mesafesinde, Marmaray ve metro
        bağlantılarına yakın bir konumda yer alır. Pendik’in kıyı hattına yakınlığı, hem oturmak
        hem de uzun vadeli yatırım için elverişli bir konum sunar.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <div class="container-site ks-cta">
    <CtaBand base={basePrefix} />
  </div>

  <MobileSaleBar fiyat={tl(13_750_000)} etiket="Son daire · D-12" />
</Base>

<style>
  .ks-hero { position: relative; overflow: hidden; }
  .ks-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 78% 40%;
  }
  .ks-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgb(14 15 17 / 0.94) 0%, rgb(14 15 17 / 0.78) 46%, rgb(14 15 17 / 0.35) 100%);
  }
  .ks-hero-in {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 1.5rem;
    align-items: center;
    padding-block: 1.6rem 1.75rem;
  }
  .ks-hero-crumb :global(.kc-crumb a) { color: rgb(244 244 242 / 0.6); }
  .ks-hero-crumb :global(.kc-crumb a:hover) { color: #fff; }
  .ks-hero-crumb :global(.kc-crumb span[aria-current]) { color: rgb(244 244 242 / 0.85); }
  .ks-hero-crumb :global(.kc-crumb-sep) { color: rgb(244 244 242 / 0.4); }
  .ks-hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.08;
    margin-top: 0.9rem;
  }
  .ks-hero-sub { margin-top: 0.6rem; max-width: 46ch; color: rgb(244 244 242 / 0.8); font-size: 0.9375rem; }
  .ks-hero-stats { display: flex; gap: 2rem; flex-wrap: wrap; margin-top: 1.1rem; }
  .ks-hero-stats li { display: flex; align-items: center; gap: 0.6rem; }
  .ks-hero-stats li + li { border-inline-start: 1px solid rgb(255 255 255 / 0.18); padding-inline-start: 2rem; }
  .ks-stat-ic { color: var(--color-red-on-dark); display: inline-flex; }
  .ks-stat-deger { font-weight: 600; color: #fff; font-size: 0.9375rem; line-height: 1.2; }
  .ks-stat-alt { font-size: 0.8125rem; color: rgb(244 244 242 / 0.6); }
  .ks-hero-help {
    background: rgb(25 27 30 / 0.92);
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: var(--radius-brand);
    padding: 1.1rem 1.2rem 1.2rem;
  }
  .ks-help-ic { color: var(--color-red-on-dark); display: inline-flex; }
  .ks-help-title { font-weight: 600; color: #fff; margin-top: 0.4rem; }
  .ks-help-sub { font-size: 0.8125rem; color: rgb(244 244 242 / 0.65); margin-top: 0.25rem; line-height: 1.45; }
  .ks-help-cta { margin-top: 0.8rem; padding: 0.5rem 1rem; font-size: 0.875rem; }

  .ks-hero-cta { display: flex; gap: 0.6rem; margin-top: 1rem; flex-wrap: wrap; }
  .ks-hero-cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.55rem 1.15rem;
    border-radius: var(--radius-brand);
    font-weight: 600;
    font-size: 0.9375rem;
  }
  .ks-hero-cta-call { background: var(--color-mey-red); color: #fff; }
  .ks-hero-cta-call:hover { background: var(--color-mey-red-700); }
  .ks-hero-cta-wa { border: 1px solid rgb(255 255 255 / 0.5); color: #fff; }
  .ks-hero-cta-wa:hover { background: rgb(255 255 255 / 0.08); }

  .ks-listing { padding-block: 1.25rem 2rem; }
  .ks-mockline { margin-bottom: 0.6rem; text-align: end; }

  .ks-intro { padding-block: 1.5rem 0.5rem; }
  .ks-intro-cols { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.8rem 2rem; margin-top: 0.8rem; }
  .ks-intro-cols p { color: var(--color-graphite-600); font-size: 0.9375rem; line-height: 1.65; }
  .ks-listing-h2 { margin-bottom: 0.9rem; }

  .ks-cta { padding-bottom: 2rem; }

  @media (max-width: 1023px) {
    .ks-hero-in { grid-template-columns: minmax(0, 1fr); }
    .ks-hero-help { max-width: 380px; }
  }

  @media (max-width: 640px) {
    .ks-hero-img { object-position: 64% 42%; }
    .ks-hero-scrim {
      background: linear-gradient(90deg, rgb(14 15 17 / 0.96) 0%, rgb(14 15 17 / 0.84) 68%, rgb(14 15 17 / 0.58) 100%);
    }
    .ks-hero-in {
      gap: 0.75rem;
      padding-block: 0.75rem 0.85rem;
    }
    .ks-hero-title { margin-top: 0.45rem; font-size: 1.85rem; }
    .ks-hero-sub {
      display: -webkit-box;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      margin-top: 0.35rem;
      max-width: 40ch;
      font-size: 0.8125rem;
      line-height: 1.4;
    }
    .ks-hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
      margin-top: 0.75rem;
    }
    .ks-hero-stats li {
      display: block;
      min-width: 0;
      padding-inline: 0.45rem;
    }
    .ks-hero-stats li:first-child { padding-inline-start: 0; }
    .ks-hero-stats li + li { padding-inline-start: 0.55rem; }
    .ks-stat-ic { display: none; }
    .ks-stat-deger { overflow-wrap: anywhere; font-size: 0.75rem; }
    .ks-stat-alt { margin-top: 0.1rem; font-size: 0.625rem; line-height: 1.25; }
    .ks-hero-help {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.65rem;
      align-items: center;
      width: 100%;
      max-width: none;
      padding: 0.45rem 0.5rem 0.45rem 0.7rem;
    }
    .ks-help-ic, .ks-help-sub { display: none; }
    .ks-help-title { margin-top: 0; font-size: 0.8125rem; }
    .ks-help-cta {
      min-height: 40px;
      margin-top: 0;
      padding: 0.45rem 0.75rem;
      display: inline-flex;
      align-items: center;
    }
    .ks-listing { padding-block: 0.7rem 1.5rem; }
    .ks-mockline { margin-bottom: 0.4rem; }
    .ks-intro { padding-block: 1rem 0.25rem; }
    .ks-intro-cols { grid-template-columns: minmax(0, 1fr); gap: 0.6rem; }
    .ks-cta { padding-bottom: 1.5rem; }
  }

  .ksm-mobile-hero { display: none; }

  @media (max-width: 640px) {
    .ksm-hero .ks-hero-left,
    .ksm-hero .ks-hero-help { display: none; }
    .ksm-hero .ks-hero-in {
      display: block;
      padding-block: 0;
    }
    .ksm-mobile-hero {
      display: grid;
      min-height: 156px;
      align-content: center;
      padding-block: 0.75rem;
    }
    .ksm-mobile-status {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: rgb(255 255 255 / 0.74);
      font-size: 0.625rem;
      font-weight: 600;
      letter-spacing: 0.09em;
    }
    .ksm-mobile-status span {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--color-mey-teal);
      box-shadow: 0 0 0 3px rgb(73 193 198 / 0.16);
    }
    .ksm-mobile-hero .ksm-mobile-h1 {
      margin-top: 0.2rem;
      color: #fff;
      font-family: var(--font-display);
      font-size: 1.9rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      line-height: 1;
      text-transform: uppercase;
    }
    .ksm-mobile-sub {
      margin-top: 0.25rem;
      color: rgb(255 255 255 / 0.68);
      font-size: 0.6875rem;
    }
    .ksm-mobile-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem;
      margin-top: 0.65rem;
    }
    .ksm-mobile-actions a {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      border: 1px solid rgb(255 255 255 / 0.38);
      border-radius: var(--radius-brand);
      color: #fff;
      background: rgb(14 15 17 / 0.46);
      font-size: 0.75rem;
      font-weight: 600;
    }
    .ksm-mobile-actions a:last-child {
      border-color: var(--color-mey-teal);
      background: rgb(73 193 198 / 0.16);
    }
    .ksm-listing .ks-mockline { display: none; }
  }
</style>
