---
/*
  SATILIK DAİRELER — canlı listeleme sayfası (tasarım: liste-ref mock, vitrinden
  terfi 2026-07-16). Koyu hero (başlık + 3 stat + yardım kartı) → sekme/filtre/
  sıralama + kart ızgarası + karşılaştırma & hızlı iletişim rayı → kat planları
  → CTA. TR + [lang] rotaları bu bileşeni sarar; sayfa içeriği şimdilik TR.

  NOINDEX BİLEREK AÇIK: fiyat/m² değerleri temsilîdir (kompakt/data.ts, sayfada
  çip). Gerçek satış verisi girildiğinde noindex'i ve astro.config'teki sitemap
  istisnasını BİRLİKTE kaldır.
*/
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../layouts/Base.astro';
import Icon from '../components/showcase/satilik/kompakt/Icon.astro';
import MockChip from '../components/showcase/satilik/kompakt/MockChip.astro';
import Breadcrumb from '../components/showcase/satilik/kompakt/Breadcrumb.astro';
import CtaBand from '../components/showcase/satilik/kompakt/CtaBand.astro';
import SoonDialog from '../components/showcase/satilik/kompakt/SoonDialog.astro';
import SaleListing, { type ListingCard, type ListingImage } from '../components/showcase/satilik/kompakt/SaleListing.tsx';
import { cardImage } from '../components/showcase/satilik/kompakt/assets.ts';
import { listing, listingProjeler, katPlanlari, satistakiDaireSayisi, tl } from '../components/showcase/satilik/kompakt/data.ts';
import { publicAsset } from '../components/showcase/satilik/media.ts';
import { localePath, type Locale } from '../lib/i18n';
import { ui, company } from '../lib/content';
import { contactNumber, telHref, whatsappHref } from '../lib/contact';
import elEleImg from '../assets/projects/el-ele-apartmani.webp';
import masukImg from '../assets/projects/masuk-apartmani.webp';
import camogluImg from '../assets/projects/camoglu-apartmani.webp';
import '../components/showcase/satilik/kompakt/kompakt.css';
import '../components/showcase/satilik-mobile/mobile-sale-proposal.css';

interface Props {
  locale: Locale;
  mobileProposal?: boolean;
}
const { locale, mobileProposal = false } = Astro.props;
const t = ui(locale);

/** yerel dil öneki dahil kök ('' | '/en' | ...) — bileşenlerin base'i */
const basePrefix = localePath(locale, '/').replace(/\/$/, '');
const root = basePrefix + '/satilik-daireler';
const salesPhone = contactNumber(company.salesContact.phone);
const salesWhatsapp = contactNumber(company.salesContact.whatsapp);

const hero = publicAsset('daire-1/bina-dis.png');

/* Proje dış cepheleri proje kartlarının görseli olur */
async function assetImage(src: ImageMetadata, alt: string): Promise<ListingImage> {
  const a = await getImage({ src, width: 400, format: 'webp', quality: 74 });
  const b = await getImage({ src, width: 720, format: 'webp', quality: 74 });
  return { src: a.src, srcset: `${a.src} 400w, ${b.src} 720w`, width: src.width, height: src.height, alt };
}
const projeGorsel: Record<string, ImageMetadata> = {
  'el-ele': elEleImg,
  masuk: masukImg,
  camoglu: camogluImg,
};

const ilanlar: ListingCard[] = await Promise.all(
  listing.map(async (u): Promise<ListingCard> => ({
    kind: 'ilan',
    id: u.id,
    tip: u.tip,
    baslik: u.baslik,
    proje: u.proje,
    projeKey: u.projeKey,
    blokKat: u.blokKat,
    oda: u.oda,
    brut: u.brut,
    banyo: u.banyo,
    balkon: u.balkon,
    kat: u.kat,
    katKey: u.katKey,
    fiyat: u.fiyat,
    fiyatText: u.fiyat === null ? null : tl(u.fiyat),
    durum: u.durum,
    badge: u.badge,
    href: `${root}/${u.detay}`,
    img: await cardImage(u.imgKey!),
  }))
);

const projeKartlari: ListingCard[] = await Promise.all(
  listingProjeler.map(async (p): Promise<ListingCard> => ({
    kind: 'proje',
    id: p.id,
    ad: p.ad,
    projeKey: p.projeKey,
    konum: p.konum,
    sold: p.sold,
    not: p.not,
    rozet: p.rozet,
    href: `${basePrefix}/projeler/${p.slug}`,
    img: await assetImage(projeGorsel[p.projeKey], `${p.ad} dış cephe`),
  }))
);

const items: ListingCard[] = [...ilanlar, ...projeKartlari];

const projeler = [
  { key: 'el-ele', ad: 'El Ele Apartmanı' },
  { key: 'masuk', ad: 'Maşuk Apartmanı' },
  { key: 'camoglu', ad: 'Çamoğlu Apartmanı' },
];

const stats = [
  { icon: 'flag', deger: '2021', alt: 'Kuruluş' },
  { icon: 'building', deger: '3 Proje', alt: 'İstanbul’da' },
  { icon: 'key', deger: 'Mey İnşaat', alt: 'Resmî Unvan' },
];
---

<Base
  locale={locale}
  page="satilik"
  path={mobileProposal ? '/showcases/satilik-mobile-kompakt' : '/satilik-daireler'}
  title={mobileProposal ? 'Satılık Mobil Öneri — Tasarım Vitrini' : undefined}
  noindex
>
  <!-- HERO -->
  <section class:list={['ks-hero', 'theatre', { 'smp-hero': mobileProposal }]} data-testid={mobileProposal ? 'smp-hero' : undefined}>
    <Image
      src={hero}
      alt=""
      widths={[480, 880, 1440]}
      sizes="100vw"
      quality={74}
      class="ks-hero-img"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="ks-hero-scrim" aria-hidden="true"></div>
    <div class="container-site ks-hero-in">
      <div class="ks-hero-left">
        <div class="ks-hero-crumb">
          <Breadcrumb items={[{ label: t.nav.home, href: localePath(locale, '/') }, { label: t.nav.forSale }]} />
        </div>
        <h1 class="ks-hero-title">Satılık Daireler</h1>
        <p class="ks-hero-sub">
          Mey İnşaat güvencesiyle, modern yaşam alanlarına yatırım yapın. Size en uygun daireyi bulun.
        </p>
        <ul class="ks-hero-stats">
          {stats.map((s) => (
            <li>
              <span class="ks-stat-ic"><Icon name={s.icon} size={20} /></span>
              <div><p class="ks-stat-deger">{s.deger}</p><p class="ks-stat-alt">{s.alt}</p></div>
            </li>
          ))}
        </ul>
      </div>
      <aside class="ks-hero-help">
        <span class="ks-help-ic"><Icon name="chat" size={22} /></span>
        <p class="ks-help-title">Size yardımcı olalım</p>
        <p class="ks-help-sub">Size en uygun daireyi bulmanızda ekibimiz yardımcı olsun.</p>
        <a class="btn-ghost ks-help-cta" href={basePrefix + '/iletisim'}>Bize Ulaşın</a>
      </aside>

      {mobileProposal && (
        <div class="smp-mobile-hero" data-testid="smp-mobile-hero">
          <p class="smp-mobile-status"><span aria-hidden="true"></span>{satistakiDaireSayisi} DAİRE SATIŞTA · PENDİK</p>
          <h1>Satılık Daireler</h1>
          <p class="smp-mobile-sub">El Ele Apartmanı · Son 3+2 dubleks</p>
          <div class="smp-mobile-actions" aria-label="Satış danışmanı">
            <a href={telHref(company.salesContact.phone) ?? '#'} aria-label={`Satış danışmanını ara: ${salesPhone?.display ?? ''}`} data-testid="smp-call">
              <Icon name="phone" size={16} /> Ara
            </a>
            <a href={whatsappHref(company.salesContact.whatsapp) ?? '#'} aria-label={`WhatsApp: ${salesWhatsapp?.display ?? ''}`} data-testid="smp-whatsapp">
              <Icon name="chat" size={16} /> WhatsApp
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- LİSTE + RAY (ada) -->
  <section class:list={['container-site', 'ks-listing', { 'smp-listing': mobileProposal }]} aria-label="Satılık daire listesi">
    <p class="ks-mockline"><MockChip /></p>
    <SaleListing
      client:load
      items={items}
      projeler={projeler}
      salesPhone={salesPhone?.display ?? ''}
      salesPhoneHref={telHref(company.salesContact.phone) ?? ''}
      salesWhatsapp={salesWhatsapp?.display ?? ''}
      salesWhatsappHref={whatsappHref(company.salesContact.whatsapp) ?? ''}
      mobileProposal={mobileProposal}
    />
  </section>

  <!-- KAT PLANLARI -->
  <section class="container-site ks-plans" aria-label="Kat planları">
    <div class="ks-plans-head">
      <h2 class="kc-h2">Kat Planları</h2>
      <button type="button" class="ks-plans-all" data-soon="Kat planları">Tüm Kat Planlarını Gör →</button>
    </div>
    <div class="ks-plans-grid" data-testid="ks-plans">
      {katPlanlari.map((p) => (
        <article class="ks-plan card">
          <div class="ks-plan-canvas">
            <svg viewBox="0 0 96 64" aria-hidden="true">
              <rect x="2" y="2" width="92" height="60" />
              <path d="M2 24h40M42 2v40M42 42h52M70 42v20M42 24h24M66 2v22" />
            </svg>
            <button type="button" class="ks-plan-zoom" data-soon={p.ad} aria-label={`${p.ad} büyüt`}>
              <Icon name="expand" size={15} />
            </button>
          </div>
          <p class="ks-plan-ad">{p.ad}</p>
          <p class="ks-plan-m2 t-tech">{p.m2}</p>
        </article>
      ))}
    </div>
    <p class="t-caption ks-plans-note">Kat planı görselleri hazırlanıyor — şema temsilîdir.</p>
  </section>

  <!-- CTA -->
  <div class="container-site ks-cta">
    <CtaBand base={basePrefix} />
  </div>

  <SoonDialog />
</Base>

<style>
  .ks-hero { position: relative; overflow: hidden; }
  .ks-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 78% 40%;
  }
  .ks-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgb(14 15 17 / 0.94) 0%, rgb(14 15 17 / 0.78) 46%, rgb(14 15 17 / 0.35) 100%);
  }
  .ks-hero-in {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 1.5rem;
    align-items: center;
    padding-block: 2.25rem 2.5rem;
  }
  .ks-hero-crumb :global(.kc-crumb a) { color: rgb(244 244 242 / 0.6); }
  .ks-hero-crumb :global(.kc-crumb a:hover) { color: #fff; }
  .ks-hero-crumb :global(.kc-crumb span[aria-current]) { color: rgb(244 244 242 / 0.85); }
  .ks-hero-crumb :global(.kc-crumb-sep) { color: rgb(244 244 242 / 0.4); }
  .ks-hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.08;
    margin-top: 0.9rem;
  }
  .ks-hero-sub { margin-top: 0.6rem; max-width: 46ch; color: rgb(244 244 242 / 0.8); font-size: 0.9375rem; }
  .ks-hero-stats { display: flex; gap: 2rem; flex-wrap: wrap; margin-top: 1.4rem; }
  .ks-hero-stats li { display: flex; align-items: center; gap: 0.6rem; }
  .ks-hero-stats li + li { border-inline-start: 1px solid rgb(255 255 255 / 0.18); padding-inline-start: 2rem; }
  .ks-stat-ic { color: var(--color-red-on-dark); display: inline-flex; }
  .ks-stat-deger { font-weight: 600; color: #fff; font-size: 0.9375rem; line-height: 1.2; }
  .ks-stat-alt { font-size: 0.8125rem; color: rgb(244 244 242 / 0.6); }
  .ks-hero-help {
    background: rgb(25 27 30 / 0.92);
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: var(--radius-brand);
    padding: 1.1rem 1.2rem 1.2rem;
  }
  .ks-help-ic { color: var(--color-red-on-dark); display: inline-flex; }
  .ks-help-title { font-weight: 600; color: #fff; margin-top: 0.4rem; }
  .ks-help-sub { font-size: 0.8125rem; color: rgb(244 244 242 / 0.65); margin-top: 0.25rem; line-height: 1.45; }
  .ks-help-cta { margin-top: 0.8rem; padding: 0.5rem 1rem; font-size: 0.875rem; }

  .ks-listing { padding-block: 1.25rem 2rem; }
  .ks-mockline { margin-bottom: 0.6rem; text-align: end; }

  .ks-plans { padding-block: 0 2rem; }
  .ks-plans-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .ks-plans-all {
    font: inherit;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-mey-red);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .ks-plans-all:hover { color: var(--color-mey-red-700); text-decoration: underline; }
  .ks-plans-grid {
    margin-top: 0.9rem;
    display: grid;
    /* 360px tavanı: iki plan kartı yarım ekrana yayılıp bandı şişirmesin */
    grid-template-columns: repeat(auto-fit, minmax(200px, 360px));
    gap: 0.9rem;
  }
  .ks-plan { padding: 0.9rem 1rem 1rem; }
  .ks-plan-canvas { position: relative; background: var(--color-concrete-050); border-radius: var(--radius-brand); padding: 0.9rem; }
  .ks-plan-canvas svg { width: 100%; height: auto; fill: none; stroke: var(--color-graphite-400); stroke-width: 1.4; }
  .ks-plan-zoom {
    position: absolute;
    right: 0.5rem;
    bottom: 0.5rem;
    display: inline-flex;
    padding: 0.35rem;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    color: var(--color-graphite-600);
    cursor: pointer;
  }
  .ks-plan-zoom:hover { color: var(--color-mey-red); border-color: var(--color-mey-red); }
  .ks-plan-ad { margin-top: 0.6rem; font-weight: 600; font-size: 0.875rem; color: var(--color-graphite-900); }
  .ks-plan-m2 { color: var(--color-graphite-400); margin-top: 0.15rem; }
  .ks-plans-note { color: var(--color-graphite-400); margin-top: 0.6rem; }

  .ks-cta { padding-bottom: 2rem; }

  @media (max-width: 1023px) {
    .ks-hero-in { grid-template-columns: minmax(0, 1fr); }
    .ks-hero-help { max-width: 380px; }
  }

  @media (max-width: 640px) {
    .ks-hero-img { object-position: 64% 42%; }
    .ks-hero-scrim {
      background: linear-gradient(90deg, rgb(14 15 17 / 0.96) 0%, rgb(14 15 17 / 0.84) 68%, rgb(14 15 17 / 0.58) 100%);
    }
    .ks-hero-in {
      gap: 0.75rem;
      padding-block: 0.75rem 0.85rem;
    }
    .ks-hero-title { margin-top: 0.45rem; font-size: 1.85rem; }
    .ks-hero-sub {
      display: -webkit-box;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      margin-top: 0.35rem;
      max-width: 40ch;
      font-size: 0.8125rem;
      line-height: 1.4;
    }
    .ks-hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
      margin-top: 0.75rem;
    }
    .ks-hero-stats li {
      display: block;
      min-width: 0;
      padding-inline: 0.45rem;
    }
    .ks-hero-stats li:first-child { padding-inline-start: 0; }
    .ks-hero-stats li + li { padding-inline-start: 0.55rem; }
    .ks-stat-ic { display: none; }
    .ks-stat-deger { overflow-wrap: anywhere; font-size: 0.75rem; }
    .ks-stat-alt { margin-top: 0.1rem; font-size: 0.625rem; line-height: 1.25; }
    .ks-hero-help {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.65rem;
      align-items: center;
      width: 100%;
      max-width: none;
      padding: 0.45rem 0.5rem 0.45rem 0.7rem;
    }
    .ks-help-ic, .ks-help-sub { display: none; }
    .ks-help-title { margin-top: 0; font-size: 0.8125rem; }
    .ks-help-cta {
      min-height: 40px;
      margin-top: 0;
      padding: 0.45rem 0.75rem;
      display: inline-flex;
      align-items: center;
    }
    .ks-listing { padding-block: 0.7rem 1.5rem; }
    .ks-mockline { margin-bottom: 0.4rem; }
    .ks-plans { padding-bottom: 1.5rem; }
    .ks-plans-grid { grid-template-columns: minmax(0, 1fr); gap: 0.65rem; }
    .ks-cta { padding-bottom: 1.5rem; }
  }

  .smp-mobile-hero { display: none; }

  @media (max-width: 640px) {
    .smp-hero .ks-hero-left,
    .smp-hero .ks-hero-help { display: none; }
    .smp-hero .ks-hero-in {
      display: block;
      padding-block: 0;
    }
    .smp-mobile-hero {
      display: grid;
      min-height: 156px;
      align-content: center;
      padding-block: 0.75rem;
    }
    .smp-mobile-status {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: rgb(255 255 255 / 0.74);
      font-size: 0.625rem;
      font-weight: 600;
      letter-spacing: 0.09em;
    }
    .smp-mobile-status span {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--color-mey-teal);
      box-shadow: 0 0 0 3px rgb(73 193 198 / 0.16);
    }
    .smp-mobile-hero h1 {
      margin-top: 0.2rem;
      color: #fff;
      font-family: var(--font-display);
      font-size: 1.9rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      line-height: 1;
      text-transform: uppercase;
    }
    .smp-mobile-sub {
      margin-top: 0.25rem;
      color: rgb(255 255 255 / 0.68);
      font-size: 0.6875rem;
    }
    .smp-mobile-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem;
      margin-top: 0.65rem;
    }
    .smp-mobile-actions a {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      border: 1px solid rgb(255 255 255 / 0.38);
      border-radius: var(--radius-brand);
      color: #fff;
      background: rgb(14 15 17 / 0.46);
      font-size: 0.75rem;
      font-weight: 600;
    }
    .smp-mobile-actions a:last-child {
      border-color: var(--color-mey-teal);
      background: rgb(73 193 198 / 0.16);
    }
    .smp-listing .ks-mockline { display: none; }
  }
</style>
