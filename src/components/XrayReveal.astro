---
/*
  Facade x-ray (vitrin Röntgen Lab, kazanan B1 — 2026-07): the cover render and
  its pixel-aligned cutaway twin (same camera, facade removed) are stacked; the
  cutaway is revealed only in a small feathered circle around the cursor, so
  hovering a flat shows that flat's interior. The whole image never swaps.
  Radius owner-calibrated: ~85px at hero scale (one flat), 55px on tiles.
  The lens follows the cursor for hover-capable pointers (mouse/pen) ONLY —
  on touch it is off by default so the image never hijacks page scrolling;
  the toggle button is the touch (and keyboard) path to the full cutaway.
  Pure CSS mask + a few lines of JS, no libraries.
*/
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  base: ImageMetadata;
  xray: ImageMetadata;
  alt: string;
  widths: number[];
  sizes: string;
  radius?: number;
  /** Both labels present -> render the full-cutaway toggle button. */
  openLabel?: string;
  closeLabel?: string;
  eager?: boolean;
  class?: string;
}
const {
  base,
  xray,
  alt,
  widths,
  sizes,
  radius = 85,
  openLabel,
  closeLabel,
  eager = false,
  class: className,
} = Astro.props;
const toggle = Boolean(openLabel && closeLabel);
---

<div class:list={['xrv', className]} data-xray style={`--r: ${radius}px;`}>
  <Image
    src={base}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={eager ? 'eager' : 'lazy'}
    class="xrv-img"
  />
  <Image
    src={xray}
    alt=""
    aria-hidden="true"
    widths={widths}
    sizes={sizes}
    class="xrv-img xrv-top"
  />
  <slot />
  {toggle && (
    <button
      type="button"
      class="t-tech xrv-toggle"
      aria-pressed="false"
      data-open={openLabel}
      data-close={closeLabel}
    >{openLabel}</button>
  )}
</div>

<style>
  .xrv {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4; /* portrait covers; an explicit height (h-full) wins */
    /* No touch-action override: on touch the lens is off, scrolling stays free. */
  }
  .xrv :global(.xrv-img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .xrv :global(.xrv-top) {
    position: absolute;
    inset: 0;
    opacity: 0;
    /* tight feather (65% -> 95%) keeps the perceived reveal within one flat */
    -webkit-mask-image: radial-gradient(circle var(--r, 85px) at var(--x, 50%) var(--y, 50%), #000 65%, transparent 95%);
    mask-image: radial-gradient(circle var(--r, 85px) at var(--x, 50%) var(--y, 50%), #000 65%, transparent 95%);
  }
  .xrv.active :global(.xrv-top) { opacity: 1; }
  .xrv.open :global(.xrv-top) {
    opacity: 1;
    -webkit-mask-image: none;
    mask-image: none;
  }
  .xrv-toggle {
    position: absolute;
    bottom: 0.75rem;
    inset-inline-start: 0.75rem;
    z-index: 2;
    background: rgb(14 15 17 / 0.85);
    color: #fff;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-brand);
    cursor: pointer;
  }
  .xrv-toggle:hover { color: var(--color-red-on-dark); }
</style>

<script>
  // Cursor position -> two CSS vars (%); the reveal itself is pure CSS.
  // Hover-capable pointers (mouse/pen) only: touch must scroll the page, not
  // drive the lens — on touch the toggle button is the way in.
  for (const el of document.querySelectorAll<HTMLElement>('.xrv[data-xray]')) {
    const track = (e: PointerEvent) => {
      const r = el.getBoundingClientRect();
      const x = Math.min(100, Math.max(0, ((e.clientX - r.left) / r.width) * 100));
      const y = Math.min(100, Math.max(0, ((e.clientY - r.top) / r.height) * 100));
      el.style.setProperty('--x', x.toFixed(2) + '%');
      el.style.setProperty('--y', y.toFixed(2) + '%');
    };
    const onToggle = (e: Event) => !!(e.target as HTMLElement).closest('.xrv-toggle');
    el.addEventListener('pointermove', (e) => {
      if (e.pointerType === 'touch') return;
      if (el.classList.contains('open') || onToggle(e)) return;
      el.classList.add('active');
      track(e);
    });
    el.addEventListener('pointerleave', () => el.classList.remove('active'));

    const btn = el.querySelector<HTMLButtonElement>('.xrv-toggle');
    btn?.addEventListener('click', () => {
      const open = el.classList.toggle('open');
      el.classList.remove('active');
      btn.setAttribute('aria-pressed', String(open));
      btn.textContent = open ? btn.dataset.close! : btn.dataset.open!;
    });
  }
</script>
