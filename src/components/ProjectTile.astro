---
/* Image-led project tile: mono red index, 1px line border, hover scale 1.02 (brief §9).
   Default 4:3; `portrait` switches to 3:4 for tall building renders.
   With `xray` (the pixel-aligned cutaway twin) the hover story becomes the
   facade x-ray lens instead of the zoom: the flat under the cursor opens up. */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import XrayReveal from './XrayReveal.astro';

interface Props {
  index: string;
  title: string;
  caption?: string;
  image: ImageMetadata;
  alt: string;
  href?: string;
  badge?: string;
  portrait?: boolean;
  xray?: ImageMetadata;
}

const { index, title, caption, image, alt, href, badge, portrait = false, xray } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag href={href} class="group card block overflow-hidden reveal">
  <div class:list={['relative overflow-hidden', portrait ? 'aspect-[3/4]' : 'aspect-[4/3]']}>
    {xray ? (
      <XrayReveal
        base={image}
        xray={xray}
        alt={alt}
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 420px, 100vw"
        radius={55}
        class="h-full w-full"
      />
    ) : (
      <Image
        src={image}
        alt={alt}
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 420px, 100vw"
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
      />
    )}
    <span class="t-tech absolute top-3 inset-inline-start-3 bg-night-950/80 text-red-on-dark px-2 py-1 rounded-brand">
      {index}
    </span>
    {badge && (
      <span class="t-tech absolute top-3 inset-inline-end-3 bg-concrete-050/90 text-graphite-600 border border-dashed border-graphite-400/60 px-2 py-1 rounded-brand">
        {badge}
      </span>
    )}
  </div>
  <div class="p-4">
    <h3 class="t-heading-s group-hover:text-mey-red transition-colors">{title}</h3>
    {caption && <p class="t-caption text-graphite-400 mt-1">{caption}</p>}
  </div>
</Tag>
