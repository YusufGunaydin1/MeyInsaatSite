---
/*
  THE signature section (design brief §11; drawing-sheet staging since 2026-07-10):
  scroll = time. A pinned full-viewport theatre scrubs 17 time-lapse frames
  (excavation -> topping-out) with inter-frame crossfade. Desktop composes like a
  construction sheet: title + company values inline-start, the building centred
  beside a vertical survey RULER (stage ticks 01–04, red fill + datum dot rising
  with scroll), and the four stages inline-end — visually roof-down (04 on top) so
  each stage sits at its height on the building, dashed leader lines pointing in.
  The in-canvas red level-line + mono readout stay (guide-line device, brief §7).

  Fallbacks (mandatory): prefers-reduced-motion, Save-Data, or no JS render the
  final-state poster + the four stages as plain text. Stage list is real text always.
*/
import type { Locale } from '../lib/i18n';
import { ui } from '../lib/content';
import SectionHeading from './SectionHeading.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui(locale);

const frameModules = import.meta.glob<{ default: string }>(
  '../assets/frames/frame-*.webp',
  { eager: true, query: '?url', import: 'default' }
);
const frameUrls = Object.keys(frameModules)
  .sort()
  .map((k) => frameModules[k] as unknown as string);
const poster = frameUrls[frameUrls.length - 1];

/*
  Stage boundaries (last frame of each stage), tuned by reviewing the real frames:
  1-2 excavation · 3-9 foundation+frame · 10-14 infill mass · 15-17 topping-out.
  Single source of truth: serialized to data-stage-bounds for the scrub script and
  used here to place each ruler tick at its stage's centre frame.
*/
const STAGE_FROM_FRAME = [2, 9, 14, 17];
const lastPos = frameUrls.length - 1;
const tickPct = STAGE_FROM_FRAME.map((max, i) => {
  const start = i === 0 ? 0 : STAGE_FROM_FRAME[i - 1];
  return (((start + max - 1) / 2 / lastPos) * 100).toFixed(2);
});

const values: { name: string; desc: string }[] = t.signature.values ?? [];
/* Outline icon paths (24px grid, stroke): shield-check · layers · clock */
const valueIcons: string[][] = [
  ['M12 3.5 19 6.2v5c0 4.4-2.9 7.8-7 9.3-4.1-1.5-7-4.9-7-9.3v-5L12 3.5Z', 'm9 11.6 2.1 2.1 4.1-4.2'],
  ['m12 3.5 8.5 4.7L12 12.9 3.5 8.2 12 3.5Z', 'm3.5 12.4 8.5 4.7 8.5-4.7', 'm3.5 16.4 8.5 4.7 8.5-4.7'],
  ['M12 20.5a8.5 8.5 0 1 1 0-17 8.5 8.5 0 0 1 0 17Z', 'M12 8.5V13l3 2'],
];
---

<section
  class="theatre blueprint-grid"
  data-scrub
  data-frames={JSON.stringify(frameUrls)}
  data-stage-bounds={JSON.stringify(STAGE_FROM_FRAME)}
  data-label-excavation={t.signature.readout.excavation}
  data-label-foundation={t.signature.readout.foundation}
  data-label-floor={t.signature.readout.floor}
  data-label-datum={t.signature.hud?.datum ?? 'KOT'}
  aria-labelledby="scroll-to-build-title"
>
  <!-- Small screens + static mode keep the classic heading above the theatre;
       on desktop the title lives INSIDE the pinned sheet (inline-start column). -->
  <div class="container-site pt-16 sm:pt-20 lg:hidden">
    <SectionHeading
      eyebrow={t.signature.eyebrow}
      title={t.signature.title}
      intro={t.signature.sub}
      onDark
    />
  </div>

  <div class="scrub-wrap" data-scrub-wrap>
    <div class="scrub-stage" data-scrub-stage>
      <!-- Cinematic backdrop: the current frame, blurred — depth without upscaling
           the 720px source. Decorative only; dark night-950 if unsupported. -->
      <canvas class="scrub-bgfx" data-bgfx aria-hidden="true"></canvas>

      <div class="scrub-hud t-tech" aria-hidden="true">
        <span>{t.signature.hud?.source}</span>
        <span>{t.signature.hud?.scroll}</span>
      </div>

      <div class="scrub-grid container-site h-full">
        <!-- Title column (desktop): eyebrow, display title, guide-rule, intro,
             values. This h2 names the section in EVERY viewport (aria-labelledby
             resolves display:none refs); small screens SHOW the heading above. -->
        <div class="scrub-title-col">
          <p class="t-tech text-mey-teal mb-3">{t.signature.eyebrow}</p>
          <h2 id="scroll-to-build-title" class="t-display-l">{t.signature.title}</h2>
          <span class="scrub-title-rule" aria-hidden="true"></span>
          <p class="t-body-l text-concrete-100/80 scrub-title-sub">{t.signature.sub}</p>
          {values.length > 0 && (
            <ul class="scrub-values" role="list">
              {values.map((v, i) => (
                <li class="scrub-value">
                  <svg
                    class="scrub-value-icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {valueIcons[i % valueIcons.length].map((d) => (
                      <path d={d} />
                    ))}
                  </svg>
                  <div>
                    <p class="t-tech scrub-value-name">{v.name}</p>
                    <p class="t-caption scrub-value-desc">{v.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- Stage list: real text, SEO/a11y-safe. DOM keeps construction order
             01→04; desktop reverses it VISUALLY so 04 sits at the roof. sr-only on
             small screens (a compact active-stage line replaces it visually). -->
        <ol class="scrub-stages" data-stage-list>
          {t.signature.stages.map((s: any, i: number) => (
            <li class="scrub-stage-item" data-stage-item={i}>
              <span class="scrub-stage-leader" aria-hidden="true"></span>
              <span class="scrub-stage-no tabular-nums" aria-hidden="true">{s.no}</span>
              <div class="scrub-stage-body">
                <h3 class="scrub-stage-name">{s.name}</h3>
                <p class="t-caption scrub-stage-desc">{s.desc}</p>
              </div>
            </li>
          ))}
        </ol>

        <div class="scrub-center">
          <!-- Survey ruler: a builder's level staff for the whole scrub — stage
               ticks at their centre frames, red fill + datum dot rise with scroll. -->
          <div class="scrub-ruler" aria-hidden="true">
            <span class="t-tech scrub-ruler-cap">{t.signature.stages[3].name}</span>
            <div class="scrub-ruler-track">
              <i class="scrub-ruler-fill" data-ruler-fill></i>
              {t.signature.stages.map((s: any, i: number) => (
                <span class="scrub-ruler-tick" style={`bottom: ${tickPct[i]}%`}>{s.no}</span>
              ))}
              <i class="scrub-ruler-dot" data-ruler-dot></i>
            </div>
            <span class="t-tech scrub-ruler-cap">{t.signature.readout.foundation}</span>
          </div>

          <div class="scrub-canvas-col">
            <!-- Compact mobile stage indicator (visual duplicate of the list's active row) -->
            <div class="scrub-mobile-stage t-tech text-concrete-100/90 lg:hidden" aria-hidden="true">
              <span data-mobile-stage>{t.signature.stages[0].no} {t.signature.stages[0].name}</span>
            </div>
            <div class="scrub-canvas-box" data-canvas-box>
              <!-- Second beat below the HomeHero cover: no longer the page LCP, so
                   it yields load priority to the hero's building image above it. -->
              <img
                src={poster}
                width="900"
                height="1600"
                alt={t.a11y.buildAnimation}
                loading="eager"
                fetchpriority="low"
                decoding="async"
                class="scrub-poster"
                data-poster
              />
              <canvas
                width="900"
                height="1600"
                class="scrub-canvas"
                aria-hidden="true"
                data-canvas
              ></canvas>
              <div class="scrub-level" data-level aria-hidden="true">
                <span class="t-tech scrub-readout" data-readout>{t.signature.readout.excavation} · −4.50 M</span>
              </div>
              <p class="t-tech scrub-loader" data-loader aria-hidden="true">{t.signature.loading} <span data-loader-pct>0%</span></p>
            </div>
          </div>
        </div>
      </div>

      <div class="scrub-progress" aria-hidden="true"><i data-progress-bar></i></div>
    </div>
  </div>

  <!-- Visible ONLY in static mode: explains why the scene isn't animating
       (OS reduced-motion / Save-Data) instead of silently looking broken. -->
  <div class="scrub-static-note container-site pb-10">
    <p class="t-tech text-concrete-100/60">{t.signature.reducedMotionNote}</p>
  </div>

  <noscript>
    <div class="container-site pb-10">
      <p class="t-tech text-concrete-100/60">{t.signature.reducedMotionNote}</p>
    </div>
  </noscript>
</section>

<style>
  .scrub-wrap {
    height: 340vh;
  }
  .scrub-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    /* svh, NOT dvh: dvh changes as the mobile URL bar hides/shows, resizing the
       whole stage mid-scroll (the canvas visibly jumped on scroll direction flips) */
    height: 100svh;
    overflow: hidden;
    padding-block: 3.25rem 1.5rem;
  }
  /* Static mode (reduced motion / Save-Data / no JS): no pin, natural height */
  [data-static] .scrub-wrap {
    height: auto;
  }
  [data-static] .scrub-stage {
    position: static;
    height: auto;
    overflow: visible;
    padding-block: 3rem;
  }
  [data-static] .scrub-bgfx,
  [data-static] .scrub-hud,
  [data-static] .scrub-progress {
    display: none;
  }
  .scrub-static-note {
    display: none;
  }
  [data-static] .scrub-static-note {
    display: block;
  }

  .scrub-bgfx {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 600ms ease-out;
  }
  [data-ready] .scrub-bgfx {
    opacity: 0.25;
  }

  .scrub-hud {
    position: absolute;
    inset-inline: 0;
    top: 0;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1320px;
    margin-inline: auto;
    padding: 1.1rem 1rem 0;
    color: rgb(244 244 242 / 0.6);
  }
  @media (min-width: 640px) {
    .scrub-hud { padding-inline: 1.5rem; }
  }

  .scrub-grid {
    position: relative;
    display: grid;
    align-items: center;
    align-content: center;
    gap: 1rem;
    grid-template-columns: 1fr;
    justify-items: center;
  }
  @media (min-width: 1024px) {
    .scrub-grid {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: clamp(1.25rem, 3vw, 3.5rem);
      justify-items: start;
    }
    /* Explicit placement: DOM keeps reading order title → stages → building,
       while the sheet composes title | building | stages. */
    .scrub-title-col { grid-column: 1; grid-row: 1; }
    .scrub-center { grid-column: 2; grid-row: 1; }
    .scrub-stages { grid-column: 3; grid-row: 1; }
  }

  /* ---- Title column (desktop-only; small screens use the heading above the pin) */
  .scrub-title-col {
    display: none;
  }
  @media (min-width: 1024px) {
    .scrub-title-col {
      display: block;
      max-width: 24rem;
    }
  }
  /* The guide-line as a title underscore (brief §7) */
  .scrub-title-rule {
    display: block;
    width: 2.75rem;
    height: 2px;
    background: var(--color-red-on-dark);
    margin-block: 1.4rem;
  }
  .scrub-title-sub {
    max-width: 30ch;
  }
  .scrub-values {
    display: grid;
    gap: 1.35rem;
    margin-block-start: 2.25rem;
  }
  .scrub-value {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.9rem;
    align-items: start;
  }
  .scrub-value-icon {
    width: 22px;
    height: 22px;
    color: var(--color-red-on-dark);
    margin-block-start: 0.1rem;
  }
  .scrub-value-name {
    color: rgb(244 244 242 / 0.92);
  }
  /* Plex Mono has no Arabic — the technical layer switches face per-locale */
  .scrub-value-name:lang(ar) {
    font-family: var(--font-arabic);
    letter-spacing: 0;
  }
  .scrub-value-desc {
    color: rgb(244 244 242 / 0.55);
    margin-block-start: 0.3rem;
    max-width: 30ch;
  }

  /* ---- Centre: survey ruler + canvas */
  .scrub-center {
    display: flex;
    align-items: stretch;
    gap: 1.1rem;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .scrub-center { width: auto; }
  }

  /*
    The canvas column must have a DEFINITE width: inside the grid's `auto` track a
    percentage width is circular and collapses to 0. Bound by 580px (respects the
    900px source — mild upscale only) and by viewport height so 9:16 fits the pin.
  */
  .scrub-canvas-col {
    width: min(100%, 84vw, calc((100svh - 9.5rem) * 0.5625));
    margin-inline: auto;
  }
  @media (min-width: 1024px) {
    .scrub-canvas-col {
      width: min(580px, calc((100svh - 9.5rem) * 0.5625));
      margin-inline: 0;
    }
  }
  /* Frames carry alpha (sky removed): no box chrome, the building floats on the
     theatre and the blurred backdrop shows through where the sky was. */
  .scrub-canvas-box {
    position: relative;
    aspect-ratio: 9 / 16;
    width: 100%;
    border-radius: var(--radius-brand);
    overflow: hidden;
  }
  .scrub-poster,
  .scrub-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .scrub-canvas {
    opacity: 0;
    transition: opacity 300ms ease-out;
  }
  [data-ready] .scrub-canvas {
    opacity: 1;
  }
  [data-ready] .scrub-poster {
    visibility: hidden;
  }

  /* ---- Survey ruler (desktop scrub only) */
  .scrub-ruler {
    display: none;
  }
  @media (min-width: 1024px) {
    .scrub-ruler {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.7rem;
      /* room for the tick numerals hanging off the inline-start side */
      padding-inline-start: 2.4rem;
    }
    [data-static] .scrub-ruler {
      display: none;
    }
  }
  .scrub-ruler-cap {
    color: rgb(244 244 242 / 0.55);
  }
  .scrub-ruler-cap:lang(ar) {
    font-family: var(--font-arabic);
    letter-spacing: 0;
  }
  .scrub-ruler-track {
    position: relative;
    flex: 1;
    width: 2px;
    background: rgb(255 255 255 / 0.16);
  }
  /* End caps of the level staff (physical centring — symmetric, RTL-safe) */
  .scrub-ruler-track::before,
  .scrub-ruler-track::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 11px;
    height: 1px;
    background: rgb(255 255 255 / 0.4);
  }
  .scrub-ruler-track::before { top: 0; }
  .scrub-ruler-track::after { bottom: 0; }
  .scrub-ruler-fill {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 0%;
    background: var(--color-red-on-dark);
  }
  .scrub-ruler-dot {
    position: absolute;
    left: 50%;
    bottom: 0%;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-red-on-dark);
    border: 2px solid var(--color-night-950);
    transform: translate(-50%, 50%);
  }
  .scrub-ruler-tick {
    position: absolute;
    inset-inline-end: calc(100% + 1rem);
    transform: translateY(50%);
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    line-height: 1;
    color: rgb(242 85 90 / 0.8);
    font-variant-numeric: tabular-nums;
  }
  /* Tick dash bridging numeral → track */
  .scrub-ruler-tick::after {
    content: '';
    position: absolute;
    top: 50%;
    inset-inline-start: calc(100% + 0.3rem);
    width: 0.7rem;
    height: 1px;
    background: rgb(255 255 255 / 0.4);
  }

  .scrub-level {
    position: absolute;
    inset-inline: 0;
    bottom: 8%;
    border-top: 2px solid var(--color-red-on-dark);
    pointer-events: none;
  }
  [data-static] .scrub-level {
    display: none;
  }
  .scrub-readout {
    position: absolute;
    inset-inline-end: 0.5rem;
    bottom: 0.375rem;
    color: var(--color-red-on-dark);
    background: rgb(14 15 17 / 0.85);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-brand);
  }

  .scrub-loader {
    position: absolute;
    inset-inline-start: 0.5rem;
    top: 0.5rem;
    color: var(--color-mey-teal);
    background: rgb(14 15 17 / 0.85);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-brand);
  }
  [data-ready] .scrub-loader,
  [data-static] .scrub-loader {
    display: none;
  }

  /* Thin progress line: small screens only — the ruler owns progress on desktop */
  .scrub-progress {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 3px;
    background: rgb(255 255 255 / 0.12);
  }
  .scrub-progress i {
    display: block;
    height: 100%;
    width: 0;
    background: var(--color-red-on-dark);
  }
  @media (min-width: 1024px) {
    .scrub-progress {
      display: none;
    }
  }

  /* ---- Stage list */
  .scrub-stages {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 28rem;
  }
  @media (min-width: 1024px) {
    .scrub-stages {
      /* Roof-down: 04 at the top — each stage reads at its height on the
         building. DOM stays 01→04 so readers and SEO get construction order. */
      flex-direction: column-reverse;
      justify-content: space-between;
      gap: 0.5rem;
      align-self: stretch;
      max-width: none;
      padding-block: 1.25rem;
    }
  }
  .scrub-stage-item {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.9rem;
  }
  @media (min-width: 1024px) {
    .scrub-stage-item {
      /* leader line | numeral | text — text column fixed so all four align */
      grid-template-columns: minmax(0.75rem, 1fr) auto minmax(0, 15rem);
    }
  }

  .scrub-stage-leader {
    display: none;
  }
  @media (min-width: 1024px) {
    .scrub-stage-leader {
      display: block;
      position: relative;
      align-self: start;
      /* optical centre of the numeral's first line */
      margin-block-start: 0.8rem;
      border-block-start: 1px dashed rgb(244 244 242 / 0.22);
    }
    /* Terminal dot on the building side */
    .scrub-stage-leader::before {
      content: '';
      position: absolute;
      inset-inline-start: -2px;
      top: -3.5px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgb(244 244 242 / 0.35);
    }
    .scrub-stage-item[data-active] .scrub-stage-leader {
      border-color: rgb(242 85 90 / 0.6);
    }
    .scrub-stage-item[data-active] .scrub-stage-leader::before {
      background: var(--color-red-on-dark);
    }
  }

  .scrub-stage-no {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: clamp(1.35rem, 1.6vw, 1.75rem);
    line-height: 1.15;
    letter-spacing: 0.02em;
    /* dimmed red — decorative numeral (aria-hidden), full red when active */
    color: rgb(242 85 90 / 0.55);
  }
  .scrub-stage-item[data-active] .scrub-stage-no {
    color: var(--color-red-on-dark);
  }
  .scrub-stage-name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    /* 0.6 keeps ~5.9:1 on night-950 (WCAG AA) */
    color: rgb(244 244 242 / 0.6);
    margin-block-start: 0.4rem;
  }
  .scrub-stage-name:lang(ar) {
    font-family: var(--font-arabic);
    letter-spacing: 0;
  }
  .scrub-stage-item[data-active] .scrub-stage-name {
    color: #fff;
  }
  .scrub-stage-desc {
    color: rgb(244 244 242 / 0.5);
    margin-block-start: 0.35rem;
    max-width: 34ch;
  }
  .scrub-stage-item[data-active] .scrub-stage-desc {
    color: rgb(244 244 242 / 0.75);
  }

  /* Small screens: the vertical rail goes screen-reader-only; compact line replaces
     it. Gated on html.js: without JS the mandated four-stage static list must show. */
  .scrub-mobile-stage {
    text-align: center;
    margin-bottom: 0.6rem;
  }
  @media (max-width: 1023px) {
    /* :global(.js): the class lives on <html>, outside this component's scope —
       a scoped `.js` compiles to `.js:where(.astro-…)` and never matches. */
    :global(.js) [data-scrub]:not([data-static]) .scrub-stages {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border-width: 0;
    }
  }
  @media (min-width: 1024px) {
    .scrub-mobile-stage {
      display: none;
    }
  }
  [data-static] .scrub-mobile-stage {
    display: none;
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('[data-scrub]');

  function initScrub(root: HTMLElement) {
    const urls: string[] = JSON.parse(root.dataset.frames || '[]');
    const wrap = root.querySelector<HTMLElement>('[data-scrub-wrap]')!;
    const canvas = root.querySelector<HTMLCanvasElement>('[data-canvas]')!;
    const bgfx = root.querySelector<HTMLCanvasElement>('[data-bgfx]')!;
    const box = root.querySelector<HTMLElement>('[data-canvas-box]')!;
    const level = root.querySelector<HTMLElement>('[data-level]')!;
    const readout = root.querySelector<HTMLElement>('[data-readout]')!;
    const loaderPct = root.querySelector<HTMLElement>('[data-loader-pct]')!;
    const mobileStage = root.querySelector<HTMLElement>('[data-mobile-stage]')!;
    const rulerFill = root.querySelector<HTMLElement>('[data-ruler-fill]')!;
    const rulerDot = root.querySelector<HTMLElement>('[data-ruler-dot]')!;
    const progressBar = root.querySelector<HTMLElement>('[data-progress-bar]')!;
    const stageItems = Array.from(
      root.querySelectorAll<HTMLElement>('[data-stage-item]')
    );

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as any).connection?.saveData === true;
    if (reduced || saveData || urls.length === 0) {
      root.dataset.static = 'true';
      stageItems.forEach((el) => (el.dataset.active = 'true'));
      return;
    }

    // Stage thresholds: single source is the component frontmatter (it also
    // places the ruler ticks) — serialized through data-stage-bounds.
    const STAGE_FROM_FRAME: number[] = JSON.parse(
      root.dataset.stageBounds || '[2, 9, 14, 17]'
    );
    const labels = {
      excavation: root.dataset.labelExcavation ?? 'KAZI',
      foundation: root.dataset.labelFoundation ?? 'TEMEL',
      floor: root.dataset.labelFloor ?? 'KAT',
      datum: root.dataset.labelDatum ?? 'KOT',
    };

    const ctx = canvas.getContext('2d')!;
    const bctx = bgfx.getContext('2d');
    let bitmaps: (ImageBitmap | HTMLImageElement)[] = [];
    let currentPos = -1;
    let currentFrame = -1;
    let bgFrame = -1;
    let ticking = false;

    function stageOf(frame: number): number {
      return STAGE_FROM_FRAME.findIndex((max) => frame <= max);
    }

    function floorOf(frame: number): number {
      return Math.min(6, Math.max(1, Math.round((frame - 3) / 2)));
    }

    // One source for every HUD element: big label, elevation, level-line height
    function meta(frame: number): { big: string; elev: string; lvl: number } {
      if (frame <= 2) return { big: labels.excavation, elev: '−4.50 M', lvl: 8 };
      if (frame <= 4) return { big: labels.foundation, elev: '±0.00 M', lvl: 12 };
      const kat = floorOf(frame);
      const h = ((kat * 18.4) / 6).toFixed(2);
      return { big: `${labels.floor} ${kat}`, elev: `+${h} M`, lvl: 15 + (kat / 6) * 70 };
    }

    function sizeBg() {
      bgfx.width = Math.max(1, Math.round(window.innerWidth / 3));
      bgfx.height = Math.max(1, Math.round(window.innerHeight / 3));
      bgFrame = -1; // force redraw at the new size
    }

    function drawBg(frame: number) {
      if (!bctx || frame === bgFrame) return;
      const bmp = bitmaps[frame - 1];
      if (!bmp) return;
      bgFrame = frame;
      try {
        // Alpha frames: clear first or the previous (taller) building ghosts
        // through the transparent sky when scrubbing backward.
        bctx.clearRect(0, 0, bgfx.width, bgfx.height);
        bctx.filter = 'blur(14px) brightness(0.55)';
        bctx.drawImage(
          bmp as CanvasImageSource,
          -32, -32, bgfx.width + 64, bgfx.height + 64
        );
      } catch {
        /* ctx.filter unsupported: backdrop stays night-950 — acceptable */
      }
    }

    function render(pos: number) {
      if (Math.abs(pos - currentPos) < 0.002) return;
      currentPos = pos;
      const base = Math.floor(pos);
      const frac = pos - base;
      const a = bitmaps[base];
      const b = bitmaps[base + 1];
      if (a) {
        ctx.globalAlpha = 1;
        // Alpha frames: clear first — without it a taller building from a later
        // frame stays visible through the transparent sky on upward scroll.
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(a as CanvasImageSource, 0, 0, canvas.width, canvas.height);
        // Crossfade to the next frame: 17 frames scrub like a continuous take
        if (b && frac > 0.01) {
          ctx.globalAlpha = frac;
          ctx.drawImage(b as CanvasImageSource, 0, 0, canvas.width, canvas.height);
          ctx.globalAlpha = 1;
        }
      }

      const frame = Math.round(pos) + 1;
      // One progress value drives every indicator: mobile bar, ruler fill + dot
      const pct = ((pos / (urls.length - 1)) * 100).toFixed(2);
      progressBar.style.width = `${pct}%`;
      rulerFill.style.height = `${pct}%`;
      rulerDot.style.bottom = `${pct}%`;
      drawBg(frame);
      if (frame === currentFrame) return;
      currentFrame = frame;

      const m = meta(frame);
      level.style.bottom = `${m.lvl}%`;
      readout.textContent = `${m.big} · ${m.elev}`;
      const active = stageOf(frame);
      stageItems.forEach((el, i) => {
        if (i === active) {
          el.dataset.active = 'true';
          el.setAttribute('aria-current', 'step');
        } else {
          delete el.dataset.active;
          el.removeAttribute('aria-current');
        }
      });
      const s = stageItems[active];
      if (s) {
        const no = s.querySelector('.scrub-stage-no')?.textContent ?? '';
        const name = s.querySelector('.scrub-stage-name')?.textContent ?? '';
        mobileStage.textContent = `${no} ${name} — ${m.big} ${m.elev}`;
      }
    }

    function progress(): number {
      const rect = wrap.getBoundingClientRect();
      const span = rect.height - window.innerHeight;
      if (span <= 0) return 1;
      return Math.min(1, Math.max(0, -rect.top / span));
    }

    function posFromProgress(): number {
      return progress() * (urls.length - 1);
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        render(posFromProgress());
      });
    }

    async function loadOne(u: string): Promise<ImageBitmap | HTMLImageElement> {
      if ('createImageBitmap' in window) {
        const res = await fetch(u);
        return await createImageBitmap(await res.blob());
      }
      const img = new Image();
      img.src = u;
      await img.decode();
      return img;
    }

    async function load() {
      let done = 0;
      // Concurrency-limited so the ~1.5MB sequence never floods the connection.
      const results: (ImageBitmap | HTMLImageElement)[] = new Array(urls.length);
      let next = 0;
      async function worker() {
        while (next < urls.length) {
          const i = next++;
          results[i] = await loadOne(urls[i]);
          done += 1;
          loaderPct.textContent = `${Math.round((done / urls.length) * 100)}%`;
        }
      }
      await Promise.all(Array.from({ length: 4 }, worker));
      bitmaps = results;
      sizeBg();
      root.dataset.ready = 'true';
      render(posFromProgress());
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener(
        'resize',
        () => {
          sizeBg();
          currentPos = -1; // force full re-render after canvas resize
          onScroll();
        },
        { passive: true }
      );
      // Expose for E2E measurement: frame index must track scroll (prove the scrub).
      (root as any).__scrub = { getFrame: () => currentFrame, getProgress: progress };
    }

    // Never compete with the initial page load (LCP): start only after window
    // 'load', then on approach (IO) or first scroll intent, whichever comes first.
    function arm() {
      let started = false;
      const start = () => {
        if (started) return;
        started = true;
        io.disconnect();
        window.removeEventListener('scroll', start);
        load();
      };
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) start();
        },
        { rootMargin: '75% 0px' }
      );
      io.observe(box);
      window.addEventListener('scroll', start, { passive: true, once: true });
    }

    if (document.readyState === 'complete') arm();
    else window.addEventListener('load', arm, { once: true });
  }

  if (section) initScrub(section);
</script>
