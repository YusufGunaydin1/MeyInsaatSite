---
import { Image } from 'astro:assets';
import { LOCALES, LOCALE_NAMES, localePath, type Locale } from '../lib/i18n';
import { ui, company, companyContent } from '../lib/content';
import { contactNumber, telHref } from '../lib/contact';
import PlaceholderChip from './PlaceholderChip.astro';
import logo from '../assets/brand/mey-logo-dark.png';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const t = ui(locale);
const prose = companyContent(locale);
const year = new Date().getFullYear();
const phone = contactNumber(company.contact.phone);
const phoneLink = telHref(company.contact.phone);

const items = [
  { href: '/', label: t.nav.home },
  { href: '/projeler', label: t.nav.projects },
  { href: '/satilik-daireler', label: t.nav.forSale },
  { href: '/kurumsal', label: t.nav.corporate },
  { href: '/hizmetler', label: t.nav.services },
  { href: '/iletisim', label: t.nav.contact },
  // Çerez bandının arkasındaki metin — her sayfadan erişilebilir olmalı (KVKK).
  // Sayfa yalnız TR yayınlanıyor (hukuki metin makine çevirisiyle yayınlanmaz), bu
  // yüzden dil öneki EKLENMEZ: localePath('en', …) var olmayan bir URL üretirdi.
  { href: '/gizlilik-ve-cerez-politikasi', label: t.footer.privacy, trOnly: true },
];
---

<footer class="theatre blueprint-grid mt-auto">
  <div class="container-site py-14">
    <div class="grid gap-10 md:grid-cols-[2fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3">
          <Image src={logo} alt="MEY İnşaat" height={30} densities={[1, 2]} class="h-[30px] w-auto" />
        </div>
        <p class="t-caption mt-4 max-w-sm text-concrete-100/70">
          {prose?.frontmatter?.boilerplate}
        </p>
        <p class="t-tech mt-4 text-mey-teal">{t.footer.groupNote}</p>
      </div>

      <nav aria-label={t.a11y.footerNav}>
        <h2 class="t-tech text-concrete-100/50 mb-3">{t.footer.sitemap}</h2>
        <ul class="space-y-2">
          {items.map((item) => (
            <li>
              <a href={item.trOnly ? item.href + '/' : localePath(locale, item.href)} class="t-caption text-concrete-100/85 hover:text-white">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <h2 class="t-tech text-concrete-100/50 mb-3">{t.footer.contact}</h2>
        <ul class="space-y-2 t-caption text-concrete-100/85">
          <li>
            {phone && phoneLink
              ? <a href={phoneLink} class="hover:text-white">{phone.display}</a>
              : <PlaceholderChip locale={locale} label={t.contact.phone} onDark />}
          </li>
          <li>
            {company.contact.email
              ? <a href={`mailto:${company.contact.email}`} class="hover:text-white">{company.contact.email}</a>
              : <PlaceholderChip locale={locale} label={t.contact.email} onDark />}
          </li>
          <li>
            {company.contact.address
              ? <span>{company.contact.address}</span>
              : <PlaceholderChip locale={locale} label={t.contact.address} onDark />}
          </li>
        </ul>
      </div>

      <div>
        <h2 class="t-tech text-concrete-100/50 mb-3">{t.footer.languages}</h2>
        <ul class="space-y-1">
          {LOCALES.map((l) => (
            <li>
              <a
                href={localePath(l, path)}
                lang={l}
                hreflang={l}
                aria-current={l === locale ? 'true' : undefined}
                class="foot-lang"
              >
                <span class="t-tech foot-lang-code" aria-hidden="true">{l.toUpperCase()}</span>
                <span class="foot-lang-name">{LOCALE_NAMES[l]}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-wrap items-center justify-between gap-2">
      <p class="t-tech text-concrete-100/50">© {year} {company.legalName ?? company.name} · {t.footer.rights}</p>
      <p class="t-tech text-concrete-100/50">{prose?.frontmatter?.slogan}</p>
    </div>
  </div>
</footer>

<style>
  /* Language rows: mono code + endonym; active carries the red guide-line */
  .foot-lang {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    column-gap: 0.6rem;
    align-items: baseline;
    padding-block: 0.2rem;
  }
  .foot-lang-code {
    color: rgb(244 244 242 / 0.55);
  }
  .foot-lang-name {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.4;
    color: rgb(244 244 242 / 0.8);
  }
  /* The Arabic endonym uses Plex Arabic only where the page already ships it
     (AR pages); elsewhere the system Arabic face renders this one row so
     Latin/Cyrillic pages never download the Arabic subset (brief §6). */
  :global(html:lang(ar)) .foot-lang-name:lang(ar) {
    font-family: var(--font-arabic);
  }
  .foot-lang:hover .foot-lang-name {
    color: #fff;
  }
  .foot-lang[aria-current] .foot-lang-code {
    color: var(--color-red-on-dark);
  }
  .foot-lang[aria-current] .foot-lang-name {
    color: #fff;
  }
</style>
