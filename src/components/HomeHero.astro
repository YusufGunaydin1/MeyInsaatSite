---
/*
  HOME HERO — sky cover under a dark scrim (2026-07, owner-directed). Three
  delivered MEY blocks under a blue sky; the copy sits in the open sky on the
  left, white over a graphite scrim that fuses with the dark header (the
  owner kept the theatre treatment when the photo changed). The copy block is
  pinned to the PHYSICAL left in every locale — the sky is only on that side
  of the photo — so RTL mirrors type alignment but not placement. The
  scroll-to-build signature follows immediately as the second beat.
  Copy comes from content/pages/home.<loc>.md so all four locales stay in sync.
*/
import { Image } from 'astro:assets';
import { localePath, type Locale } from '../lib/i18n';
import { pageContent } from '../lib/content';
import heroImg from '../assets/photos/hero-three-blocks-sky.webp';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const fm = pageContent('home', locale)?.frontmatter ?? {};
const headlineLines: string[] = String(fm.hero?.headline ?? '').split('\n');
---

<section class="theatre home-hero" aria-label={fm.hero?.mediaAlt}>
  <!-- The delivered blocks. Decorative (the headline carries meaning); the LCP
       image, so eager + high priority. -->
  <Image
    src={heroImg}
    alt=""
    aria-hidden="true"
    widths={[768, 1280, 1600, 2048, 2880]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    class="home-hero-bg"
  />
  <div class="home-hero-scrim" aria-hidden="true"></div>

  <div class="container-site home-hero-inner">
    <!-- The red guide-line marks the content edge (brief §7/§8 hero wireframe). -->
    <div class="home-hero-copy guide-line-v">
      <p class="t-tech home-hero-eyebrow">{fm.hero?.eyebrow}</p>
      <h1 class="t-display-xl uppercase home-hero-title">
        {headlineLines.map((line: string, i: number) => (
          <>
            {line}
            {i < headlineLines.length - 1 && <br />}
          </>
        ))}
      </h1>
      <p class="t-body-l home-hero-sub">{fm.hero?.sub}</p>
      <div class="home-hero-cta">
        <a href={localePath(locale, '/projeler')} class="btn-primary">
          {fm.hero?.primaryCta}
          <span aria-hidden="true" class="rtl:-scale-x-100 inline-block">→</span>
        </a>
        <a href={localePath(locale, '/iletisim')} class="btn-ghost">{fm.hero?.secondaryCta}</a>
      </div>
    </div>
  </div>

  {fm.hero?.mediaTag && (
    <div class="t-tech home-hero-tag" aria-hidden="true">{fm.hero.mediaTag}</div>
  )}
</section>

<style>
  .home-hero {
    position: relative;
    overflow: hidden;
    min-height: min(84svh, 720px);
    display: flex;
    align-items: center;
    padding-block: clamp(3rem, 9vh, 6rem);
  }
  /* 22% x: on portrait crops keep the sky + gray tower (left of frame) instead
     of the facade center; 25% y: on wide crops trim sky top before the ground
     wall so the block tops and the MEY sign stay in frame. */
  .home-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 22% 25%;
  }
  /* Graphite scrim, heavy over the physical left where the copy sits: the
     bright sky and the towers' pale facades would otherwise sink white type
     below AA. A lighter bottom wash seats the delivered-tag and keeps the
     duotone-lite mood (brief §10); the right stays clear so the blocks and
     both MEY signs read. */
  .home-hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgb(14 15 17 / 0.78) 0%,
        rgb(14 15 17 / 0.52) 38%,
        rgb(14 15 17 / 0.1) 66%,
        rgb(14 15 17 / 0) 100%
      ),
      linear-gradient(to top, rgb(14 15 17 / 0.5) 0%, rgb(14 15 17 / 0.12) 32%, rgb(14 15 17 / 0) 55%);
  }
  .home-hero-inner {
    position: relative;
    /* Flex item: without an explicit width the container shrink-wraps the
       narrow copy block and centers, pulling the copy off the left edge. */
    width: 100%;
  }
  /* margin-right (physical, not logical): pins the block to the left in RTL
     too — the photo's sky only exists on the left. Width fits the headline's
     authored 2-line break; narrower wraps it to 4. Guide-line recolored to the
     theatre-safe red; a restrained text-shadow keeps type legible where the
     scrim thins (the cinematic-hero exception to the flat rule; buttons opt
     out below). */
  .home-hero-copy {
    max-width: 42rem;
    margin-right: auto;
    padding-inline-start: 1.5rem;
    border-inline-start-color: var(--color-red-on-dark);
    text-shadow: 0 1px 8px rgb(14 15 17 / 0.55);
  }
  .home-hero-eyebrow {
    color: var(--color-red-on-dark);
  }
  /* t-display-xl (108px cap) is sized for full-bleed covers; the sky pocket
     left of the towers fits ~600px lines — cap lower, keep the Oswald voice. */
  .home-hero-title {
    margin-top: 1rem;
    font-size: clamp(2rem, 3.9vw, 3.5rem);
  }
  .home-hero-sub {
    margin-top: 1.25rem;
    max-width: 42ch;
    color: rgb(244 244 242 / 0.82);
  }
  .home-hero-cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    text-shadow: none;
  }
  .home-hero-tag {
    position: absolute;
    inset-inline-end: max(1rem, calc((100vw - 1320px) / 2 + 1.5rem));
    bottom: 1.25rem;
    background: rgb(14 15 17 / 0.85);
    color: #fff;
    padding: 0.3rem 0.55rem;
    border-radius: var(--radius-brand);
  }

  /* RTL copy right-aligns inside the left-pinned block, landing on the
     tower/facade seam — carry the scrim further right so white type stays on
     dark ground there too. */
  :global([dir='rtl']) .home-hero-scrim {
    background:
      linear-gradient(
        to right,
        rgb(14 15 17 / 0.8) 0%,
        rgb(14 15 17 / 0.62) 46%,
        rgb(14 15 17 / 0.16) 76%,
        rgb(14 15 17 / 0) 100%
      ),
      linear-gradient(to top, rgb(14 15 17 / 0.5) 0%, rgb(14 15 17 / 0.12) 32%, rgb(14 15 17 / 0) 55%);
  }

  /* Portrait crops center on the gray facade; aim the frame at the open sky
     instead — the copy stays on sky, the towers hold the right edge. The copy
     still brushes that edge, so the scrim comes down from the top-left and
     leaves only the lower third (trees, facade base) clear. */
  @media (max-width: 768px) {
    .home-hero-bg {
      object-position: 0% 25%;
    }
    .home-hero-scrim {
      background:
        linear-gradient(
          165deg,
          rgb(14 15 17 / 0.8) 0%,
          rgb(14 15 17 / 0.6) 50%,
          rgb(14 15 17 / 0.14) 78%,
          rgb(14 15 17 / 0) 100%
        ),
        linear-gradient(to top, rgb(14 15 17 / 0.45) 0%, rgb(14 15 17 / 0) 40%);
    }
  }
</style>
