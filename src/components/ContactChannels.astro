---
/*
  General company channels — landline and email only. The mobile call/WhatsApp
  number is intentionally scoped to the for-sale experience.
*/
import type { Locale } from '../lib/i18n';
import { ui, company } from '../lib/content';
import { contactNumber, telHref } from '../lib/contact';
import PlaceholderChip from './PlaceholderChip.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui(locale);
const c = company.contact;
const phone = contactNumber(c.phone);

const channels = [
  {
    key: 'phone',
    label: t.contact.phone,
    value: phone?.display,
    href: telHref(c.phone),
  },
  {
    key: 'email',
    label: t.contact.email,
    value: c.email,
    href: c.email ? `mailto:${c.email}` : null,
  },
];
---

<div class="grid gap-px sm:grid-cols-2 bg-line border border-line rounded-brand overflow-hidden reveal">
  {channels.map((ch) =>
    ch.href ? (
      <a href={ch.href} class="bg-white p-5 hover:bg-concrete-100 transition-colors block">
        <p class="t-tech text-graphite-400">{ch.label}</p>
        <p class="t-heading-s mt-2 tabular-nums">{ch.value}</p>
      </a>
    ) : (
      <div class="bg-white p-5">
        <p class="t-tech text-graphite-400">{ch.label}</p>
        <p class="mt-2"><PlaceholderChip locale={locale} /></p>
      </div>
    )
  )}
</div>
