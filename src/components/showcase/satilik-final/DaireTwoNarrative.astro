---
import { getSaleMediaList } from '../satilik-daireler/media';
import { apartmentPresentations, compactSaleContent } from './data';
import PropertyImage from './PropertyImage.astro';
import RoomAtlas from './RoomAtlas.astro';

const apartment = compactSaleContent.apartments['daire-2'];
const presentation = apartmentPresentations['daire-2'];
const lower = getSaleMediaList(presentation.lowerMediaIds);
const upper = getSaleMediaList(presentation.upperMediaIds);
const arrival = getSaleMediaList(['d2:d2-merdiven-1.png', 'd2:d2-koridor.png']);
---

<section class="sd-story-section" aria-labelledby="d2-arrival-title">
  <div class="sd-container sd-d2-arrival">
    <div class="sd-d2-arrival-copy">
      <p class="sd-eyebrow">Daire 2’nin vurgusu</p>
      <h2 class="sd-section-title" id="d2-arrival-title">Merdiven hattı, mekân sırasını kuruyor.</h2>
      <p>{apartment.character}</p>
    </div>
    <div class="sd-d2-arrival-media">{arrival.map((media) => <PropertyImage media={media} sizes="(min-width: 760px) 430px, 50vw" />)}</div>
  </div>
</section>

<section class="sd-story-section is-soft" aria-labelledby="d2-floor-title">
  <div class="sd-container">
    <header class="sd-section-heading">
      <div><p class="sd-eyebrow">Kat hikâyesi</p><h2 class="sd-section-title" id="d2-floor-title">Üst kattan alt kata iki farklı düzen.</h2></div>
      <p>Daire 2’de önce üst kattaki çatı geometrisi, ardından alt kattaki doğrusal salon ve mutfak akışı gösterilir.</p>
    </header>
    <div class="sd-floor-grid">
      <article class="sd-floor-card">
        <div class="sd-floor-card-media">{upper.map((media) => <PropertyImage media={media} sizes="(min-width: 760px) 280px, 50vw" />)}</div>
        <div class="sd-floor-card-copy"><p class="sd-eyebrow">Üst kat</p><h3>{apartment.upperTitle}</h3><p>{apartment.upperStory}</p></div>
      </article>
      <article class="sd-floor-card">
        <div class="sd-floor-card-media">{lower.map((media) => <PropertyImage media={media} sizes="(min-width: 760px) 280px, 50vw" />)}</div>
        <div class="sd-floor-card-copy"><p class="sd-eyebrow">Alt kat</p><h3>{apartment.lowerTitle}</h3><p>{apartment.lowerStory}</p></div>
      </article>
    </div>
  </div>
</section>

<RoomAtlas apartmentSlug="daire-2" />

