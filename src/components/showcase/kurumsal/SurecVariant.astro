---
/*
  VARYANT C — "SÜREÇ" (Yöntem / Nasıl Çalışırız).
  Register: yöntem odaklı, güveni süreçle veren. Tek gür jest: SÜREÇ OMURGASI —
  8 marka ikonundan kurulu 5 adımlık yatay şerit (Etüt→Kaba İnşaat→Duvar&Cephe→
  Kalite→Teslim), kırmızı kılavuz çizgiyle bağlı. Hikaye yatay zaman çizelgesi,
  çizim↔yapı kanıtıyla desteklenir.
*/
import { Image } from 'astro:assets';
import StatsStrip from '../../StatsStrip.astro';
import PlaceholderChip from '../../PlaceholderChip.astro';
import { corp, img } from './data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const proof = corp.buildings[2]; // Sapanbağları — çizim↔yapı kanıtı
---

<div class="src" data-testid="variant-surec">
  <!-- HERO + süreç şeridi teaser -->
  <section class="container-site src-hero">
    <div class="guide-line-v ps-6 sm:ps-10">
      <p class="t-tech text-mey-red">{corp.eyebrow} · YÖNTEM</p>
      <h1 class="t-display-xl mt-4">{corp.slogan}</h1>
      <p class="t-body-l mt-6 max-w-2xl text-graphite-600">{corp.lead}</p>
    </div>
    <ol class="src-ribbon mt-10" aria-hidden="true">
      {corp.process.map((s) => (
        <li class="src-ribbon-item"><span class="t-tech src-ribbon-no">{s.no}</span><span class="t-tech src-ribbon-nm">{s.name}</span></li>
      ))}
    </ol>
  </section>

  <!-- SİGNATURE: SÜREÇ OMURGASI -->
  <section class="src-spine theatre blueprint-grid" data-testid="src-spine">
    <div class="container-site">
      <p class="t-tech" style="color: var(--color-red-on-dark);">{corp.processTitle.toUpperCase()}</p>
      <h2 class="t-display-l mt-3">Çizimden anahtar teslimine</h2>
      <p class="t-body-l mt-3 max-w-2xl" style="color: rgb(244 244 242 / 0.72);">{corp.processIntro}</p>
      <ol class="src-steps mt-12">
        {corp.process.map((s) => (
          <li class="src-step reveal">
            <div class="src-step-ic"><Image src={s.icon} alt={s.name} widths={[120, 200]} sizes="120px" class="src-step-img" loading="lazy" /></div>
            <span class="t-tech src-step-no">{s.no}</span>
            <h3 class="t-heading-s src-step-nm mt-1">{s.name}</h3>
            <p class="t-caption src-step-tx mt-2">{s.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- HİKAYE — yatay zaman çizelgesi -->
  <section class="container-site section-pad" data-testid="src-story">
    <p class="t-tech text-mey-red">ZAMAN ÇİZELGESİ</p>
    <h2 class="t-display-l mt-3">{corp.storyTitle}</h2>
    <ol class="src-timeline mt-10">
      {corp.story.map((m) => (
        <li class="src-tl-node reveal">
          <span class="src-tl-dot" aria-hidden="true"></span>
          <p class="t-tech text-mey-red src-tl-tag">{m.tag}</p>
          <h3 class="t-heading-m mt-1">{m.title}</h3>
          <p class="t-body mt-2 text-graphite-600">
            {m.text}
            {m.pending && <span class="ms-1 align-middle inline-block"><PlaceholderChip locale="tr" label={m.pending} /></span>}
          </p>
        </li>
      ))}
    </ol>
  </section>

  <!-- ÇİZİM↔YAPI kanıtı -->
  <section class="src-proof" data-testid="src-proof">
    <div class="container-site src-proof-in">
      <div class="src-proof-text">
        <p class="t-tech text-mey-teal-700">ÇİZİM = YAPI</p>
        <h2 class="t-display-l mt-3">Çizdiğimizi inşa ederiz</h2>
        <p class="t-body-l mt-4 text-graphite-600">
          Aksonometrik çizimde gördüğünüz her detay — cephe ritmi, kat düzeni,
          malzeme — sahada birebir inşa edilir. Söz verilen proje, teslim edilen projedir.
        </p>
        <p class="t-caption mt-4 text-graphite-400">{corp.repNote}</p>
      </div>
      <div class="src-proof-pair">
        <figure class="src-proof-iso">
          <Image src={proof.iso} alt={`${proof.name} — aksonometrik çizim (temsilî)`} widths={[360, 560]} sizes="(min-width: 900px) 26vw, 45vw" class="src-img-contain" loading="lazy" />
          <figcaption class="t-tech src-proof-cap">ÇİZİM</figcaption>
        </figure>
        <span class="src-proof-eq t-tech" aria-hidden="true">→</span>
        <figure class="src-proof-photo">
          <Image src={proof.photo} alt={`${proof.name} — tamamlanmış yapı (temsilî görsel)`} widths={[360, 560]} sizes="(min-width: 900px) 26vw, 45vw" class="sc-img" loading="lazy" />
          <figcaption class="t-tech src-proof-cap">YAPI</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- İLKELER — kompakt mono satır -->
  <section class="container-site section-pad">
    <p class="t-tech text-mey-red">İLKELER</p>
    <h2 class="t-display-l mt-3">{corp.valuesTitle}</h2>
    <div class="src-values mt-8">
      {corp.values.map((v) => (
        <article class="src-value">
          <span class="t-tech src-value-no">{v.no}</span>
          <h3 class="t-heading-s mt-2">{v.name}</h3>
          <p class="t-body mt-2 text-graphite-600">{v.text}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- PORTFÖY şeridi + SAYILAR -->
  <section class="src-alt">
    <div class="container-site section-pad" style="padding-block: clamp(3.5rem, 8vh, 6rem);">
      <div class="src-pf-head">
        <div>
          <p class="t-tech text-mey-teal-700">PORTFÖY</p>
          <h2 class="t-display-l mt-3">{corp.portfolioTitle}</h2>
        </div>
        <a class="t-tech src-pf-all" href={`${base}/projeler`}>TÜM PROJELER <span aria-hidden="true">→</span></a>
      </div>
      <div class="src-pf mt-8">
        {corp.buildings.map((b) => (
          <a class="src-pf-item" href={`${base}/projeler/${b.slug}`}>
            <div class="src-pf-img"><Image src={b.photo} alt={`${b.name} (temsilî görsel)`} widths={[320, 520]} sizes="(min-width: 900px) 30vw, 90vw" class="sc-img" loading="lazy" /></div>
            <h3 class="t-heading-s mt-3">{b.name}</h3>
            <p class="t-tech text-graphite-400 mt-1">{b.meta}</p>
          </a>
        ))}
      </div>
      <div class="mt-12"><StatsStrip locale="tr" /></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="theatre blueprint-grid src-cta">
    <div class="container-site">
      <p class="t-tech" style="color: var(--color-red-on-dark);">İLETİŞİM</p>
      <h2 class="t-display-l mt-3">{corp.ctaTitle}</h2>
      <p class="t-body-l mt-3 max-w-xl" style="color: rgb(244 244 242 / 0.72);">{corp.ctaSub}</p>
      <div class="src-cta-row mt-7">
        <a class="btn-primary" href={`${base}/projeler`}>{corp.ctaProjects} <span aria-hidden="true">→</span></a>
        <a class="btn-ghost" href={`${base}/iletisim`}>{corp.ctaContact}</a>
      </div>
    </div>
  </section>
</div>

<style>
  .sc-img { display: block; width: 100%; height: 100%; object-fit: cover; }
  .src-img-contain { display: block; width: 100%; height: 100%; object-fit: contain; }
  .src-alt { background: var(--color-concrete-100); border-block: 1px solid var(--color-line); }
  .src-hero { padding-block: clamp(3rem, 7vh, 5.5rem); }

  /* HERO şerit teaser */
  .src-ribbon { display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; list-style: none; padding: 0; border-top: 1px solid var(--color-line); padding-top: 1.25rem; }
  .src-ribbon-item { display: inline-flex; align-items: baseline; gap: 0.4rem; }
  .src-ribbon-no { color: var(--color-mey-red); }
  .src-ribbon-nm { color: var(--color-graphite-400); }

  /* SÜREÇ OMURGASI (koyu) */
  .src-spine { padding-block: clamp(3.5rem, 9vh, 6.5rem); }
  .src-steps { list-style: none; padding: 0; display: grid; gap: 1.5rem; grid-template-columns: 1fr; position: relative; }
  @media (min-width: 860px) { .src-steps { grid-template-columns: repeat(5, 1fr); gap: 1rem; } }
  .src-step { position: relative; padding-top: 0.5rem; }
  /* bağlayıcı kırmızı kılavuz çizgi (desktop) */
  @media (min-width: 860px) {
    .src-steps::before { content: ""; position: absolute; top: 42px; inset-inline: 8%; height: 2px; background: linear-gradient(to right, rgb(242 85 90 / 0.15), var(--color-red-on-dark), rgb(242 85 90 / 0.15)); }
  }
  .src-step-ic { width: 84px; height: 84px; background: var(--color-night-800); border: 1px solid rgb(255 255 255 / 0.1); border-radius: var(--radius-brand); display: grid; place-items: center; position: relative; z-index: 1; padding: 8px; }
  .src-step-img { width: 100%; height: 100%; object-fit: contain; }
  .src-step-no { color: var(--color-red-on-dark); display: inline-block; margin-top: 0.9rem; }
  .src-step-nm { color: #fff; }
  .src-step-tx { color: rgb(244 244 242 / 0.6); max-width: 26ch; }

  /* Yatay zaman çizelgesi */
  .src-timeline { list-style: none; padding: 0; display: grid; gap: 2rem; grid-template-columns: 1fr; }
  @media (min-width: 800px) { .src-timeline { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; } }
  .src-tl-node { position: relative; padding-top: 1.5rem; border-top: 2px solid var(--color-line); max-width: 42ch; }
  .src-tl-dot { position: absolute; top: -7px; inset-inline-start: 0; width: 12px; height: 12px; background: var(--color-mey-red); border-radius: 50%; }

  /* ÇİZİM↔YAPI */
  .src-proof { background: #fff; border-block: 1px solid var(--color-line); padding-block: clamp(3.5rem, 8vh, 6rem); }
  .src-proof-in { display: grid; gap: 2.5rem; align-items: center; }
  @media (min-width: 900px) { .src-proof-in { grid-template-columns: 1fr 1fr; } }
  .src-proof-text { max-width: 46ch; }
  .src-proof-pair { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 0.9rem; }
  .src-proof-iso { aspect-ratio: 3 / 4; background:
      linear-gradient(to right, rgb(73 193 198 / 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(73 193 198 / 0.06) 1px, transparent 1px), var(--color-concrete-050);
    background-size: 28px 28px, 28px 28px, auto; border: 1px solid var(--color-line); border-radius: var(--radius-brand); overflow: hidden; }
  .src-proof-photo { aspect-ratio: 3 / 4; border: 1px solid var(--color-line); border-radius: var(--radius-brand); overflow: hidden; }
  .src-proof-cap { position: absolute; bottom: 0; inset-inline-start: 0; color: var(--color-graphite-400); background: rgb(255 255 255 / 0.85); padding: 0.15rem 0.4rem; }
  .src-proof-iso, .src-proof-photo { position: relative; }
  .src-proof-eq { color: var(--color-mey-red); font-size: 1.25rem; }

  /* İlkeler */
  .src-values { display: grid; gap: 1px; background: var(--color-line); border: 1px solid var(--color-line); border-radius: var(--radius-brand); overflow: hidden; }
  @media (min-width: 640px) { .src-values { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .src-values { grid-template-columns: repeat(4, 1fr); } }
  .src-value { background: #fff; padding: 1.5rem 1.35rem; }
  .src-value-no { color: var(--color-mey-red); }

  /* Portföy şeridi */
  .src-pf-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .src-pf-all { color: var(--color-mey-teal-700); }
  .src-pf-all:hover { color: var(--color-graphite-900); }
  .src-pf { display: grid; gap: 1.25rem; grid-template-columns: 1fr; }
  @media (min-width: 720px) { .src-pf { grid-template-columns: repeat(3, 1fr); } }
  .src-pf-img { aspect-ratio: 4 / 3; border: 1px solid var(--color-line); border-radius: var(--radius-brand); overflow: hidden; }
  .src-pf-img .sc-img { transition: transform 300ms ease-out; }
  .src-pf-item:hover .sc-img { transform: scale(1.02); }

  .src-cta { padding-block: clamp(3.5rem, 9vh, 6.5rem); }
  .src-cta-row { display: flex; flex-wrap: wrap; gap: 0.9rem; }
</style>
