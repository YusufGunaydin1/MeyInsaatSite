---
/*
  SERGİ kabuğu — mimari minimal katalog. Masaüstünde yapışkan SOL RAY navigasyon
  (mono numaralı, kırmızı string-line aktif göstergesi, altta kalıcı randevu
  eylemi); mobilde üst bar + açılır panel. Ana marka diline en yakın yön:
  concrete zemin, Oswald display, Plex Mono teknik katman, 2px köşe, gölgesiz.
*/
import { Image } from 'astro:assets';
import SatilikShell from '../../../../layouts/SatilikShell.astro';
import logo from '../../../../assets/brand/mey-logo.png';
import { ui } from '../data';

interface Props {
  title: string;
  description: string;
  current: string;
}

const { title, description, current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/sergi';
const href = (h: string) => (h ? `${root}/${h}` : root);
---

<SatilikShell title={title} description={description} bodyClass="sv-sergi">
  <div class="srg-frame">
    <aside class="srg-rail" aria-label="Katalog navigasyonu">
      <a class="srg-brand" href={href('')}>
        <Image src={logo} alt="MEY İnşaat" width={120} densities={[1, 2]} loading="eager" />
        <span class="t-tech srg-brand-line">EL ELE APARTMANI<br />SATIŞ KATALOĞU</span>
      </a>
      <nav class="srg-nav" data-testid="sv-nav-desktop">
        {ui.nav.map((item, i) => (
          <a
            href={href(item.href)}
            aria-current={current === item.href ? 'page' : undefined}
            class="srg-nav-item"
          >
            <span class="t-tech srg-nav-no">{String(i + 1).padStart(2, '0')}</span>
            <span class="srg-nav-label">{item.label}</span>
          </a>
        ))}
      </nav>
      <div class="srg-rail-foot">
        <a class="btn-primary srg-rail-cta" href={href('iletisim')} data-testid="sv-rail-randevu">{ui.cta.randevu}</a>
        <a class="t-tech srg-rail-back" href={base + '/showcases/satilik-daireler'}>← TASARIM YÖNLERİ</a>
      </div>
    </aside>

    <header class="srg-topbar">
      <a class="srg-top-brand" href={href('')}>
        <Image src={logo} alt="MEY İnşaat" width={92} densities={[1, 2]} loading="eager" />
        <span class="t-tech">EL ELE · KATALOG</span>
      </a>
      <button
        type="button"
        class="srg-top-toggle t-tech"
        aria-expanded="false"
        aria-controls="srg-panel"
        data-snav-toggle
        data-testid="sv-nav-toggle"
      >
        MENÜ
      </button>
      <nav class="srg-panel" id="srg-panel" data-snav-panel hidden aria-label="Katalog navigasyonu (mobil)" data-testid="sv-nav-mobile">
        {ui.nav.map((item, i) => (
          <a
            href={href(item.href)}
            aria-current={current === item.href ? 'page' : undefined}
            class="srg-panel-item"
          >
            <span class="t-tech srg-nav-no">{String(i + 1).padStart(2, '0')}</span>
            {item.label}
          </a>
        ))}
        <a class="btn-primary srg-panel-cta" href={href('iletisim')}>{ui.cta.randevu}</a>
      </nav>
    </header>

    <div class="srg-body">
      <main id="main" class="srg-main">
        <slot />
      </main>

      <footer class="srg-foot">
        <div class="srg-foot-row">
          <p class="t-tech">{ui.brand} — {ui.project.toUpperCase()}</p>
          <p class="t-tech srg-foot-mid">{ui.kicker.toUpperCase()}</p>
          <nav aria-label="Alt navigasyon" class="srg-foot-nav">
            {ui.nav.map((item) => (
              <a class="t-tech" href={href(item.href)}>{item.label.toUpperCase()}</a>
            ))}
          </nav>
        </div>
        <p class="t-caption srg-foot-note">{ui.disclaimer}</p>
      </footer>
    </div>
  </div>
</SatilikShell>

<style is:global>
  .sv-sergi {
    background: var(--color-concrete-050);
  }
  /* Sergi plakası: ince çerçeve + mono künye satırı — tüm sayfalar kullanır */
  .sv-sergi .srg-plate {
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    padding: clamp(0.5rem, 1.2vw, 0.8rem);
  }
  .sv-sergi .srg-plate img { display: block; width: 100%; height: auto; border-radius: var(--radius-brand); }
  .sv-sergi .srg-plate-kunye {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0.2rem 0.1rem;
  }
  .sv-sergi .srg-rule {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-block: clamp(2.6rem, 6vh, 4.2rem) 1.6rem;
  }
  .sv-sergi .srg-rule::after {
    content: '';
    flex: 1;
    border-top: 1px solid var(--color-mey-red);
  }
</style>

<style>
  .srg-frame { min-height: 100dvh; }
  @media (min-width: 1024px) {
    .srg-frame { display: grid; grid-template-columns: 250px minmax(0, 1fr); }
  }

  /* ── Sol ray (masaüstü) ── */
  .srg-rail {
    display: none;
    border-inline-end: 1px solid var(--color-line);
    background: var(--color-concrete-050);
  }
  @media (min-width: 1024px) {
    .srg-rail {
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100dvh;
      padding: 1.6rem 1.4rem;
    }
  }
  .srg-brand { display: grid; gap: 0.7rem; }
  .srg-brand-line { color: var(--color-graphite-400); line-height: 1.5; }
  .srg-nav { margin-top: 2.2rem; display: grid; }
  .srg-nav-item {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.55rem 0.6rem;
    border-inline-start: 2px solid transparent;
    color: var(--color-graphite-600);
    font-size: 0.9375rem;
  }
  .srg-nav-item:hover { color: var(--color-graphite-900); background: var(--color-concrete-100); }
  .srg-nav-item[aria-current='page'] {
    border-inline-start-color: var(--color-mey-red);
    color: var(--color-graphite-900);
    font-weight: 500;
  }
  .srg-nav-no { color: var(--color-graphite-400); }
  .srg-nav-item[aria-current='page'] .srg-nav-no { color: var(--color-mey-red); }
  .srg-rail-foot { margin-top: auto; display: grid; gap: 0.9rem; }
  .srg-rail-cta { justify-content: center; }
  .srg-rail-back { color: var(--color-mey-teal-700); }
  .srg-rail-back:hover { color: var(--color-graphite-900); }

  /* ── Üst bar (mobil) ── */
  .srg-topbar {
    position: sticky;
    top: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 1rem;
    background: var(--color-concrete-050);
    border-bottom: 1px solid var(--color-line);
  }
  @media (min-width: 1024px) { .srg-topbar { display: none; } }
  .srg-top-brand { display: flex; align-items: center; gap: 0.7rem; color: var(--color-graphite-400); }
  .srg-top-toggle {
    border: 1px solid var(--color-graphite-900);
    border-radius: var(--radius-brand);
    background: transparent;
    color: var(--color-graphite-900);
    padding: 0.5rem 0.9rem;
    cursor: pointer;
  }
  .srg-panel {
    position: absolute;
    inset-inline: 0;
    top: 100%;
    background: var(--color-concrete-050);
    border-bottom: 1px solid var(--color-line);
    display: grid;
    padding: 0.6rem 1rem 1.1rem;
    gap: 0.15rem;
  }
  .srg-panel-item {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.6rem 0.5rem;
    border-inline-start: 2px solid transparent;
    color: var(--color-graphite-600);
  }
  .srg-panel-item[aria-current='page'] {
    border-inline-start-color: var(--color-mey-red);
    color: var(--color-graphite-900);
    font-weight: 500;
  }
  .srg-panel-cta { margin-top: 0.8rem; justify-content: center; }

  /* ── Gövde ── */
  .srg-body { display: flex; flex-direction: column; min-height: 100dvh; }
  .srg-main { flex: 1; padding: clamp(1.4rem, 3vw, 2.6rem) clamp(1rem, 3vw, 2.6rem) 0; }

  .srg-foot {
    margin-top: clamp(3rem, 8vh, 5rem);
    border-top: 1px solid var(--color-line);
    padding: 1.4rem clamp(1rem, 3vw, 2.6rem) 1.8rem;
  }
  .srg-foot-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 2rem;
    justify-content: space-between;
    color: var(--color-graphite-400);
  }
  .srg-foot-mid { color: var(--color-mey-teal-700); }
  .srg-foot-nav { display: flex; flex-wrap: wrap; gap: 0.5rem 1.1rem; }
  .srg-foot-nav a { color: var(--color-graphite-400); }
  .srg-foot-nav a:hover { color: var(--color-graphite-900); }
  .srg-foot-note { margin-top: 0.9rem; color: var(--color-graphite-400); max-width: 72ch; }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-snav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-snav-panel]');

  function setOpen(open: boolean) {
    if (!toggle || !panel) return;
    toggle.setAttribute('aria-expanded', String(open));
    panel.hidden = !open;
    if (open) panel.querySelector<HTMLElement>('a')?.focus();
    else toggle.focus();
  }

  toggle?.addEventListener('click', () => setOpen(panel?.hidden !== false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel && !panel.hidden) setOpen(false);
  });
  document.addEventListener('click', (e) => {
    if (panel && !panel.hidden && !panel.contains(e.target as Node) && e.target !== toggle) setOpen(false);
  });
</script>
