---
/* Sergi plakası: numaralı eser gibi asılan fotoğraf — mono künye satırıyla. */
import { Image } from 'astro:assets';
import { shot, entry } from '../media';

interface Props {
  imgKey: string;
  /** plaka numarası, örn. 'EE-D1-04' */
  plate: string;
  widths?: number[];
  sizes?: string;
  /** 4:3 kadraj kilidi (karışık oranlı ızgaralarda hiza için) */
  crop?: boolean;
  loading?: 'eager' | 'lazy';
  class?: string;
}

const {
  imgKey,
  plate,
  widths = [480, 880, 1400],
  sizes = '(min-width: 1024px) 46vw, 94vw',
  crop = false,
  loading = 'lazy',
  class: className = '',
} = Astro.props;

const { img, alt, caption } = shot(imgKey);
const floor = entry(imgKey).floor;
const floorTag = floor === 'ust' ? 'ÜST KAT' : floor === 'alt' ? 'ALT KAT' : null;
---

<figure class:list={['srg-plate', className]}>
  <div class:list={[crop && 'srg-crop']}>
    <Image src={img} alt={alt} widths={widths} sizes={sizes} loading={loading} />
  </div>
  <figcaption class="srg-plate-kunye">
    <span class="t-tech srg-no">{plate}{floorTag && ` · ${floorTag}`}</span>
    <span class="srg-cap t-caption">{caption}</span>
  </figcaption>
</figure>

<style>
  .srg-no { color: var(--color-mey-red); white-space: nowrap; }
  .srg-cap { color: var(--color-graphite-600); text-align: end; }
  .srg-crop :global(img) { aspect-ratio: 4 / 3; object-fit: cover; }
</style>
