---
/*
  AKŞAM kabuğu — çağdaş premium vitrin. Gece-lacivert sahne gövdeyi uçlarda
  sarar (koyu bar + koyu ayak), ışık fotoğraflardan gelir. Mobil menü alt-sayfa
  (bottom sheet); kaydırınca beliren yapışkan randevu çubuğu (iletisim'de kapalı).
  Koyu alanlar .theatre sözleşmesini kullanır (odak rengi, ghost buton).
*/
import { Image } from 'astro:assets';
import SatilikShell from '../../../../layouts/SatilikShell.astro';
import logo from '../../../../assets/brand/mey-logo-dark.png';
import { ui } from '../data';

interface Props {
  title: string;
  description: string;
  current: string;
  /** iletisim sayfasında yapışkan çubuk gizlenir */
  stickyCta?: boolean;
}

const { title, description, current, stickyCta = true } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/aksam';
const href = (h: string) => (h ? `${root}/${h}` : root);
---

<SatilikShell title={title} description={description} bodyClass="sv-aksam">
  <header class="aks-bar theatre">
    <a class="aks-brand" href={href('')}>
      <span class="aks-brand-box"><Image src={logo} alt="MEY İnşaat" width={96} densities={[1, 2]} loading="eager" /></span>
      <span class="t-tech aks-brand-text">EL ELE APARTMANI</span>
    </a>
    <nav class="aks-nav" aria-label="Site navigasyonu" data-testid="sv-nav-desktop">
      {ui.nav.map((item) => (
        <a
          href={href(item.href)}
          aria-current={current === item.href ? 'page' : undefined}
          class="aks-nav-link"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <button
      type="button"
      class="aks-menu-btn t-tech"
      aria-expanded="false"
      aria-controls="aks-sheet"
      data-snav-toggle
      data-testid="sv-nav-toggle"
    >
      MENÜ
    </button>
  </header>

  <div class="aks-sheet-wrap" data-snav-panel hidden>
    <div class="aks-sheet-backdrop" data-snav-close></div>
    <nav class="aks-sheet theatre" id="aks-sheet" aria-label="Site navigasyonu (mobil)" data-testid="sv-nav-mobile">
      <p class="t-tech aks-sheet-kicker">{ui.project.toUpperCase()}</p>
      {ui.nav.map((item) => (
        <a
          href={href(item.href)}
          aria-current={current === item.href ? 'page' : undefined}
          class="aks-sheet-link"
        >
          {item.label}
        </a>
      ))}
      <button class="btn-ghost aks-sheet-close" type="button" data-snav-close>Kapat ✕</button>
    </nav>
  </div>

  <main id="main" class="aks-main">
    <span data-aks-sentinel aria-hidden="true"></span>
    <slot />
  </main>

  <footer class="aks-foot theatre blueprint-grid">
    <div class="aks-foot-inner">
      <div>
        <p class="t-heading-s aks-foot-name">{ui.project}</p>
        <p class="t-caption aks-foot-sub">{ui.brand} · {ui.kicker}</p>
      </div>
      <nav aria-label="Alt navigasyon" class="aks-foot-nav">
        {ui.nav.map((item) => (
          <a class="t-tech" href={href(item.href)}>{item.label.toUpperCase()}</a>
        ))}
      </nav>
      <div class="aks-foot-note">
        <p class="t-caption">{ui.disclaimer}</p>
        <a class="t-tech aks-foot-back" href={base + '/showcases/satilik-daireler'}>← TASARIM YÖNLERİ</a>
      </div>
    </div>
  </footer>

  {stickyCta && (
    <div class="aks-sticky theatre" data-aks-sticky hidden data-testid="sv-sticky-cta">
      <p class="t-tech aks-sticky-text">ÖZEL GEZİ · İKİ DAİRE DE RANDEVUYLA</p>
      <div class="aks-sticky-actions">
        <a class="btn-primary" href={href('iletisim')}>{ui.cta.randevu}</a>
        <a class="btn-ghost" href={href('daireler')}>{ui.cta.daireleri}</a>
      </div>
    </div>
  )}
</SatilikShell>

<style is:global>
  .sv-aksam { background: var(--color-night-950); }
  /* Açık bant: koyu sahne içinde gündüz kesiti */
  .sv-aksam .aks-light {
    background: var(--color-concrete-050);
    color: var(--color-graphite-600);
  }
  .sv-aksam .aks-dark {
    background: var(--color-night-950);
    color: var(--color-concrete-100);
  }
  .sv-aksam .aks-dark h1, .sv-aksam .aks-dark h2, .sv-aksam .aks-dark h3 { color: #fff; }
  .sv-aksam .aks-container { max-width: 1320px; margin-inline: auto; padding-inline: clamp(1rem, 3vw, 1.5rem); }
</style>

<style>
  .aks-bar {
    position: sticky;
    top: 0;
    z-index: 45;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem clamp(1rem, 3vw, 1.5rem);
    border-bottom: 1px solid rgb(255 255 255 / 0.1);
  }
  .aks-brand { display: flex; align-items: center; gap: 0.8rem; }
  .aks-brand-box {
    display: inline-flex;
    background: var(--color-concrete-050);
    border-radius: var(--radius-brand);
    padding: 0.35rem 0.55rem;
  }
  .aks-brand-text { color: rgb(244 244 242 / 0.75); }
  .aks-nav { display: none; align-items: center; gap: clamp(0.9rem, 2vw, 1.6rem); }
  @media (min-width: 1024px) { .aks-nav { display: flex; } }
  .aks-nav-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(244 244 242 / 0.7);
    padding-block: 0.3rem;
    border-bottom: 2px solid transparent;
  }
  .aks-nav-link:hover { color: #fff; border-bottom-color: rgb(244 244 242 / 0.3); }
  .aks-nav-link[aria-current='page'] { color: #fff; border-bottom-color: var(--color-red-on-dark); }
  .aks-menu-btn {
    border: 1px solid rgb(255 255 255 / 0.3);
    border-radius: var(--radius-brand);
    background: transparent;
    color: #fff;
    padding: 0.5rem 0.9rem;
    cursor: pointer;
  }
  @media (min-width: 1024px) { .aks-menu-btn { display: none; } }

  /* Bottom sheet (mobil) */
  .aks-sheet-wrap { position: fixed; inset: 0; z-index: 55; }
  .aks-sheet-backdrop { position: absolute; inset: 0; background: rgb(0 0 0 / 0.55); }
  .aks-sheet {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    border-top: 1px solid rgb(255 255 255 / 0.14);
    border-start-start-radius: 6px;
    border-start-end-radius: 6px;
    padding: 1.2rem 1.2rem 1.6rem;
    display: grid;
    gap: 0.2rem;
    max-height: 82dvh;
    overflow-y: auto;
  }
  .aks-sheet-kicker { color: var(--color-red-on-dark); margin-bottom: 0.5rem; }
  .aks-sheet-link {
    padding: 0.7rem 0.6rem;
    font-size: 1.0625rem;
    color: rgb(244 244 242 / 0.85);
    border-inline-start: 2px solid transparent;
  }
  .aks-sheet-link:hover { color: #fff; background: rgb(255 255 255 / 0.05); }
  .aks-sheet-link[aria-current='page'] { color: #fff; border-inline-start-color: var(--color-red-on-dark); }
  .aks-sheet-close { margin-top: 0.9rem; justify-content: center; }

  .aks-main { display: block; }

  .aks-foot { border-top: 1px solid rgb(255 255 255 / 0.1); }
  .aks-foot-inner {
    max-width: 1320px;
    margin-inline: auto;
    padding: 2.2rem clamp(1rem, 3vw, 1.5rem) 5.5rem;
    display: grid;
    gap: 1.6rem;
  }
  @media (min-width: 900px) { .aks-foot-inner { grid-template-columns: 1.1fr 1.4fr 1.2fr; gap: 2.4rem; } }
  .aks-foot-name { color: #fff; }
  .aks-foot-sub { color: rgb(244 244 242 / 0.6); margin-top: 0.3rem; }
  .aks-foot-nav { display: flex; flex-wrap: wrap; gap: 0.5rem 1.1rem; align-content: start; }
  .aks-foot-nav a { color: rgb(244 244 242 / 0.6); }
  .aks-foot-nav a:hover { color: #fff; }
  .aks-foot-note { color: rgb(244 244 242 / 0.55); display: grid; gap: 0.6rem; }
  .aks-foot-back { color: var(--color-mey-teal); }
  .aks-foot-back:hover { color: #fff; }

  /* Yapışkan randevu çubuğu */
  .aks-sticky {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.7rem clamp(1rem, 3vw, 1.5rem);
    border-top: 1px solid rgb(255 255 255 / 0.14);
    background: rgb(14 15 17 / 0.96);
  }
  .aks-sticky-text { color: rgb(244 244 242 / 0.7); }
  .aks-sticky-actions { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  @media (max-width: 640px) { .aks-sticky-text { display: none; } }
</style>

<script>
  // Bottom-sheet menü
  const toggle = document.querySelector<HTMLButtonElement>('[data-snav-toggle]');
  const wrap = document.querySelector<HTMLElement>('[data-snav-panel]');

  function setOpen(open: boolean) {
    if (!toggle || !wrap) return;
    toggle.setAttribute('aria-expanded', String(open));
    wrap.hidden = !open;
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) wrap.querySelector<HTMLElement>('a')?.focus();
    else toggle.focus();
  }
  toggle?.addEventListener('click', () => setOpen(wrap?.hidden !== false));
  wrap?.querySelectorAll('[data-snav-close]').forEach((el) =>
    el.addEventListener('click', () => setOpen(false))
  );
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && wrap && !wrap.hidden) setOpen(false);
  });

  // Kaydırınca beliren yapışkan randevu çubuğu
  const sticky = document.querySelector<HTMLElement>('[data-aks-sticky]');
  const sentinel = document.querySelector('[data-aks-sentinel]');
  if (sticky && sentinel && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      ([entry]) => { sticky.hidden = entry.isIntersecting; },
      { rootMargin: '600px 0px 0px 0px' }
    );
    io.observe(sentinel);
  } else if (sticky) {
    sticky.hidden = false;
  }
</script>
