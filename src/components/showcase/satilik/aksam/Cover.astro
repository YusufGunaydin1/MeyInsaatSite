---
/* Akşam kapağı: orana kilitli, cover-kırpımlı fotoğraf — koyu sahne panelleri için. */
import { Image } from 'astro:assets';
import { shot } from '../media';

interface Props {
  imgKey: string;
  /** CSS aspect-ratio değeri, örn. '16/9', '4/3', '3/4' */
  ratio?: string;
  widths?: number[];
  sizes?: string;
  loading?: 'eager' | 'lazy';
  caption?: boolean;
  class?: string;
}

const {
  imgKey,
  ratio = '16/9',
  widths = [560, 960, 1600],
  sizes = '(min-width: 1024px) 60vw, 100vw',
  loading = 'lazy',
  caption = false,
  class: className = '',
} = Astro.props;

const s = shot(imgKey);
---

<figure class:list={['aks-cover', className]} style={`--aks-ratio: ${ratio}`}>
  <Image src={s.img} alt={s.alt} widths={widths} sizes={sizes} loading={loading} />
  {caption && <figcaption class="t-tech aks-cover-cap">{s.caption.toUpperCase()}</figcaption>}
</figure>

<style>
  .aks-cover { position: relative; overflow: hidden; border-radius: var(--radius-brand); }
  .aks-cover :global(img) {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: var(--aks-ratio);
    object-fit: cover;
  }
  .aks-cover-cap {
    position: absolute;
    inset-inline-start: 0.8rem;
    bottom: 0.7rem;
    color: #fff;
    background: rgb(14 15 17 / 0.72);
    padding: 0.3rem 0.55rem;
    border-radius: var(--radius-brand);
  }
</style>
