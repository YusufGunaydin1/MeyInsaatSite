---
/* Albüm figürü: çerçeveli fotoğraf + italik serif altyazı (manifest'ten). */
import { Image } from 'astro:assets';
import { shot } from '../media';

interface Props {
  imgKey: string;
  widths?: number[];
  sizes?: string;
  /** altyazıyı gizle (hero gibi yerlerde) */
  quiet?: boolean;
  class?: string;
  loading?: 'eager' | 'lazy';
}

const {
  imgKey,
  widths = [480, 880, 1320],
  sizes = '(min-width: 1180px) 1100px, 94vw',
  quiet = false,
  class: className = '',
  loading = 'lazy',
} = Astro.props;

const { img, alt, caption } = shot(imgKey);
---

<figure class:list={['alb-frame', className]}>
  <Image src={img} alt={alt} widths={widths} sizes={sizes} loading={loading} />
  {!quiet && <figcaption class="alb-serif-cap alb-fig-cap">{caption}</figcaption>}
</figure>

<style>
  .alb-fig-cap { padding-top: 0.55rem; }
</style>
