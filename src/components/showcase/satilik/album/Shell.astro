---
/*
  ALBÜM kabuğu — sıcak editoryal butik. Ortalanmış serif künye başlığı, ince
  small-caps navigasyon, mobilde tam ekran perde menü, kolofon ayak. Tema
  sınıfı sv-album; albüme özgü tip yardımcıları burada global (sv-album altında).
*/
import SatilikShell from '../../../../layouts/SatilikShell.astro';
import '@fontsource/ibm-plex-serif/400.css';
import '@fontsource/ibm-plex-serif/400-italic.css';
import '@fontsource/ibm-plex-serif/500.css';
import '@fontsource/ibm-plex-serif/600.css';
import { ui } from '../data';

interface Props {
  title: string;
  description: string;
  /** aktif sayfa anahtarı: '' | 'daireler' | 'daire-1' | ... */
  current: string;
}

const { title, description, current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/album';
const href = (h: string) => (h ? `${root}/${h}` : root);
---

<SatilikShell title={title} description={description} bodyClass="sv-album">
  <header class="alb-header">
    <div class="alb-head-inner">
      <p class="alb-brand t-tech">{ui.brand}</p>
      <a class="alb-masthead" href={href('')}>{ui.project}</a>
      <p class="alb-kicker">{ui.kicker}</p>

      <nav class="alb-nav" aria-label="Site navigasyonu" data-testid="sv-nav-desktop">
        {ui.nav.map((item) => (
          <a
            href={href(item.href)}
            aria-current={current === item.href ? 'page' : undefined}
            class="alb-nav-link"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <button
        class="alb-menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="alb-sheet"
        data-snav-toggle
        data-testid="sv-nav-toggle"
      >
        Menü
      </button>
    </div>
  </header>

  <div class="alb-sheet" id="alb-sheet" data-snav-panel hidden>
    <div class="alb-sheet-inner">
      <p class="t-tech alb-sheet-kicker">{ui.project}</p>
      <nav aria-label="Site navigasyonu (mobil)" data-testid="sv-nav-mobile">
        {ui.nav.map((item) => (
          <a
            href={href(item.href)}
            aria-current={current === item.href ? 'page' : undefined}
            class="alb-sheet-link"
          >
            {item.label}
          </a>
        ))}
      </nav>
      <button class="alb-sheet-close" type="button" data-snav-close>Kapat ✕</button>
    </div>
  </div>

  <main id="main" class="alb-main">
    <slot />
  </main>

  <footer class="alb-footer">
    <div class="alb-foot-inner">
      <div>
        <p class="alb-foot-name">{ui.project}</p>
        <p class="t-caption">{ui.brand} · {ui.kicker.toLowerCase()}</p>
      </div>
      <nav aria-label="Alt navigasyon" class="alb-foot-nav">
        {ui.nav.map((item) => (
          <a href={href(item.href)}>{item.label}</a>
        ))}
      </nav>
      <div class="alb-foot-note">
        <p class="t-caption">{ui.disclaimer}</p>
        <a class="t-tech alb-foot-back" href={base + '/showcases/satilik-daireler'}>← Tasarım yönlerine dön</a>
      </div>
    </div>
  </footer>
</SatilikShell>

<style is:global>
  .sv-album {
    --alb-bg: #f6f3ec;
    --alb-surface: #fbf9f4;
    --alb-line: #e5dfd2;
    --alb-ink: #201e1a;
    --alb-body: #4d4a43;
    --alb-serif: 'IBM Plex Serif', Georgia, 'Times New Roman', serif;
    background: var(--alb-bg);
    color: var(--alb-body);
  }
  .sv-album h1, .sv-album h2, .sv-album h3 { color: var(--alb-ink); }

  .sv-album .alb-display {
    font-family: var(--alb-serif);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--alb-ink);
  }
  .sv-album .alb-eyebrow {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-mey-red);
  }
  .sv-album .alb-serif-cap {
    font-family: var(--alb-serif);
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--alb-body);
  }
  .sv-album .alb-link {
    font-family: var(--alb-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--alb-ink);
    border-bottom: 1px solid var(--color-mey-red);
    padding-bottom: 0.1rem;
    transition: color 150ms ease-out;
  }
  .sv-album .alb-link:hover { color: var(--color-mey-red); }
  .sv-album .alb-frame {
    border: 1px solid var(--alb-line);
    border-radius: var(--radius-brand);
    background: var(--alb-surface);
    padding: clamp(0.5rem, 1.4vw, 0.9rem);
  }
  .sv-album .alb-frame img { display: block; width: 100%; height: auto; border-radius: var(--radius-brand); }
</style>

<style>
  .alb-header { border-bottom: 1px solid var(--alb-line); }
  .alb-head-inner {
    max-width: 1180px;
    margin-inline: auto;
    padding: clamp(1.4rem, 3.5vw, 2.4rem) 1rem 0;
    text-align: center;
    position: relative;
  }
  .alb-brand { color: var(--color-graphite-400); letter-spacing: 0.22em; }
  .alb-masthead {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--alb-serif);
    font-weight: 600;
    font-size: clamp(1.9rem, 4.6vw, 3rem);
    line-height: 1.05;
    color: var(--alb-ink);
  }
  .alb-kicker {
    margin-top: 0.45rem;
    font-family: var(--alb-serif);
    font-style: italic;
    color: var(--alb-body);
  }
  .alb-nav {
    margin-top: 1.4rem;
    padding-block: 0.9rem;
    border-top: 1px solid var(--alb-line);
    display: none;
    justify-content: center;
    column-gap: clamp(1.1rem, 2.6vw, 2.2rem);
    flex-wrap: wrap;
  }
  @media (min-width: 900px) { .alb-nav { display: flex; } }
  .alb-nav-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--alb-body);
    padding-block: 0.2rem;
    border-bottom: 2px solid transparent;
  }
  .alb-nav-link:hover { color: var(--alb-ink); }
  .alb-nav-link[aria-current='page'] { color: var(--alb-ink); border-bottom-color: var(--color-mey-red); }

  .alb-menu-btn {
    position: absolute;
    top: clamp(1.2rem, 3vw, 2rem);
    inset-inline-end: 1rem;
    border: 1px solid var(--alb-line);
    border-radius: var(--radius-brand);
    background: var(--alb-surface);
    padding: 0.5rem 0.9rem;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--alb-ink);
    cursor: pointer;
  }
  @media (min-width: 900px) { .alb-menu-btn { display: none; } }

  .alb-sheet {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: var(--alb-bg);
    overflow-y: auto;
  }
  .alb-sheet-inner {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 3rem 1.5rem;
    text-align: center;
  }
  .alb-sheet-kicker { color: var(--color-mey-red); margin-bottom: 1rem; }
  .alb-sheet nav { display: flex; flex-direction: column; gap: 0.4rem; }
  .alb-sheet-link {
    font-family: var(--alb-serif);
    font-size: 1.6rem;
    padding: 0.45rem 1rem;
    color: var(--alb-ink);
  }
  .alb-sheet-link[aria-current='page'] { color: var(--color-mey-red); }
  .alb-sheet-close {
    margin-top: 1.6rem;
    border: 1px solid var(--alb-ink);
    border-radius: var(--radius-brand);
    background: transparent;
    padding: 0.55rem 1.2rem;
    font: inherit;
    color: var(--alb-ink);
    cursor: pointer;
  }

  .alb-main { flex: 1; }

  .alb-footer { border-top: 1px solid var(--alb-line); margin-top: clamp(3rem, 8vh, 6rem); }
  .alb-foot-inner {
    max-width: 1180px;
    margin-inline: auto;
    padding: 2.2rem 1rem 2.6rem;
    display: grid;
    gap: 1.6rem;
  }
  @media (min-width: 900px) {
    .alb-foot-inner { grid-template-columns: 1.1fr 1fr 1.2fr; gap: 2.5rem; }
  }
  .alb-foot-name { font-family: var(--alb-serif); font-weight: 600; font-size: 1.35rem; color: var(--alb-ink); }
  .alb-foot-nav { display: flex; flex-wrap: wrap; gap: 0.35rem 1.1rem; align-content: start; }
  .alb-foot-nav a { font-size: 0.875rem; color: var(--alb-body); }
  .alb-foot-nav a:hover { color: var(--color-mey-red); }
  .alb-foot-note { display: grid; gap: 0.6rem; color: var(--color-graphite-400); }
  .alb-foot-back { color: var(--color-mey-teal-700); }
  .alb-foot-back:hover { color: var(--alb-ink); }
</style>

<script>
  // Mobil perde menü: aç/kapa, Esc, odak yönetimi. Sayfa başına bir kez kurulur.
  const toggle = document.querySelector<HTMLButtonElement>('[data-snav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-snav-panel]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-snav-close]');

  function setOpen(open: boolean) {
    if (!toggle || !panel) return;
    toggle.setAttribute('aria-expanded', String(open));
    panel.hidden = !open;
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) panel.querySelector<HTMLElement>('a, button')?.focus();
    else toggle.focus();
  }

  toggle?.addEventListener('click', () => setOpen(panel?.hidden !== false));
  closeBtn?.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel && !panel.hidden) setOpen(false);
  });
</script>
