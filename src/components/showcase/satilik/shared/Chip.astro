---
/* "Bilgi yakında" rozeti — gerçek bilgi asla uydurulmaz, eksik alan görünür kalır. */
import { ui } from '../data';

interface Props {
  label?: string;
  onDark?: boolean;
}
const { label, onDark = false } = Astro.props;
---

<span class:list={['t-tech sv-chip', onDark && 'sv-chip-dark']} data-testid="sv-chip">
  {label && <span class="sv-chip-label">{label}:</span>}
  <span>{ui.placeholder}</span>
</span>

<style>
  .sv-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px dashed rgb(102 105 109 / 0.6);
    border-radius: var(--radius-brand);
    padding: 0.25rem 0.55rem;
    color: var(--color-graphite-400);
    white-space: nowrap;
  }
  .sv-chip-dark {
    border-color: rgb(255 255 255 / 0.3);
    color: rgb(244 244 242 / 0.6);
  }
</style>
