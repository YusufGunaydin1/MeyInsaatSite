---
/* SSS — yerel <details>: JS'siz çalışır, kompakt akordeon. */
import { sss } from './data';
---

<div class="kc-faq" data-testid="kc-faq">
  <h3 class="t-heading-s">Sıkça Sorulan Sorular</h3>
  {sss.map((q) => (
    <details class="kc-faq-item">
      <summary>{q.soru}</summary>
      <p>{q.cevap}</p>
    </details>
  ))}
</div>

<style>
  .kc-faq-item { border-bottom: 1px solid var(--color-line); }
  .kc-faq-item:first-of-type { margin-top: 0.5rem; }
  .kc-faq-item summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-block: 0.6rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-graphite-900);
  }
  .kc-faq-item summary::-webkit-details-marker { display: none; }
  .kc-faq-item summary::after {
    content: '+';
    font-family: var(--font-mono);
    color: var(--color-mey-red);
    flex-shrink: 0;
  }
  .kc-faq-item[open] summary::after { content: '−'; }
  .kc-faq-item p { padding-bottom: 0.75rem; font-size: 0.875rem; line-height: 1.55; }
</style>
