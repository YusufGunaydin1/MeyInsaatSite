---
/*
  Koyu CTA bandı — ref'lerdeki telefon numarası gerçek satış hattı yayınlanana
  dek gösterilmez (company.json: phone=null, sayı UYDURULMAZ): telefon düğmesi
  dürüst "yakında" diyaloğunu açar, Randevu Al gerçek iletişim sayfasına gider.
*/
import Icon from './Icon.astro';

interface Props {
  base: string;
}
const { base } = Astro.props;
---

<section class="kc-ctaband theatre" data-testid="kc-ctaband">
  <div class="container-site kc-ctaband-in">
    <div>
      <h2 class="t-heading-m kc-ctaband-title">Hayalinizdeki daireyi birlikte bulalım.</h2>
      <p class="t-caption kc-ctaband-sub">
        Detaylı bilgi almak veya daireleri yerinde görmek için bizimle iletişime geçin.
      </p>
    </div>
    <div class="kc-ctaband-actions">
      <button type="button" class="btn-ghost" data-soon="Satış hattı" data-testid="kc-phone-soon">
        <Icon name="phone" size={17} /> Satış hattı — yakında
      </button>
      <a class="btn-primary" href={base + '/iletisim'}>
        <Icon name="calendar" size={17} /> Randevu Al
      </a>
    </div>
  </div>
</section>

<style>
  .kc-ctaband { border-radius: var(--radius-brand); }
  .kc-ctaband-in {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding-block: 1.6rem;
  }
  .kc-ctaband-title { color: #fff; }
  .kc-ctaband-sub { color: rgb(244 244 242 / 0.65); margin-top: 0.25rem; max-width: 46ch; }
  .kc-ctaband-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
</style>
