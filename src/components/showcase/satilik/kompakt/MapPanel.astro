---
/*
  Konum paneli — harici karo servisi YOK: mevcut vaziyet görseli stilize zemin,
  üstünde pin; yanında mesafe listesi (mesafeler temsilî — sayfa çipi kapsar).
*/
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { yakinCevre, proje } from './data';
import vaziyet from '../../../../assets/projects/el-ele-apartmani-vaziyet.webp';

interface Props {
  title?: string;
  compact?: boolean;
}
const { title = 'Yakın Lokasyonlar', compact = false } = Astro.props;
---

<div class:list={['kc-map card', compact && 'kc-map-compact']} data-testid="kc-map">
  <div class="kc-map-canvas">
    <Image src={vaziyet} alt={`${proje.ad} vaziyet planı üzerinde konum işareti`} widths={[480, 880]} sizes="(min-width: 900px) 420px, 94vw" class="kc-map-img" />
    <span class="kc-map-pin" aria-hidden="true"><Icon name="pin" size={26} /></span>
    <span class="t-tech kc-map-tag">{proje.lokasyon}</span>
  </div>
  <div class="kc-map-list">
    <h3 class="t-heading-s">{title}</h3>
    <ul>
      {yakinCevre.map((y) => (
        <li>
          <span class="kc-map-ic"><Icon name={y.icon} size={17} /></span>
          <span class="kc-map-ad">{y.ad}</span>
          <span class="kc-map-mesafe tabular-nums">{y.mesafe}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .kc-map {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    overflow: hidden;
  }
  .kc-map-compact { grid-template-columns: minmax(0, 1fr); }
  .kc-map-canvas { position: relative; min-height: 220px; }
  .kc-map-img { width: 100%; height: 100%; object-fit: cover; display: block; filter: saturate(0.55) contrast(0.95); }
  .kc-map-pin {
    position: absolute;
    top: 44%;
    left: 52%;
    transform: translate(-50%, -90%);
    color: var(--color-mey-red);
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    padding: 0.3rem;
    display: inline-flex;
  }
  .kc-map-tag {
    position: absolute;
    bottom: 0.6rem;
    left: 0.6rem;
    background: rgb(14 15 17 / 0.82);
    color: var(--color-concrete-100);
    padding: 0.25rem 0.55rem;
    border-radius: var(--radius-brand);
  }
  .kc-map-list { padding: 1rem 1.1rem 1.1rem; }
  .kc-map-list ul { margin-top: 0.6rem; }
  .kc-map-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-block: 0.42rem;
    border-bottom: 1px solid var(--color-line);
    font-size: 0.9rem;
  }
  .kc-map-list li:last-child { border-bottom: none; }
  .kc-map-ic { color: var(--color-mey-teal-700); display: inline-flex; flex-shrink: 0; }
  .kc-map-ad { min-width: 0; }
  .kc-map-mesafe {
    margin-inline-start: auto;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-graphite-900);
    white-space: nowrap;
  }
  @media (max-width: 760px) {
    .kc-map { grid-template-columns: minmax(0, 1fr); }
    .kc-map-canvas { min-height: 180px; }
  }
</style>
