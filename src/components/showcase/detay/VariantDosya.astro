---
/*
  VARYANT C — DOSYA: proje künyesi bir teknik pafta gibi beyaz sayfaya basılır
  (köşe register işaretleri). Hikâye + mono özet + zaman çizelgesi; altta
  aksonometrik çizim, ikonlu sayılar, vaziyet paftası ve malzeme paleti.
  İzometrik/vaziyet görselleri temsilîdir; gri değerler örnek yerleşimdir.
*/
import { Image } from 'astro:assets';
import DetayHero from './DetayHero.astro';
import izometrik from '../../../assets/projects/ali-izometrik.webp';
import vaziyet from '../../../assets/projects/ali-vaziyet.webp';
import dokuBeton from '../../../assets/projects/ali-doku-beton.webp';
import dokuTugla from '../../../assets/projects/ali-doku-tugla.webp';
import dokuCam from '../../../assets/projects/ali-doku-cam.webp';
import dokuMetal from '../../../assets/projects/ali-doku-metal.webp';

interface Props {
  name: string;
  typeLabel: string;
  statusLabel: string;
}
const { name, typeLabel, statusLabel } = Astro.props;

const ozet = [
  { k: 'PROJE TİPİ', v: typeLabel, sample: false },
  { k: 'STATÜ', v: statusLabel, sample: false },
  { k: 'YER', v: 'İSTANBUL · BAĞCILAR', sample: true },
  { k: 'YIL', v: '2024', sample: true },
  { k: 'MÜŞTERİ', v: 'ÖZEL', sample: true },
  { k: 'MÜTEAHHİT', v: 'MEY İNŞAAT', sample: false },
];

const zaman = [
  { t: '03.2023', ad: 'Projelendirme', d: 'Proje ve ruhsat süreçleri tamamlandı.' },
  { t: '07.2023', ad: 'Kaba İnşaat', d: 'Taşıyıcı sistem ve kaba inşaat tamamlandı.' },
  { t: '06.2024', ad: 'Teslim', d: 'İnce işler ve kontroller tamamlanarak teslim edildi.' },
];

const malzeme = [
  { img: dokuBeton, ad: 'BETON', ton: 'Açık Gri' },
  { img: dokuTugla, ad: 'TUĞLA GÖRÜNÜMÜ', ton: 'Kiremit Kırmızısı' },
  { img: dokuCam, ad: 'CAM', ton: 'Mavi Tonu' },
  { img: dokuMetal, ad: 'METAL AKSAMLAR', ton: 'Antrasit' },
];
---

<section class="container-site section-pad" data-testid="variant-dosya">
  <div class="vc-sheet">
    <span class="vc-mark vc-mark-tl" aria-hidden="true"></span>
    <span class="vc-mark vc-mark-tr" aria-hidden="true"></span>
    <span class="vc-mark vc-mark-bl" aria-hidden="true"></span>
    <span class="vc-mark vc-mark-br" aria-hidden="true"></span>

    <div class="vc-grid">
      <DetayHero name={name} typeLabel={typeLabel} statusLabel={statusLabel} fill />

      <div class="vc-doc">
        <header class="vc-head">
          <div>
            <p class="vc-index" aria-hidden="true">01 /</p>
            <h2 class="t-display-l vc-title">{name}</h2>
          </div>
          <div class="vc-brand">
            <span class="t-tech text-mey-red">MEY İNŞAAT</span>
            <span class="t-tech vc-page">01 / 06</span>
          </div>
        </header>

        <div class="vc-cols">
          <div class="vc-col">
            <h3 class="t-tech text-mey-red vc-col-h">PROJE HİKAYESİ</h3>
            <p class="t-caption vc-story">
              Ali Apartmanı, konforlu yaşamı merkeze alan modern bir konut
              projesi olarak tasarlandı.
            </p>
            <p class="t-caption vc-story">
              Cam balkon detayları, geniş açıklıklar ve fonksiyonel planlamasıyla
              gün ışığını iç mekâna taşıyarak ferah ve yaşanabilir alanlar sunar.
            </p>
            <p class="t-caption vc-story">
              MEY İnşaat'ın kalite anlayışıyla tamamlanan proje, sade çizgileri ve
              kalıcı malzeme seçimiyle çevresiyle uyumlu, zamansız bir mimari
              kimlik kazanır.
            </p>
          </div>

          <div class="vc-col vc-col-mid">
            <h3 class="t-tech text-mey-red vc-col-h">PROJE ÖZETİ</h3>
            <dl class="vc-ozet">
              {ozet.map((o) => (
                <div class="vc-ozet-row">
                  <dt class="t-tech vc-ozet-k">{o.k}</dt>
                  <dd class:list={['t-tech vc-ozet-v', o.sample && 'vc-sample']}>{o.v}</dd>
                </div>
              ))}
            </dl>
          </div>

          <div class="vc-col">
            <h3 class="t-tech text-mey-red vc-col-h">ZAMAN ÇİZELGESİ</h3>
            <ol class="vc-tl">
              {zaman.map((z) => (
                <li class="vc-tl-item">
                  <p class="t-tech vc-sample">{z.t}</p>
                  <p class="t-heading-s vc-tl-ad">{z.ad}</p>
                  <p class="t-caption vc-tl-d">{z.d}</p>
                </li>
              ))}
            </ol>
          </div>
        </div>

        <div class="vc-band">
          <figure class="vc-pafta">
            <Image
              src={izometrik}
              alt="Ali Apartmanı — aksonometrik çizim (temsilî)"
              widths={[480, 800]}
              sizes="(min-width: 1024px) 18vw, 60vw"
              class="vc-pafta-img vc-iso"
              data-testid="vc-iso"
            />
            <figcaption class="t-tech vc-cap">AKSONOMETRİ — TEMSİLİ</figcaption>
          </figure>

          <div class="vc-stats">
            <div class="vc-stat">
              <svg class="vc-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 11.5 12 4l9 7.5" />
                <path d="M5.5 10v10h13V10" />
                <path d="M10 20v-5.5h4V20" />
              </svg>
              <p class="vc-stat-v">{typeLabel}</p>
            </div>
            <div class="vc-stat">
              <svg class="vc-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="m12 3-9 4.5 9 4.5 9-4.5L12 3Z" />
                <path d="m3 12 9 4.5 9-4.5" />
                <path d="m3 16.5 9 4.5 9-4.5" />
              </svg>
              <p class="vc-stat-v"><span class="vc-sample">6</span> KAT</p>
            </div>
            <div class="vc-stat">
              <svg class="vc-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="4" y="4" width="16" height="16" />
                <path d="M4 13h8V4" />
                <path d="M12 13h8" />
                <path d="M12 13v7" />
              </svg>
              <p class="vc-stat-v"><span class="vc-sample">24</span> DAİRE</p>
            </div>
            <div class="vc-stat">
              <svg class="vc-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 21s-7-5.6-7-11a7 7 0 1 1 14 0c0 5.4-7 11-7 11Z" />
                <circle cx="12" cy="10" r="2.5" />
              </svg>
              <p class="vc-stat-v vc-sample">BAĞCILAR<br />İSTANBUL</p>
            </div>
          </div>

          <figure class="vc-pafta">
            <Image
              src={vaziyet}
              alt="Vaziyet paftası — konum krokisi (temsilî)"
              widths={[640, 1024]}
              sizes="(min-width: 1024px) 24vw, 100vw"
              class="vc-pafta-img vc-map"
              data-testid="vc-map"
            />
            <figcaption class="t-tech vc-cap">VAZİYET — TEMSİLİ</figcaption>
          </figure>
        </div>

        <footer class="vc-mat">
          <h3 class="t-tech text-mey-red vc-mat-h">CEPHE &amp; MALZEME</h3>
          <ul class="vc-chips">
            {malzeme.map((m) => (
              <li class="vc-chip">
                <Image src={m.img} alt={`${m.ad} — ${m.ton}`} widths={[176, 352]} sizes="88px" class="vc-chip-img" />
                <p class="t-tech vc-chip-ad">{m.ad}</p>
                <p class="t-caption vc-chip-ton">{m.ton}</p>
              </li>
            ))}
          </ul>
          <a class="t-tech vc-cta" href="#">
            DETAYLI PROJE BİLGİSİ <span aria-hidden="true" class="rtl:-scale-x-100 inline-block">→</span>
          </a>
        </footer>
      </div>
    </div>
  </div>
</section>

<style>
  /* Pafta: beyaz sayfa + köşe register işaretleri */
  .vc-sheet {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    padding: clamp(1.25rem, 3vw, 2.75rem);
  }
  .vc-mark { position: absolute; width: 14px; height: 14px; color: var(--color-graphite-400); opacity: 0.55; }
  .vc-mark::before, .vc-mark::after { content: ""; position: absolute; background: currentColor; }
  .vc-mark::before { inset-inline-start: 50%; top: 0; width: 1px; height: 100%; }
  .vc-mark::after { top: 50%; inset-inline-start: 0; height: 1px; width: 100%; }
  .vc-mark-tl { top: 8px; inset-inline-start: 8px; }
  .vc-mark-tr { top: 8px; inset-inline-end: 8px; }
  .vc-mark-bl { bottom: 8px; inset-inline-start: 8px; }
  .vc-mark-br { bottom: 8px; inset-inline-end: 8px; }

  .vc-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) {
    .vc-grid { grid-template-columns: minmax(0, 0.68fr) minmax(0, 1.32fr); gap: 2.75rem; align-items: start; }
  }
  .vc-doc { min-width: 0; }

  .vc-head {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: start;
    justify-content: space-between;
  }
  .vc-index {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--color-mey-red);
    line-height: 1;
  }
  .vc-title { text-transform: uppercase; margin-block-start: 0.35rem; }
  .vc-brand { display: grid; gap: 0.4rem; justify-items: end; }
  .vc-page { color: var(--color-graphite-400); }

  /* Üç sütun: hikâye · özet · zaman çizelgesi */
  .vc-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    border-block-start: 1px solid var(--color-line);
    margin-block-start: 1.75rem;
    padding-block-start: 1.75rem;
  }
  @media (min-width: 900px) {
    .vc-cols { grid-template-columns: 1.1fr 1fr 1fr; gap: 2.25rem; }
    .vc-col-mid { border-inline: 1px solid var(--color-line); padding-inline: 2.25rem; }
  }
  .vc-col-h { margin-block-end: 1rem; }
  .vc-story { color: var(--color-graphite-600); }
  .vc-story + .vc-story { margin-block-start: 0.85rem; }

  .vc-ozet { display: grid; gap: 0.7rem; }
  .vc-ozet-row { display: grid; grid-template-columns: 7rem 1fr; gap: 0.75rem; align-items: baseline; }
  .vc-ozet-k { color: var(--color-graphite-400); }
  .vc-ozet-k::after { content: " :"; }
  .vc-ozet-v { color: var(--color-graphite-900); }
  .vc-sample { color: var(--color-graphite-400); }

  .vc-tl { list-style: none; position: relative; padding-inline-start: 1.4rem; display: grid; gap: 1.4rem; }
  .vc-tl::before {
    content: "";
    position: absolute;
    inset-inline-start: 5px;
    top: 0.4rem;
    bottom: 0.4rem;
    width: 2px;
    background: var(--color-mey-red);
    opacity: 0.85;
  }
  .vc-tl-item { position: relative; }
  .vc-tl-item::before {
    content: "";
    position: absolute;
    inset-inline-start: -1.4rem;
    top: 0.15rem;
    width: 12px;
    height: 12px;
    border: 2px solid var(--color-mey-red);
    border-radius: 50%;
    background: #fff;
  }
  .vc-tl-ad { margin-block-start: 0.25rem; }
  .vc-tl-d { color: var(--color-graphite-600); margin-block-start: 0.25rem; }

  /* Alt bant: aksonometri · sayılar · vaziyet */
  .vc-band {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    border-block-start: 1px solid var(--color-line);
    margin-block-start: 2rem;
    padding-block-start: 2rem;
  }
  @media (min-width: 900px) {
    .vc-band { grid-template-columns: 0.8fr 1.1fr 1.1fr; align-items: stretch; }
  }
  .vc-pafta {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: #fff;
  }
  .vc-pafta-img { width: 100%; display: block; flex: 1; object-fit: cover; min-height: 0; }
  .vc-iso { aspect-ratio: 3 / 4; }
  .vc-map { aspect-ratio: 16 / 10; object-position: 62% 45%; }
  @media (min-width: 900px) {
    .vc-iso, .vc-map { aspect-ratio: auto; height: 100%; }
  }
  .vc-cap {
    color: var(--color-graphite-400);
    border-block-start: 1px solid var(--color-line);
    padding: 0.45rem 0.7rem;
  }

  .vc-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    overflow: hidden;
  }
  .vc-stat {
    background: #fff;
    padding: 1.1rem 1rem;
    display: grid;
    justify-items: center;
    align-content: center;
    gap: 0.6rem;
    text-align: center;
  }
  .vc-ico { width: 26px; height: 26px; color: var(--color-mey-red); }
  .vc-stat-v {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-graphite-900);
    font-variant-numeric: tabular-nums;
  }
  .vc-stat-v .vc-sample { font-size: 1.35rem; }

  /* Malzeme paleti + CTA */
  .vc-mat {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    align-items: center;
    border-block-start: 1px solid var(--color-line);
    margin-block-start: 2rem;
    padding-block-start: 1.75rem;
  }
  .vc-mat-h { flex-basis: 100%; }
  @media (min-width: 1200px) {
    .vc-mat-h { flex-basis: auto; }
  }
  .vc-chips { list-style: none; display: flex; flex-wrap: wrap; gap: 1.5rem; }
  .vc-chip { display: grid; gap: 0.3rem; justify-items: start; }
  .vc-chip-img {
    width: 88px;
    height: 88px;
    object-fit: cover;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    display: block;
  }
  .vc-chip-ad { color: var(--color-graphite-900); }
  .vc-chip-ton { color: var(--color-graphite-400); }
  .vc-cta {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-mey-red);
    border: 1px solid var(--color-mey-red);
    border-radius: var(--radius-brand);
    padding: 0.85rem 1.2rem;
    transition: background-color 200ms ease-out, color 200ms ease-out;
  }
  .vc-cta:hover { background: var(--color-mey-red); color: #fff; }
</style>
