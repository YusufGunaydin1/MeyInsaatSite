---
/*
  VARYANT B — KOLAJ: orta sütun hikâye + büyük serif alıntı + özellik satırı;
  sağda iki bindirmeli görsel (salon dikey kırpım + malzeme natürmortu karesi).
  Bindirme düz kalır (gölge yok) — ayrımı hairline çerçeveler yapar.
*/
import { Image } from 'astro:assets';
import DetayHero from './DetayHero.astro';
import salon from '../../../assets/projects/ali-salon.webp';
import malzeme from '../../../assets/projects/ali-malzeme.webp';

interface Props {
  name: string;
  typeLabel: string;
  statusLabel: string;
}
const { name, typeLabel, statusLabel } = Astro.props;

const features = ['Gün ışığı', 'Cam balkon', 'Merkezi konum'];
---

<section class="container-site section-pad" data-testid="variant-kolaj">
  <div class="vb-grid">
    <DetayHero name={name} typeLabel={typeLabel} statusLabel={statusLabel} />

    <div class="vb-mid">
      <p class="t-tech text-mey-red mb-3">PROJELER</p>
      <h2 class="t-display-l">{name}</h2>
      <p class="t-body mt-6 vb-para">
        Ali Apartmanı, modern aile yaşamının ihtiyaçları düşünülerek tasarlandı.
        Ferah iç mekânlar, bol gün ışığı alan yaşam alanları ve cam balkon
        detayları ile konforu estetikle buluşturuyor.
      </p>

      <blockquote class="vb-quote guide-line-v" data-testid="vb-quote">
        “Şehrin içinde,<br />huzurlu bir yaşam.”
      </blockquote>

      <ul class="vb-features">
        {features.map((f) => (
          <li class="vb-feature t-body">{f}</li>
        ))}
      </ul>

      <footer class="vb-foot">
        <div class="guide-line-v vb-brand">
          <p class="t-tech text-mey-red">MEY İNŞAAT</p>
          <p class="t-tech vb-status">{statusLabel}</p>
        </div>
        <a class="vb-cta" href="#">Projeyi keşfet <span aria-hidden="true" class="rtl:-scale-x-100 inline-block">→</span></a>
      </footer>
    </div>

    <div class="vb-collage">
      <figure class="vb-fig vb-fig-1">
        <Image
          src={salon}
          alt="Salon — gün ışığı alan yaşam alanı (temsilî görsel)"
          widths={[480, 800]}
          sizes="(min-width: 1024px) 24vw, 80vw"
          class="vb-img vb-img-portrait"
          data-testid="vb-foto-1"
        />
      </figure>
      <figure class="vb-fig vb-fig-2">
        <Image
          src={malzeme}
          alt="Cephe malzemeleri — tuğla, cam balkon, beton (temsilî kompozisyon)"
          widths={[480, 800]}
          sizes="(min-width: 1024px) 20vw, 60vw"
          class="vb-img vb-img-square"
          data-testid="vb-foto-2"
        />
      </figure>
    </div>
  </div>
</section>

<style>
  .vb-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  @media (min-width: 1024px) {
    .vb-grid {
      grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr) minmax(0, 0.82fr);
      gap: 3rem;
      align-items: start;
    }
  }
  .vb-mid { min-width: 0; max-width: 34rem; }
  .vb-para { max-width: 40ch; }

  .vb-quote {
    font-family: "IBM Plex Serif", "IBM Plex Sans", serif;
    font-size: clamp(1.75rem, 2.6vw, 2.4rem);
    line-height: 1.3;
    color: var(--color-graphite-900);
    padding-inline-start: 1.5rem;
    margin-block-start: 2.5rem;
  }

  .vb-features {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    border-block-start: 1px solid var(--color-line);
    margin-block-start: 2.5rem;
    padding-block-start: 1.25rem;
  }
  .vb-feature { color: var(--color-graphite-900); }
  .vb-feature + .vb-feature {
    border-inline-start: 1px solid var(--color-mey-red);
    margin-inline-start: 1.5rem;
    padding-inline-start: 1.5rem;
  }

  .vb-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: end;
    justify-content: space-between;
    margin-block-start: 2.75rem;
  }
  .vb-brand { padding-inline-start: 1rem; display: grid; gap: 0.45rem; }
  .vb-status { color: var(--color-graphite-400); }
  .vb-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-mey-red);
  }
  .vb-cta:hover { color: var(--color-mey-red-700); }

  /* Kolaj — düz bindirme; kare, dikeyin alt köşesine oturur */
  .vb-collage { min-width: 0; }
  .vb-fig {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
  }
  .vb-fig-1 { width: 78%; }
  .vb-fig-2 {
    width: 64%;
    margin-inline-start: 36%;
    margin-block-start: -28%;
    position: relative;
    z-index: 1;
  }
  .vb-img { width: 100%; height: auto; display: block; }
  .vb-img-portrait { aspect-ratio: 3 / 4; object-fit: cover; }
  .vb-img-square { aspect-ratio: 1 / 1; object-fit: cover; }
</style>
