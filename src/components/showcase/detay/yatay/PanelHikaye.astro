---
/*
  PANEL 01 — HİKÂYE: kolaj kurgusunun tek-ekran hâli (kazanan B formu).
  Sol sütun hikâye + serif alıntı + özellikler + marka; sağda iki bindirmeli
  görsel, yükseklikleri svh ile sınırlı → panel her zaman tek ekrana sığar.
*/
import { Image } from 'astro:assets';
import salon from '../../../../assets/projects/ali-salon.webp';
import malzeme from '../../../../assets/projects/ali-malzeme.webp';

interface Props {
  name: string;
  statusLabel: string;
}
const { name, statusLabel } = Astro.props;

const features = ['Gün ışığı', 'Cam balkon', 'Merkezi konum'];
---

<div class="ph">
  <div class="ph-text">
    <div>
      <p class="t-tech text-mey-red mb-3">PROJELER</p>
      <h2 class="ph-title">{name}</h2>
      <p class="t-body ph-para">
        Ali Apartmanı, modern aile yaşamının ihtiyaçları düşünülerek tasarlandı.
        Ferah iç mekânlar, bol gün ışığı alan yaşam alanları ve cam balkon
        detayları ile konforu estetikle buluşturuyor.
      </p>
    </div>

    <blockquote class="ph-quote guide-line-v" data-testid="ph-quote">
      “Şehrin içinde,<br />huzurlu bir yaşam.”
    </blockquote>

    <div>
      <ul class="ph-features">
        {features.map((f) => (
          <li class="ph-feature t-body">{f}</li>
        ))}
      </ul>
      <div class="guide-line-v ph-brand">
        <p class="t-tech text-mey-red">MEY İNŞAAT</p>
        <p class="t-tech ph-status">{statusLabel}</p>
      </div>
    </div>
  </div>

  <div class="ph-collage">
    <figure class="ph-fig ph-fig-1">
      <Image
        src={salon}
        alt="Salon — gün ışığı alan yaşam alanı (temsilî görsel)"
        widths={[480, 800]}
        sizes="(min-width: 1024px) 26vw, 80vw"
        class="ph-img"
        data-testid="ph-foto-1"
      />
    </figure>
    <figure class="ph-fig ph-fig-2">
      <Image
        src={malzeme}
        alt="Cephe malzemeleri — tuğla, cam balkon, beton (temsilî kompozisyon)"
        widths={[480, 800]}
        sizes="(min-width: 1024px) 18vw, 60vw"
        class="ph-img"
        data-testid="ph-foto-2"
      />
    </figure>
  </div>
</div>

<style>
  .ph {
    height: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    min-width: 0;
  }
  @media (min-width: 1024px) {
    .ph { grid-template-columns: minmax(0, 1fr) minmax(0, 0.82fr); gap: clamp(2rem, 3vw, 3rem); }
  }

  .ph-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.75rem;
    max-width: 34rem;
  }
  .ph-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 3.2vw, 3rem);
    letter-spacing: 0.01em;
    line-height: 1.05;
    color: var(--color-graphite-900);
  }
  .ph-para { max-width: 42ch; margin-block-start: 1.25rem; }
  .ph-quote {
    font-family: "IBM Plex Serif", "IBM Plex Sans", serif;
    font-size: clamp(1.6rem, 2.2vw, 2.1rem);
    line-height: 1.3;
    color: var(--color-graphite-900);
    padding-inline-start: 1.5rem;
  }
  .ph-features {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    border-block-start: 1px solid var(--color-line);
    padding-block-start: 1rem;
  }
  .ph-feature { color: var(--color-graphite-900); }
  .ph-feature + .ph-feature {
    border-inline-start: 1px solid var(--color-mey-red);
    margin-inline-start: 1.4rem;
    padding-inline-start: 1.4rem;
  }
  .ph-brand { margin-block-start: 1.5rem; padding-inline-start: 1rem; display: grid; gap: 0.4rem; }
  .ph-status { color: var(--color-graphite-400); }

  /* Kolaj — svh sınırlı, düz bindirme */
  .ph-collage { min-width: 0; }
  .ph-fig {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
  }
  .ph-img { width: 100%; height: 100%; display: block; object-fit: cover; }
  /* Genişlik sütunu asla aşamaz; B ölçüsündeki sahneye (~30-34rem) sığar */
  .ph-fig-1 {
    width: min(72%, 22rem);
    aspect-ratio: 3 / 4;
  }
  .ph-fig-2 {
    width: 54%;
    max-width: 15rem;
    aspect-ratio: 1 / 1;
    margin-inline-start: auto;
    margin-block-start: -26%;
    position: relative;
    z-index: 1;
  }
</style>
