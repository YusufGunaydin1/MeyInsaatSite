---
/*
  YATAY DETAY — kalıbın kendisi: sahne, B varyantının SAYFA ÖLÇÜSÜNDE durur
  (mütevazı 3:4 foto + editoryal sağ alan; tam-ekran tiyatro DEĞİL — 2026-07-11
  düzeltmesi). Sol foto hiç değişmez; sayfa dikey kaydıkça bölüm iğnelenir ve
  yalnız sağ pencere üç kareyi 1:1 yatay tarar (scroll = ilerleme; imza
  bölümüyle aynı dil). Sayfa değişiyor hissi yok, giriş cihazı sorunu yok.
  Masaüstü + hareket-serbest dışında (mobil, prefers-reduced-motion, no-JS)
  paneller normal dikey akışta üst üste durur; içerik hiçbir modda kilitli değil.
  RTL notu: pan yönü LTR varsayar; kalıp prod'a inerken dir'e göre işaret döner.
*/
import DetayHero from '../DetayHero.astro';
import PanelHikaye from './PanelHikaye.astro';
import PanelMekan from './PanelMekan.astro';
import PanelKunye from './PanelKunye.astro';

interface Props {
  name: string;
  typeLabel: string;
  statusLabel: string;
}
const { name, typeLabel, statusLabel } = Astro.props;
---

<section class="yd" data-yatay data-testid="yatay-detay">
  <div class="yd-sticky">
    <div class="yd-stage container-site">
      <div class="yd-spread">
        <DetayHero name={name} typeLabel={typeLabel} statusLabel={statusLabel} fill />

        <div class="yd-window">
          <div class="yd-track" data-testid="yd-track">
            <article class="yd-panel" data-ad="HİKÂYE" data-testid="yd-panel-hikaye">
              <PanelHikaye name={name} statusLabel={statusLabel} />
            </article>
            <article class="yd-panel" data-ad="MEKÂN" data-testid="yd-panel-mekan">
              <PanelMekan typeLabel={typeLabel} statusLabel={statusLabel} />
            </article>
            <article class="yd-panel" data-ad="KÜNYE" data-testid="yd-panel-kunye">
              <PanelKunye typeLabel={typeLabel} statusLabel={statusLabel} />
            </article>
          </div>
        </div>
      </div>

      <div class="yd-foot">
        <span class="t-tech yd-label" data-yd-label data-testid="yd-progress">01 / 03 — HİKÂYE</span>
        <span class="yd-nav">
          <button class="yd-btn" type="button" data-yd-prev aria-label="Önceki bölüm">
            <span aria-hidden="true">←</span>
          </button>
          <button class="yd-btn" type="button" data-yd-next aria-label="Sonraki bölüm">
            <span aria-hidden="true">→</span>
          </button>
        </span>
      </div>
    </div>
  </div>
  <!-- Pan pisti: sticky, ebeveynin İÇERİK kutusunda yol alır — padding işe yaramaz -->
  <div class="yd-runway" aria-hidden="true"></div>
</section>

<style>
  /* ---- Varsayılan: dikey yığın (mobil / reduced-motion / no-JS) ---- */
  .yd-spread {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .yd-stage { padding-block: clamp(1.5rem, 4vh, 2.5rem); }
  .yd-foot { display: none; }
  .yd-runway { display: none; }
  .yd-track {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .yd-panel { min-width: 0; }

  /* Statik masaüstünde (reduced-motion / no-JS) sayfa tek sütuna düşüp fotoğrafı
     ekran genişliğine şişiriyordu; kompakt sayfa iki sütun KALIR — foto solda
     3:4 ve yapışkan, kareler sağda alt alta. Yalnız pan/iğne devre dışı. */
  @media (min-width: 1024px) {
    .yd:not(.yd-pinned) .yd-spread {
      grid-template-columns: minmax(0, 25rem) minmax(0, 1fr);
      gap: clamp(1.5rem, 3vw, 3rem);
      align-items: start;
    }
    .yd:not(.yd-pinned) .yd-spread :global(.dh-col-fill) {
      align-self: start;
      position: sticky;
      top: 5rem;
    }
    .yd:not(.yd-pinned) .yd-spread :global(.dh-col-fill .dh-media) { height: auto; }
    .yd:not(.yd-pinned) .yd-spread :global(.dh-col-fill .dh-img) {
      height: auto;
      aspect-ratio: 3 / 4;
    }
  }

  /* ---- İğneli yatay mod (JS + masaüstü + hareket serbest → .yd-pinned) ---- */
  .yd-pinned .yd-runway {
    /* pan pisti: kare başına 80svh dikey scroll (2 geçiş) */
    display: block;
    height: 160svh;
  }
  .yd-pinned .yd-sticky {
    position: sticky;
    /* JS, sahneyi görünür alanda dikey ortalayacak şekilde --yd-top yazar */
    top: var(--yd-top, 5rem);
  }
  .yd-pinned .yd-spread {
    /* B ölçüsü: foto 3:4 kalır, sahne yüksekliğini bu değişken belirler */
    --yd-h: clamp(30rem, 38vw, 34rem);
    grid-template-columns: calc(var(--yd-h) * 3 / 4) minmax(0, 1fr);
    grid-template-rows: var(--yd-h);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: stretch;
  }
  .yd-pinned .yd-window {
    overflow: hidden;
    min-width: 0;
    min-height: 0;
    height: 100%;
  }
  .yd-pinned .yd-track {
    flex-direction: row;
    gap: 0;
    height: 100%;
    will-change: transform;
  }
  .yd-pinned .yd-panel {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    /* komşu kareye sızma yok; içerik sığmazsa kare kendi içinde kaydırır */
    overflow: hidden auto;
    /* kareler arasında nefes: geçiş anında içerikler dip dibe girmez */
    padding-inline-end: clamp(2.5rem, 4vw, 4.5rem);
  }

  .yd-pinned .yd-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-block-start: 1rem;
  }
  .yd-label { color: var(--color-graphite-400); }
  .yd-nav { display: inline-flex; gap: 0.5rem; }
  .yd-btn {
    width: 2rem;
    height: 2rem;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    color: var(--color-graphite-600);
    background: #fff;
    transition: border-color 200ms ease-out, color 200ms ease-out;
  }
  .yd-btn:hover { border-color: var(--color-mey-red); color: var(--color-mey-red); }

  /* İğneli modda çocuk panellerin görselleri sabit oranı bırakıp satırı doldurur
     (yığın modunda oranlar panellerin kendi scoped stillerinden gelir). */
  .yd-pinned .yd-track :global(.pm-ch-media) {
    aspect-ratio: auto;
    height: 100%;
    align-self: stretch;
  }
  /* Vaziyet dar rayda kare kırpım: yatay pafta şerit gibi ezilmesin */
  .yd-pinned .yd-track :global(.pm-map-img) {
    aspect-ratio: 1 / 1;
    flex: none;
  }
  .yd-pinned .yd-track :global(.pk-iso-img) {
    aspect-ratio: auto;
  }
</style>

<script>
  const roots = document.querySelectorAll<HTMLElement>('[data-yatay]');

  roots.forEach((root) => {
    const sticky = root.querySelector<HTMLElement>('.yd-sticky');
    const track = root.querySelector<HTMLElement>('.yd-track');
    const win = root.querySelector<HTMLElement>('.yd-window');
    const label = root.querySelector<HTMLElement>('[data-yd-label]');
    const prev = root.querySelector<HTMLButtonElement>('[data-yd-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-yd-next]');
    if (!sticky || !track || !win) return;

    const panels = Array.from(track.children) as HTMLElement[];
    const names = panels.map((p) => p.dataset.ad ?? '');
    const N = panels.length;
    const mq = matchMedia('(min-width: 1024px) and (prefers-reduced-motion: no-preference)');
    let pinned = false;
    let ticking = false;
    let topOff = 0;

    /* Sahne görünür alandan kısa: pin noktası = dikey ortalanmış konum */
    const total = () => root.offsetHeight - sticky.offsetHeight;
    const pan = () => track.scrollWidth - win.clientWidth;
    const progress = () => {
      const t = total();
      if (t <= 0) return 0;
      return Math.min(1, Math.max(0, (topOff - root.getBoundingClientRect().top) / t));
    };

    function apply() {
      if (!pinned) return;
      const p = progress();
      track!.style.transform = `translate3d(${-p * pan()}px, 0, 0)`;
      const idx = Math.min(N - 1, Math.round(p * (N - 1)));
      if (label) {
        label.textContent = `${String(idx + 1).padStart(2, '0')} / ${String(N).padStart(2, '0')} — ${names[idx]}`;
      }
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        apply();
      });
    }

    /** Kare atlama: ok düğmeleri sayfayı ilgili karenin scroll konumuna taşır. */
    function jump(delta: number) {
      const t = total();
      if (t <= 0) return;
      const step = t / (N - 1);
      const target = Math.min(N - 1, Math.max(0, Math.round(progress() * (N - 1)) + delta));
      const rootTop = root.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({ top: rootTop - topOff + target * step, behavior: 'smooth' });
    }

    function setMode() {
      pinned = mq.matches;
      root.classList.toggle('yd-pinned', pinned);
      if (pinned) {
        topOff = Math.max(24, (window.innerHeight - sticky!.offsetHeight) / 2);
        root.style.setProperty('--yd-top', `${topOff}px`);
      } else {
        track!.style.transform = '';
      }
      apply();
    }

    mq.addEventListener('change', setMode);
    addEventListener('scroll', onScroll, { passive: true });
    addEventListener('resize', setMode, { passive: true });
    prev?.addEventListener('click', () => jump(-1));
    next?.addEventListener('click', () => jump(1));

    /* Klavye odağı ekran dışı panelde kalmasın: odaklanan panelin karesine atla */
    track.addEventListener('focusin', (e) => {
      if (!pinned || !(e.target instanceof Node)) return;
      const i = panels.findIndex((p) => p.contains(e.target as Node));
      if (i < 0) return;
      const t = total();
      const rootTop = root.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({ top: rootTop - topOff + (i * t) / (N - 1) });
    });

    setMode();
  });
</script>
