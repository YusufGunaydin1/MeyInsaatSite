---
/* Kompakt MEKÂN: üç bölüm TAM GENİŞLİK şerit yerine sıkı satır (küçük thumb +
   no + ad + tek satır) → dikey yer büyük ölçüde düşer. Altında sıkı künye ızgarası. */
import { Image } from 'astro:assets';
import { ui, project } from '../../../../lib/content';
import cephe from '../../../../assets/projects/ali-cephe-cizim.webp';
import mutfak from '../../../../assets/projects/ali-mutfak.webp';
import salon from '../../../../assets/projects/ali-salon.webp';

const t = ui('tr');
const td = t.projects.detail;
const p = project('ali', 'tr');
const tip = String(t.projects.types?.[p?.data?.type] ?? 'Konut').toUpperCase();
const imgs = [cephe, mutfak, salon];
const chapters = (td.spaces.chapters as { name: string; text: string; alt: string }[]).map(
  (c, i) => ({ ...c, no: String(i + 1).padStart(2, '0'), img: imgs[i] })
);
const s = td.samples;
const specs = [
  { k: tip, v: 'PROJE TİPİ' },
  { k: `${s.floors} ${td.spaces.floorsWord}`, v: 'KAT' },
  { k: `${s.units} ${td.spaces.unitsWord}`, v: 'DAİRE' },
  { k: s.place, v: 'KONUM' },
];
---

<section class="mm">
  <p class="t-tech mm-head">MEKÂN</p>
  <ol class="mm-list">
    {chapters.map((c) => (
      <li class="mm-row">
        <figure class="mm-thumb">
          <Image src={c.img} alt={c.alt} widths={[120, 240]} sizes="88px" class="mm-thumb-img" data-testid="m-strip" />
        </figure>
        <div class="mm-body">
          <p class="mm-rowhead"><span class="mm-no">{c.no}</span><span class="t-tech mm-name">{c.name}</span></p>
          <p class="t-caption mm-text">{c.text}</p>
        </div>
      </li>
    ))}
  </ol>

  <dl class="mm-specs">
    {specs.map((sp) => (
      <div class="mm-spec">
        <dt class="mm-spec-k">{sp.k}</dt>
        <dd class="t-tech mm-spec-v">{sp.v}</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  .mm-head { font-size: 0.62rem; color: var(--color-mey-red); margin-block-end: 0.55rem; }
  .mm-list { list-style: none; display: grid; gap: 0.55rem; padding: 0; }
  .mm-row {
    display: grid; grid-template-columns: 88px minmax(0, 1fr); gap: 0.7rem;
    align-items: center;
  }
  .mm-thumb {
    overflow: hidden; border-radius: var(--radius-brand);
    border: 1px solid var(--color-line); background: var(--color-concrete-100);
  }
  .mm-thumb-img { width: 100%; display: block; aspect-ratio: 4 / 3; object-fit: cover; }
  .mm-body { min-width: 0; }
  .mm-rowhead { display: flex; align-items: baseline; gap: 0.4rem; }
  .mm-no {
    font-family: var(--font-display); font-weight: 600; font-size: 0.85rem;
    color: var(--color-mey-red); line-height: 1;
  }
  .mm-name { font-size: 0.66rem; color: var(--color-graphite-900); }
  .mm-text {
    font-size: 0.68rem; line-height: 1.35; color: var(--color-graphite-600);
    margin-block-start: 0.15rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .mm-specs {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
    background: var(--color-line); border: 1px solid var(--color-line);
    border-radius: var(--radius-brand); overflow: hidden;
    margin-block-start: 0.85rem;
  }
  .mm-spec { background: #fff; padding: 0.5rem 0.6rem; }
  .mm-spec-k {
    font-family: var(--font-mono); font-weight: 500; font-size: 0.82rem;
    color: var(--color-graphite-900); font-variant-numeric: tabular-nums;
  }
  .mm-spec-v { font-size: 0.55rem; color: var(--color-graphite-400); margin-block-start: 0.1rem; }
</style>
