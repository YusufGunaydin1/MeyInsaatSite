---
/* Kompakt KÜNYE: solda şeffaf izometrik render (kartsız, sayfada yüzer) + sağda
   sıkı özet; altında sıkı zaman çizelgesi, malzeme çipleri ve tam-genişlik CTA. */
import { Image } from 'astro:assets';
import { ui, project } from '../../../../lib/content';
import { localePath } from '../../../../lib/i18n';
import iso from '../../../../assets/projects/ali-izometrik.webp';
import beton from '../../../../assets/projects/ali-doku-beton.webp';
import tugla from '../../../../assets/projects/ali-doku-tugla.webp';
import cam from '../../../../assets/projects/ali-doku-cam.webp';
import metal from '../../../../assets/projects/ali-doku-metal.webp';

const t = ui('tr');
const td = t.projects.detail;
const p = project('ali', 'tr');
const tip = String(t.projects.types?.[p?.data?.type] ?? 'Konut').toUpperCase();
const statu = String(t.projects.status?.[p?.data?.status] ?? 'Tamamlandı').toUpperCase();
const s = td.samples;
const L = td.dossier.labels;
const ozet = [
  { k: L.type, v: tip, sample: false },
  { k: L.status, v: statu, sample: false },
  { k: L.place, v: s.placeCity, sample: true },
  { k: L.year, v: s.year, sample: true },
];
const dokular = [beton, tugla, cam, metal];
const materials = (td.dossier.materials as string[]).map((ad, i) => ({ ad, img: dokular[i] }));
---

<section class="mk">
  <p class="t-tech mk-head">KÜNYE</p>

  <div class="mk-top">
    <figure class="mk-iso">
      <Image src={iso} alt={td.dossier.isoAlt} widths={[180, 360]} sizes="150px" class="mk-iso-img" data-testid="m-iso" />
      <figcaption class="t-tech mk-cap">{td.dossier.isoCaption}</figcaption>
    </figure>
    <dl class="mk-ozet">
      {ozet.map((o) => (
        <div class="mk-ozet-row">
          <dt class="t-tech mk-ozet-k">{o.k}</dt>
          <dd class:list={['t-tech mk-ozet-v', o.sample && 'mk-sample']}>{o.v}</dd>
        </div>
      ))}
    </dl>
  </div>

  <ol class="mk-tl">
    {td.dossier.timeline.map((z: { date: string; name: string }) => (
      <li class="mk-tl-item">
        <span class="t-tech mk-tl-date mk-sample">{z.date}</span>
        <span class="t-tech mk-tl-name">{z.name}</span>
      </li>
    ))}
  </ol>

  <div class="mk-mat">
    <p class="t-tech mk-mat-head">{td.dossier.materialsTitle}</p>
    <ul class="mk-chips">
      {materials.map((m) => (
        <li class="mk-chip">
          <Image src={m.img} alt={m.ad} widths={[80, 160]} sizes="38px" class="mk-chip-img" />
          <span class="t-tech mk-chip-ad">{m.ad}</span>
        </li>
      ))}
    </ul>
  </div>

  <a class="t-tech mk-cta" href={localePath('tr', '/iletisim')} data-testid="m-cta">
    {td.dossier.cta} <span aria-hidden="true">→</span>
  </a>
</section>

<style>
  .mk-head { font-size: 0.62rem; color: var(--color-mey-red); margin-block-end: 0.6rem; }

  .mk-top { display: grid; grid-template-columns: 42% minmax(0, 1fr); gap: 0.9rem; align-items: center; }
  /* Şeffaf render kartsız yüzer (arka plan yok) */
  .mk-iso { display: flex; flex-direction: column; }
  .mk-iso-img { width: 100%; display: block; aspect-ratio: 1 / 1; object-fit: contain; }
  .mk-cap { font-size: 0.5rem; color: var(--color-graphite-400); margin-block-start: 0.2rem; }

  .mk-ozet { display: grid; gap: 0.35rem; min-width: 0; }
  .mk-ozet-row { display: grid; grid-template-columns: minmax(4.5rem, auto) 1fr; gap: 0.5rem; align-items: baseline; }
  .mk-ozet-k { font-size: 0.55rem; color: var(--color-graphite-400); }
  .mk-ozet-k::after { content: " :"; }
  .mk-ozet-v { font-size: 0.6rem; color: var(--color-graphite-900); }
  .mk-sample { color: var(--color-graphite-400); }

  .mk-tl {
    list-style: none; display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem; padding: 0; margin-block-start: 0.9rem;
    border-block-start: 1px solid var(--color-line); padding-block-start: 0.7rem;
  }
  .mk-tl-item { display: grid; gap: 0.15rem; position: relative; padding-inline-start: 0.7rem; }
  .mk-tl-item::before {
    content: ""; position: absolute; inset-inline-start: 0; top: 0.2rem;
    width: 7px; height: 7px; border: 2px solid var(--color-mey-red);
    border-radius: 50%; background: var(--color-concrete-050);
  }
  .mk-tl-date { font-size: 0.55rem; }
  .mk-tl-name { font-size: 0.62rem; color: var(--color-graphite-900); }

  .mk-mat { margin-block-start: 0.95rem; }
  .mk-mat-head { font-size: 0.58rem; color: var(--color-mey-red); margin-block-end: 0.45rem; }
  .mk-chips { list-style: none; display: flex; gap: 0.7rem; padding: 0; }
  .mk-chip { display: grid; gap: 0.2rem; justify-items: center; }
  .mk-chip-img {
    width: 38px; height: 38px; object-fit: cover; display: block;
    border: 1px solid var(--color-line); border-radius: var(--radius-brand);
  }
  .mk-chip-ad { font-size: 0.5rem; color: var(--color-graphite-600); }

  .mk-cta {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    margin-block-start: 1.1rem; padding: 0.7rem 1rem;
    color: var(--color-mey-red); border: 1px solid var(--color-mey-red);
    border-radius: var(--radius-brand); font-size: 0.68rem;
    transition: background-color 200ms ease-out, color 200ms ease-out;
  }
  .mk-cta:hover { background: var(--color-mey-red); color: #fff; }
</style>
