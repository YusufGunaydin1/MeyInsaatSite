---
/*
  VARYANT A — KOMPAKT AKIŞ: tek yoğun kaydırma. Aynı içerik (hikâye/mekân/künye)
  ama küçük çevrelenmiş görseller, sıkı satırlar ve tipografi ile — canlı mobilin
  tam-taşma uzun yığınına karşı yer kazandırır. Hairline ayraçlar bölümleri ayırır.
*/
import MHero from './MHero.astro';
import MHikaye from './MHikaye.astro';
import MMekan from './MMekan.astro';
import MKunye from './MKunye.astro';
import { ui } from '../../../../lib/content';
const note = ui('tr').projects.detail.samplesNote;
---

<div class="mka" data-testid="mobil-kompakt">
  <MHero />
  <div class="mka-sec"><MHikaye /></div>
  <div class="mka-sec"><MMekan /></div>
  <div class="mka-sec"><MKunye /></div>
  <p class="t-caption mka-note">{note}</p>
</div>

<style>
  .mka { display: grid; gap: 1.05rem; }
  .mka-sec {
    border-block-start: 1px solid var(--color-line);
    padding-block-start: 1.05rem;
  }
  .mka-note {
    font-size: 0.54rem; line-height: 1.4; color: var(--color-graphite-400);
    border-block-start: 1px solid var(--color-line); padding-block-start: 0.7rem;
    margin: 0;
  }
</style>
