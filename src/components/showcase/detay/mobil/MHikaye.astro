---
/* Kompakt HİKÂYE: kısa paragraf + Plex Serif alıntı (kırmızı guide-line) +
   sıkı özellik pill'leri. Büyük display başlık YOK — mobilde yer tasarrufu. */
import '@fontsource/ibm-plex-serif/400.css';
import { ui } from '../../../../lib/content';
const td = ui('tr').projects.detail;
---

<section class="mhk">
  <p class="t-body mhk-para">{td.story.para}</p>
  <blockquote class="mhk-quote">{td.story.quote}</blockquote>
  <ul class="mhk-feats">
    {td.story.features.map((f: string) => <li class="t-tech mhk-feat">{f}</li>)}
  </ul>
</section>

<style>
  .mhk-para {
    font-size: 0.85rem; line-height: 1.55;
    color: var(--color-graphite-600); margin: 0;
  }
  .mhk-quote {
    font-family: "IBM Plex Serif", "IBM Plex Sans", serif;
    font-size: 1.15rem; line-height: 1.3; white-space: pre-line;
    color: var(--color-graphite-900);
    border-inline-start: 2px solid var(--color-mey-red);
    padding-inline-start: 0.75rem;
    margin-block: 0.9rem 0;
  }
  .mhk-feats {
    list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem;
    margin-block-start: 0.9rem; padding: 0;
  }
  .mhk-feat {
    font-size: 0.62rem; color: var(--color-graphite-900);
    border: 1px solid var(--color-line); border-radius: var(--radius-brand);
    padding: 0.25rem 0.55rem; background: #fff;
  }
</style>
