---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = `${base}/showcases/satilik-daireler`;

const pages = [
  {
    label: 'Daire 1',
    detail: 'Kat anlatısını, yaşam alanlarını ve seçili fotoğrafları inceleyin.',
    href: `${root}/daire-1`,
  },
  {
    label: 'Daire 2',
    detail: 'Farklı içerik sırasını, merdiven hattını ve oda seçkisini görün.',
    href: `${root}/daire-2`,
  },
  {
    label: 'El Ele Apartmanı',
    detail: 'Dış cephe, giriş, ortak alan ve otopark bağlamını açın.',
    href: `${root}/el-ele-apartmani`,
  },
  {
    label: 'Galeri',
    detail: 'Daire, bina, ortak alan ve çevre seçkilerini filtreleyin.',
    href: `${root}/galeri`,
  },
  {
    label: 'Bilgi ve randevu',
    detail: 'Doğrulama, hata ve başarı durumları bulunan demo formunu deneyin.',
    href: `${root}/iletisim`,
  },
] as const;
---

<section
  class="showcases-sale-entry"
  data-testid="showcases-sale-entry"
  aria-labelledby="showcases-sale-title"
>
  <div class="showcases-sale-entry__inner">
    <div class="showcases-sale-entry__intro">
      <div>
        <p class="showcases-sale-entry__kicker">Yeni · tek tasarım sistemi</p>
        <h2 id="showcases-sale-title">Satılık Daireler · El Ele Apartmanı</h2>
        <p class="showcases-sale-entry__summary">
          İki yeni 3+2 dubleksi keşfetme, ayrıntılarını inceleme, bina bağlamını görme ve
          bilgi talebi hazırlama akışının tüm sayfalarına buradan geçin.
        </p>
      </div>
      <a class="showcases-sale-entry__primary" data-sale-route href={root}>
        Genel sayfayı aç <span aria-hidden="true">→</span>
      </a>
    </div>

    <nav class="showcases-sale-entry__links" aria-label="Satılık Daireler sayfaları">
      {pages.map((page) => (
        <a class="showcases-sale-entry__link" data-sale-route href={page.href}>
          <span class="showcases-sale-entry__link-title">{page.label}</span>
          <span class="showcases-sale-entry__link-copy">{page.detail}</span>
          <span class="showcases-sale-entry__link-action">
            Sayfayı aç <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </nav>
  </div>
</section>

<style>
  .showcases-sale-entry {
    padding-block: 2.5rem;
    border-top: 1px solid rgb(255 255 255 / 0.08);
    color: rgb(255 255 255 / 0.7);
    background: #141719;
  }

  .showcases-sale-entry__inner {
    width: min(calc(100% - 2rem), 1180px);
    margin-inline: auto;
    padding: 1.25rem;
    border: 1px solid rgb(255 255 255 / 0.14);
    border-top: 2px solid #e2393e;
    border-radius: var(--radius-brand);
    background: #1b1f22;
  }

  .showcases-sale-entry__intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: end;
  }

  .showcases-sale-entry__kicker {
    margin: 0;
    color: #f2555a;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .showcases-sale-entry h2 {
    margin: 0.4rem 0 0;
    color: #fff;
    font-size: clamp(1.7rem, 3vw, 2.35rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .showcases-sale-entry__summary {
    max-width: 66ch;
    margin: 0.6rem 0 0;
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .showcases-sale-entry__primary {
    display: inline-flex;
    min-height: 44px;
    padding: 0.7rem 0.9rem;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 1px solid #e2393e;
    border-radius: var(--radius-brand);
    color: #fff;
    background: #c92228;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .showcases-sale-entry__primary:hover { background: #a91c21; }

  .showcases-sale-entry__links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin-top: 1.1rem;
  }

  .showcases-sale-entry__link {
    display: grid;
    min-height: 118px;
    padding: 0.9rem;
    grid-template-rows: auto 1fr auto;
    gap: 0.45rem;
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-brand);
    background: #111416;
  }

  .showcases-sale-entry__link:hover,
  .showcases-sale-entry__link:focus-visible {
    border-color: rgb(242 85 90 / 0.68);
    background: #202529;
  }

  .showcases-sale-entry__primary:focus-visible,
  .showcases-sale-entry__link:focus-visible {
    outline: 2px solid #f2555a;
    outline-offset: 3px;
  }

  .showcases-sale-entry__link-title {
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .showcases-sale-entry__link-copy {
    color: rgb(255 255 255 / 0.56);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .showcases-sale-entry__link-action {
    color: #7fc8c7;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .showcases-sale-entry__intro {
      grid-template-columns: 1fr;
      gap: 1rem;
      align-items: start;
    }

    .showcases-sale-entry__primary { justify-self: start; }
    .showcases-sale-entry__links { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 520px) {
    .showcases-sale-entry { padding-block: 2rem; }
    .showcases-sale-entry__inner { width: min(calc(100% - 1.5rem), 1180px); padding: 1rem; }
    .showcases-sale-entry__links { grid-template-columns: 1fr; }
    .showcases-sale-entry__link { min-height: 104px; }
    .showcases-sale-entry__primary { width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .showcases-sale-entry__primary,
    .showcases-sale-entry__link { transition: none; }
  }
</style>
