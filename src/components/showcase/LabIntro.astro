---
/* Shared dark intro header for every /showcases/*-lab page (DRY chrome). */
interface Props {
  kicker: string;
  title: string;
  desc: string;
}
const { kicker, title, desc } = Astro.props;
---

<section class="theatre blueprint-grid lab-intro">
  <div class="container-site">
    <p class="t-tech" style="color: var(--color-red-on-dark);">{kicker}</p>
    <h1 class="t-display-l mt-2">{title}</h1>
    <p class="t-body-l mt-4 max-w-2xl" style="color: rgb(244 244 242 / 0.72);">{desc}</p>
    <a class="t-tech lab-back mt-6" href="/showcases">
      <span aria-hidden="true">←</span> Vitrine dön
    </a>
  </div>
</section>

<style>
  .lab-intro {
    padding-block: clamp(2.5rem, 6vh, 4.5rem);
  }
  .lab-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-mey-teal);
  }
  .lab-back:hover {
    color: #fff;
  }
</style>
