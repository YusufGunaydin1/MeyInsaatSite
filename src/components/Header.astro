---
import { Image } from 'astro:assets';
import { LOCALES, localePath, type Locale } from '../lib/i18n';
import { ui } from '../lib/content';
// Dark-surface lockup: same mark, wordmark recolored white (standard dark variant)
import logo from '../assets/brand/mey-logo-dark.png';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const t = ui(locale);

const items = [
  { href: '/', label: t.nav.home },
  { href: '/projeler', label: t.nav.projects },
  { href: '/kurumsal', label: t.nav.corporate },
  { href: '/hizmetler', label: t.nav.services },
  { href: '/iletisim', label: t.nav.contact },
];

const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<!-- Dark institutional header (2026-07 revision): night bar + boxed mark + wide-tracked
     caps nav. Bookends the light body together with the dark footer/theatre. -->
<header class="bg-night-950">
  <div class="container-site flex items-center justify-between gap-4 h-16 md:h-24">
    <a
      href={localePath(locale, '/')}
      class="flex items-center shrink-0"
      aria-label="MEY İnşaat"
    >
      <Image src={logo} alt="MEY İnşaat" height={44} densities={[1, 2]} loading="eager" class="h-9 md:h-11 w-auto" />
    </a>

    <nav aria-label={t.a11y.mainNav} class="hidden md:flex items-center gap-8">
      {items.map((item) => (
        <a
          href={localePath(locale, item.href)}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'nav-caps py-1 border-b-2 transition-colors',
            isActive(item.href)
              ? 'text-white border-red-on-dark'
              : 'text-concrete-100/70 border-transparent hover:text-white hover:border-concrete-100/30',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <details class="relative group" data-lang-switcher>
        <summary
          class="list-none cursor-pointer t-tech text-concrete-100/70 hover:text-white px-2 py-2 flex items-center gap-1 select-none"
          aria-label={t.a11y.languageSwitcher}
        >
          {locale.toUpperCase()}<span aria-hidden="true" class="text-concrete-100/50">▾</span>
        </summary>
        <ul
          class="absolute end-0 top-full mt-1 z-40 card min-w-24 py-1"
          role="list"
        >
          {LOCALES.map((l) => (
            <li>
              <a
                href={localePath(l, path)}
                aria-current={l === locale ? 'true' : undefined}
                class:list={[
                  't-tech block px-4 py-2 hover:bg-concrete-100',
                  l === locale ? 'text-mey-red' : 'text-graphite-600',
                ]}
              >
                {l.toUpperCase()}
              </a>
            </li>
          ))}
        </ul>
      </details>

      <details class="md:hidden relative" data-mobile-menu>
        <summary
          class="list-none cursor-pointer p-2 text-white select-none"
          aria-label={t.a11y.openMenu}
        >
          <span aria-hidden="true" class="block w-5 space-y-1">
            <span class="block h-0.5 bg-current"></span>
            <span class="block h-0.5 bg-current"></span>
            <span class="block h-0.5 bg-current"></span>
          </span>
        </summary>
        <nav
          aria-label={t.a11y.mainNav}
          class="absolute end-0 top-full mt-1 z-40 card min-w-48 py-1"
        >
          {items.map((item) => (
            <a
              href={localePath(locale, item.href)}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'block px-4 py-2.5 text-sm font-medium hover:bg-concrete-100',
                isActive(item.href)
                  ? 'text-mey-red'
                  : 'text-graphite-900',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  /* Reference-genre nav: small caps, wide tracking. Arabic gets no letterspacing
     (tracking breaks connected script) and its own face via :lang. */
  .nav-caps {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .nav-caps:lang(ar) {
    font-family: var(--font-arabic);
    letter-spacing: 0;
    font-size: 0.9375rem;
  }
</style>

<script>
  // Close open <details> menus when clicking elsewhere.
  document.addEventListener('click', (e) => {
    for (const d of document.querySelectorAll<HTMLDetailsElement>(
      'details[data-lang-switcher][open], details[data-mobile-menu][open]'
    )) {
      if (!d.contains(e.target as Node)) d.open = false;
    }
  });
</script>
