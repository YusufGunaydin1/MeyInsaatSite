---
import { Image } from 'astro:assets';
import { LOCALES, LOCALE_NAMES, localePath, type Locale } from '../lib/i18n';
import { ui } from '../lib/content';
// Dark-surface lockup: same mark, wordmark recolored white (standard dark variant)
import logo from '../assets/brand/mey-logo-dark.png';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const t = ui(locale);

const items = [
  { href: '/', label: t.nav.home },
  { href: '/projeler', label: t.nav.projects },
  { href: '/satilik-daireler', label: t.nav.forSale },
  { href: '/kurumsal', label: t.nav.corporate },
  { href: '/hizmetler', label: t.nav.services },
  { href: '/iletisim', label: t.nav.contact },
];

const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<!-- Dark institutional header (2026-07 revision): night bar + boxed mark + wide-tracked
     caps nav. Bookends the light body together with the dark footer/theatre. -->
<header class="bg-night-950">
  <div class="container-site flex items-center justify-between gap-4 h-16 md:h-24">
    <a
      href={localePath(locale, '/')}
      class="flex items-center shrink-0"
      aria-label="MEY İnşaat"
    >
      <Image src={logo} alt="MEY İnşaat" height={44} densities={[1, 2]} loading="eager" class="h-9 md:h-11 w-auto" />
    </a>

    <nav aria-label={t.a11y.mainNav} class="hidden md:flex items-center gap-8">
      {items.map((item) => (
        <a
          href={localePath(locale, item.href)}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'nav-caps py-1 border-b-2 transition-colors',
            isActive(item.href)
              ? 'text-white border-red-on-dark'
              : 'text-concrete-100/70 border-transparent hover:text-white hover:border-concrete-100/30',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <details class="relative group" data-lang-switcher>
        <summary
          class="lang-summary list-none cursor-pointer t-tech select-none"
          aria-label={t.a11y.languageSwitcher}
        >
          {locale.toUpperCase()}<span aria-hidden="true" class="lang-caret">▾</span>
        </summary>
        <ul
          class="menu-panel absolute end-0 top-full mt-2 z-40 min-w-44"
          role="list"
        >
          {LOCALES.map((l) => (
            <li>
              <a
                href={localePath(l, path)}
                lang={l}
                hreflang={l}
                aria-current={l === locale ? 'true' : undefined}
                class="lang-item"
              >
                <span class="t-tech lang-code" aria-hidden="true">{l.toUpperCase()}</span>
                <span class="lang-name">{LOCALE_NAMES[l]}</span>
              </a>
            </li>
          ))}
        </ul>
      </details>

      <details class="md:hidden relative" data-mobile-menu>
        <summary
          class="burger-summary list-none cursor-pointer text-white select-none"
          aria-label={t.a11y.openMenu}
        >
          <span aria-hidden="true" class="block w-5 space-y-1">
            <span class="block h-0.5 bg-current"></span>
            <span class="block h-0.5 bg-current"></span>
            <span class="block h-0.5 bg-current"></span>
          </span>
        </summary>
        <nav
          aria-label={t.a11y.mainNav}
          class="menu-panel absolute end-0 top-full mt-2 z-40 min-w-48"
        >
          {items.map((item) => (
            <a
              href={localePath(locale, item.href)}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class="menu-item"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  /* Reference-genre nav: small caps, wide tracking. Arabic gets no letterspacing
     (tracking breaks connected script) and its own face via :lang. */
  .nav-caps {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .nav-caps:lang(ar) {
    font-family: var(--font-arabic);
    letter-spacing: 0;
    font-size: 0.9375rem;
  }

  /* ---- Language switcher: hairline-boxed control, echoes the boxed logo ---- */
  .lang-summary {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: var(--radius-brand);
    color: rgb(244 244 242 / 0.75);
    transition: color 150ms ease-out, border-color 150ms ease-out;
  }
  .lang-summary:hover,
  details[open] > .lang-summary {
    color: #fff;
    border-color: rgb(255 255 255 / 0.45);
  }
  .lang-summary::-webkit-details-marker {
    display: none;
  }
  .lang-caret {
    display: inline-block;
    color: rgb(244 244 242 / 0.5);
    transition: transform 200ms ease-out;
  }
  details[open] .lang-caret {
    transform: rotate(180deg);
  }

  /* Dropdown panels live on the dark bar — dark surface, hairline, flat */
  .menu-panel {
    background: var(--color-night-800);
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: var(--radius-brand);
    padding-block: 0.375rem;
  }

  /* Language rows: mono code + native name; active = red guide-line (brief §7) */
  .lang-item {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    column-gap: 0.6rem;
    align-items: baseline;
    padding: 0.55rem 0.9rem;
    border-inline-start: 2px solid transparent;
    transition: background-color 150ms ease-out;
  }
  .lang-item:hover {
    background: rgb(255 255 255 / 0.06);
  }
  .lang-code {
    color: rgb(244 244 242 / 0.55);
  }
  .lang-name {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.3;
    color: rgb(244 244 242 / 0.85);
  }
  /* The Arabic endonym uses Plex Arabic only where the page already ships it
     (AR pages). Elsewhere it falls to the system Arabic face — one menu row is
     not worth downloading the whole subset on Latin/Cyrillic pages (brief §6). */
  :global(html:lang(ar)) .lang-name:lang(ar) {
    font-family: var(--font-arabic);
  }
  .lang-item:hover .lang-name {
    color: #fff;
  }
  .lang-item[aria-current] {
    border-inline-start-color: var(--color-red-on-dark);
  }
  .lang-item[aria-current] .lang-code {
    color: var(--color-red-on-dark);
  }
  .lang-item[aria-current] .lang-name {
    color: #fff;
  }

  /* Mobile menu: same panel voice; active page gets the red guide-line */
  .burger-summary {
    padding: 0.5rem;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: var(--radius-brand);
    transition: border-color 150ms ease-out;
  }
  .burger-summary:hover,
  details[open] > .burger-summary {
    border-color: rgb(255 255 255 / 0.45);
  }
  .burger-summary::-webkit-details-marker {
    display: none;
  }
  .menu-item {
    display: block;
    padding: 0.65rem 1rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.875rem;
    color: rgb(244 244 242 / 0.85);
    border-inline-start: 2px solid transparent;
    transition: background-color 150ms ease-out;
  }
  .menu-item:lang(ar) {
    font-family: var(--font-arabic);
  }
  .menu-item:hover {
    background: rgb(255 255 255 / 0.06);
    color: #fff;
  }
  .menu-item[aria-current='page'] {
    color: #fff;
    border-inline-start-color: var(--color-red-on-dark);
  }
</style>

<script>
  // Close open <details> menus when clicking elsewhere.
  document.addEventListener('click', (e) => {
    for (const d of document.querySelectorAll<HTMLDetailsElement>(
      'details[data-lang-switcher][open], details[data-mobile-menu][open]'
    )) {
      if (!d.contains(e.target as Node)) d.open = false;
    }
  });
</script>
