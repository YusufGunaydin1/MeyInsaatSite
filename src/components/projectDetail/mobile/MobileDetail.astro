---
/*
  KOMPAKT MOBİL DETAY (Variant A — "Kompakt Akış"). Canlı masaüstü adımlı sahnenin
  (`DetailStage` `.pds`) mobil karşılığı: aynı içerik, TEK yoğun kaydırma — küçük
  çevrelenmiş görseller, sıkı satır/tipografi, bindirmeli hero başlığı, bölüm
  satırları, satır-içi künye ızgarası, yüzen şeffaf izometrik, yatay zaman çizelgesi.
  <1024px'te `.pds` yerine bu görünür (DetailStage genişlik anahtarı). Veri/locale
  DetailStage'in mevcut prop'larından gelir; RTL/AR frame'lerle aynı dilde. Dipnot
  YOK — paylaşımlı `.pds-note` kullanılır. Hero başlığı sayfa `<h1>`'i.
*/
import '@fontsource/ibm-plex-serif/400.css';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Locale } from '../../../lib/i18n';
import MapLinks from '../../MapLinks.astro';

interface Props {
  name: string;
  typeLabel: string;
  statusLabel: string;
  eyebrow: string;
  cover: ImageMetadata;
  imgs: {
    salon: ImageMetadata;
    mutfak: ImageMetadata;
    cephe: ImageMetadata;
    izometrik: ImageMetadata;
    vaziyet: ImageMetadata;
    malzeme: ImageMetadata;
    dokular: ImageMetadata[];
  };
  detail: Record<string, any>;
  ctaHref: string;
  locale: Locale;
  /** gerçek adres — varsa künyede harita bağlantıları */
  mapQuery?: string | null;
}
const { name, typeLabel, statusLabel, eyebrow, cover, imgs, detail: td, ctaHref, locale, mapQuery } = Astro.props;

const s = td.samples;
const L = td.dossier.labels;

// MEKÂN — üç bölüm sıkı satır olarak [cephe, iç mekân, yaşam] = [cephe, mutfak, salon]
const chapterImgs = [imgs.cephe, imgs.mutfak, imgs.salon];
const chapters = (td.spaces.chapters as { name: string; text: string; alt: string }[]).map(
  (c, i) => ({ ...c, no: String(i + 1).padStart(2, '0'), img: chapterImgs[i] })
);
// Satır-içi künye ızgarası: büyük değer + küçük (locale) etiket
const specs = [
  { big: typeLabel, small: L.type },
  { big: s.floors, small: td.spaces.floorsWord },
  { big: s.units, small: td.spaces.unitsWord },
  { big: s.place, small: L.place },
];
// KÜNYE özeti
const ozet = [
  { k: L.type, v: typeLabel, sample: false },
  { k: L.status, v: statusLabel, sample: false },
  { k: L.place, v: s.address ?? s.placeCity, sample: false },
  { k: L.year, v: s.year, sample: true },
];
const materials = (td.dossier.materials as string[]).map((ad, i) => ({ ad, img: imgs.dokular[i] }));
---

<div class="pdm" data-testid="pd-mobile">
  <!-- HERO (div — sayfada tek <header>/banner site başlığıdır) -->
  <div class="pdm-hero">
    <figure class="pdm-media">
      <Image src={cover} alt={name} widths={[320, 640]} sizes="(min-width: 1024px) 1px, 100vw" class="pdm-cover" data-testid="pdm-cover" />
      <span class="pdm-pole" aria-hidden="true"></span>
      <span class="pdm-tag t-tech" style="--y: 8%">{typeLabel}</span>
      <span class="pdm-tag t-tech" style="--y: 26%">{statusLabel}</span>
      <div class="pdm-over">
        <p class="t-tech pdm-eyebrow">{eyebrow}</p>
        <h1 class="pdm-title">{name}</h1>
      </div>
    </figure>
    <p class="t-tech pdm-meta">
      <span>{s.placeCity}</span>
      <span class="pdm-dot" aria-hidden="true">·</span>
      <span class="pdm-s">{s.floors} {td.spaces.floorsWord}</span>
      <span class="pdm-dot" aria-hidden="true">·</span>
      <span class="pdm-s">{s.units} {td.spaces.unitsWord}</span>
      <span class="pdm-dot" aria-hidden="true">·</span>
      <span class="pdm-s">{s.year}</span>
    </p>
  </div>

  <!-- HİKÂYE -->
  <section class="pdm-sec">
    <p class="t-body pdm-para">{td.story.para}</p>
    <blockquote class="pdm-quote" data-testid="pdm-quote">{td.story.quote}</blockquote>
    <ul class="pdm-feats">
      {td.story.features.map((f: string) => <li class="t-tech pdm-feat">{f}</li>)}
    </ul>
  </section>

  <!-- MEKÂN -->
  <section class="pdm-sec">
    <p class="t-tech pdm-head">{td.frames.spaces}</p>
    <ol class="pdm-list">
      {chapters.map((c) => (
        <li class="pdm-row">
          <figure class="pdm-thumb">
            <Image src={c.img} alt={c.alt} widths={[120, 240]} sizes="88px" class="pdm-thumb-img" data-testid="pdm-strip" />
          </figure>
          <div class="pdm-rowbody">
            <p class="pdm-rowhead"><span class="pdm-no">{c.no}</span><span class="t-tech pdm-name">{c.name}</span></p>
            <p class="t-caption pdm-text">{c.text}</p>
          </div>
        </li>
      ))}
    </ol>
    <dl class="pdm-specs">
      {specs.map((sp) => (
        <div class="pdm-spec">
          <dt class="pdm-spec-k tabular-nums">{sp.big}</dt>
          <dd class="t-tech pdm-spec-v">{sp.small}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- KÜNYE -->
  <section class="pdm-sec">
    <p class="t-tech pdm-head">{td.frames.dossier}</p>
    <div class="pdm-top">
      <figure class="pdm-iso">
        <Image src={imgs.izometrik} alt={td.dossier.isoAlt} widths={[200, 400]} sizes="150px" class="pdm-iso-img" data-testid="pdm-iso" />
        <figcaption class="t-tech pdm-iso-cap">{td.dossier.isoCaption}</figcaption>
      </figure>
      <dl class="pdm-ozet">
        {ozet.map((o) => (
          <div class="pdm-ozet-row">
            <dt class="t-tech pdm-ozet-k">{o.k}</dt>
            <dd class:list={['t-tech pdm-ozet-v', o.sample && 'pdm-sample']}>{o.v}</dd>
          </div>
        ))}
      </dl>
    </div>
    {mapQuery && (
      <div class="pdm-map">
        <MapLinks address={mapQuery} locale={locale} label={td.dossier.mapOpen ?? 'HARİTADA AÇ'} />
      </div>
    )}

    <ol class="pdm-tl">
      {td.dossier.timeline.map((z: { date: string; name: string }) => (
        <li class="pdm-tl-item">
          <span class="t-tech pdm-tl-date pdm-sample">{z.date}</span>
          <span class="t-tech pdm-tl-name">{z.name}</span>
        </li>
      ))}
    </ol>

    <div class="pdm-mat">
      <p class="t-tech pdm-mat-head">{td.dossier.materialsTitle}</p>
      <ul class="pdm-chips">
        {materials.map((m) => (
          <li class="pdm-chip">
            <Image src={m.img} alt={m.ad} widths={[80, 160]} sizes="38px" class="pdm-chip-img" />
            <span class="t-tech pdm-chip-ad">{m.ad}</span>
          </li>
        ))}
      </ul>
    </div>

    <a class="t-tech pdm-cta" href={ctaHref} data-testid="pdm-cta">
      {td.dossier.cta} <span aria-hidden="true" class="rtl:-scale-x-100 inline-block">→</span>
    </a>
  </section>
</div>

<style>
  /* Görünürlük anahtarı TÜKETİCİDE: DetailStage bunu ≥1024px'te gizler
     (`.pds-mobile`). Bileşen kendini gizlemez → vitrinde (masaüstü cihaz
     çerçevesi) doğrudan kullanıldığında görünür kalır. */
  .pdm {
    max-inline-size: 32rem;
    margin-inline: auto;
    padding-inline: 1rem;
    padding-block: clamp(1.25rem, 4vh, 2.25rem);
    display: grid;
    gap: 1.05rem;
  }

  /* HERO */
  .pdm-media {
    position: relative; overflow: hidden;
    border-radius: var(--radius-brand); background: var(--color-concrete-100);
  }
  .pdm-cover { width: 100%; display: block; aspect-ratio: 5 / 4; object-fit: cover; }
  .pdm-pole { position: absolute; inset-block: 0; inset-inline-start: 0.7rem; width: 2px; background: var(--color-mey-red); opacity: 0.9; }
  .pdm-tag {
    position: absolute; top: var(--y); inset-inline-start: 0.7rem;
    background: rgb(14 15 17 / 0.85); color: #fff;
    padding-block: 0.15rem; padding-inline: 0.7rem 0.5rem;
    border-radius: var(--radius-brand); font-size: 0.6rem; white-space: nowrap;
  }
  .pdm-tag::before { content: ""; position: absolute; inset-inline-start: 0; top: 50%; width: 0.4rem; height: 2px; background: var(--color-mey-red); }
  .pdm-over {
    position: absolute; inset-inline: 0; inset-block-end: 0;
    padding: 1.6rem 0.85rem 0.7rem;
    background: linear-gradient(to top, rgb(14 15 17 / 0.82), rgb(14 15 17 / 0));
  }
  .pdm-eyebrow { color: #ff9a9d; font-size: 0.58rem; margin-block-end: 0.15rem; }
  .pdm-title {
    font-family: var(--font-display); font-weight: 600; font-size: 1.5rem;
    line-height: 1.02; letter-spacing: 0.01em; color: #fff;
  }
  .pdm-title:lang(ar) { font-family: var(--font-arabic); font-weight: 700; letter-spacing: 0; line-height: 1.2; }
  .pdm-meta { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-block-start: 0.55rem; font-size: 0.62rem; color: var(--color-graphite-900); }
  .pdm-s { color: var(--color-graphite-400); }
  .pdm-dot { color: var(--color-mey-red); }

  /* Bölüm ayracı */
  .pdm-sec { border-block-start: 1px solid var(--color-line); padding-block-start: 1.05rem; }

  /* HİKÂYE */
  .pdm-para { font-size: 0.85rem; line-height: 1.55; color: var(--color-graphite-600); margin: 0; }
  .pdm-quote {
    font-family: "IBM Plex Serif", "IBM Plex Sans", serif;
    font-size: 1.15rem; line-height: 1.3; white-space: pre-line; color: var(--color-graphite-900);
    border-inline-start: 2px solid var(--color-mey-red); padding-inline-start: 0.75rem; margin-block: 0.9rem 0;
  }
  .pdm-quote:lang(ar) { font-family: var(--font-arabic); }
  .pdm-feats { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem; margin-block-start: 0.9rem; padding: 0; }
  .pdm-feat { font-size: 0.62rem; color: var(--color-graphite-900); border: 1px solid var(--color-line); border-radius: var(--radius-brand); padding: 0.25rem 0.55rem; background: #fff; }

  /* MEKÂN */
  .pdm-head { font-size: 0.62rem; color: var(--color-mey-red); margin-block-end: 0.55rem; }
  .pdm-list { list-style: none; display: grid; gap: 0.55rem; padding: 0; }
  .pdm-row { display: grid; grid-template-columns: 88px minmax(0, 1fr); gap: 0.7rem; align-items: center; }
  .pdm-thumb { overflow: hidden; border-radius: var(--radius-brand); border: 1px solid var(--color-line); background: var(--color-concrete-100); }
  .pdm-thumb-img { width: 100%; display: block; aspect-ratio: 4 / 3; object-fit: cover; }
  .pdm-rowbody { min-width: 0; }
  .pdm-rowhead { display: flex; align-items: baseline; gap: 0.4rem; }
  .pdm-no { font-family: var(--font-display); font-weight: 600; font-size: 0.85rem; color: var(--color-mey-red); line-height: 1; }
  .pdm-name { font-size: 0.66rem; color: var(--color-graphite-900); }
  .pdm-text {
    font-size: 0.68rem; line-height: 1.35; color: var(--color-graphite-600); margin-block-start: 0.15rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .pdm-specs {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
    background: var(--color-line); border: 1px solid var(--color-line);
    border-radius: var(--radius-brand); overflow: hidden; margin-block-start: 0.85rem;
  }
  .pdm-spec { background: #fff; padding: 0.5rem 0.6rem; }
  .pdm-spec-k { font-family: var(--font-mono); font-weight: 500; font-size: 0.82rem; color: var(--color-graphite-900); }
  .pdm-spec-v { font-size: 0.55rem; color: var(--color-graphite-400); margin-block-start: 0.1rem; }

  /* KÜNYE */
  .pdm-top { display: grid; grid-template-columns: 42% minmax(0, 1fr); gap: 0.9rem; align-items: center; }
  /* Şeffaf render kartsız yüzer (arka plan yok) */
  .pdm-iso { display: flex; flex-direction: column; }
  .pdm-iso-img { width: 100%; display: block; aspect-ratio: 1 / 1; object-fit: contain; }
  .pdm-iso-cap { font-size: 0.5rem; color: var(--color-graphite-400); margin-block-start: 0.2rem; }
  .pdm-ozet { display: grid; gap: 0.35rem; min-width: 0; }
  .pdm-ozet-row { display: grid; grid-template-columns: minmax(4.5rem, auto) 1fr; gap: 0.5rem; align-items: baseline; }
  .pdm-ozet-k { font-size: 0.55rem; color: var(--color-graphite-400); }
  .pdm-ozet-k::after { content: " :"; }
  .pdm-ozet-v { font-size: 0.6rem; color: var(--color-graphite-900); }
  .pdm-sample { color: var(--color-graphite-400); }
  .pdm-map { margin-block-start: 0.7rem; }

  .pdm-tl {
    list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.4rem;
    padding: 0; margin-block-start: 0.9rem; border-block-start: 1px solid var(--color-line); padding-block-start: 0.7rem;
  }
  .pdm-tl-item { display: grid; gap: 0.15rem; position: relative; padding-inline-start: 0.7rem; }
  .pdm-tl-item::before {
    content: ""; position: absolute; inset-inline-start: 0; top: 0.2rem; width: 7px; height: 7px;
    border: 2px solid var(--color-mey-red); border-radius: 50%; background: var(--color-concrete-050);
  }
  .pdm-tl-date { font-size: 0.55rem; }
  .pdm-tl-name { font-size: 0.62rem; color: var(--color-graphite-900); }

  .pdm-mat { margin-block-start: 0.95rem; }
  .pdm-mat-head { font-size: 0.58rem; color: var(--color-mey-red); margin-block-end: 0.45rem; }
  .pdm-chips { list-style: none; display: flex; gap: 0.7rem; padding: 0; }
  .pdm-chip { display: grid; gap: 0.2rem; justify-items: center; }
  .pdm-chip-img { width: 38px; height: 38px; object-fit: cover; display: block; border: 1px solid var(--color-line); border-radius: var(--radius-brand); }
  .pdm-chip-ad { font-size: 0.5rem; color: var(--color-graphite-600); }

  .pdm-cta {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    margin-block-start: 1.1rem; padding: 0.7rem 1rem;
    color: var(--color-mey-red); border: 1px solid var(--color-mey-red);
    border-radius: var(--radius-brand); font-size: 0.68rem;
    transition: background-color 200ms ease-out, color 200ms ease-out;
  }
  .pdm-cta:hover { background: var(--color-mey-red); color: #fff; }
</style>
