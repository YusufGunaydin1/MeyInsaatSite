---
/*
  KARE 01 — HİKÂYE: eyebrow + proje adı (sayfanın h1'i) + kısa paragraf,
  Plex Serif alıntı (kırmızı guide-line), ince kırmızı çizgilerle bölünen
  özellik satırı, marka bloğu; sağda salon (3:4) + köşesine binen malzeme (1:1).
  Alıntı serifi superfamily içi tek istisna — yalnız bu sayfada yüklenir.
*/
import '@fontsource/ibm-plex-serif/400.css';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  statusLabel: string;
  eyebrow: string;
  t: Record<string, any>;
  brand: string;
  salon: ImageMetadata;
  malzeme: ImageMetadata;
}
const { name, statusLabel, eyebrow, t, brand, salon, malzeme } = Astro.props;
---

<div class="ph">
  <div class="ph-text">
    <div>
      <p class="t-tech text-mey-red mb-3">{eyebrow}</p>
      <h1 class="ph-title">{name}</h1>
      <p class="t-body ph-para">{t.para}</p>
    </div>

    <blockquote class="ph-quote guide-line-v" data-testid="pd-quote">{t.quote}</blockquote>

    <div>
      <ul class="ph-features">
        {t.features.map((f: string) => (
          <li class="ph-feature t-body">{f}</li>
        ))}
      </ul>
      <div class="guide-line-v ph-brand">
        <p class="t-tech text-mey-red">{brand}</p>
        <p class="t-tech ph-status">{statusLabel}</p>
      </div>
    </div>
  </div>

  <div class="ph-collage">
    <figure class="ph-fig ph-fig-1">
      <Image
        src={salon}
        alt={t.salonAlt}
        widths={[480, 800]}
        sizes="(min-width: 1024px) 26vw, 80vw"
        class="ph-img"
        data-testid="pd-foto-1"
      />
    </figure>
    <figure class="ph-fig ph-fig-2">
      <Image
        src={malzeme}
        alt={t.malzemeAlt}
        widths={[480, 800]}
        sizes="(min-width: 1024px) 18vw, 60vw"
        class="ph-img"
        data-testid="pd-foto-2"
      />
    </figure>
  </div>
</div>

<style>
  .ph {
    height: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    min-width: 0;
  }
  @media (min-width: 1024px) {
    .ph { grid-template-columns: minmax(0, 1fr) minmax(0, 0.82fr); gap: clamp(2rem, 3vw, 3rem); }
  }

  .ph-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.75rem;
    max-width: 34rem;
  }
  .ph-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 3.2vw, 3rem);
    letter-spacing: 0.01em;
    line-height: 1.05;
    color: var(--color-graphite-900);
  }
  .ph-title:lang(ar) {
    font-family: var(--font-arabic);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
  }
  .ph-para { max-width: 42ch; margin-block-start: 1.25rem; }
  /* Plex Serif'te Arapça glif yok → AR alıntı Plex Sans Arabic'e düşer */
  .ph-quote {
    font-family: "IBM Plex Serif", "IBM Plex Sans", serif;
    font-size: clamp(1.6rem, 2.2vw, 2.1rem);
    line-height: 1.3;
    color: var(--color-graphite-900);
    padding-inline-start: 1.5rem;
    white-space: pre-line;
  }
  .ph-quote:lang(ar) { font-family: var(--font-arabic); }
  .ph-features {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    border-block-start: 1px solid var(--color-line);
    padding-block-start: 1rem;
  }
  .ph-feature { color: var(--color-graphite-900); }
  .ph-feature + .ph-feature {
    border-inline-start: 1px solid var(--color-mey-red);
    margin-inline-start: 1.4rem;
    padding-inline-start: 1.4rem;
  }
  .ph-brand { margin-block-start: 1.5rem; padding-inline-start: 1rem; display: grid; gap: 0.4rem; }
  .ph-status { color: var(--color-graphite-400); }

  /* Kolaj — düz bindirme, hairline çerçeve, gölgesiz */
  .ph-collage { min-width: 0; }
  .ph-fig {
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
  }
  .ph-img { width: 100%; height: 100%; display: block; object-fit: cover; }
  .ph-fig-1 {
    width: min(72%, 22rem);
    aspect-ratio: 3 / 4;
  }
  .ph-fig-2 {
    width: 54%;
    max-width: 15rem;
    aspect-ratio: 1 / 1;
    margin-inline-start: auto;
    margin-block-start: -26%;
    position: relative;
    z-index: 1;
  }
</style>
