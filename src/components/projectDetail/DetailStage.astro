---
/*
  YATAY DETAY SAHNESİ — ADIMLI (2026-07-11 kararı: scroll-pan kaldırıldı).
  Editoryal, sayfa ölçüsünde. Sol foto hiç değişmez; sağ pencere üç kareyi 1:1
  gösterir ve kareler YALNIZ Önceki/Sonraki düğmeleriyle değişir — iğne yok,
  sayfa scroll'u karelere dokunmaz. RTL'de kayma işareti döner (sağdan sola).
  prefers-reduced-motion aynı adımlı deneyimi alır (geçiş animasyonsuz).
  Dar ekran + no-JS: kareler DOM sırasıyla dikey yığın; içerik kilitli değil.
  Görünmeyen kareler inert + aria-hidden: klavye odağı ekran dışında kalamaz.
*/
import type { ImageMetadata } from 'astro';
import type { Locale } from '../../lib/i18n';
import { localePath } from '../../lib/i18n';
import { ui } from '../../lib/content';
import StagePhoto from './StagePhoto.astro';
import FrameStory from './FrameStory.astro';
import FrameSpaces from './FrameSpaces.astro';
import FrameDossier from './FrameDossier.astro';

export interface StageImages {
  salon: ImageMetadata;
  mutfak: ImageMetadata;
  cephe: ImageMetadata;
  izometrik: ImageMetadata;
  vaziyet: ImageMetadata;
  malzeme: ImageMetadata;
  dokular: ImageMetadata[];
}

interface Props {
  locale: Locale;
  name: string;
  typeLabel: string;
  statusLabel: string;
  cover: ImageMetadata;
  coverXray?: ImageMetadata;
  imgs: StageImages;
}
const { locale, name, typeLabel, statusLabel, cover, coverXray, imgs } = Astro.props;

const t = ui(locale);
const td = t.projects.detail;
const eyebrow = String(t.nav.projects).toUpperCase();

const frames = [
  { id: 'hikaye', name: td.frames.story },
  { id: 'mekan', name: td.frames.spaces },
  { id: 'kunye', name: td.frames.dossier },
];
---

<section class="pds" data-pd-stage data-testid="pd-stage">
  <div class="pds-stage container-site">
      <div class="pds-spread">
        <div class="pds-left">
          <StagePhoto
            name={name}
            typeLabel={typeLabel}
            statusLabel={statusLabel}
            pendingLabel={td.pendingTag}
            cover={cover}
            coverXray={coverXray}
          />
          <div class="pds-foot">
            <span class="t-tech pds-label" data-pd-label data-testid="pd-progress">
              01 / 03 — {frames[0].name}
            </span>
            <span class="pds-nav">
              <button class="t-tech pds-btn" type="button" data-pd-prev aria-label={td.prev}>
                <span aria-hidden="true" class="rtl:-scale-x-100 inline-block">←</span>
                {td.prevShort}
              </button>
              <button class="t-tech pds-btn" type="button" data-pd-next aria-label={td.next}>
                {td.nextShort}
                <span aria-hidden="true" class="rtl:-scale-x-100 inline-block">→</span>
              </button>
            </span>
          </div>
        </div>

        <div class="pds-window">
          <div class="pds-track" data-testid="pd-track">
            <article class="pds-frame" data-name={frames[0].name} data-testid="pd-frame-hikaye">
              <FrameStory
                name={name}
                statusLabel={statusLabel}
                eyebrow={eyebrow}
                t={td.story}
                brand={td.brand}
                salon={imgs.salon}
                malzeme={imgs.malzeme}
              />
            </article>
            <article class="pds-frame" data-name={frames[1].name} data-testid="pd-frame-mekan">
              <FrameSpaces
                typeLabel={typeLabel}
                statusLabel={statusLabel}
                t={td.spaces}
                samples={td.samples}
                cephe={imgs.cephe}
                mutfak={imgs.mutfak}
                salon={imgs.salon}
                vaziyet={imgs.vaziyet}
              />
            </article>
            <article class="pds-frame" data-name={frames[2].name} data-testid="pd-frame-kunye">
              <FrameDossier
                typeLabel={typeLabel}
                statusLabel={statusLabel}
                t={td.dossier}
                samples={td.samples}
                brand={td.brand}
                ctaHref={localePath(locale, '/iletisim')}
                izometrik={imgs.izometrik}
                dokular={imgs.dokular}
              />
            </article>
          </div>
        </div>
      </div>
  </div>
</section>

<!-- Dürüstlük dipnotu: örnek/temsilî değerlerin TEK açıklaması -->
<div class="container-site">
  <p class="t-caption pds-note" data-testid="pd-note">{td.samplesNote}</p>
</div>

<style>
  /* ---- Varsayılan: dikey yığın (dar ekran / no-JS) ---- */
  .pds-spread {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .pds-stage { padding-block: clamp(1.5rem, 4vh, 2.5rem); }
  /* Yığın modunda 3:4 foto tam konteyneri kaplamasın (no-JS masaüstü) */
  .pds-left { display: grid; gap: 0.65rem; align-content: start; min-width: 0; max-width: 32rem; }
  .pds-live .pds-left { max-width: none; }
  .pds-foot { display: none; }
  .pds-track {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .pds-frame { min-width: 0; }
  .pds-note {
    color: var(--color-graphite-400);
    max-width: 62ch;
    margin-block: 0.5rem 0;
  }

  /* ---- Adımlı mod (JS + ≥1024 → .pds-live): tek kare + düğmeler ---- */
  .pds-live .pds-spread {
    /* B ölçüsü: sahne yüksekliği; foto 3:4 kalır (ilerleme satırı payı düşülür) */
    --pds-h: clamp(30rem, 38vw, 34rem);
    --pds-foot: 3rem;
    grid-template-columns: calc((var(--pds-h) - var(--pds-foot)) * 3 / 4) minmax(0, 1fr);
    grid-template-rows: var(--pds-h);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: stretch;
  }
  .pds-live .pds-left {
    grid-template-rows: minmax(0, 1fr) auto;
    min-height: 0;
    height: 100%;
  }
  .pds-live .pds-window {
    overflow: hidden;
    min-width: 0;
    min-height: 0;
    height: 100%;
  }
  .pds-live .pds-track {
    flex-direction: row;
    gap: 0;
    height: 100%;
    transition: transform 420ms cubic-bezier(0.33, 1, 0.68, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .pds-live .pds-track { transition: none; }
  }
  .pds-live .pds-frame {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    /* komşu kareye sızma yok; içerik sığmazsa kare kendi içinde kaydırır */
    overflow: hidden auto;
    /* kareler arasında nefes: geçiş anında içerikler dip dibe girmez */
    padding-inline-end: clamp(2.5rem, 4vw, 4.5rem);
  }

  .pds-live .pds-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .pds-label { color: var(--color-graphite-400); }
  .pds-nav { display: inline-flex; gap: 0.5rem; }
  /* Eylem düğmeleri göze çarpar: marka kırmızısı zemin + beyaz yazı.
     Pasif uç nötr kalır — tek kırmızı, basılabilir olandır. */
  .pds-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--color-mey-red);
    border-radius: var(--radius-brand);
    color: #fff;
    background: var(--color-mey-red);
    cursor: pointer;
    transition: background-color 200ms ease-out, border-color 200ms ease-out;
  }
  .pds-btn:hover:not(:disabled) {
    background: var(--color-mey-red-700);
    border-color: var(--color-mey-red-700);
  }
  .pds-btn:disabled {
    background: transparent;
    border-color: var(--color-line);
    color: var(--color-graphite-400);
    opacity: 0.6;
    cursor: default;
  }

  /* Adımlı modda kare görselleri sabit oranı bırakıp satırı doldurur
     (yığın modunda oranlar karelerin kendi scoped stillerinden gelir). */
  .pds-live .pds-track :global(.pm-ch-media) {
    aspect-ratio: auto;
    height: 100%;
    align-self: stretch;
  }
  /* Vaziyet dar rayda kare kırpım: yatay pafta şerit gibi ezilmesin */
  .pds-live .pds-track :global(.pm-map-img) {
    aspect-ratio: 1 / 1;
    flex: none;
  }
  .pds-live .pds-track :global(.pk-iso-img) {
    aspect-ratio: auto;
  }
</style>

<script>
  const roots = document.querySelectorAll<HTMLElement>('[data-pd-stage]');

  roots.forEach((root) => {
    const track = root.querySelector<HTMLElement>('.pds-track');
    const win = root.querySelector<HTMLElement>('.pds-window');
    const label = root.querySelector<HTMLElement>('[data-pd-label]');
    const prev = root.querySelector<HTMLButtonElement>('[data-pd-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-pd-next]');
    if (!track || !win || !prev || !next) return;

    const frames = Array.from(track.children) as HTMLElement[];
    const names = frames.map((p) => p.dataset.name ?? '');
    const N = frames.length;
    const mq = matchMedia('(min-width: 1024px)');
    /* RTL'de kareler sağdan sola akar: kayma işareti döner */
    const sign = document.documentElement.dir === 'rtl' ? 1 : -1;
    let idx = 0;

    function apply() {
      const live = mq.matches;
      root.classList.toggle('pds-live', live);
      track!.style.transform = live ? `translate3d(${sign * idx * 100}%, 0, 0)` : '';
      if (label) {
        label.textContent = `${String(idx + 1).padStart(2, '0')} / ${String(N).padStart(2, '0')} — ${names[idx]}`;
      }
      prev!.disabled = idx === 0;
      next!.disabled = idx === N - 1;
      /* Görünmeyen kareler odak ve okuyucu akışından çıkar: klavye odağı
         ekran dışı karede kalamaz, pan hizası bozulamaz */
      frames.forEach((f, i) => {
        const off = live && i !== idx;
        f.toggleAttribute('inert', off);
        if (off) f.setAttribute('aria-hidden', 'true');
        else f.removeAttribute('aria-hidden');
      });
    }

    prev.addEventListener('click', () => {
      idx = Math.max(0, idx - 1);
      apply();
    });
    next.addEventListener('click', () => {
      idx = Math.min(N - 1, idx + 1);
      apply();
    });

    mq.addEventListener('change', apply);

    /* Tarayıcı, odak/scrollIntoView ile overflow:hidden pencereyi kaydırabilir —
       kayma hizasını bozar; pencerenin kendi scroll'u daima sıfırda tutulur */
    win.addEventListener('scroll', () => {
      if (win.scrollLeft !== 0) win.scrollLeft = 0;
      if (win.scrollTop !== 0) win.scrollTop = 0;
    });

    apply();
  });
</script>
