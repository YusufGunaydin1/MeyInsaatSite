---
import Base from '../layouts/Base.astro';
import { localePath } from '../lib/i18n';
import { ui } from '../lib/content';

const t = ui('tr');
---

<Base locale="tr" page="home" path="/" title="Sayfa bulunamadı — MEY İnşaat" noindex>
  <section class="container-site section-pad">
    <div class="guide-line-v ps-6 sm:ps-10 max-w-3xl">
      <p class="t-tech text-mey-red mb-4">404</p>
      <h1 class="t-display-xl">Sayfa bulunamadı.</h1>
      <p class="t-body-l mt-6">Aradığınız sayfa taşınmış veya hiç var olmamış olabilir.</p>
      <div class="mt-8">
        <a href={localePath('tr', '/')} class="btn-primary">{t.nav.home}</a>
      </div>
    </div>
  </section>
</Base>
