---
import ProjectDetailPage from '../../../features/ProjectDetailPage.astro';
import { NON_DEFAULT_LOCALES, type Locale } from '../../../lib/i18n';
import { projects } from '../../../lib/content';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.flatMap((lang) =>
    projects('tr').map((p) => ({ params: { lang, slug: p.slug } }))
  );
}

const locale = Astro.params.lang as Locale;
const { slug } = Astro.params;
---

<ProjectDetailPage locale={locale} slug={slug!} />
