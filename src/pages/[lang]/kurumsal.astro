---
import CorporatePage from '../../features/CorporatePage.astro';
import { NON_DEFAULT_LOCALES, type Locale } from '../../lib/i18n';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<CorporatePage locale={locale} />
