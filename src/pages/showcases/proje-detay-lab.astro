---
/*
  PROJE DETAY LAB — /showcases/proje-detay-lab.
  Ali detay sayfası için üç editoryal varyant (referans: sahibinin ChatGPT
  kolajları; kompozisyonlar korunur, renk/tip MEY token'larına çevrilir —
  brief §4 krem+serif+terakota görünümünü reddeder, taban concrete-050 kalır).
  Kazanan İKİ varyant, "foto solda sabit + sağ panel yatay kaydırmalı" detay
  sayfasına dönüşecek. Alıntı sesi IBM Plex Serif: superfamily içi, yalnız bu
  sayfada yüklenir; brief §6'ya girmesi onaya bağlı. noindex.

  Görsel kaynak eşlemesi (images/Buildings_Main_Images/galllery/ali → src/assets/projects):
  mutfak/banyo/salon iç mekân · izometrik aksonometri · cephe-cizim şerit ·
  vaziyet kroki · malzeme natürmort · doku-* çipleri (scratchpad sharp kırpımları).
*/
import '@fontsource/ibm-plex-serif/400.css';
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import VariantBolumler from '../../components/showcase/detay/VariantBolumler.astro';
import VariantKolaj from '../../components/showcase/detay/VariantKolaj.astro';
import VariantDosya from '../../components/showcase/detay/VariantDosya.astro';
import { project, ui } from '../../lib/content';

const t = ui('tr');
const ali = project('ali', 'tr');
const name = ali?.md?.frontmatter?.name ?? 'Ali Apartmanı';
const d = ali?.data ?? {};
const typeLabel = String(t.projects.types?.[d.type] ?? d.type ?? 'Konut').toUpperCase();
const statusLabel = String(t.projects.status?.[d.status] ?? d.status ?? 'Tamamlandı').toUpperCase();

const sampleNote =
  'Gri değerler (Bağcılar · 6 kat · 24 daire · 2024 · zaman çizelgesi) örnek yerleşimdir — ' +
  'MEY doğruladığında gerçek verilerle değişecek. İç mekân, aksonometri ve vaziyet görselleri temsilîdir.';
---

<Base
  locale="tr"
  page="home"
  path="/showcases/proje-detay-lab"
  title="Proje Detay Lab — Tasarım Vitrini"
  noindex
>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Proje Detay Lab"
    title="Proje Detay — 3 Varyant"
    desc={`Ali detay sayfasının sağ paneli için üç kurgu: A numaralı bölümler, B kolaj + alıntı, C teknik dosya. Kompozisyonlar referans kolajlardan; renk ve tipografi MEY token'larına çevrildi (taban krem değil concrete-050; alıntı IBM Plex Serif — superfamily içi deneme). ${sampleNote} Kazanan iki varyant, foto sabit + yatay kaydırmalı detay sayfasına dönüşecek.`}
  />

  <Specimen
    id="DETAY / A"
    name="Bölümler — 01 cephe · 02 iç mekân · 03 yaşam"
    why="Sağ panel bir dergi endeksi gibi üç numaralı bölümle okunur; her bölümün geniş bir şerit görseli var. Tekrarlanabilir içerik modeli: üç bina da aynı üç bölümü doldurur."
  >
    <VariantBolumler name={name} typeLabel={typeLabel} statusLabel={statusLabel} />
  </Specimen>

  <Specimen
    id="DETAY / B"
    name="Kolaj — hikâye + alıntı + bindirmeli görseller"
    why="En editoryal ses: orta sütunda kısa hikâye ve büyük serif alıntı, sağda iki bindirmeli görsel. Az veriyle bile dolu ve dengeli durur — bilgi eksikken en dayanıklı kurgu."
  >
    <VariantKolaj name={name} typeLabel={typeLabel} statusLabel={statusLabel} />
  </Specimen>

  <Specimen
    id="DETAY / C"
    name="Dosya — teknik pafta: özet · zaman çizelgesi · aksonometri · vaziyet · malzeme"
    why="Künye bir teknik paftaya basılır: mono özet, kırmızı raylı zaman çizelgesi, aksonometrik çizim, vaziyet krokisi ve malzeme paleti. 'Çizdiğimizi inşa ederiz' iddiasının sayfa hâli — en yüksek bilgi yoğunluğu."
  >
    <VariantDosya name={name} typeLabel={typeLabel} statusLabel={statusLabel} />
  </Specimen>
</Base>
