---
/*
  İLETİŞİM / CTA LAB — /showcases/cta-lab. Ana sayfa iletişim/çağrı bölümü için
  3 varyant. İletişim bilgileri henüz yok → dürüst "[Bilgi bekleniyor]"
  placeholder'ları (üretimdeki disiplinle aynı). noindex.
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import { Image } from 'astro:assets';
import redLines from '../../assets/showcase/minimal-red-architectural-lines.webp';

const channels = [
  { label: 'TELEFON', value: '[Bilgi bekleniyor]' },
  { label: 'WHATSAPP', value: '[Bilgi bekleniyor]' },
  { label: 'E-POSTA', value: '[Bilgi bekleniyor]' },
];
---

<Base locale="tr" page="home" path="/showcases/cta-lab" title="İletişim Lab — Tasarım Vitrini" noindex>
  <LabIntro
    kicker="MEY İnşaat · Dahili · İletişim Lab"
    title="İletişim / CTA — Tasarım Varyantları"
    desc="Ana sayfayı iletişime bağlayan son bölüm için 3 varyant. İletişim bilgileri geldiğinde placeholder'lar gerçek numaralarla değişir."
  />

  <!-- A — dark theatre CTA over the brand red lines -->
  <Specimen
    id="İLETİŞİM / A"
    name="Koyu çağrı — kırmızı çizgi zemin"
    why="Markanın kırmızı mimari çizgileri koyu zeminde; büyük Oswald çağrı + kanal satırı + kırmızı CTA. Sayfayı güçlü kapatır."
  >
    <section class="theatre blueprint-grid cta-a">
      <Image src={redLines} alt="" aria-hidden="true" widths={[768, 1280, 1600]} sizes="100vw" class="cta-a-bg" />
      <div class="cta-a-scrim" aria-hidden="true"></div>
      <div class="container-site cta-a-inner">
        <p class="t-tech" style="color: var(--color-red-on-dark);">05 — İLETİŞİM</p>
        <h2 class="t-display-l mt-2" style="color:#fff;">Projenizi konuşalım.</h2>
        <p class="t-body-l mt-4 max-w-xl" style="color: rgb(244 244 242 / 0.82);">Arsanız ya da projeniz için, 23 yıllık MEY Grubu güvencesiyle baştan sona tek elden.</p>
        <div class="cta-a-channels">
          {channels.map((c) => (
            <div class="cta-a-ch">
              <span class="t-tech cta-a-ch-l">{c.label}</span>
              <span class="t-tech cta-a-ch-v">{c.value}</span>
            </div>
          ))}
        </div>
        <div class="cta-a-actions">
          <a href="/iletisim" class="btn-primary">İletişim <span aria-hidden="true">→</span></a>
          <a href="/projeler" class="btn-ghost">Projeleri gör</a>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- B — split statement + channel cards -->
  <Specimen
    id="İLETİŞİM / B"
    name="Bölünmüş — ifade + kanal kartları"
    why="Solda guide-line'lı çağrı, sağda telefon/WhatsApp/e-posta kartları. İşlevsel ve net; kanalları öne çıkarır."
  >
    <section class="container-site section-pad">
      <div class="cta-b">
        <div class="cta-b-copy guide-line-v">
          <p class="t-tech text-mey-red">05 — İLETİŞİM</p>
          <h2 class="t-display-l mt-2">Projeleriniz için konuşalım</h2>
          <p class="t-body-l mt-4 max-w-sm text-graphite-600">Telefon, WhatsApp veya e-posta ile doğrudan ulaşın.</p>
          <a href="/iletisim" class="btn-primary mt-6">İletişim <span aria-hidden="true">→</span></a>
        </div>
        <ul class="cta-b-list">
          {channels.map((c) => (
            <li class="cta-b-card">
              <span class="t-tech cta-b-l">{c.label}</span>
              <span class="cta-b-v">{c.value}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </Specimen>

  <!-- C — big statement band -->
  <Specimen
    id="İLETİŞİM / C"
    name="Büyük ifade bandı — tipografik"
    why="Dev Oswald 'KONUŞALIM.' + mono kanal satırı; sakin açık zeminde tek güçlü tipografik jest."
  >
    <section class="bg-concrete-100 border-y border-line section-pad">
      <div class="container-site cta-c">
        <div class="cta-c-head">
          <p class="t-tech text-mey-red">05 — İLETİŞİM</p>
          <h2 class="cta-c-big">KONUŞALIM.</h2>
        </div>
        <div class="cta-c-side">
          <p class="t-body text-graphite-600 max-w-xs">Projeleriniz için doğrudan ulaşın — MEY Grubu güvencesiyle.</p>
          <ul class="cta-c-channels">
            {channels.map((c) => (
              <li class="cta-c-ch"><span class="t-tech text-graphite-400">{c.label}</span><span class="t-tech cta-c-v">{c.value}</span></li>
            ))}
          </ul>
          <a href="/iletisim" class="btn-primary mt-2">İletişim <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>
  </Specimen>
</Base>

<style>
  /* A — dark CTA */
  .cta-a { position: relative; overflow: hidden; min-height: min(56svh, 480px); display: flex; align-items: center; padding-block: clamp(3rem, 8vh, 5.5rem); }
  .cta-a-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5; }
  .cta-a-scrim { position: absolute; inset: 0; background: linear-gradient(to right, rgb(14 15 17 / 0.92) 0%, rgb(14 15 17 / 0.7) 50%, rgb(14 15 17 / 0.45) 100%); }
  .cta-a-inner { position: relative; }
  .cta-a-channels { display: flex; flex-wrap: wrap; gap: 1.75rem; margin-top: 1.75rem; }
  .cta-a-ch { display: flex; flex-direction: column; gap: 0.25rem; }
  .cta-a-ch-l { color: var(--color-mey-teal); }
  .cta-a-ch-v { color: rgb(244 244 242 / 0.85); text-transform: none; }
  .cta-a-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }

  /* B — split */
  .cta-b { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  @media (min-width: 900px) { .cta-b { grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center; } }
  .cta-b-copy { padding-inline-start: 1.5rem; }
  .cta-b-list { list-style: none; display: grid; gap: 1px; background: var(--color-line); border: 1px solid var(--color-line); border-radius: var(--radius-brand); overflow: hidden; }
  .cta-b-card { background: #fff; padding: 1.25rem 1.4rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .cta-b-l { color: var(--color-graphite-400); }
  .cta-b-v { font-family: var(--font-display); font-weight: 600; font-size: 1.25rem; letter-spacing: 0.01em; color: var(--color-graphite-900); }

  /* C — big statement */
  .cta-c { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: end; }
  @media (min-width: 900px) { .cta-c { grid-template-columns: 1.4fr 0.6fr; gap: 3rem; } }
  .cta-c-big { font-family: var(--font-display); font-weight: 700; font-size: clamp(3.5rem, 12vw, 9rem); line-height: 0.9; letter-spacing: 0.005em; text-transform: uppercase; color: var(--color-graphite-900); margin-top: 0.5rem; }
  .cta-c-side { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .cta-c-channels { list-style: none; display: grid; gap: 0.5rem; width: 100%; }
  .cta-c-ch { display: flex; justify-content: space-between; gap: 1rem; padding-block: 0.5rem; border-top: 1px solid var(--color-line); }
  .cta-c-v { color: var(--color-graphite-600); text-transform: none; }
</style>
