---
/*
  PROJE DETAY YATAY LAB — /showcases/proje-detay-yatay-lab.
  Seçilen yön (2026-07-11): B'nin tek-ekran formu + yatay ilerleme. Bina
  fotoğrafı solda sabit; sağ pencere üç kompakt paneli yatay tarar:
  01 HİKÂYE (kolaj) → 02 MEKÂN (bölümler + sayılar + vaziyet) → 03 KÜNYE
  (özet + zaman çizelgesi + aksonometri + malzeme + CTA). Sayfa değiştirme
  hissi yok: dikey scroll iğneli sahnede yatay pan'a çevrilir (imza bölümüyle
  aynı "scroll = ilerleme" dili); ok düğmeleri ve klavye odağı kareye atlar.
  Mobil / prefers-reduced-motion / no-JS → paneller dikey yığın. noindex.
*/
import '@fontsource/ibm-plex-serif/400.css';
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import YatayDetay from '../../components/showcase/detay/yatay/YatayDetay.astro';
import { project, ui } from '../../lib/content';

const t = ui('tr');
const ali = project('ali', 'tr');
const name = ali?.md?.frontmatter?.name ?? 'Ali Apartmanı';
const d = ali?.data ?? {};
const typeLabel = String(t.projects.types?.[d.type] ?? d.type ?? 'Konut').toUpperCase();
const statusLabel = String(t.projects.status?.[d.status] ?? d.status ?? 'Tamamlandı').toUpperCase();
---

<Base
  locale="tr"
  page="home"
  path="/showcases/proje-detay-yatay-lab"
  title="Proje Detay Yatay Lab — Tasarım Vitrini"
  noindex
>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Proje Detay Yatay Lab"
    title="Proje Detay — Yatay Kurgu"
    desc="Sahne, B varyantının SAYFA ÖLÇÜSÜNDE: mütevazı 3:4 foto solda hiç değişmez, sağ pencere dikey scroll ile YATAY akar (01 hikâye → 02 mekân → 03 künye) — tam-ekran tiyatro değil. Sayfa değişiyor hissi yok; ok düğmeleri kareden kareye atlar. Mobil, reduced-motion ve JS'siz durumda paneller alt alta düşer. Gri değerler (Bağcılar · 6 kat · 24 daire · 2024 · zaman çizelgesi) örnek yerleşimdir; iç mekân, aksonometri ve vaziyet görselleri temsilîdir. Alıntı IBM Plex Serif — superfamily içi deneme, brief §6 onayı bekliyor."
  />

  <Specimen
    id="DETAY / YATAY"
    name="Tek ekran × 3 kare — foto sabit, panel sağa akar"
    why="B'nin tek-ekran dengesi korunur, derinlik dikeyde değil yatayda büyür: kaydırdıkça bina yerinde durur, hikâye → mekân → künye kareleri akar. Ziyaretçi sayfa değiştirmez; binanın etrafında döner gibi okur."
  >
    <YatayDetay name={name} typeLabel={typeLabel} statusLabel={statusLabel} />
  </Specimen>
</Base>
