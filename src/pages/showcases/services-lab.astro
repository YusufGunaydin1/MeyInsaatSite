---
/*
  HİZMETLER LAB — /showcases/services-lab. Ana sayfa "Ne yapıyoruz" bölümü için
  3 varyant; biri MEY'in kendi 3D ikon setiyle (beyaz zeminli, beyaz kartlarda
  kaynaşır). Paylaşılan chrome + gerçek token'lar. noindex.
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import { Image } from 'astro:assets';
import icon1 from '../../assets/showcase/icon-1.webp';
import icon2 from '../../assets/showcase/icon-2.webp';
import icon3 from '../../assets/showcase/icon-3.webp';
import icon4 from '../../assets/showcase/icon-4.webp';
import icon5 from '../../assets/showcase/icon-5.webp';
import icon6 from '../../assets/showcase/icon-6.webp';

const services = [
  { idx: '01', icon: icon3, name: 'Kaba İnşaat', desc: 'Betonarme taşıyıcı sistem — temelden çatıya sağlam yapı.' },
  { idx: '02', icon: icon4, name: 'Cephe & Mimari', desc: 'Modern, dayanıklı cephe ve mimari detay uygulaması.' },
  { idx: '03', icon: icon6, name: 'Proje & Ruhsat', desc: 'Projelendirme, ruhsat ve saha yönetimi tek elden.' },
  { idx: '04', icon: icon5, name: 'Kentsel Dönüşüm', desc: 'Riskli yapıdan modern, güvenli konuta dönüşüm.' },
  { idx: '05', icon: icon1, name: 'Konut Projeleri', desc: 'Aileler için modern, huzurla yaşanacak konutlar.' },
  { idx: '06', icon: icon2, name: 'Anahtar Teslim', desc: 'Arsadan anahtara kadar baştan sona tek elden.' },
];
---

<Base locale="tr" page="home" path="/showcases/services-lab" title="Hizmetler Lab — Tasarım Vitrini" noindex>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Hizmetler Lab"
    title="Hizmetler — Tasarım Varyantları"
    desc="Ana sayfa 'Ne yapıyoruz' bölümü için 3 varyant. Biri MEY'in kendi 3D ikon setini kullanır (henüz sitede kullanılmıyor)."
  />

  <!-- A — 3D icon cards -->
  <Specimen
    id="HİZMETLER / A"
    name="3D ikon kartları — marka ikon seti"
    why="MEY'in özel 3D ikonları (kırmızı+teal) beyaz kartlarda; hizmetleri sıcak ve tanınır kılar. Marka ikon setini sahneye çıkarır."
  >
    <section class="container-site section-pad">
      <p class="t-tech text-mey-red">03 — HİZMETLER</p>
      <h2 class="t-display-l mt-2 mb-8">Ne yapıyoruz</h2>
      <div class="sv-a">
        {services.map((s) => (
          <div class="sv-a-card">
            <span class="sv-a-icon"><Image src={s.icon} alt="" aria-hidden="true" widths={[160, 320]} sizes="120px" class="sv-a-icon-img" /></span>
            <div>
              <h3 class="t-heading-s">{s.name}</h3>
              <p class="t-caption text-graphite-600 mt-1">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  </Specimen>

  <!-- B — numbered process rail with a red connecting guide-line -->
  <Specimen
    id="HİZMETLER / B"
    name="Numaralı süreç rayı — kırmızı guide-line"
    why="Mono numaralar bir kırmızı su-terazisi çizgisiyle bağlanır; hizmeti bir inşaat sürecinin adımları gibi okutur. Brief §7 yapısal motifi."
  >
    <section class="bg-concrete-100 border-y border-line">
      <div class="container-site section-pad">
        <p class="t-tech text-mey-red">03 — HİZMETLER</p>
        <h2 class="t-display-l mt-2 mb-10">Baştan sona tek elden</h2>
        <ol class="sv-b">
          {services.map((s) => (
            <li class="sv-b-step">
              <span class="t-tech sv-b-no">{s.idx}</span>
              <h3 class="t-heading-s sv-b-name">{s.name}</h3>
              <p class="t-caption text-graphite-600 mt-1">{s.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>
  </Specimen>

  <!-- C — split: sticky heading + editorial list -->
  <Specimen
    id="HİZMETLER / C"
    name="Bölünmüş liste — editoryal"
    why="Solda sabit başlık + guide-line, sağda mono endeksli hizmet listesi; hover'da kırmızıya döner. Tip öne çıkar, sakin ve kurumsal."
  >
    <section class="container-site section-pad">
      <div class="sv-c">
        <div class="sv-c-head guide-line-v">
          <p class="t-tech text-mey-red">03 — HİZMETLER</p>
          <h2 class="t-display-l mt-2">Ne yapıyoruz</h2>
          <p class="t-body mt-4 max-w-xs text-graphite-600">Arsa değerlendirmeden anahtar teslime, konut projelerini baştan sona yürütürüz.</p>
        </div>
        <ul class="sv-c-list">
          {services.map((s) => (
            <li class="sv-c-row">
              <span class="t-tech sv-c-idx">{s.idx}</span>
              <div>
                <h3 class="sv-c-name">{s.name}</h3>
                <p class="t-caption text-graphite-600 mt-1">{s.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </Specimen>
</Base>

<style>
  /* A — icon cards (icons carry a white bg → white cards blend) */
  .sv-a { display: grid; gap: 1px; background: var(--color-line); border: 1px solid var(--color-line); border-radius: var(--radius-brand); overflow: hidden; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .sv-a { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .sv-a { grid-template-columns: repeat(3, 1fr); } }
  .sv-a-card { background: #fff; padding: 1.5rem; display: flex; gap: 1rem; align-items: flex-start; }
  .sv-a-icon { flex: none; width: 76px; height: 76px; }
  .sv-a-icon-img { width: 100%; height: 100%; object-fit: contain; display: block; }

  /* B — numbered rail with red connecting line */
  .sv-b { display: grid; grid-template-columns: 1fr; gap: 2rem; position: relative; list-style: none; }
  .sv-b-step { position: relative; padding-inline-start: 3.25rem; }
  .sv-b-no { display: inline-flex; align-items: center; justify-content: center; position: absolute; inset-inline-start: 0; top: 0; width: 2.25rem; height: 2.25rem; background: #fff; border: 1px solid var(--color-mey-red); color: var(--color-mey-red); border-radius: var(--radius-brand); }
  .sv-b-name { color: var(--color-graphite-900); }
  /* vertical connector on mobile */
  .sv-b::before { content: ""; position: absolute; inset-inline-start: calc(1.125rem - 0.5px); top: 1.5rem; bottom: 1.5rem; width: 1px; background: var(--color-mey-red); opacity: 0.4; }
  @media (min-width: 900px) {
    .sv-b { grid-template-columns: repeat(3, 1fr); gap: 2.5rem 2rem; }
    .sv-b-step { padding-inline-start: 0; padding-top: 3.25rem; }
    .sv-b-no { top: 0; }
    /* horizontal connector across each row of 3 */
    .sv-b::before { inset-inline: 1.125rem; top: calc(1.125rem - 0.5px); bottom: auto; left: 1.125rem; right: 1.125rem; width: auto; height: 1px; }
  }

  /* C — split editorial list */
  .sv-c { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  @media (min-width: 900px) { .sv-c { grid-template-columns: 0.8fr 1.2fr; gap: 4rem; align-items: start; } .sv-c-head { position: sticky; top: 6rem; } }
  .sv-c-head { padding-inline-start: 1.5rem; }
  .sv-c-list { list-style: none; }
  .sv-c-row { display: grid; grid-template-columns: auto 1fr; gap: 1.25rem; padding-block: 1.25rem; border-top: 1px solid var(--color-line); }
  .sv-c-row:first-child { border-top: 0; }
  .sv-c-idx { color: var(--color-mey-red); padding-top: 0.35rem; }
  .sv-c-name { font-family: var(--font-display); font-weight: 600; font-size: 1.35rem; letter-spacing: 0.01em; text-transform: uppercase; color: var(--color-graphite-900); transition: color 200ms ease-out; }
  .sv-c-row:hover .sv-c-name { color: var(--color-mey-red); }
</style>
