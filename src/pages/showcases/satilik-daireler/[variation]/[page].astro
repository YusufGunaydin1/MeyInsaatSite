---
import ApartmentDetail from '../../../../components/showcase/satilik-daireler/ApartmentDetail.astro';
import ApartmentsOverview from '../../../../components/showcase/satilik-daireler/ApartmentsOverview.astro';
import BuildingStory from '../../../../components/showcase/satilik-daireler/BuildingStory.astro';
import CuratedGallery from '../../../../components/showcase/satilik-daireler/CuratedGallery.astro';
import SaleChrome from '../../../../components/showcase/satilik-daireler/SaleChrome.astro';
import SaleLayout from '../../../../components/showcase/satilik-daireler/SaleLayout.astro';
import ViewingRequest from '../../../../components/showcase/satilik-daireler/ViewingRequest.astro';
import {
  nestedPageSlugs,
  saleContent,
  variationSlugs,
  variations,
  type NestedPageSlug,
  type VariationSlug,
} from '../../../../components/showcase/satilik-daireler/data';

export function getStaticPaths() {
  return variationSlugs.flatMap((variation) =>
    nestedPageSlugs.map((page) => ({ params: { variation, page }, props: { variation, page } }))
  );
}

interface Props {
  variation: VariationSlug;
  page: NestedPageSlug;
}

const { variation, page } = Astro.props;
const variant = variations[variation];
const pageTitles: Record<NestedPageSlug, string> = {
  daireler: 'Daireler',
  'daire-1': 'Daire 1',
  'daire-2': 'Daire 2',
  'el-ele-apartmani': 'El Ele Apartmanı',
  galeri: 'Galeri',
  iletisim: 'Görüşme Talebi',
};
const themeColors: Record<VariationSlug, string> = {
  editoryal: '#f4f1eb',
  mimari: '#f3f3f0',
  monolit: '#111311',
};
---

<SaleLayout
  title={`${pageTitles[page]} · ${variant.name} · ${saleContent.project.name}`}
  description={`${pageTitles[page]} — ${saleContent.meta.description}`}
  themeColor={themeColors[variation]}
>
  <SaleChrome variation={variation} currentPage={page} hideStickyCta={page === 'iletisim' || page === 'galeri'}>
    {page === 'daireler' && <ApartmentsOverview variation={variation} />}
    {page === 'daire-1' && <ApartmentDetail variation={variation} apartmentSlug="daire-1" />}
    {page === 'daire-2' && <ApartmentDetail variation={variation} apartmentSlug="daire-2" />}
    {page === 'el-ele-apartmani' && <BuildingStory variation={variation} />}
    {page === 'galeri' && <CuratedGallery variation={variation} />}
    {page === 'iletisim' && <ViewingRequest variation={variation} />}
  </SaleChrome>
</SaleLayout>
