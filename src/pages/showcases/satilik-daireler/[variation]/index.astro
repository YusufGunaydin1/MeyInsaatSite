---
import SaleChrome from '../../../../components/showcase/satilik-daireler/SaleChrome.astro';
import SaleHome from '../../../../components/showcase/satilik-daireler/SaleHome.astro';
import SaleLayout from '../../../../components/showcase/satilik-daireler/SaleLayout.astro';
import {
  saleContent,
  variationSlugs,
  variations,
  type VariationSlug,
} from '../../../../components/showcase/satilik-daireler/data';

export function getStaticPaths() {
  return variationSlugs.map((variation) => ({ params: { variation }, props: { variation } }));
}

interface Props { variation: VariationSlug }
const { variation } = Astro.props;
const variant = variations[variation];
const themeColors: Record<VariationSlug, string> = {
  editoryal: '#f4f1eb',
  mimari: '#f3f3f0',
  monolit: '#111311',
};
---

<SaleLayout
  title={`${variant.name} · ${saleContent.meta.title}`}
  description={`${variant.direction}: ${saleContent.meta.description}`}
  themeColor={themeColors[variation]}
>
  <SaleChrome variation={variation} currentPage="">
    <SaleHome variation={variation} />
  </SaleChrome>
</SaleLayout>

