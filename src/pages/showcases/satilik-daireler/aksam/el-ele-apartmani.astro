---
/* AKŞAM · El Ele Apartmanı — tümü koyu bina dosyası: gece sahnesinin kendisi. */
import Shell from '../../../../components/showcase/satilik/aksam/Shell.astro';
import Cover from '../../../../components/showcase/satilik/aksam/Cover.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import { building, ui } from '../../../../components/showcase/satilik/data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/aksam';
---

<Shell
  title="El Ele Apartmanı — Akşam Vitrini"
  description={building.intro}
  current="el-ele-apartmani"
>
  <section class="aks-dark aks-b-wrap" data-testid="sv-building">
    <div class="aks-container">
      <header class="aks-b-open reveal">
        <Cover imgKey={building.exterior} ratio="3/4" sizes="(min-width: 1024px) 40vw, 94vw" loading="eager" caption />
        <div class="aks-b-meta">
          <p class="t-tech aks-b-kicker">{building.eyebrow}</p>
          <h1 class="t-display-l">GECENİN SAHNESİ:<br />BİNANIN KENDİSİ</h1>
          <p class="t-body-l aks-b-lede">{building.intro}</p>
          <dl class="aks-b-facts" data-testid="sv-facts">
            {building.facts.map((f) => (
              <div class="aks-b-fact">
                <dt class="t-tech">{f.label.toUpperCase()}</dt>
                <dd>{f.pending ? <Chip onDark /> : f.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </header>

      <div class="aks-b-craft reveal">
        {building.craft.map((c, i) => (
          <article class="aks-b-craft-item">
            <p class="t-tech aks-b-craft-no">{String(i + 1).padStart(2, '0')}</p>
            <h2 class="aks-b-craft-title">{c.title}</h2>
            <p class="t-caption aks-b-craft-text">{c.text}</p>
          </article>
        ))}
      </div>

      <div class="aks-b-common reveal">
        <Cover imgKey={building.entrance} ratio="4/5" sizes="(min-width: 900px) 46vw, 94vw" caption />
        <Cover imgKey={building.parking} ratio="4/3" sizes="(min-width: 900px) 46vw, 94vw" caption />
      </div>
      <p class="t-caption aks-b-note reveal">
        Giriş karesi Mey İnşaat'ın kendi kayıt filigranını taşır. Konum ve mesafe bilgileri
        satış duyurusuyla açıklanacak.
      </p>

      <div class="aks-b-env reveal">
        {building.environment.map((k, i) => (
          <Cover
            imgKey={k}
            ratio={i === 0 ? '21/9' : '16/10'}
            sizes={i === 0 ? '(min-width: 1320px) 1280px, 96vw' : '(min-width: 900px) 46vw, 94vw'}
            class={i === 0 ? 'aks-b-env-wide' : ''}
            caption
          />
        ))}
      </div>

      <div class="aks-b-cta reveal">
        <h2 class="t-heading-m aks-b-cta-title">Sahneyi yerinde görün</h2>
        <div class="aks-b-cta-row">
          <a class="btn-primary" href={`${root}/iletisim`} data-testid="sv-cta-randevu">{ui.cta.randevu}</a>
          <a class="btn-ghost" href={`${root}/daireler`}>{ui.cta.daireleri}</a>
          <a class="btn-ghost" href={`${root}/galeri?bolum=bina`}>{ui.cta.fotograflar}</a>
        </div>
      </div>
    </div>
  </section>
</Shell>

<style>
  .aks-b-wrap { padding-block: clamp(2rem, 5vh, 3.4rem); }
  .aks-b-open { display: grid; gap: 1.8rem; }
  @media (min-width: 1024px) { .aks-b-open { grid-template-columns: 5fr 7fr; gap: clamp(2rem, 4vw, 3.6rem); align-items: center; } }
  .aks-b-kicker { color: var(--color-red-on-dark); }
  .aks-b-meta h1 { margin-top: 0.5rem; }
  .aks-b-lede { margin-top: 0.9rem; color: rgb(244 244 242 / 0.78); max-width: 58ch; }
  .aks-b-facts {
    margin-top: 1.3rem;
    padding-top: 1rem;
    border-top: 1px solid rgb(255 255 255 / 0.12);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.9rem 1.4rem;
  }
  .aks-b-fact dt { color: rgb(244 244 242 / 0.5); }
  .aks-b-fact dd { margin-top: 0.3rem; color: #fff; font-weight: 500; font-size: 0.9375rem; }

  .aks-b-craft {
    margin-top: clamp(2.4rem, 6vh, 4rem);
    display: grid;
    gap: 1.4rem;
  }
  @media (min-width: 900px) { .aks-b-craft { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.8rem; } }
  .aks-b-craft-item {
    background: var(--color-night-800);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-brand);
    padding: 1.1rem 1.2rem;
  }
  .aks-b-craft-no { color: var(--color-red-on-dark); }
  .aks-b-craft-title { font-family: var(--font-display); font-weight: 600; font-size: 1.2rem; color: #fff; margin-top: 0.4rem; }
  .aks-b-craft-text { color: rgb(244 244 242 / 0.68); margin-top: 0.45rem; }

  .aks-b-common { margin-top: clamp(2.4rem, 6vh, 4rem); display: grid; gap: 1.2rem; }
  @media (min-width: 800px) { .aks-b-common { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .aks-b-note { margin-top: 0.8rem; color: rgb(244 244 242 / 0.55); }

  .aks-b-env { margin-top: clamp(2.4rem, 6vh, 4rem); display: grid; gap: 1.2rem; }
  @media (min-width: 800px) {
    .aks-b-env { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .aks-b-env :global(.aks-b-env-wide) { grid-column: 1 / -1; }
  }

  .aks-b-cta { margin-top: clamp(2.4rem, 6vh, 4rem); text-align: center; display: grid; justify-items: center; gap: 0.9rem; }
  .aks-b-cta-title { color: #fff; }
  .aks-b-cta-row { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-content: center; }
</style>
