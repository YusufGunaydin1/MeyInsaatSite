---
/* AKŞAM · Giriş — koyu sahne + ışıklı fotoğraf: özel akşam gösterimi duygusu. */
import { Image } from 'astro:assets';
import Shell from '../../../../components/showcase/satilik/aksam/Shell.astro';
import Cover from '../../../../components/showcase/satilik/aksam/Cover.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import { shot } from '../../../../components/showcase/satilik/media';
import { apartments, building, ui } from '../../../../components/showcase/satilik/data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/aksam';
const hero = shot('daire-1/d1-teras-1.png');
const bina = shot(building.exterior);
---

<Shell
  title="El Ele Apartmanı — Akşam Vitrini"
  description="Müteahhitten sıfır 3+2 dubleks iki daire; akşam gösterimi tadında premium vitrin."
  current=""
>
  <section class="aks-hero theatre">
    <Image
      src={hero.img}
      alt={hero.alt}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      class="aks-hero-img"
    />
    <div class="aks-hero-scrim" aria-hidden="true"></div>
    <div class="aks-container aks-hero-text">
      <p class="t-tech aks-hero-kicker">{ui.kicker.toUpperCase()}</p>
      <h1 class="t-display-xl aks-hero-title">AKŞAM IŞIĞINDA<br />İKİ EV</h1>
      <p class="t-body-l aks-hero-lede">
        El Ele Apartmanı'ndaki iki 3+2 dubleks, aracı olmadan yapımcısından satın alınıyor.
        Vitrin ışığı fotoğraflardan; gerisi sessiz.
      </p>
      <div class="aks-hero-cta">
        <a class="btn-primary" href={`${root}/daireler`} data-testid="sv-cta-daireler">{ui.cta.daireleri}</a>
        <a class="btn-ghost" href={`${root}/el-ele-apartmani`}>{ui.cta.bina}</a>
      </div>
    </div>
  </section>

  <section class="aks-light">
    <div class="aks-container aks-strip reveal">
      <p class="t-tech"><span class="aks-strip-num">2</span> DAİRE</p>
      <p class="t-tech"><span class="aks-strip-num">3+2</span> ODA DÜZENİ</p>
      <p class="t-tech"><span class="aks-strip-num">2</span> KAT — DUBLEKS</p>
      <p class="t-tech aks-strip-source">DOĞRUDAN MÜTEAHHİTTEN</p>
    </div>
  </section>

  <section class="aks-dark aks-duo-wrap">
    <div class="aks-container">
      <p class="t-tech aks-sec-kicker reveal">VİTRİN · İKİ PANEL</p>
      <div class="aks-duo reveal" data-testid="sv-duo">
        {apartments.map((apt) => (
          <a class="aks-panel" href={`${root}/${apt.id}`} data-testid={`sv-open-${apt.id}`}>
            <Cover imgKey={apt.lead} ratio="4/5" sizes="(min-width: 900px) 46vw, 94vw" />
            <div class="aks-panel-meta">
              <p class="t-tech aks-panel-no">{apt.no} — {apt.tagline.toUpperCase()}</p>
              <h2 class="aks-panel-name">{apt.name}</h2>
              <p class="t-caption aks-panel-hook">{apt.hook}</p>
              <span class="t-tech aks-panel-open">{(apt.id === 'daire-1' ? ui.cta.daire1 : ui.cta.daire2).toUpperCase()} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="aks-light">
    <div class="aks-container aks-bina reveal">
      <figure class="aks-bina-fig">
        <Image src={bina.img} alt={bina.alt} widths={[480, 800]} sizes="(min-width: 1024px) 34vw, 94vw" />
      </figure>
      <div>
        <p class="t-tech aks-sec-kicker-light">{building.eyebrow}</p>
        <h2 class="t-display-l">Yapan da satan da aynı el</h2>
        <p class="t-body-l aks-bina-lede">{building.intro}</p>
        <ul class="aks-bina-facts" data-testid="sv-facts">
          {building.facts.slice(0, 4).map((f) => (
            <li class="aks-bina-fact">
              <span class="t-tech">{f.label.toUpperCase()}</span>
              {f.pending ? <Chip /> : <strong>{f.value}</strong>}
            </li>
          ))}
        </ul>
        <a class="btn-ghost aks-bina-btn" href={`${root}/el-ele-apartmani`}>{ui.cta.bina}</a>
      </div>
    </div>
  </section>

  <section class="aks-dark">
    <div class="aks-container aks-env reveal">
      <p class="t-tech aks-sec-kicker">ÇEVRE</p>
      <Cover imgKey="daire-1/cevre-manzara.png" ratio="21/9" sizes="(min-width: 1320px) 1280px, 96vw" caption />
      <div class="aks-env-row">
        <p class="t-caption aks-env-note">
          Kıyı şeridi ve sahil parkı, dosyadaki çevre karelerinden; konum bilgisi satış
          duyurusuyla açıklanacak.
        </p>
        <a class="t-tech aks-env-link" href={`${root}/galeri?bolum=cevre`} data-testid="sv-cta-galeri">
          {ui.cta.fotograflar.toUpperCase()} →
        </a>
      </div>
    </div>
  </section>

  <section class="aks-dark aks-final theatre blueprint-grid">
    <div class="aks-container aks-final-inner reveal">
      <h2 class="t-display-l">Perde akşam açılır</h2>
      <p class="t-body-l aks-final-text">
        İki daire de randevuyla, size uyan saatte gezdirilir — dilerseniz gün batımında.
      </p>
      <div class="aks-hero-cta">
        <a class="btn-primary" href={`${root}/iletisim`} data-testid="sv-cta-randevu">{ui.cta.randevu}</a>
        <a class="btn-ghost" href={`${root}/iletisim`}>{ui.cta.gorus}</a>
      </div>
    </div>
  </section>
</Shell>

<style>
  /* Hero */
  .aks-hero { position: relative; min-height: min(78dvh, 760px); display: flex; align-items: flex-end; }
  .aks-hero :global(.aks-hero-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .aks-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgb(14 15 17 / 0.94) 0%, rgb(14 15 17 / 0.62) 45%, rgb(14 15 17 / 0.2) 100%);
  }
  .aks-hero-text { position: relative; padding-block: clamp(2rem, 6vh, 4rem); max-width: 1320px; width: 100%; }
  .aks-hero-kicker { color: var(--color-red-on-dark); }
  .aks-hero-title { color: #fff; margin-top: 0.6rem; }
  .aks-hero-lede { margin-top: 1rem; max-width: 54ch; color: rgb(244 244 242 / 0.85); }
  .aks-hero-cta { margin-top: 1.5rem; display: flex; gap: 0.9rem; flex-wrap: wrap; }

  /* Sayaç şeridi */
  .aks-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 2.4rem;
    padding-block: 1.1rem;
    color: var(--color-graphite-400);
    border-bottom: 1px solid var(--color-line);
  }
  .aks-strip-num { color: var(--color-mey-red); font-size: 1.05rem; }
  .aks-strip-source { margin-inline-start: auto; color: var(--color-mey-teal-700); }

  /* İki panel */
  .aks-duo-wrap { padding-block: clamp(2.2rem, 6vh, 4rem); }
  .aks-sec-kicker { color: var(--color-mey-teal); }
  .aks-sec-kicker-light { color: var(--color-mey-teal-700); }
  .aks-duo { margin-top: 1.2rem; display: grid; gap: 1.4rem; }
  @media (min-width: 900px) { .aks-duo { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1.8rem; } }
  .aks-panel { display: block; }
  .aks-panel :global(.aks-cover img) { transition: transform 400ms ease-out; }
  .aks-panel:hover :global(.aks-cover img) { transform: scale(1.02); }
  .aks-panel-meta { padding-top: 0.9rem; }
  .aks-panel-no { color: var(--color-red-on-dark); }
  .aks-panel-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: #fff;
    margin-top: 0.3rem;
  }
  .aks-panel-hook { color: rgb(244 244 242 / 0.7); margin-top: 0.4rem; max-width: 46ch; }
  .aks-panel-open { display: inline-block; margin-top: 0.7rem; color: var(--color-mey-teal); }
  .aks-panel:hover .aks-panel-open { color: #fff; }

  /* Bina bandı (ışık) */
  .aks-bina { padding-block: clamp(2.4rem, 6vh, 4.2rem); display: grid; gap: 1.8rem; }
  @media (min-width: 1024px) { .aks-bina { grid-template-columns: 4fr 7fr; gap: clamp(2rem, 4vw, 3.4rem); align-items: center; } }
  .aks-bina-fig { border: 1px solid var(--color-line); border-radius: var(--radius-brand); overflow: hidden; }
  .aks-bina-fig :global(img) { display: block; width: 100%; height: auto; }
  .aks-bina h2 { margin-top: 0.5rem; }
  .aks-bina-lede { margin-top: 0.9rem; max-width: 58ch; }
  .aks-bina-facts { margin-top: 1.2rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.9rem 1.4rem; }
  .aks-bina-fact { display: grid; gap: 0.3rem; color: var(--color-graphite-400); }
  .aks-bina-fact strong { color: var(--color-graphite-900); font-weight: 500; }
  .aks-bina-btn { margin-top: 1.3rem; }

  /* Çevre bandı */
  .aks-env { padding-block: clamp(2.2rem, 6vh, 4rem); display: grid; gap: 1rem; }
  .aks-env-row { display: flex; flex-wrap: wrap; gap: 0.8rem 2rem; align-items: baseline; justify-content: space-between; }
  .aks-env-note { color: rgb(244 244 242 / 0.65); max-width: 60ch; }
  .aks-env-link { color: var(--color-mey-teal); }
  .aks-env-link:hover { color: #fff; }

  /* Final */
  .aks-final { border-top: 1px solid rgb(255 255 255 / 0.08); }
  .aks-final-inner { padding-block: clamp(3rem, 9vh, 5.5rem); text-align: center; display: grid; justify-items: center; gap: 1rem; }
  .aks-final-text { color: rgb(244 244 242 / 0.75); max-width: 52ch; }
</style>
