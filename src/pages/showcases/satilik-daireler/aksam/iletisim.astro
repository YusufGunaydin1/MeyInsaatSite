---
/* AKŞAM · İletişim — koyu sahnede randevu formu; yapışkan çubuk bu sayfada kapalı. */
import Shell from '../../../../components/showcase/satilik/aksam/Shell.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import ViewingForm from '../../../../components/showcase/satilik/shared/ViewingForm';
import { form } from '../../../../components/showcase/satilik/data';

const channels = ['Telefon', 'WhatsApp', 'E-posta'];
---

<Shell
  title="Randevu — Akşam Vitrini"
  description="Özel gezi randevusu bırakın; Mey İnşaat tercih ettiğiniz kanaldan dönsün."
  current="iletisim"
  stickyCta={false}
>
  <section class="aks-dark aks-c-wrap">
    <div class="aks-container">
      <header class="aks-c-head reveal">
        <p class="t-tech aks-c-kicker">RANDEVU</p>
        <h1 class="t-display-l">{form.title.toUpperCase()}</h1>
        <p class="t-body-l aks-c-lede">{form.intro}</p>
      </header>

      <div class="aks-c-grid reveal">
        <div class="aks-c-form">
          <ViewingForm client:load />
        </div>
        <aside class="aks-c-side">
          <p class="t-tech aks-c-side-title">DOĞRUDAN KANALLAR</p>
          {channels.map((c) => (
            <div class="aks-c-ch">
              <span class="t-tech">{c.toUpperCase()}</span>
              <Chip onDark />
            </div>
          ))}
          <p class="t-caption aks-c-note">
            Kanal bilgileri satış duyurusuyla eklenecek. Bu vitrin sürümünde form gerçek
            veri göndermez; durumlar tasarım için canlandırılır.
          </p>
        </aside>
      </div>
    </div>
  </section>
</Shell>

<style>
  .aks-c-wrap { padding-block: clamp(2rem, 5vh, 3.4rem); }
  .aks-c-kicker { color: var(--color-red-on-dark); }
  .aks-c-head h1 { margin-top: 0.4rem; }
  .aks-c-lede { margin-top: 0.8rem; color: rgb(244 244 242 / 0.75); max-width: 64ch; }

  .aks-c-grid { margin-top: 1.8rem; display: grid; gap: 1.8rem; }
  @media (min-width: 1024px) {
    .aks-c-grid { grid-template-columns: 7fr 4fr; gap: clamp(2rem, 4vw, 3.4rem); align-items: start; }
    .aks-c-side { position: sticky; top: 5rem; }
  }
  .aks-c-form {
    background: var(--color-night-800);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-brand);
    padding: clamp(1.1rem, 2.5vw, 1.8rem);
  }
  .aks-c-side {
    background: var(--color-night-800);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-inline-start: 2px solid var(--color-red-on-dark);
    border-radius: var(--radius-brand);
    padding: 1.1rem 1.2rem;
    display: grid;
    gap: 0.9rem;
  }
  .aks-c-side-title { color: var(--color-red-on-dark); }
  .aks-c-ch { display: flex; justify-content: space-between; align-items: center; gap: 1rem; color: rgb(244 244 242 / 0.7); }
  .aks-c-note { color: rgb(244 244 242 / 0.55); }
</style>
