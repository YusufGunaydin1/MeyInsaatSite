---
/* AKŞAM · Daireler — iki vitrin paneli yan yana; kıyas düzyazıyla, listeyle değil. */
import Shell from '../../../../components/showcase/satilik/aksam/Shell.astro';
import Cover from '../../../../components/showcase/satilik/aksam/Cover.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import { apartments, ui } from '../../../../components/showcase/satilik/data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/aksam';
---

<Shell
  title="Daireler — Akşam Vitrini"
  description="El Ele Apartmanı'ndaki iki 3+2 dubleks: iki panel, iki karakter."
  current="daireler"
>
  <section class="aks-dark aks-d-wrap">
    <div class="aks-container">
      <header class="aks-d-head reveal">
        <p class="t-tech aks-d-kicker">VİTRİN</p>
        <h1 class="t-display-l">İKİ PANEL, İKİ EV</h1>
        <p class="t-body-l aks-d-lede">
          Satışta yalnız bu iki daire var. Panellerde kısa karakter; ayrıntı, her evin kendi
          sayfasında ve en doğrusu yerinde.
        </p>
      </header>

      <div class="aks-d-duo">
        {apartments.map((apt) => (
          <article class="aks-d-panel reveal" data-testid={`sv-apt-${apt.id}`}>
            <Cover imgKey={apt.lead} ratio="4/5" sizes="(min-width: 900px) 46vw, 94vw" />
            <div class="aks-d-meta">
              <p class="t-tech aks-d-no">{apt.no} — {apt.tagline.toUpperCase()}</p>
              <h2 class="aks-d-name">{apt.name}</h2>
              <p class="t-caption aks-d-hook">{apt.hook}</p>
              <ul class="aks-d-char">
                {apt.character.slice(0, 3).map((c) => (
                  <li class="t-caption">— {c}</li>
                ))}
              </ul>
              <dl class="aks-d-facts" data-testid="sv-facts">
                {apt.facts.slice(0, 4).map((f) => (
                  <div class="aks-d-fact">
                    <dt class="t-tech">{f.label.toUpperCase()}</dt>
                    <dd>{f.pending ? <Chip onDark /> : f.value}</dd>
                  </div>
                ))}
              </dl>
              <div class="aks-d-cta">
                <a class="btn-primary" href={`${root}/${apt.id}`} data-testid={`sv-open-${apt.id}`}>
                  {apt.id === 'daire-1' ? ui.cta.daire1 : ui.cta.daire2}
                </a>
                <a class="btn-ghost" href={`${root}/galeri?bolum=${apt.id}`}>{ui.cta.fotograflar}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="aks-light">
    <div class="aks-container aks-d-compare reveal">
      <h2 class="t-heading-m">Hangi panel sizin eviniz?</h2>
      <p class="t-body">
        Denizle yaşayan, terasında ufka bakan bir ev arıyorsanız Daire 1'e; çatıların
        sessizliğinde içine dönük bir düzen arıyorsanız Daire 2'ye bakın. İkisi de aynı
        binada — aynı akşam ikisini de gezebilirsiniz.
      </p>
      <a class="t-tech aks-d-compare-link" href={`${root}/iletisim`}>{ui.cta.randevu.toUpperCase()} →</a>
    </div>
  </section>
</Shell>

<style>
  .aks-d-wrap { padding-block: clamp(2rem, 5vh, 3.6rem); }
  .aks-d-kicker { color: var(--color-mey-teal); }
  .aks-d-head h1 { margin-top: 0.5rem; }
  .aks-d-lede { margin-top: 0.8rem; color: rgb(244 244 242 / 0.75); max-width: 60ch; }

  .aks-d-duo { margin-top: 1.8rem; display: grid; gap: 2rem; }
  @media (min-width: 900px) { .aks-d-duo { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 2rem; } }
  .aks-d-meta { padding-top: 1rem; }
  .aks-d-no { color: var(--color-red-on-dark); }
  .aks-d-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    color: #fff;
    margin-top: 0.3rem;
  }
  .aks-d-hook { color: rgb(244 244 242 / 0.72); margin-top: 0.5rem; }
  .aks-d-char { margin-top: 0.8rem; display: grid; gap: 0.25rem; color: rgb(244 244 242 / 0.6); }
  .aks-d-facts {
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgb(255 255 255 / 0.12);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem 1.2rem;
  }
  .aks-d-fact dt { color: rgb(244 244 242 / 0.5); }
  .aks-d-fact dd { margin-top: 0.25rem; color: #fff; font-weight: 500; font-size: 0.9375rem; }
  .aks-d-cta { margin-top: 1.2rem; display: flex; gap: 0.8rem; flex-wrap: wrap; }

  .aks-d-compare { padding-block: clamp(2rem, 5vh, 3.2rem); display: grid; gap: 0.7rem; max-width: 760px; }
  .aks-d-compare-link { color: var(--color-mey-red); }
  .aks-d-compare-link:hover { color: var(--color-mey-red-700); }
</style>
