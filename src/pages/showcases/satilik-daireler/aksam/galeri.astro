---
/* AKŞAM · Galeri — koyu sahnede küratörlü arşiv; filtre + lightbox (ada). */
import Shell from '../../../../components/showcase/satilik/aksam/Shell.astro';
import GalleryLightbox from '../../../../components/showcase/satilik/shared/GalleryLightbox';
import { lightboxItems } from '../../../../components/showcase/satilik/shared/imageVariants';
import { galleryComposition, ui } from '../../../../components/showcase/satilik/data';

const groupLabels: Record<string, string> = {
  'daire-1': 'Daire 1',
  'daire-2': 'Daire 2',
  bina: 'Bina & Ortak',
  cevre: 'Çevre',
};
const items = await lightboxItems(galleryComposition, groupLabels);
---

<Shell
  title="Galeri — Akşam Vitrini"
  description="Daire 1, Daire 2, bina ve çevre fotoğrafları — koyu sahnede."
  current="galeri"
>
  <section class="aks-dark aks-g-wrap">
    <div class="aks-container">
      <header class="aks-g-head reveal">
        <p class="t-tech aks-g-kicker">GALERİ</p>
        <h1 class="t-display-l">IŞIK, KARELERDE</h1>
        <p class="t-body-l aks-g-lede">
          Kareye dokunun; oklarla gezin, Esc ile sahneden çıkın. Filtreler daire, bina ve çevreye göre.
        </p>
      </header>
      <div class="aks-g-body reveal">
        <GalleryLightbox client:load items={items} tabs={ui.galleryTabs} />
      </div>
    </div>
  </section>
</Shell>

<style>
  .aks-g-wrap { padding-block: clamp(2rem, 5vh, 3.4rem); }
  .aks-g-kicker { color: var(--color-mey-teal); }
  .aks-g-head h1 { margin-top: 0.4rem; }
  .aks-g-lede { margin-top: 0.7rem; color: rgb(244 244 242 / 0.72); max-width: 58ch; }
  .aks-g-body { margin-top: 1.6rem; }
</style>
