---
/*
  AKŞAM · Daire 1 — ışık bandı ritmi: koyu antre → aydınlık bölüm satırları
  (metin/görsel dönüşümlü) → koyu manzara perdesi → koyu geçiş paneli.
  (Daire 2 sayfası bilerek farklı: gece kartları ızgarası.)
*/
import Shell from '../../../../components/showcase/satilik/aksam/Shell.astro';
import Cover from '../../../../components/showcase/satilik/aksam/Cover.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import { daire1 as apt, daire2, ui } from '../../../../components/showcase/satilik/data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/aksam';
const lightSections = apt.sections.filter((s) => s.id !== 'teras');
const teras = apt.sections.find((s) => s.id === 'teras')!;
---

<Shell title="Daire 1 — Akşam Vitrini" description={apt.hook} current="daire-1">
  <article data-testid="sv-detail-daire-1">
    <section class="aks-dark aks-1-head">
      <div class="aks-container reveal">
        <p class="t-tech aks-1-kicker">{apt.no} — {apt.tagline.toUpperCase()}</p>
        <h1 class="t-display-l">DAİRE 1</h1>
        <p class="t-body-l aks-1-lede">{apt.intro}</p>
        <dl class="aks-1-facts" data-testid="sv-facts">
          {apt.facts.map((f) => (
            <div class="aks-1-fact">
              <dt class="t-tech">{f.label.toUpperCase()}</dt>
              <dd>{f.pending ? <Chip onDark /> : f.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <section class="aks-light aks-1-body">
      <div class="aks-container">
        {lightSections.map((s, i) => (
          <div class:list={['aks-1-row reveal', i % 2 === 1 && 'aks-1-row-flip']} id={s.id}>
            <div class="aks-1-text">
              <p class="t-tech aks-1-row-kicker">{s.eyebrow}</p>
              <h2 class="t-heading-m">{s.title}</h2>
              <p class="t-body aks-1-row-body">{s.text}</p>
            </div>
            <div class:list={['aks-1-figs', s.keys.length > 1 && 'aks-1-figs-two']}>
              {s.keys.slice(0, s.keys.length > 3 ? 4 : s.keys.length).map((k, j) => (
                <Cover
                  imgKey={k}
                  ratio={s.keys.length === 1 ? '16/10' : j === 0 ? '4/3' : '4/3'}
                  sizes="(min-width: 1024px) 30vw, 94vw"
                  caption={j === 0}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="aks-dark aks-1-view">
      <div class="aks-container reveal">
        <p class="t-tech aks-1-view-kicker">{teras.eyebrow} — GÜNÜN SON IŞIĞI</p>
        <h2 class="t-display-l aks-1-view-title">{teras.title}</h2>
        <p class="t-body aks-1-view-text">{teras.text}</p>
        <div class="aks-1-view-figs">
          <Cover imgKey="daire-1/d1-teras-3.png" ratio="21/9" sizes="(min-width: 1320px) 1280px, 96vw" caption />
          <div class="aks-1-view-two">
            <Cover imgKey="daire-1/d1-teras-1.png" ratio="16/10" sizes="(min-width: 900px) 46vw, 94vw" />
            <Cover imgKey="daire-1/d1-teras-2.png" ratio="16/10" sizes="(min-width: 900px) 46vw, 94vw" />
          </div>
        </div>
      </div>
    </section>

    <section class="aks-dark aks-1-switch theatre blueprint-grid">
      <div class="aks-container aks-1-switch-inner reveal">
        <div>
          <p class="t-tech aks-1-switch-kicker">ÖTEKİ PANEL</p>
          <h2 class="t-heading-m aks-1-switch-title">{daire2.name} — {daire2.tagline}</h2>
        </div>
        <div class="aks-1-switch-cta">
          <a class="btn-primary" href={`${root}/iletisim?daire=daire-1`} data-testid="sv-cta-randevu">{ui.cta.randevu}</a>
          <a class="btn-ghost" href={`${root}/daire-2`} data-testid="sv-switch-daire-2">{ui.cta.daire2}</a>
          <a class="btn-ghost" href={`${root}/galeri?bolum=daire-1`}>{ui.cta.fotograflar}</a>
        </div>
      </div>
    </section>
  </article>
</Shell>

<style>
  .aks-1-head { padding-block: clamp(2rem, 5vh, 3.4rem); }
  .aks-1-kicker { color: var(--color-red-on-dark); }
  .aks-1-head h1 { margin-top: 0.4rem; }
  .aks-1-lede { margin-top: 0.9rem; color: rgb(244 244 242 / 0.78); max-width: 68ch; }
  .aks-1-facts {
    margin-top: 1.4rem;
    padding-top: 1.1rem;
    border-top: 1px solid rgb(255 255 255 / 0.12);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.9rem 1.4rem;
  }
  .aks-1-fact dt { color: rgb(244 244 242 / 0.5); }
  .aks-1-fact dd { margin-top: 0.3rem; color: #fff; font-weight: 500; }

  .aks-1-body { padding-block: clamp(2.2rem, 5vh, 3.6rem); }
  .aks-1-row { display: grid; gap: 1.2rem; padding-block: clamp(1.4rem, 3.5vh, 2.4rem); }
  .aks-1-row + .aks-1-row { border-top: 1px solid var(--color-line); }
  @media (min-width: 1024px) {
    .aks-1-row { grid-template-columns: 4fr 7fr; gap: clamp(1.8rem, 4vw, 3.2rem); align-items: start; }
    .aks-1-row-flip .aks-1-text { order: 2; }
  }
  .aks-1-row-kicker { color: var(--color-mey-teal-700); }
  .aks-1-text h2 { margin-top: 0.4rem; }
  .aks-1-row-body { margin-top: 0.6rem; max-width: 46ch; }
  .aks-1-figs { display: grid; gap: 1rem; }
  @media (min-width: 700px) { .aks-1-figs-two { grid-template-columns: repeat(2, minmax(0, 1fr)); } }

  .aks-1-view { padding-block: clamp(2.4rem, 6vh, 4rem); }
  .aks-1-view-kicker { color: var(--color-red-on-dark); }
  .aks-1-view-title { margin-top: 0.4rem; }
  .aks-1-view-text { margin-top: 0.7rem; color: rgb(244 244 242 / 0.75); max-width: 60ch; }
  .aks-1-view-figs { margin-top: 1.4rem; display: grid; gap: 1.1rem; }
  .aks-1-view-two { display: grid; gap: 1.1rem; }
  @media (min-width: 800px) { .aks-1-view-two { grid-template-columns: repeat(2, minmax(0, 1fr)); } }

  .aks-1-switch { border-top: 1px solid rgb(255 255 255 / 0.08); }
  .aks-1-switch-inner {
    padding-block: clamp(1.8rem, 4vh, 2.8rem);
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem 2.4rem;
    align-items: center;
    justify-content: space-between;
  }
  .aks-1-switch-kicker { color: var(--color-mey-teal); }
  .aks-1-switch-title { color: #fff; margin-top: 0.3rem; }
  .aks-1-switch-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }
</style>
