---
/* ALBÜM · El Ele Apartmanı — bina, ortak alanlar, çevre ve Mey İnşaat güveni. */
import Shell from '../../../../components/showcase/satilik/album/Shell.astro';
import Figure from '../../../../components/showcase/satilik/album/Figure.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import { building, ui } from '../../../../components/showcase/satilik/data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/album';
---

<Shell
  title="El Ele Apartmanı — Bina · Albüm"
  description={building.intro}
  current="el-ele-apartmani"
>
  <section class="alb-b-open reveal" data-testid="sv-building">
    <Figure imgKey={building.exterior} sizes="(min-width: 900px) 42vw, 94vw" loading="eager" class="alb-b-fig" />
    <div class="alb-b-text">
      <p class="alb-eyebrow">{building.eyebrow}</p>
      <h1 class="alb-display">Beyaz cephe, ferforje ve deniz</h1>
      <p class="alb-b-intro">{building.intro}</p>
      <dl class="alb-b-facts" data-testid="sv-facts">
        {building.facts.map((f) => (
          <div class="alb-b-fact">
            <dt class="t-tech">{f.label}</dt>
            <dd>{f.pending ? <Chip /> : f.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="alb-b-craft reveal">
    <header class="alb-b-head">
      <p class="alb-eyebrow">Mey İnşaat</p>
      <h2 class="alb-display">Yapan el, satan el</h2>
    </header>
    <div class="alb-b-craft-grid">
      {building.craft.map((c, i) => (
        <article class="alb-b-craft-item">
          <p class="t-tech alb-b-craft-no">{String(i + 1).padStart(2, '0')}</p>
          <h3>{c.title}</h3>
          <p>{c.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="alb-b-common reveal">
    <header class="alb-b-head">
      <p class="alb-eyebrow">Ortak alanlar</p>
      <h2 class="alb-display">Girişten otoparka aynı özen</h2>
    </header>
    <div class="alb-b-common-grid">
      <Figure imgKey={building.entrance} sizes="(min-width: 900px) 44vw, 94vw" />
      <Figure imgKey={building.parking} sizes="(min-width: 900px) 44vw, 94vw" />
    </div>
    <p class="alb-b-note alb-serif-cap">
      Giriş fotoğrafı Mey İnşaat'ın kendi kayıt filigranını taşır; teslim öncesi çekimdir.
    </p>
  </section>

  <section class="alb-b-env reveal">
    <header class="alb-b-head">
      <p class="alb-eyebrow">Çevre</p>
      <h2 class="alb-display">Kıyı parkının çeperinde</h2>
    </header>
    <div class="alb-b-env-figs">
      {building.environment.map((k, i) => (
        <Figure imgKey={k} sizes={i === 0 ? '(min-width: 1180px) 1100px, 94vw' : '(min-width: 900px) 44vw, 94vw'} class={i === 0 ? 'alb-b-env-wide' : ''} />
      ))}
    </div>
    <p class="alb-b-note">
      Konum, adres ve mesafeler satış bilgisiyle birlikte yayınlanacak; o güne dek yalnız
      dosyadaki kareler konuşuyor.
    </p>
  </section>

  <section class="alb-b-cta reveal">
    <h2 class="alb-display">Daireleri görmeye gelin</h2>
    <div class="alb-b-cta-row">
      <a class="btn-primary" href={`${root}/iletisim`} data-testid="sv-cta-randevu">{ui.cta.randevu}</a>
      <a class="alb-link" href={`${root}/daireler`}>{ui.cta.daireleri}</a>
      <a class="alb-link" href={`${root}/galeri?bolum=bina`}>{ui.cta.fotograflar}</a>
    </div>
  </section>
</Shell>

<style>
  section { max-width: 1180px; margin-inline: auto; padding-inline: 1rem; }

  .alb-b-open { padding-top: clamp(1.8rem, 4.5vw, 3.2rem); display: grid; gap: 1.6rem; }
  @media (min-width: 900px) {
    .alb-b-open { grid-template-columns: 5fr 6fr; gap: clamp(2rem, 4.5vw, 3.6rem); align-items: start; }
  }
  .alb-b-text h1 { font-size: clamp(1.9rem, 4.4vw, 3rem); margin-top: 0.6rem; }
  .alb-b-intro { margin-top: 1rem; font-size: 1.0625rem; line-height: 1.75; }
  .alb-b-facts {
    margin-top: 1.4rem;
    border-top: 1px solid var(--alb-line);
    padding-top: 1.1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem 1.4rem;
  }
  .alb-b-fact dt { color: var(--color-graphite-400); }
  .alb-b-fact dd { margin-top: 0.25rem; font-weight: 500; color: var(--alb-ink); }

  .alb-b-head { text-align: center; max-width: 700px; margin-inline: auto; }
  .alb-b-head h2 { font-size: clamp(1.6rem, 3.2vw, 2.3rem); margin-top: 0.6rem; }

  .alb-b-craft { padding-top: clamp(3rem, 8vh, 5.5rem); }
  .alb-b-craft-grid { margin-top: 1.8rem; display: grid; gap: 1.4rem; }
  @media (min-width: 900px) { .alb-b-craft-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 2rem; } }
  .alb-b-craft-no { color: var(--color-mey-red); }
  .alb-b-craft-item h3 { font-family: var(--alb-serif); font-weight: 600; font-size: 1.2rem; margin-top: 0.5rem; }
  .alb-b-craft-item p + p, .alb-b-craft-item h3 + p { margin-top: 0.5rem; line-height: 1.65; }

  .alb-b-common { padding-top: clamp(3rem, 8vh, 5.5rem); }
  .alb-b-common-grid { margin-top: 1.8rem; display: grid; gap: 1.2rem; }
  @media (min-width: 720px) { .alb-b-common-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .alb-b-note { max-width: 640px; margin: 1.1rem auto 0; text-align: center; color: var(--color-graphite-400); }

  .alb-b-env { padding-top: clamp(3rem, 8vh, 5.5rem); }
  .alb-b-env-figs { margin-top: 1.8rem; display: grid; gap: 1.2rem; }
  @media (min-width: 720px) {
    .alb-b-env-figs { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .alb-b-env-figs :global(.alb-b-env-wide) { grid-column: 1 / -1; }
  }

  .alb-b-cta { text-align: center; padding-top: clamp(3rem, 8vh, 5rem); }
  .alb-b-cta h2 { font-size: clamp(1.6rem, 3.2vw, 2.3rem); }
  .alb-b-cta-row { margin-top: 1.3rem; display: flex; justify-content: center; align-items: center; gap: 1.3rem; flex-wrap: wrap; }
</style>
