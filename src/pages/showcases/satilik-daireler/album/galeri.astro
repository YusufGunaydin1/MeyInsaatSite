---
/* ALBÜM · Galeri — küratörlü koleksiyon; filtre + erişilebilir lightbox (ada). */
import Shell from '../../../../components/showcase/satilik/album/Shell.astro';
import GalleryLightbox from '../../../../components/showcase/satilik/shared/GalleryLightbox';
import { lightboxItems } from '../../../../components/showcase/satilik/shared/imageVariants';
import { galleryComposition, ui } from '../../../../components/showcase/satilik/data';

const groupLabels: Record<string, string> = {
  'daire-1': 'Daire 1',
  'daire-2': 'Daire 2',
  bina: 'Bina & Ortak',
  cevre: 'Çevre',
};
const items = await lightboxItems(galleryComposition, groupLabels);
---

<Shell
  title="Galeri — El Ele Apartmanı · Albüm"
  description="Daire 1, Daire 2, bina ve çevreden küratörlü fotoğraflar."
  current="galeri"
>
  <section class="alb-g-head reveal">
    <p class="alb-eyebrow">Galeri</p>
    <h1 class="alb-display">Albümün tamamı</h1>
    <p class="alb-g-lede">
      Kareler daireye, binaya ve çevreye göre gruplu; bir fotoğrafa dokunun,
      büyük görünümde ok tuşlarıyla gezin, Esc ile geri dönün.
    </p>
  </section>

  <section class="alb-g-body reveal">
    <GalleryLightbox client:load items={items} tabs={ui.galleryTabs} />
  </section>
</Shell>

<style>
  section { max-width: 1180px; margin-inline: auto; padding-inline: 1rem; }
  .alb-g-head { text-align: center; max-width: 700px; padding-top: clamp(2.2rem, 6vw, 4rem); }
  .alb-g-head h1 { font-size: clamp(1.9rem, 4.4vw, 3rem); margin-top: 0.7rem; }
  .alb-g-lede { margin-top: 1rem; line-height: 1.7; }
  .alb-g-body { padding-top: clamp(1.8rem, 4vw, 2.8rem); }
</style>
