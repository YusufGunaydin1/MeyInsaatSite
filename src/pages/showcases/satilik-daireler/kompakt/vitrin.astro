---
/*
  SATILIK DAİRELER — KOMPAKT · Landing B "vitrin" (ref: genel-sayfa-ref-b2).
  A ile AYNI bileşen sistemi, farklı dizilim: proje sekmeleri + kart vitrini önde,
  yaşam kalitesi şeridi, tip kartları, 4 avantaj, önerilen projeler, konum + form.
*/
import { Image } from 'astro:assets';
import Base from '../../../../layouts/Base.astro';
import Icon from '../../../../components/showcase/satilik/kompakt/Icon.astro';
import MockChip from '../../../../components/showcase/satilik/kompakt/MockChip.astro';
import MapPanel from '../../../../components/showcase/satilik/kompakt/MapPanel.astro';
import TypeCards from '../../../../components/showcase/satilik/kompakt/TypeCards.astro';
import SoonDialog from '../../../../components/showcase/satilik/kompakt/SoonDialog.astro';
import UnitsExplorer, { type ExplorerItem } from '../../../../components/showcase/satilik/kompakt/UnitsExplorer.tsx';
import RailForm from '../../../../components/showcase/satilik/kompakt/RailForm.tsx';
import { cardImage } from '../../../../components/showcase/satilik/kompakt/assets.ts';
import { units, tl, projeTeasers } from '../../../../components/showcase/satilik/kompakt/data.ts';
import { publicAsset, entry } from '../../../../components/showcase/satilik/media.ts';
import aliImg from '../../../../assets/projects/ali.webp';
import sapanImg from '../../../../assets/projects/sapanbaglari.webp';
import elEleImg from '../../../../assets/projects/el-ele-apartmani.webp';
import '../../../../components/showcase/satilik/kompakt/kompakt.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
/* Aile canlıya taşındı (2026-07-16): liste + detaylar artık /satilik-daireler altında */
const kompakt = base + '/satilik-daireler';

const heroKey = 'daire-1/d1-teras-3.png';
const hero = { img: publicAsset(heroKey), alt: entry(heroKey).alt };
const yasamKeys = ['daire-1/d1-salon-alt.png', 'daire-2/d2-mutfak-alt.png'];
const yasam = yasamKeys.map((k) => ({ img: publicAsset(k), alt: entry(k).alt }));

/* Vitrin: yalnız GERÇEK satılık iki dubleks fiyat taşır; diğer projeler teaser. */
const musait = units.filter((u) => u.durum === 'musait');
const items: ExplorerItem[] = [
  ...(await Promise.all(
    musait.map(async (u): Promise<ExplorerItem> => ({
      id: u.id,
      kind: 'unit',
      proje: 'el-ele',
      projeLabel: 'El Ele Apartmanı',
      no: u.no,
      kat: u.kat,
      katKey: u.katKey,
      tip: u.tip,
      oda: u.oda,
      brut: u.brut,
      fiyatText: u.fiyat ? tl(u.fiyat) : undefined,
      durum: 'musait',
      badge: u.badge,
      href: `${kompakt}/${u.detay}`,
      cta: 'Detaylı İncele',
      img: u.foto ? await cardImage(u.foto) : undefined,
    }))
  )),
  ...projeTeasers.map((t): ExplorerItem => ({
    id: 'teaser-' + t.slug,
    kind: 'teaser',
    proje: t.slug,
    projeLabel: t.ad,
    href: `${base}/projeler/${t.slug}`,
    cta: 'Projeyi Gör',
  })),
];

const kalite = [
  { icon: 'rail', title: 'Geniş balkonlar', sub: 'Ferforje korkuluklu' },
  { icon: 'sea', title: 'Doğal ışık', sub: 'Dam pencereli katlar' },
  { icon: 'stairs', title: 'İki katlı yaşam', sub: 'Dubleks düzen' },
  { icon: 'shield', title: 'Yüksek işçilik', sub: 'Çizen de yapan da biziz' },
];

const avantajlar = [
  { no: '01', title: 'Aracısız süreç', sub: 'Binayı yapan firmadan, tek muhatapla satın alım.' },
  { no: '02', title: 'Kaliteli yapı', sub: 'Sağlam malzeme, titiz işçilik ve uzun ömürlü yapılar.' },
  { no: '03', title: 'Şeffaf bilgi', sub: 'Açık iletişim; eksik bilgi uydurulmaz, "yakında" denir.' },
  { no: '04', title: 'Teslime hazır', sub: 'Sıfır daireler boş ve gezilebilir durumda.' },
];

const onerilen = [
  { ad: 'Ali Apartmanı', img: aliImg, href: base + '/projeler/ali' },
  { ad: 'El Ele Apartmanı', img: elEleImg, href: base + '/projeler/el-ele-apartmani' },
  { ad: 'Sapanbağları', img: sapanImg, href: base + '/projeler/sapanbaglari' },
];
---

<Base
  locale="tr"
  page="home"
  path="/projeler"
  title="Satılık Daireler — Kompakt B · Vitrin — MEY İnşaat"
  description="MEY İnşaat satılık daire vitrini: öne çıkan daireler, daire tipleri, konum ve randevu."
  noindex
>
  <!-- HERO -->
  <section class="kcb-hero theatre">
    <Image src={hero.img} alt="" widths={[880, 1440]} sizes="100vw" class="kcb-hero-img" loading="eager" />
    <div class="kcb-hero-scrim" aria-hidden="true"></div>
    <div class="container-site kcb-hero-in">
      <p class="t-tech kc-eyebrow">SATILIK DAİRELER</p>
      <h1 class="kcb-hero-title">Yaşam alanlarınızı<br />yükselten detaylar.</h1>
      <p class="kcb-hero-sub">
        Mey İnşaat projelerindeki satılık daireleri inceleyin. Modern mimari, sağlam yapı ve değer kazanan lokasyonlar.
      </p>
      <div class="kcb-hero-actions">
        <a class="btn-primary" href="#vitrin">Daireleri Keşfet <Icon name="arrow-right" size={16} /></a>
        <a class="kcb-hero-alt" href={base + '/projeler'}>Projelerimizi inceleyin <Icon name="arrow-right" size={15} /></a>
      </div>
    </div>
  </section>

  <!-- SEKMELER + FİLTRE + KART VİTRİNİ -->
  <section class="container-site kcb-vitrin" id="vitrin" aria-label="Satılık daire vitrini">
    <div class="kcb-vitrin-head">
      <h2 class="kc-h2">En güncel satılık daireler</h2>
      <MockChip />
    </div>
    <UnitsExplorer client:load mode="b" items={items} />
    <p class="kcb-all">
      <a class="btn-ghost" href={kompakt} data-testid="kc-tum-daireler">
        Tüm Daireleri Görüntüle <Icon name="arrow-right" size={16} />
      </a>
    </p>
  </section>

  <!-- YAŞAM KALİTESİ ŞERİDİ -->
  <section class="kcb-kalite-band" aria-label="Yaşam kalitesi">
    <div class="container-site kcb-kalite">
      <div class="kcb-kalite-media">
        {yasam.map((y) => (
          <Image src={y.img} alt={y.alt} widths={[420, 720]} sizes="(min-width: 900px) 300px, 46vw" />
        ))}
      </div>
      <div>
        <p class="t-tech kc-eyebrow">YAŞAM KALİTESİ</p>
        <h2 class="t-heading-m kcb-kalite-title">Her detay, konforunuz için düşünüldü.</h2>
        <p class="t-caption kcb-kalite-sub">
          Ferforje balkonlar, ferah iç mekânlar ve doğal ışık alan yaşam alanları günlük hayata değer katıyor.
        </p>
        <ul class="kcb-kalite-list">
          {kalite.map((k) => (
            <li>
              <span class="kcb-kalite-ic"><Icon name={k.icon} size={19} /></span>
              <p class="kcb-kalite-item">{k.title}</p>
              <p class="kcb-kalite-itemsub">{k.sub}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DAİRE TİPLERİ -->
  <section class="container-site kc-section" aria-label="Daire tipleri">
    <TypeCards unitsHref={kompakt} />
  </section>

  <!-- 4 AVANTAJ -->
  <section class="kcb-adv-band" aria-label="Neden MEY İnşaat">
    <div class="container-site kcb-adv">
      <div>
        <p class="t-tech kc-eyebrow">NEDEN MEY İNŞAAT?</p>
        <h2 class="t-heading-m kcb-adv-title">Değer katan 4 temel avantaj</h2>
      </div>
      <ol class="kcb-adv-list">
        {avantajlar.map((a) => (
          <li>
            <span class="kcb-adv-no">{a.no}</span>
            <p class="kcb-adv-item">{a.title}</p>
            <p class="kcb-adv-sub">{a.sub}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ÖNERİLEN PROJELER -->
  <section class="container-site kc-section-tight" aria-label="Önerilen projeler">
    <div class="kcb-oneri-head">
      <p class="t-tech kc-eyebrow">SİZİN İÇİN ÖNERİLER</p>
      <h2 class="t-heading-m">Benzer tercihleri olanlara önerilen projeler</h2>
    </div>
    <div class="kcb-oneri">
      {onerilen.map((o) => (
        <a class="kcb-oneri-card card" href={o.href}>
          <Image src={o.img} alt={o.ad} widths={[420, 720]} sizes="(min-width: 900px) 300px, 94vw" />
          <p class="kcb-oneri-ad">{o.ad}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- KONUM + FORM -->
  <section class="container-site kc-section" aria-label="Konum ve iletişim">
    <div class="kcb-konum">
      <div>
        <p class="t-tech kc-eyebrow">KONUM</p>
        <h2 class="t-heading-m kcb-konum-title">Hayallerinizdeki eve bir adım daha yakın.</h2>
        <div class="kcb-konum-map"><MapPanel compact title="Yakın Çevre" /></div>
      </div>
      <div>
        <p class="t-tech kc-eyebrow">BİZİMLE GÖRÜŞÜN</p>
        <h2 class="t-heading-m kcb-konum-title">Size uygun daireyi birlikte bulalım.</h2>
        <div class="kcb-konum-form"><RailForm client:load konu="Satılık daireler" wide /></div>
      </div>
    </div>
  </section>

  <SoonDialog />
</Base>

<style>
  .kcb-hero { position: relative; overflow: hidden; }
  .kcb-hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 55%; }
  .kcb-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgb(14 15 17 / 0.92) 0%, rgb(14 15 17 / 0.7) 50%, rgb(14 15 17 / 0.3) 100%);
  }
  .kcb-hero-in { position: relative; padding-block: 3rem; }
  .kcb-hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 3.4vw, 2.7rem);
    line-height: 1.12;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #fff;
    margin-top: 0.5rem;
  }
  .kcb-hero-sub { margin-top: 0.7rem; max-width: 52ch; color: rgb(244 244 242 / 0.8); font-size: 0.9375rem; }
  .kcb-hero-actions { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; margin-top: 1.1rem; }
  .kcb-hero-alt { display: inline-flex; align-items: center; gap: 0.4rem; color: #fff; font-size: 0.875rem; border-bottom: 1px solid rgb(255 255 255 / 0.4); padding-bottom: 0.15rem; }
  .kcb-hero-alt:hover { border-color: #fff; }

  .kcb-vitrin { padding-block: 1.5rem 0.75rem; }
  .kcb-vitrin-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.8rem; }
  .kcb-all { margin-top: 1rem; text-align: center; }

  .kcb-kalite-band { background: #fff; border-block: 1px solid var(--color-line); margin-top: 1.5rem; }
  .kcb-kalite {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 1.75rem;
    align-items: center;
    padding-block: 1.75rem;
  }
  .kcb-kalite-media { display: grid; grid-template-columns: 1.3fr 1fr; gap: 0.6rem; }
  .kcb-kalite-media img { width: 100%; height: 240px; object-fit: cover; border-radius: var(--radius-brand); display: block; }
  .kcb-kalite-title { margin-top: 0.4rem; }
  .kcb-kalite-sub { margin-top: 0.5rem; max-width: 56ch; }
  .kcb-kalite-list { margin-top: 1rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.9rem; }
  .kcb-kalite-ic { color: var(--color-mey-red); display: inline-flex; }
  .kcb-kalite-item { font-weight: 600; font-size: 0.875rem; color: var(--color-graphite-900); margin-top: 0.3rem; }
  .kcb-kalite-itemsub { font-size: 0.8125rem; color: var(--color-graphite-400); }

  .kcb-adv-band { background: var(--color-concrete-100); }
  .kcb-adv {
    display: grid;
    grid-template-columns: minmax(180px, 0.8fr) minmax(0, 2.4fr);
    gap: 1.5rem;
    padding-block: 1.75rem;
    align-items: start;
  }
  .kcb-adv-title { margin-top: 0.4rem; }
  .kcb-adv-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1.1rem; }
  .kcb-adv-no { font-family: var(--font-mono); font-weight: 500; font-size: 0.8125rem; color: var(--color-mey-red); }
  .kcb-adv-item { font-weight: 600; color: var(--color-graphite-900); margin-top: 0.25rem; font-size: 0.9375rem; }
  .kcb-adv-sub { font-size: 0.8125rem; color: var(--color-graphite-400); line-height: 1.45; margin-top: 0.15rem; }

  .kcb-oneri-head { margin-bottom: 0.9rem; }
  .kcb-oneri-head h2 { margin-top: 0.3rem; }
  .kcb-oneri { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.9rem; }
  .kcb-oneri-card { overflow: hidden; transition: border-color 150ms ease-out; }
  .kcb-oneri-card:hover { border-color: var(--color-graphite-400); }
  .kcb-oneri-card img { width: 100%; height: 150px; object-fit: cover; display: block; }
  .kcb-oneri-ad { padding: 0.7rem 0.9rem; font-weight: 600; font-size: 0.9375rem; color: var(--color-graphite-900); }

  .kcb-konum { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); gap: 1.75rem; align-items: start; }
  .kcb-konum-title { margin-top: 0.4rem; }
  .kcb-konum-map, .kcb-konum-form { margin-top: 0.9rem; }

  @media (max-width: 1023px) {
    .kcb-kalite, .kcb-adv, .kcb-konum { grid-template-columns: minmax(0, 1fr); }
    .kcb-kalite-media img { height: 170px; }
  }
</style>
