---
/* SERGİ · Daireler — iki eserlik asma düzeni: plaka + künye sütunu. */
import Shell from '../../../../components/showcase/satilik/sergi/Shell.astro';
import Plate from '../../../../components/showcase/satilik/sergi/Plate.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import { apartments, ui } from '../../../../components/showcase/satilik/data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/sergi';
---

<Shell
  title="Daireler — Satış Kataloğu · Sergi"
  description="El Ele Apartmanı'ndaki iki 3+2 dubleks: katalog künyeleriyle."
  current="daireler"
>
  <header class="srg-d-head reveal">
    <p class="t-tech srg-d-kicker">KATALOG · 02</p>
    <h1 class="t-display-l">İKİ ESER</h1>
    <p class="t-body-l srg-d-lede">
      Satışta yalnız iki daire var. İkisi de 3+2 dubleks; karakterleri ayrıdır ve
      aşağıda kendi künyeleriyle asılıdır — kıyas tablosu değil, sergi düzeni.
    </p>
  </header>

  {apartments.map((apt, i) => (
    <>
      <h2 class="srg-rule t-tech">ESER {apt.no} · {apt.tagline.toUpperCase()}</h2>
      <section class="srg-d-item reveal" data-testid={`sv-apt-${apt.id}`}>
        <Plate
          imgKey={apt.lead}
          plate={`EE-${apt.no}`}
          sizes="(min-width: 1024px) 52vw, 94vw"
          class={i % 2 === 1 ? 'srg-d-flip' : ''}
        />
        <div class="srg-d-meta">
          <h3 class="t-heading-m">{apt.name}</h3>
          <p class="srg-d-hook">{apt.hook}</p>
          <ul class="srg-d-char">
            {apt.character.map((c) => (
              <li class="t-caption">— {c}</li>
            ))}
          </ul>
          <dl class="srg-d-kunye" data-testid="sv-facts">
            {apt.facts.slice(0, 5).map((f) => (
              <div class="srg-d-kunye-row">
                <dt class="t-tech">{f.label.toUpperCase()}</dt>
                <dd>{f.pending ? <Chip /> : f.value}</dd>
              </div>
            ))}
          </dl>
          <div class="srg-d-cta">
            <a class="btn-primary" href={`${root}/${apt.id}`} data-testid={`sv-open-${apt.id}`}>
              {apt.id === 'daire-1' ? ui.cta.daire1 : ui.cta.daire2}
            </a>
            <a class="btn-ghost" href={`${root}/galeri?bolum=${apt.id}`}>{ui.cta.fotograflar}</a>
          </div>
        </div>
      </section>
    </>
  ))}

  <p class="srg-d-note t-caption reveal">
    Karar için en doğru sıra: önce plakalar, sonra <a class="srg-d-link" href={`${root}/iletisim`}>yerinde gezi</a>.
  </p>
</Shell>

<style>
  .srg-d-kicker { color: var(--color-mey-teal-700); }
  .srg-d-head h1 { margin-top: 0.6rem; }
  .srg-d-lede { margin-top: 0.9rem; max-width: 62ch; }

  .srg-d-item { display: grid; gap: 1.5rem; }
  @media (min-width: 1024px) {
    .srg-d-item { grid-template-columns: 7fr 5fr; gap: clamp(1.8rem, 3.5vw, 3rem); align-items: start; }
    .srg-d-item :global(.srg-d-flip) { order: 2; }
  }
  .srg-d-hook { margin-top: 0.6rem; line-height: 1.65; }
  .srg-d-char { margin-top: 0.9rem; display: grid; gap: 0.3rem; color: var(--color-graphite-600); }

  .srg-d-kunye {
    margin-top: 1.1rem;
    border: 1px solid var(--color-line);
    border-inline-start: 2px solid var(--color-mey-red);
    border-radius: var(--radius-brand);
    background: #fff;
    padding: 0.9rem 1rem;
    display: grid;
    gap: 0.55rem;
  }
  .srg-d-kunye-row { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; }
  .srg-d-kunye-row dt { color: var(--color-graphite-400); }
  .srg-d-kunye-row dd { font-weight: 500; color: var(--color-graphite-900); text-align: end; }

  .srg-d-cta { margin-top: 1.2rem; display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .srg-d-note { margin-top: clamp(2.4rem, 6vh, 4rem); color: var(--color-graphite-400); }
  .srg-d-link { color: var(--color-mey-red); text-decoration: underline; text-underline-offset: 3px; }
</style>
