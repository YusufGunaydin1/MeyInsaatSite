---
/* SERGİ · Galeri — küratörlü arşiv duvarı; filtreli, lightbox'lı. */
import Shell from '../../../../components/showcase/satilik/sergi/Shell.astro';
import GalleryLightbox from '../../../../components/showcase/satilik/shared/GalleryLightbox';
import { lightboxItems } from '../../../../components/showcase/satilik/shared/imageVariants';
import { galleryComposition, ui } from '../../../../components/showcase/satilik/data';

const groupLabels: Record<string, string> = {
  'daire-1': 'EE-01',
  'daire-2': 'EE-02',
  bina: 'EE-BN',
  cevre: 'EE-ÇV',
};
const items = await lightboxItems(galleryComposition, groupLabels);
---

<Shell
  title="Galeri — Satış Kataloğu · Sergi"
  description="Katalogdaki tüm plakalar: Daire 1, Daire 2, bina ve çevre."
  current="galeri"
>
  <header class="srg-g-head reveal">
    <p class="t-tech srg-g-kicker">KATALOG · 06</p>
    <h1 class="t-display-l">PLAKA ARŞİVİ</h1>
    <p class="t-body-l srg-g-lede">
      Filtreler eser numarasına göre çalışır; plakaya dokunun, oklarla gezin, Esc ile kapanır.
    </p>
  </header>

  <div class="srg-g-body reveal">
    <GalleryLightbox client:load items={items} tabs={ui.galleryTabs} />
  </div>
</Shell>

<style>
  .srg-g-kicker { color: var(--color-mey-teal-700); }
  .srg-g-head h1 { margin-top: 0.5rem; }
  .srg-g-lede { margin-top: 0.8rem; max-width: 60ch; }
  .srg-g-body { margin-top: 1.8rem; }
</style>
