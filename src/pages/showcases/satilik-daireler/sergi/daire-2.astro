---
/*
  SERGİ · Daire 2 — "EE-02" ÇİZİM PAFTASI düzeni: Daire 1'in plaka ızgarasının
  aksine tek sütun, tam genişlik kareler ve pafta kenarına asılmış mono notlar;
  künye üstte yatay antet şerididir. Ev üst katından anlatılır.
*/
import Shell from '../../../../components/showcase/satilik/sergi/Shell.astro';
import Plate from '../../../../components/showcase/satilik/sergi/Plate.astro';
import Chip from '../../../../components/showcase/satilik/shared/Chip.astro';
import { daire2 as apt, ui } from '../../../../components/showcase/satilik/data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = base + '/showcases/satilik-daireler/sergi';
let plateNo = 0;
const nextPlate = () => `EE-D2-${String(++plateNo).padStart(2, '0')}`;
---

<Shell title="Daire 2 — EE-02 · Sergi" description={apt.hook} current="daire-2">
  <article data-testid="sv-detail-daire-2">
    <header class="srg-p-antet reveal" data-testid="sv-facts">
      <div class="srg-p-antet-name">
        <p class="t-tech srg-p-kicker">ESER 02 · {apt.tagline.toUpperCase()}</p>
        <h1 class="t-display-l">DAİRE 2</h1>
      </div>
      <dl class="srg-p-antet-facts">
        {apt.facts.map((f) => (
          <div class="srg-p-antet-cell">
            <dt class="t-tech">{f.label.toUpperCase()}</dt>
            <dd>{f.pending ? <Chip /> : f.value}</dd>
          </div>
        ))}
      </dl>
    </header>

    <p class="t-body-l srg-p-lede reveal">{apt.intro}</p>

    {apt.sections.map((s, i) => (
      <section class:list={['srg-p-sheet reveal', i % 2 === 1 && 'srg-p-sheet-flip']} id={s.id}>
        <aside class="srg-p-margin">
          <p class="t-tech srg-p-margin-no">{s.eyebrow}</p>
          <h2 class="t-heading-s srg-p-margin-title">{s.title}</h2>
          <p class="t-caption srg-p-margin-text">{s.text}</p>
        </aside>
        <div class="srg-p-figs">
          {s.keys.map((k) => (
            <Plate imgKey={k} plate={nextPlate()} sizes="(min-width: 1024px) 62vw, 94vw" />
          ))}
        </div>
      </section>
    ))}

    <nav class="srg-p-next reveal" aria-label="Katalogda gezinme">
      <a class="t-tech srg-p-next-link" href={`${root}/daire-1`} data-testid="sv-switch-daire-1">
        ← ÖNCEKİ ESER: EE-01 · DAİRE 1
      </a>
      <div class="srg-p-next-cta">
        <a class="btn-primary" href={`${root}/iletisim?daire=daire-2`} data-testid="sv-cta-randevu">{ui.cta.randevu}</a>
        <a class="btn-ghost" href={`${root}/galeri?bolum=daire-2`}>{ui.cta.fotograflar}</a>
      </div>
    </nav>
  </article>
</Shell>

<style>
  .srg-p-antet {
    border: 1px solid var(--color-line);
    border-inline-start: 2px solid var(--color-mey-red);
    border-radius: var(--radius-brand);
    background: #fff;
    padding: 1.1rem 1.3rem;
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 1024px) {
    .srg-p-antet { grid-template-columns: minmax(220px, 3fr) 9fr; align-items: center; }
  }
  .srg-p-kicker { color: var(--color-mey-teal-700); }
  .srg-p-antet-name h1 { margin-top: 0.4rem; }
  .srg-p-antet-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.8rem 1.2rem;
  }
  .srg-p-antet-cell dt { color: var(--color-graphite-400); }
  .srg-p-antet-cell dd { margin-top: 0.25rem; font-weight: 500; color: var(--color-graphite-900); font-size: 0.9375rem; }

  .srg-p-lede { margin-top: 1.4rem; max-width: 70ch; }

  .srg-p-sheet {
    margin-top: clamp(2.4rem, 6vh, 4rem);
    display: grid;
    gap: 1.1rem;
  }
  @media (min-width: 1024px) {
    .srg-p-sheet { grid-template-columns: 3fr 9fr; gap: clamp(1.6rem, 3vw, 2.6rem); }
    .srg-p-sheet-flip { grid-template-columns: 9fr 3fr; }
    .srg-p-sheet-flip .srg-p-margin { order: 2; }
    .srg-p-margin { position: sticky; top: 1.4rem; align-self: start; }
  }
  .srg-p-margin { border-top: 1px solid var(--color-mey-red); padding-top: 0.6rem; }
  .srg-p-margin-no { color: var(--color-mey-red); }
  .srg-p-margin-title { margin-top: 0.35rem; }
  .srg-p-margin-text { margin-top: 0.5rem; }

  .srg-p-figs { display: grid; gap: 1.2rem; }

  .srg-p-next {
    margin-top: clamp(2.6rem, 6vh, 4.2rem);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: #fff;
    padding: 1.2rem 1.3rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: center;
    justify-content: space-between;
  }
  .srg-p-next-link { color: var(--color-mey-red); }
  .srg-p-next-link:hover { color: var(--color-mey-red-700); }
  .srg-p-next-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }
</style>
