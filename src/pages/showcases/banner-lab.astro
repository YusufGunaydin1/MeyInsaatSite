---
/*
  BANNER LAB — dahili tasarım vitrini (/showcases/banner-lab).
  Ana sayfa BANNER (tam-genişlik kanıt/çağrı bandı) için 3 varyant, alt alta.
  Gerçek site token'larıyla + gerçek proje binalarıyla. RedApple seçer → üretime alınır.
  Navigasyonda YOK, noindex, sitemap dışı.

  Varyantlar (tek cümle "neden"):
  A · KOT BANDI    — üretimdeki bandın rafine hali; tek bina tam-genişlik, kırmızı kot
                     çizgisi + iki uçta mono etiket + alt scrim (vaziyet planı okuması).
  B · PROJE ŞERİDİ — bandı portföy kanıtına çevirir; üç gerçek proje yan yana (Ali ·
                     El Ele · Şanbağları), mono künye + hover.
  C · KIRMIZI ÇAĞRI— koyu dönüşüm bandı; markanın kırmızı mimari çizgileri motif,
                     Oswald çağrı + kırmızı CTA.
*/
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import heroCorner from '../../assets/photos/hero-residential-corner-building.webp';
import redLines from '../../assets/showcase/minimal-red-architectural-lines.webp';
import ali from '../../assets/showcase/ali.webp';
import elEle from '../../assets/showcase/el-ele-apartmani.webp';
import sanbaglari from '../../assets/showcase/sanbaglari.webp';

const strip = [
  { idx: '01', name: 'ALİ', type: 'KONUT · İSTANBUL', image: ali },
  { idx: '02', name: 'EL ELE APARTMANI', type: 'KONUT · İSTANBUL', image: elEle },
  { idx: '03', name: 'ŞANBAĞLARI', type: 'KONUT · İSTANBUL', image: sanbaglari },
];
---

<Base locale="tr" page="home" path="/showcases/banner-lab" title="Banner Lab — Tasarım Vitrini" noindex>
  <!-- LAB INTRO -->
  <section class="theatre blueprint-grid lab-intro">
    <div class="container-site">
      <p class="t-tech" style="color: var(--color-red-on-dark);">MEY İnşaat · Dahili · Banner Lab</p>
      <h1 class="t-display-l mt-2">Banner — Tasarım Varyantları</h1>
      <p class="t-body-l mt-4 max-w-2xl" style="color: rgb(244 244 242 / 0.72);">
        Ana sayfa tam-genişlik bandı için 3 varyant, alt alta. Beğendiğini seç — seçilen
        üretime alınır. Gerçek proje binaları: Ali · El Ele Apartmanı · Şanbağları.
      </p>
      <a class="t-tech lab-back mt-6" href="/showcases">
        <span aria-hidden="true">←</span> Vitrine dön
      </a>
    </div>
  </section>

  <!-- ============================ BANNER / A — KOT BANDI ============================ -->
  <article class="lab-item">
    <div class="lab-cap">
      <div class="container-site lab-cap-row">
        <span class="t-tech lab-cap-id">BANNER / A</span>
        <div>
          <p class="t-tech lab-cap-name">Kot bandı — rafine kanıt</p>
          <p class="lab-cap-why t-caption">
            Üretimdeki bandın rafine hali: tek bina tam-genişlik, kırmızı kot çizgisi + iki
            uçta mono etiket + alt scrim — fotoğrafı bir vaziyet planı gibi okutur.
          </p>
        </div>
      </div>
    </div>
    <div class="lab-stage">
      <section class="ban-a" aria-label="Teslim edilmiş MEY konut projesi">
        <Image
          src={heroCorner}
          alt="Teslim edilmiş MEY konut projesi — köşe cephe"
          widths={[768, 1280, 1728]}
          sizes="100vw"
          loading="eager"
          class="ban-a-img"
        />
        <div class="ban-a-scrim" aria-hidden="true"></div>
        <div class="container-site ban-a-tags">
          <span class="t-tech ban-a-tag">TESLİM EDİLDİ · 6 KAT</span>
          <span class="t-tech ban-a-tag ban-a-tag-end">İSTANBUL · KONUT</span>
        </div>
      </section>
    </div>
  </article>

  <!-- ============================ BANNER / B — PROJE ŞERİDİ ============================ -->
  <article class="lab-item">
    <div class="lab-cap">
      <div class="container-site lab-cap-row">
        <span class="t-tech lab-cap-id">BANNER / B</span>
        <div>
          <p class="t-tech lab-cap-name">Proje şeridi — triptik</p>
          <p class="lab-cap-why t-caption">
            Bandı portföy kanıtına çevirir: üç gerçek proje yan yana (Ali · El Ele · Şanbağları),
            mono künye + hover 1.02 — teslim edilen işin şeridi.
          </p>
        </div>
      </div>
    </div>
    <div class="lab-stage">
      <section class="ban-b" aria-label="MEY proje şeridi">
        {strip.map((p) => (
          <figure class="ban-b-cell group">
            <Image
              src={p.image}
              alt={`MEY konut projesi — ${p.name}`}
              widths={[440, 640, 880]}
              sizes="(min-width: 640px) 33vw, 100vw"
              loading="eager"
              class="ban-b-img"
            />
            <div class="ban-b-scrim" aria-hidden="true"></div>
            <span class="t-tech ban-b-idx">{p.idx}</span>
            <figcaption class="ban-b-cap">
              <span class="ban-b-name">{p.name}</span>
              <span class="t-tech ban-b-type">{p.type}</span>
            </figcaption>
          </figure>
        ))}
      </section>
    </div>
  </article>

  <!-- ============================ BANNER / C — KIRMIZI ÇAĞRI ============================ -->
  <article class="lab-item">
    <div class="lab-cap">
      <div class="container-site lab-cap-row">
        <span class="t-tech lab-cap-id">BANNER / C</span>
        <div>
          <p class="t-tech lab-cap-name">Kırmızı çağrı — dönüşüm bandı</p>
          <p class="lab-cap-why t-caption">
            Koyu dönüşüm/çağrı bandı: markanın kırmızı mimari çizgileri koyu zeminde motif,
            teal blueprint + Oswald çağrı + kırmızı CTA — sayfayı iletişime bağlar.
          </p>
        </div>
      </div>
    </div>
    <div class="lab-stage">
      <section class="theatre blueprint-grid ban-c">
        <Image
          src={redLines}
          alt=""
          aria-hidden="true"
          widths={[768, 1280, 1728]}
          sizes="100vw"
          loading="eager"
          class="ban-c-bg"
        />
        <div class="ban-c-scrim" aria-hidden="true"></div>
        <div class="container-site ban-c-inner">
          <p class="t-tech ban-c-eyebrow">SIRADAKİ PROJE</p>
          <h2 class="t-display-l uppercase ban-c-title">PROJENİZİ KONUŞALIM.</h2>
          <p class="t-body-l ban-c-sub">
            Arsanız ya da projeniz için, 23 yıllık MEY Grubu güvencesiyle baştan sona tek elden.
          </p>
          <div class="ban-c-cta">
            <a href="/iletisim" class="btn-primary">
              İletişim <span aria-hidden="true">→</span>
            </a>
            <a href="/projeler" class="btn-ghost">Projeleri gör</a>
          </div>
        </div>
      </section>
    </div>
  </article>
</Base>

<style>
  /* ---- Lab chrome (shared) ---- */
  .lab-intro {
    padding-block: clamp(2.5rem, 6vh, 4.5rem);
  }
  .lab-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-mey-teal);
  }
  .lab-back:hover { color: #fff; }

  .lab-item {
    border-top: 1px solid var(--color-line);
  }
  .lab-cap {
    background: var(--color-night-800);
    border-block: 1px solid rgb(255 255 255 / 0.08);
  }
  .lab-cap-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem 1.25rem;
    align-items: start;
    padding-block: 0.9rem;
  }
  .lab-cap-id {
    color: var(--color-red-on-dark);
    border: 1px solid rgb(242 85 90 / 0.35);
    border-radius: var(--radius-brand);
    padding: 0.25rem 0.55rem;
    align-self: start;
    white-space: nowrap;
  }
  .lab-cap-name { color: #fff; }
  .lab-cap-why {
    color: rgb(244 244 242 / 0.6);
    margin-top: 0.35rem;
    max-width: 62ch;
  }

  /* ================= BANNER / A — survey band ================= */
  .ban-a {
    position: relative;
    overflow: hidden;
    height: min(60svh, 560px);
    min-height: 300px;
  }
  .ban-a-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ban-a-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgb(14 15 17 / 0.75) 0%, rgb(14 15 17 / 0.1) 42%, transparent 70%);
  }
  .ban-a-tags {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block-end: 1.25rem;
  }
  .ban-a-tag {
    background: rgb(14 15 17 / 0.85);
    color: #fff;
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-brand);
  }
  .ban-a-tag-end { color: var(--color-mey-teal); }

  /* ================= BANNER / B — project triptych ================= */
  .ban-b {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-line);
  }
  @media (min-width: 640px) {
    .ban-b { grid-template-columns: repeat(3, 1fr); }
  }
  .ban-b-cell {
    position: relative;
    overflow: hidden;
    height: min(52svh, 520px);
    min-height: 300px;
    background: var(--color-night-950);
  }
  .ban-b-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease-out;
  }
  .ban-b-cell:hover .ban-b-img { transform: scale(1.02); }
  .ban-b-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgb(14 15 17 / 0.82) 0%, rgb(14 15 17 / 0.12) 45%, transparent 68%);
  }
  .ban-b-idx {
    position: absolute;
    top: 0.75rem;
    inset-inline-start: 0.75rem;
    background: rgb(14 15 17 / 0.8);
    color: var(--color-red-on-dark);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-brand);
  }
  .ban-b-cap {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .ban-b-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.15rem, 2.4vw, 1.6rem);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.05;
  }
  .ban-b-type { color: rgb(244 244 242 / 0.75); }

  /* ================= BANNER / C — dark red-line CTA ================= */
  .ban-c {
    position: relative;
    overflow: hidden;
    min-height: min(56svh, 480px);
    display: flex;
    align-items: center;
    padding-block: clamp(3rem, 8vh, 5.5rem);
  }
  .ban-c-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
  }
  .ban-c-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgb(14 15 17 / 0.92) 0%, rgb(14 15 17 / 0.7) 45%, rgb(14 15 17 / 0.45) 100%);
  }
  .ban-c-inner { position: relative; max-width: 42rem; }
  .ban-c-eyebrow { color: var(--color-red-on-dark); }
  .ban-c-title { margin-top: 0.85rem; }
  .ban-c-sub {
    margin-top: 1rem;
    color: rgb(244 244 242 / 0.82);
    max-width: 42ch;
  }
  .ban-c-cta {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
