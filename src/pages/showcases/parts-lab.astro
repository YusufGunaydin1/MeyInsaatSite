---
/*
  YARATICI PARÇALAR LAB — /showcases/parts-lab. Ana sayfada henüz OLMAYAN yeni
  bölüm fikirleri; gerçek asset'lerle (inşaat aşamaları, önce/sonra, malzeme,
  iç mekan) ve gerçek rakamlarla (23 yıl grup, 6 yıl inşaat — uydurma yok).
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import { Image } from 'astro:assets';
import p1 from '../../assets/showcase/process-1.webp';
import p2 from '../../assets/showcase/process-2.webp';
import p3 from '../../assets/showcase/process-3.webp';
import p4 from '../../assets/showcase/process-4.webp';
import p5 from '../../assets/showcase/process-5.webp';
import p6 from '../../assets/showcase/process-6.webp';
import beforeAfter from '../../assets/showcase/before-after.webp';
import materials from '../../assets/photos/materials-finish-palette.webp';
import planningDesk from '../../assets/photos/planning-design-desk.webp';
import lobby from '../../assets/photos/lobby-elevator-stairwell.webp';

const stages = [
  { no: '01', name: 'Kazı & Zemin', img: p1 },
  { no: '02', name: 'Kaba İnşaat', img: p2 },
  { no: '03', name: 'Duvar & Dolgu', img: p3 },
  { no: '04', name: 'Cephe & Yalıtım', img: p4 },
  { no: '05', name: 'Tamamlanan Cephe', img: p5 },
  { no: '06', name: 'Teslim', img: p6 },
];
const mood = [
  { img: materials, tag: 'MALZEME & FİNİŞ', name: 'Seçilmiş malzeme paleti' },
  { img: planningDesk, tag: 'PLANLAMA', name: 'Projeden sahaya' },
  { img: lobby, tag: 'İÇ MEKAN', name: 'Ortak alan & teslim kalitesi' },
];
const SW = [400, 720, 960];
---

<Base locale="tr" page="home" path="/showcases/parts-lab" title="Yaratıcı Parçalar Lab — Tasarım Vitrini" noindex>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Yaratıcı Parçalar"
    title="Yeni Bölüm Fikirleri"
    desc="Ana sayfada henüz olmayan yaratıcı bölümler: inşaat yolculuğu, önce/sonra dönüşüm, malzeme & doku, neden MEY. Beğendiğini ana sayfaya ekleriz."
  />

  <!-- P1 — construction journey strip (static cousin of the scroll-to-build) -->
  <Specimen
    id="PARÇA / P1"
    name="İnşaat yolculuğu — statik şerit"
    why="Scroll-to-build'in kaydırmasız kuzeni: 6 gerçek aşama yan yana, mono numaralı, kırmızı taban çizgisiyle. Animasyon kapalı cihazlarda da süreci anlatır."
  >
    <section class="theatre blueprint-grid section-pad">
      <div class="container-site">
        <p class="t-tech" style="color: var(--color-red-on-dark);">İNŞAAT YOLCULUĞU</p>
        <h2 class="t-display-l mt-2 mb-8" style="color:#fff;">Temelden teslime</h2>
        <ol class="pt-journey">
          {stages.map((s) => (
            <li class="pt-stage">
              <span class="pt-stage-media"><Image src={s.img} alt={`${s.name} aşaması`} widths={SW} sizes="(min-width:768px) 30vw, 70vw" class="pt-img" /></span>
              <span class="t-tech pt-no">{s.no}</span>
              <span class="pt-name">{s.name}</span>
            </li>
          ))}
        </ol>
      </div>
    </section>
  </Specimen>

  <!-- P2 — before / after transformation -->
  <Specimen
    id="PARÇA / P2"
    name="Önce / Sonra — dönüşüm bandı"
    why="Tek karede inşaattan teslime dönüşüm; 'ÖNCE' ve 'SONRA' mono etiketleri + kırmızı ayraç. Kentsel dönüşüm hikâyesini bir bakışta anlatır."
  >
    <section class="pt-ba" aria-label="Önce ve sonra — MEY konut dönüşümü">
      <Image src={beforeAfter} alt="Önce inşaat halinde, sonra tamamlanmış MEY konut projesi" widths={[768, 1280, 1600]} sizes="100vw" class="pt-ba-img" />
      <span class="pt-ba-divider" aria-hidden="true"></span>
      <span class="t-tech pt-ba-tag pt-ba-before">ÖNCE</span>
      <span class="t-tech pt-ba-tag pt-ba-after">SONRA · TESLİM</span>
    </section>
  </Specimen>

  <!-- P3 — materials & texture mood board -->
  <Specimen
    id="PARÇA / P3"
    name="Malzeme & doku — kalite kanıtı"
    why="Malzeme paleti, planlama ve iç mekan üçlüsü; 'kalite detayda' mesajını gerçek görsellerle verir. Güven için dokusal kanıt."
  >
    <section class="container-site section-pad">
      <p class="t-tech text-mey-red">KALİTE DETAYDA</p>
      <h2 class="t-display-l mt-2 mb-8">Malzeme & doku</h2>
      <div class="pt-mood">
        {mood.map((m) => (
          <figure class="pt-mood-cell group">
            <Image src={m.img} alt={m.name} widths={SW} sizes="(min-width:768px) 32vw, 100vw" class="pt-img" />
            <figcaption class="pt-mood-cap">
              <span class="t-tech pt-mood-tag">{m.tag}</span>
              <span class="pt-mood-name">{m.name}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  </Specimen>

  <!-- P4 — why MEY / real numbers (no fabricated stats) -->
  <Specimen
    id="PARÇA / P4"
    name="Neden MEY — güven şeridi"
    why="Gerçek rakamlar (23 yıl grup, 6 yıl inşaat) + niteliksel güven vaatleri; koyu tiyatro + teal blueprint. Uydurma sayı yok."
  >
    <section class="theatre blueprint-grid section-pad">
      <div class="container-site">
        <p class="t-tech" style="color: var(--color-red-on-dark);">NEDEN MEY</p>
        <h2 class="t-display-l mt-2 mb-10" style="color:#fff;">Sözünü tutan bir grup</h2>
        <div class="pt-why">
          <div class="pt-why-cell">
            <span class="pt-why-num tabular-nums">23</span>
            <span class="t-tech pt-why-lbl">YIL MEY GRUBU GÜVENCESİ</span>
          </div>
          <div class="pt-why-cell">
            <span class="pt-why-num tabular-nums">6</span>
            <span class="t-tech pt-why-lbl">YIL MEY İNŞAAT DENEYİMİ</span>
          </div>
          <div class="pt-why-cell">
            <span class="pt-why-word">TEK ELDEN</span>
            <span class="t-tech pt-why-lbl">ARSADAN ANAHTAR TESLİME</span>
          </div>
          <div class="pt-why-cell">
            <span class="pt-why-word">ŞEFFAF</span>
            <span class="t-tech pt-why-lbl">GERÇEK ŞANTİYE, GERÇEK GÖRSEL</span>
          </div>
        </div>
      </div>
    </section>
  </Specimen>
</Base>

<style>
  .pt-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 300ms ease-out; }

  /* P1 journey */
  .pt-journey { list-style: none; display: grid; grid-auto-flow: column; grid-auto-columns: 78%; gap: 1rem; overflow-x: auto; padding-bottom: 0.5rem; scroll-snap-type: x mandatory; }
  .pt-stage { position: relative; scroll-snap-align: start; }
  .pt-stage-media { display: block; aspect-ratio: 4 / 3; overflow: hidden; border-radius: var(--radius-brand); border: 1px solid rgb(255 255 255 / 0.08); }
  .pt-no { display: inline-block; margin-top: 0.75rem; color: var(--color-red-on-dark); }
  .pt-name { display: block; font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: 0.01em; text-transform: uppercase; color: #fff; margin-top: 0.15rem; }
  /* 3-up on desktop (not 6) so each stage image is big enough to read the actual
     construction phase — the source shots carry a lot of surrounding street. */
  @media (min-width: 768px) {
    .pt-journey { grid-auto-flow: row; grid-template-columns: repeat(3, 1fr); grid-auto-columns: auto; overflow: visible; gap: 1.75rem 1.25rem; }
  }

  /* P2 before/after */
  .pt-ba { position: relative; overflow: hidden; height: min(58svh, 560px); min-height: 300px; }
  .pt-ba-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pt-ba-divider { position: absolute; top: 0; bottom: 0; inset-inline-start: 50%; width: 2px; background: var(--color-mey-red); opacity: 0.85; }
  .pt-ba-tag { position: absolute; top: 1rem; background: rgb(14 15 17 / 0.82); color: #fff; padding: 0.3rem 0.6rem; border-radius: var(--radius-brand); }
  .pt-ba-before { inset-inline-start: 1rem; }
  .pt-ba-after { inset-inline-end: 1rem; color: var(--color-mey-teal); }

  /* P3 mood */
  .pt-mood { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 768px) { .pt-mood { grid-template-columns: repeat(3, 1fr); } }
  .pt-mood-cell { position: relative; overflow: hidden; border-radius: var(--radius-brand); aspect-ratio: 4 / 5; background: var(--color-night-950); }
  .pt-mood-cell:hover .pt-img { transform: scale(1.02); }
  .pt-mood-cap { position: absolute; inset-inline: 0; bottom: 0; padding: 1rem; background: linear-gradient(to top, rgb(14 15 17 / 0.85), transparent); display: flex; flex-direction: column; gap: 0.25rem; }
  .pt-mood-tag { color: var(--color-mey-teal); }
  .pt-mood-name { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; letter-spacing: 0.01em; text-transform: uppercase; color: #fff; line-height: 1.1; }

  /* P4 why / numbers */
  .pt-why { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgb(255 255 255 / 0.1); border: 1px solid rgb(255 255 255 / 0.1); border-radius: var(--radius-brand); overflow: hidden; }
  @media (min-width: 900px) { .pt-why { grid-template-columns: repeat(4, 1fr); } }
  .pt-why-cell { background: var(--color-night-800); padding: 1.75rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .pt-why-num { font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 7vw, 4.5rem); line-height: 0.9; color: var(--color-red-on-dark); }
  .pt-why-word { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1; letter-spacing: 0.01em; text-transform: uppercase; color: #fff; }
  .pt-why-lbl { color: rgb(244 244 242 / 0.6); }
</style>
