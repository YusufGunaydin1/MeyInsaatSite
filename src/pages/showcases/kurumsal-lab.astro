---
/*
  KURUMSAL LAB — /showcases/kurumsal-lab.
  Kurumsal sayfasının tasarım + içerik yükseltmesi: üç ayrı yön alt alta, her biri
  Specimen künye çubuğuyla. Üçü de AYNI içerik modelini (kurumsal/data.ts) kullanır;
  yalnız yerleşim ve register değişir. Onaylanan varyant CorporatePage.astro'ya
  taşınır. Navigasyonda YOK, noindex.
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import DossierVariant from '../../components/showcase/kurumsal/DossierVariant.astro';
import GalleryVariant from '../../components/showcase/kurumsal/GalleryVariant.astro';
import SurecVariant from '../../components/showcase/kurumsal/SurecVariant.astro';
import SeckiVariant from '../../components/showcase/kurumsal/SeckiVariant.astro';
---

<Base
  locale="tr"
  page="home"
  path="/showcases/kurumsal-lab"
  title="Kurumsal Lab — Tasarım Vitrini"
  noindex
>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Kurumsal Lab"
    title="Kurumsal — Tasarım & İçerik Yükseltmesi"
    desc="Mevcut Kurumsal sayfası tek sütun düzyazıydı; galeri (aksonometri render'leri, 8 marka ikonu, üç gerçek bina, malzeme) kullanılmıyordu. Aşağıda üç yön: her biri aynı sıkılaştırılmış içeriği farklı bir kurguyla sunar — eksik sert bilgiler görünür rozet olarak kalır. Bir yön seç; CorporatePage'e taşınır."
  />

  <Specimen
    id="D · PAFTA ★"
    name="Bütünsel sistem — tüm sayfa tek mimari çizim seti"
    why="Bütünlük düzeltmesi: tek yüzey (concrete-050), ayrım boşluk + kırmızı string-line rayıyla (arka plan takası yok); TEK koyu an (süreç). Her bölüm aynı ray+mono eyebrow+Oswald başlık; her görsel aynı hairline pafta. İmza: hero = gerçek binanın AKSONOMETRİsi çizim olarak — blueprint zemin + KAT 1–6 kot skalası + kırmızı kot çizgisi. Tek hareket: portföy paftası hover'da ÇİZİM→YAPI geçişi. Beğenilen içerik korunur; aday: prod'a bu."
  >
    <SeckiVariant />
  </Specimen>

  <Specimen
    id="A · KÜNYE"
    name="Teknik dossier — çizim↔yapı, mono katman"
    why="Mühendislik künyesi dili: tek gür an, şeffaf aksonometriyi gerçek yapıyla bir kot çizgisiyle karşılaştırır (çizdiğimizi inşa ederiz). Değerler 2×2 künye ızgarası, portföy aksonometri kaydı. En 'teknik/blueprint' yön."
  >
    <DossierVariant />
  </Specimen>

  <Specimen
    id="B · VİTRİN"
    name="Kurumsal galeri — tam-taşma skyline, foto öncelikli"
    why="Ant Yapı/VINCI güveni: tam-taşma üç-bina skyline'ı survey gibi okunur; 8 marka ikonu kabiliyet galerisi, üç gerçek bina kartı, malzeme & işçilik kanıtı. En 'kurumsal/fotoğrafik' yön."
  >
    <GalleryVariant />
  </Specimen>

  <Specimen
    id="C · SÜREÇ"
    name="Yöntem — süreç omurgası, yatay zaman çizelgesi"
    why="Güveni süreçle verir: 8 ikondan kurulu 5 adımlık koyu süreç omurgası (Etüt→Teslim) tek gür an. Hikaye yatay zaman çizelgesi, çizim↔yapı kanıtıyla. En 'kabiliyet/nasıl' yön."
  >
    <SurecVariant />
  </Specimen>
</Base>
