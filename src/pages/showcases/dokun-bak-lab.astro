---
/*
  DOKUN-BAK LAB — /showcases/dokun-bak-lab. Mobilde "İç görünümü aç" düğmesi
  bütün kesiti tek seferde açıyor; sahibi bunu istemiyor (hepsi birden = keşif
  hissi yok). Bu lab dokunmatik için KISMİ gösterim alternatifleri sunar —
  hiçbiri kaydırmayı bloke etmez (touch-action override yok; A yalnız temiz
  dokunuşu algılar, B düğme, C yalnız küçük tutamacı sürükler):
    A  Dokun-bak    — dokunduğun noktada masaüstü merceğinin aynısı, ~2 sn
    B  Kat kesiti   — ▲▼ ile kat kat; seçili kat iki seviye çizgisi arasında
    C  Perde        — tutamaç sürükledikçe kesit alttan yukarı açılır
  Telefonda (veya dar pencerede) denenmeli. Masaüstü hover üretimde aynı kalır.
  noindex.
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import { Image } from 'astro:assets';
import ali from '../../assets/projects/ali.webp';
import aliXray from '../../assets/projects/ali-xray.webp';
import elele from '../../assets/projects/el-ele-apartmani.webp';
import eleleXray from '../../assets/projects/el-ele-apartmani-xray.webp';
import sapan from '../../assets/projects/sapanbaglari.webp';
import sapanXray from '../../assets/projects/sapanbaglari-xray.webp';

const IMG = { widths: [600, 1086], sizes: '(min-width:900px) 40vw, 100vw' };
---

<Base locale="tr" page="home" path="/showcases/dokun-bak-lab" title="Dokun-Bak Lab — Tasarım Vitrini" noindex>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Dokun-Bak Lab"
    title="Mobilde kısmi iç görünüm — 3 alternatif"
    desc="Tam kesit düğmesinin yerine adaylar: hepsi iç mekânı PARÇA PARÇA gösterir, hiçbiri sayfa kaydırmayı engellemez. Telefonda ya da dar pencerede dene; masaüstünde fare merceği üretimde olduğu gibi kalıyor."
  />

  <!-- ─────────────── A — dokun-bak ─────────────── -->
  <Specimen
    id="DOKUN / A"
    name="Dokun-bak — parmağının altındaki daire"
    why="Masaüstü merceğinin dokunmatik çevirisi: dokunduğun noktada aynı küçük yumuşak mercek açılır, ~2 saniye sonra kendiliğinden söner; başka yere dokununca oraya taşınır. Kaydırma jesti mercek açmaz — yalnız temiz dokunuş."
  >
    <section class="container-site section-pad">
      <div class="dh">
        <figure class="dk" data-peek style="--r: 85px;">
          <Image src={ali} alt="Ali Apartmanı — dış cephe" {...IMG} class="dk-img" />
          <Image src={aliXray} alt="" aria-hidden="true" {...IMG} class="dk-img dk-top dk-soft" />
          <span class="t-tech dk-hint">DOKUN — DAİRENİN İÇİNİ GÖR</span>
        </figure>
        <div class="dh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">A · DOKUN-BAK</p>
          <h2 class="t-heading-m">Dokun, bak, kaybolsun</h2>
          <p class="t-body mt-3 text-graphite-600">
            Bir daireye dokun: içi 2 saniyeliğine açılır. Sürükleyip
            kaydırırsan sayfa kayar, mercek açılmaz.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── B — kat kesiti ─────────────── -->
  <Specimen
    id="DOKUN / B"
    name="Kat kesiti — ▲▼ ile kat kat gezinme"
    why="Onaylanan seviye-çizgisi diliyle: seçili kat iki kırmızı çizgi arasında tam genişlikte açılır, ▲▼ katları gezdirir. Hiçbir an binanın tamamı açılmaz; klavye için de doğal (düğmeler odaklanabilir)."
  >
    <section class="container-site section-pad">
      <div class="dh">
        <figure class="db" data-floors="6" style="--bt: 13%; --bb: 88%;">
          <Image src={elele} alt="El Ele Apartmanı — dış cephe" {...IMG} class="dk-img" />
          <Image src={eleleXray} alt="" aria-hidden="true" {...IMG} class="dk-img dk-top db-band" />
          <span class="db-line db-line-a" aria-hidden="true"></span>
          <span class="db-line db-line-b" aria-hidden="true"></span>
          <div class="db-bar">
            <button type="button" class="t-tech db-btn" data-dir="-1" aria-label="Alt kat">▼</button>
            <span class="t-tech db-label" data-label>KAT —</span>
            <button type="button" class="t-tech db-btn" data-dir="1" aria-label="Üst kat">▲</button>
          </div>
        </figure>
        <div class="dh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">B · KAT KESİTİ</p>
          <h2 class="t-heading-m">Kat kat, kontrollü</h2>
          <p class="t-body mt-3 text-graphite-600">
            ▲▼ ile gez: seçili katın içi açılır, gerisi cephe kalır.
            Mimari kat kesiti gibi okunur.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── C — perde ─────────────── -->
  <Specimen
    id="DOKUN / C"
    name="Perde — tutamaçla alttan yukarı sıyır"
    why="Kenardaki tutamacı yukarı sürükledikçe kesit alttan açılır — bina yükselir gibi. Ne kadarının görüneceği tamamen ziyaretçinin elinde; tutamaç dışında dokunmatik serbest, kaydırma hiç etkilenmez."
  >
    <section class="container-site section-pad">
      <div class="dh">
        <figure class="dc" data-curtain>
          <Image src={sapan} alt="Sapanbağları — dış cephe" {...IMG} class="dk-img" />
          <Image src={sapanXray} alt="" aria-hidden="true" {...IMG} class="dk-img dk-top dc-wipe" />
          <span class="dc-edge" aria-hidden="true"></span>
          <button type="button" class="dc-handle" aria-label="İç görünüm perdesi — yukarı sürükle">
            <span class="t-tech dc-grip">═</span>
          </button>
        </figure>
        <div class="dh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">C · PERDE</p>
          <h2 class="t-heading-m">Alttan yukarı, senin hızında</h2>
          <p class="t-body mt-3 text-graphite-600">
            Tutamacı sürükle: kesit o hizaya kadar açılır. Bırakınca kalır;
            aşağı çekince cephe geri gelir. Ok tuşları da çalışır.
          </p>
        </div>
      </div>
    </section>
  </Specimen>
</Base>

<style>
  .dh { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) {
    .dh { grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr); gap: 3.5rem; align-items: start; }
    .dh-info { position: sticky; top: 6rem; }
  }
  .dh-info { padding-inline-start: 1.5rem; }

  /* ortak: hizalı iki katman (kaydırmayı bloke eden hiçbir kural YOK) */
  .dk, .db, .dc {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
    max-width: 560px;
  }
  figure :global(.dk-img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  figure :global(.dk-top) {
    position: absolute;
    inset: 0;
    height: 100%;
    opacity: 0;
    pointer-events: none;
  }

  /* A — dokun-bak: üretimdeki yumuşak mercek, dokunuş noktasında */
  figure :global(.dk-soft) {
    -webkit-mask-image: radial-gradient(circle var(--r, 85px) at var(--x, 50%) var(--y, 50%), #000 65%, transparent 95%);
    mask-image: radial-gradient(circle var(--r, 85px) at var(--x, 50%) var(--y, 50%), #000 65%, transparent 95%);
    transition: opacity 250ms ease-out;
  }
  .dk.show :global(.dk-soft) { opacity: 1; }
  .dk-hint {
    position: absolute;
    bottom: 0.75rem;
    inset-inline: 0;
    margin-inline: auto;
    width: fit-content;
    background: rgb(14 15 17 / 0.85);
    color: var(--color-mey-teal);
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-brand);
    transition: opacity 300ms ease-out;
    pointer-events: none;
  }
  .dk.used .dk-hint { opacity: 0; }

  /* B — kat kesiti: seçili kat bandı + seviye çizgileri + alt bar */
  figure :global(.db-band) {
    clip-path: inset(var(--y1, 50%) 0 calc(100% - var(--y2, 50%)) 0);
  }
  .db.show :global(.db-band) { opacity: 1; }
  .db-line {
    position: absolute;
    inset-inline: 0;
    height: 1px;
    background: var(--color-mey-red);
    opacity: 0;
    transition: opacity 150ms ease-out;
    pointer-events: none;
  }
  .db.show .db-line { opacity: 1; }
  .db-line-a { top: var(--y1, 50%); }
  .db-line-b { top: var(--y2, 50%); }
  .db-bar {
    position: absolute;
    bottom: 0.75rem;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: rgb(14 15 17 / 0.85);
    border-radius: var(--radius-brand);
    padding: 0.2rem;
  }
  .db-btn {
    color: #fff;
    min-width: 2.4rem;
    min-height: 2.4rem;
    cursor: pointer;
    border-radius: var(--radius-brand);
  }
  .db-btn:hover { color: var(--color-red-on-dark); }
  .db-label { color: var(--color-mey-teal); min-width: 4.5ch; text-align: center; }

  /* C — perde: alttan yukarı sıyırma + kenar rayında tutamaç */
  figure :global(.dc-wipe) {
    clip-path: inset(calc(100% - var(--h, 0%)) 0 0 0);
    opacity: 1; /* görünürlüğü clip yönetir */
  }
  .dc-edge {
    position: absolute;
    inset-inline: 0;
    top: calc(100% - var(--h, 0%));
    height: 1px;
    background: var(--color-mey-red);
    opacity: 0.9;
    pointer-events: none;
  }
  .dc-handle {
    position: absolute;
    inset-inline-end: 0.5rem;
    /* asla figür sınırına taşma: kırpılmaz VE hit-test her zaman tutamacı bulur */
    top: clamp(1.375rem, calc(100% - var(--h, 0%)), calc(100% - 1.375rem));
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    background: rgb(14 15 17 / 0.9);
    color: var(--color-mey-teal);
    border: 1px solid rgb(255 255 255 / 0.25);
    border-radius: var(--radius-brand);
    cursor: grab;
    touch-action: none; /* yalnız TUTAMAÇ jesti yakalar; görselin kalanı serbest */
    z-index: 2;
  }
  .dc-handle:active { cursor: grabbing; }
  .dc-grip { pointer-events: none; }
</style>

<script>
  /* A — dokun-bak: yalnız TEMİZ dokunuş (≤10px hareket, ≤400ms) mercek açar;
     kaydırma jesti sayfayı kaydırır. ~2 sn sonra kendiliğinden kapanır. */
  for (const el of document.querySelectorAll<HTMLElement>('[data-peek]')) {
    let sx = 0, sy = 0, st = 0, timer: number | undefined;
    el.addEventListener('pointerdown', (e) => {
      sx = e.clientX; sy = e.clientY; st = performance.now();
    });
    el.addEventListener('pointerup', (e) => {
      const moved = Math.hypot(e.clientX - sx, e.clientY - sy);
      if (moved > 10 || performance.now() - st > 400) return;
      const r = el.getBoundingClientRect();
      el.style.setProperty('--x', (((e.clientX - r.left) / r.width) * 100).toFixed(2) + '%');
      el.style.setProperty('--y', (((e.clientY - r.top) / r.height) * 100).toFixed(2) + '%');
      el.classList.add('show', 'used');
      window.clearTimeout(timer);
      timer = window.setTimeout(() => el.classList.remove('show'), 2000);
    });
  }

  /* B — kat kesiti: ▲▼ kat seçer; bant --bt..--bb aralığında eşit bölünür. */
  for (const el of document.querySelectorAll<HTMLElement>('[data-floors]')) {
    const floors = Number(el.dataset.floors ?? 6);
    const top = parseFloat(getComputedStyle(el).getPropertyValue('--bt'));
    const bottom = parseFloat(getComputedStyle(el).getPropertyValue('--bb'));
    const band = (bottom - top) / floors;
    const label = el.querySelector<HTMLElement>('[data-label]')!;
    let floor = 0; // 0 = kapalı; 1..floors = alt→üst
    const apply = () => {
      if (floor === 0) { el.classList.remove('show'); label.textContent = 'KAT —'; return; }
      const y2 = bottom - (floor - 1) * band;
      el.style.setProperty('--y1', (y2 - band).toFixed(2) + '%');
      el.style.setProperty('--y2', y2.toFixed(2) + '%');
      el.classList.add('show');
      label.textContent = 'KAT ' + floor;
    };
    for (const btn of el.querySelectorAll<HTMLButtonElement>('.db-btn')) {
      btn.addEventListener('click', () => {
        floor = Math.min(floors, Math.max(0, floor + Number(btn.dataset.dir)));
        apply();
      });
    }
  }

  /* C — perde: tutamaç sürüklenir (pointer capture); ok tuşları da çalışır. */
  for (const el of document.querySelectorAll<HTMLElement>('[data-curtain]')) {
    const handle = el.querySelector<HTMLButtonElement>('.dc-handle')!;
    const set = (pct: number) => {
      el.style.setProperty('--h', Math.min(96, Math.max(0, pct)).toFixed(2) + '%');
    };
    const fromClientY = (clientY: number) => {
      const r = el.getBoundingClientRect();
      set(((r.bottom - clientY) / r.height) * 100);
    };
    handle.addEventListener('pointerdown', (e) => {
      handle.setPointerCapture(e.pointerId);
      e.preventDefault();
    });
    handle.addEventListener('pointermove', (e) => {
      if (handle.hasPointerCapture(e.pointerId)) fromClientY(e.clientY);
    });
    handle.addEventListener('keydown', (e) => {
      const cur = parseFloat(el.style.getPropertyValue('--h')) || 0;
      if (e.key === 'ArrowUp') { set(cur + 8); e.preventDefault(); }
      if (e.key === 'ArrowDown') { set(cur - 8); e.preventDefault(); }
    });
  }
</script>
