---
/*
  RÖNTGEN LAB — /showcases/xray-lab. KARAR (2026-07): "Yumuşak geçiş" (eski B)
  KAZANDI; halka (A) ve kat bandı (C) varyantları silindi. Bu sayfa artık yalnız
  kazanan mekaniğin iyileştirme varyantlarını sunar — hepsi istenen şekilde
  DAHA KÜÇÜK alan gösterir. Mekanik: kapak render'ı + aynı kadrajlı kesit ikizi
  piksel-hizalı üst üste; kesit yalnız imleç çevresinde, tüylü kenarla görünür.
  CSS mask + ~30 satır JS; kütüphane yok. Dokunmatik: parmakla sürükleme.
  Klavye/dokunmatik garantisi: KESİT düğmesi tam kesiti açar. noindex.
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import { Image } from 'astro:assets';
import ali from '../../assets/projects/ali.webp';
import aliXray from '../../assets/projects/ali-xray.webp';
import elele from '../../assets/projects/el-ele-apartmani.webp';
import eleleXray from '../../assets/projects/el-ele-apartmani-xray.webp';
import sapan from '../../assets/projects/sapanbaglari.webp';
import sapanXray from '../../assets/projects/sapanbaglari-xray.webp';

const tiles = [
  { name: 'Ali Apartmanı', base: ali, xray: aliXray },
  { name: 'El Ele Apartmanı', base: elele, xray: eleleXray },
  { name: 'Sapanbağları', base: sapan, xray: sapanXray },
];

/* B-iyileştirmeleri karşılaştırılabilir olsun diye dördü de aynı binada (El Ele). */
---

<Base locale="tr" page="home" path="/showcases/xray-lab" title="Röntgen Lab — Tasarım Vitrini" noindex>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Röntgen Lab · 2. tur"
    title="Yumuşak mercek kazandı — küçültülmüş iyileştirmeler"
    desc="Karar: halkasız, tüylü kenarlı yumuşak geçiş. Bu turda mercek alanı küçültüldü ve dört ince iyileştirme sunuluyor; dördü de karşılaştırma kolay olsun diye aynı binada. Dokunmatikte parmak sürükler; KESİT düğmesi tam kesiti açar."
  />

  <!-- ─────────────── B1 — küçültülmüş taban ─────────────── -->
  <Specimen
    id="RÖNTGEN / B1"
    name="Küçük yumuşak mercek — kazananın küçültülmüşü"
    why="Beğenilen efektin birebir kendisi, yalnız alan küçültüldü (190px → 130px yarıçap): tek seferde aşağı yukarı tek daire görünür. Başka hiçbir şey eklenmedi — sıfır süsleme referansı."
  >
    <section class="container-site section-pad">
      <div class="xh">
        <figure class="xr" data-xray="soft" style="--r: 130px;">
          <Image src={elele} alt="El Ele Apartmanı — dış cephe" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img" />
          <Image src={eleleXray} alt="" aria-hidden="true" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img xr-top" />
          <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
        </figure>
        <div class="xh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">B1 · TABAN</p>
          <h2 class="t-heading-m">Aynı efekt, daha dar alan</h2>
          <p class="t-body mt-3 text-graphite-600">
            Yarıçap küçüldü; imleç neredeyse yalnız oradaki daire açılır.
            Diğer üç varyant bunun üzerine birer ince dokunuş ekler.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── B2 — odak karartması ─────────────── -->
  <Specimen
    id="RÖNTGEN / B2"
    name="Odak karartması — çevre hafif söner"
    why="Mercek aynı; aktifken cephenin geri kalanına çok hafif bir karartma iner. Göz kendiliğinden açılan daireye gider — sınır çizgisi çizmeden odak hissi verir. Karartma %25 opaklıkta, sakin."
  >
    <section class="container-site section-pad">
      <div class="xh">
        <figure class="xr" data-xray="soft" style="--r: 120px;">
          <Image src={elele} alt="El Ele Apartmanı — dış cephe" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img" />
          <span class="xr-veil" aria-hidden="true"></span>
          <Image src={eleleXray} alt="" aria-hidden="true" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img xr-top" />
          <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
        </figure>
        <div class="xh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">B2 · ODAK</p>
          <h2 class="t-heading-m">Çevre kısılır, daire parlar</h2>
          <p class="t-body mt-3 text-graphite-600">
            Sinema karartması gibi: dış cephe %25 kısılır, mercek içi tam
            parlaklıkta kalır. Efekt bittiğinde iz bırakmaz.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── B3 — keskin çekirdek, geniş tüy ─────────────── -->
  <Specimen
    id="RÖNTGEN / B3"
    name="Keskin çekirdek — iki kademeli tüy"
    why="Merceğin ortası (≈%45) tam net, kenara doğru iki kademede erir: imlecin altındaki daire kesin okunur, komşu daireler yarı saydam 'ipucu' olarak sezilir. Net alan küçüktür; hissedilen derinlik artar."
  >
    <section class="container-site section-pad">
      <div class="xh">
        <figure class="xr" data-xray="soft-core" style="--r: 150px;">
          <Image src={elele} alt="El Ele Apartmanı — dış cephe" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img" />
          <Image src={eleleXray} alt="" aria-hidden="true" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img xr-top" />
          <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
        </figure>
        <div class="xh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">B3 · ÇEKİRDEK</p>
          <h2 class="t-heading-m">Ortada kesin, kenarda sezgi</h2>
          <p class="t-body mt-3 text-graphite-600">
            Net görünen alan B1'den de dar; ama kenardaki yarı saydam kuşak
            komşu dairelerin varlığını hissettirir.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── B4 — mono etiket eşliği ─────────────── -->
  <Specimen
    id="RÖNTGEN / B4"
    name="Mono etiket — merceğin altında 'İÇ GÖRÜNÜM'"
    why="Mercek B1 ile aynı; altında imleci izleyen küçük bir mono etiket süzülür. Çizgisiz kalır ama teknik bir imza ekler — ziyaretçiye bunun bilinçli bir 'kesit aracı' olduğunu söyler (render/gerçek ayrımı netleşir)."
  >
    <section class="container-site section-pad">
      <div class="xh">
        <figure class="xr" data-xray="soft" style="--r: 125px;">
          <Image src={elele} alt="El Ele Apartmanı — dış cephe" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img" />
          <Image src={eleleXray} alt="" aria-hidden="true" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img xr-top" />
          <span class="t-tech xr-tag" aria-hidden="true">İÇ GÖRÜNÜM</span>
          <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
        </figure>
        <div class="xh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">B4 · ETİKET</p>
          <h2 class="t-heading-m">Sessiz bir teknik imza</h2>
          <p class="t-body mt-3 text-graphite-600">
            Etiket merceğin altında, imleçle birlikte gezer. Halka kadar sert
            değil; ama "bu bir iç görünüm" bilgisini görünür kılar.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── KART ÖLÇEĞİ — kazanan mercek /projeler ızgarasında ─────────────── -->
  <Specimen
    id="RÖNTGEN / KART"
    name="Kart ölçeğinde — yumuşak mercek proje kartlarında"
    why="Seçilen iyileştirme hangisi olursa olsun kart ölçeğinde de çalışacak; burada B1 mekaniği kart boyutuna indirildi (70px). Üç binanın da kesit ikizi hazır."
  >
    <section class="container-site section-pad">
      <div class="xd-grid">
        {tiles.map((tl) => (
          <figure class="card xd-tile">
            <div class="xr xd-media" data-xray="soft" style="--r: 70px;">
              <Image src={tl.base} alt={`${tl.name} — dış cephe`} widths={[480, 800]} sizes="(min-width:1024px) 30vw, 100vw" class="xr-img" />
              <Image src={tl.xray} alt="" aria-hidden="true" widths={[480, 800]} sizes="(min-width:1024px) 30vw, 100vw" class="xr-img xr-top" />
              <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
            </div>
            <figcaption class="xd-cap t-heading-s">{tl.name}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  </Specimen>
</Base>

<style>
  /* Demo bağlamı: görsel + açıklama sütunu */
  .xh { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) {
    .xh { grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr); gap: 3.5rem; align-items: start; }
    .xh-info { position: sticky; top: 6rem; }
  }
  .xh-info { padding-inline-start: 1.5rem; }

  /* Çekirdek: iki piksel-hizalı katman; üstteki (kesit) yalnız mercek içinde görünür */
  .xr {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
    max-width: 560px;
    touch-action: none; /* dokunmatikte parmak merceği sürükler */
  }
  .xr :global(.xr-img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  .xr :global(.xr-top) {
    position: absolute;
    inset: 0;
    height: 100%;
    opacity: 0;
  }
  .xr.active :global(.xr-top) { opacity: 1; }

  /* Kazanan mekanik: tüylü kenarlı yumuşak mercek (tek kademe) */
  [data-xray='soft'] :global(.xr-top) {
    -webkit-mask-image: radial-gradient(circle var(--r, 130px) at var(--x, 50%) var(--y, 50%), #000 58%, transparent 100%);
    mask-image: radial-gradient(circle var(--r, 130px) at var(--x, 50%) var(--y, 50%), #000 58%, transparent 100%);
  }

  /* B3 — keskin çekirdek + iki kademeli tüy: orta tam net, kenar yarı saydam ipucu */
  [data-xray='soft-core'] :global(.xr-top) {
    -webkit-mask-image: radial-gradient(circle var(--r, 150px) at var(--x, 50%) var(--y, 50%), #000 45%, rgb(0 0 0 / 0.38) 68%, transparent 100%);
    mask-image: radial-gradient(circle var(--r, 150px) at var(--x, 50%) var(--y, 50%), #000 45%, rgb(0 0 0 / 0.38) 68%, transparent 100%);
  }

  /* B2 — odak karartması: mercek dışında kalan cepheye hafif perde */
  .xr-veil {
    position: absolute;
    inset: 0;
    background: rgb(14 15 17 / 0.25);
    -webkit-mask-image: radial-gradient(circle calc(var(--r, 120px) * 1.25) at var(--x, 50%) var(--y, 50%), transparent 55%, #000 100%);
    mask-image: radial-gradient(circle calc(var(--r, 120px) * 1.25) at var(--x, 50%) var(--y, 50%), transparent 55%, #000 100%);
    opacity: 0;
    transition: opacity 180ms ease-out;
    pointer-events: none;
  }
  .xr.active .xr-veil { opacity: 1; }
  .xr.open .xr-veil { opacity: 0; }

  /* B4 — merceği izleyen mono etiket */
  .xr-tag {
    position: absolute;
    left: var(--x, 50%);
    top: calc(var(--y, 50%) + var(--r, 125px) + 0.5rem);
    transform: translateX(-50%);
    background: rgb(14 15 17 / 0.85);
    color: var(--color-mey-teal);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-brand);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }
  .xr.active .xr-tag { opacity: 1; }
  .xr.open .xr-tag { opacity: 0; }

  /* Tam kesit (klavye + dokunmatik garantisi): düğme katmanı bütünüyle açar */
  .xr.open :global(.xr-top) {
    opacity: 1 !important;
    -webkit-mask-image: none !important;
    mask-image: none !important;
  }
  .xr-toggle {
    position: absolute;
    bottom: 0.75rem;
    inset-inline-start: 0.75rem;
    z-index: 2;
    background: rgb(14 15 17 / 0.85);
    color: #fff;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-brand);
    cursor: pointer;
  }
  .xr-toggle:hover { color: var(--color-red-on-dark); }

  /* Kart ızgarası: dış kart çerçeveyi taşır, .xr yalnız medya kutusudur */
  .xd-grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .xd-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .xd-grid { grid-template-columns: repeat(3, 1fr); } }
  .xd-tile { overflow: hidden; }
  .xd-media { max-width: none; border: 0; border-radius: 0; }
  .xd-cap {
    padding: 0.9rem 1rem;
    border-top: 1px solid var(--color-line);
    background: #fff;
  }
</style>

<script>
  /*
    Mercek takibi: imleç konumu iki CSS değişkenine (%) yazılır; görünüm tamamen
    CSS'te. Fare: hover. Dokunmatik: parmak sürükler (touch-action: none).
    Düğme: tam kesit aç/kapat (klavye erişimi).
  */
  for (const el of document.querySelectorAll<HTMLElement>('[data-xray]')) {
    const track = (e: PointerEvent) => {
      const r = el.getBoundingClientRect();
      const x = Math.min(100, Math.max(0, ((e.clientX - r.left) / r.width) * 100));
      const y = Math.min(100, Math.max(0, ((e.clientY - r.top) / r.height) * 100));
      el.style.setProperty('--x', x.toFixed(2) + '%');
      el.style.setProperty('--y', y.toFixed(2) + '%');
    };
    el.addEventListener('pointermove', (e) => {
      if (el.classList.contains('open')) return;
      el.classList.add('active');
      track(e);
    });
    el.addEventListener('pointerdown', (e) => {
      if (el.classList.contains('open') || (e.target as HTMLElement).closest('.xr-toggle')) return;
      el.classList.add('active');
      track(e);
    });
    el.addEventListener('pointerleave', () => el.classList.remove('active'));

    const btn = el.querySelector<HTMLButtonElement>('.xr-toggle');
    btn?.addEventListener('click', () => {
      const open = el.classList.toggle('open');
      el.classList.remove('active');
      btn.setAttribute('aria-pressed', String(open));
      btn.textContent = open ? btn.dataset.close! : btn.dataset.open!;
    });
  }
</script>
