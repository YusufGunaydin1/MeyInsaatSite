---
/*
  RÖNTGEN LAB — /showcases/xray-lab. Bina kapak render'ı + aynı kadrajlı "kesit"
  (cephe kalkmış, daireler döşeli) ikizi piksel-hizalı: imleç nereye gelirse
  oradaki dairenin içi görünür. Tam görsel değişimi YOK — sadece imleç altındaki
  bölge. CSS clip-path/mask + ~30 satır JS; kütüphane yok, WebGL yok.
  Dokunmatik: parmakla sürükleme. Klavye/erişilebilirlik: KESİT AÇ düğmesi tam
  kesiti gösterir. noindex.
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import { Image } from 'astro:assets';
import ali from '../../assets/projects/ali.webp';
import aliXray from '../../assets/projects/ali-xray.webp';
import elele from '../../assets/projects/el-ele-apartmani.webp';
import eleleXray from '../../assets/projects/el-ele-apartmani-xray.webp';
import sapan from '../../assets/projects/sapanbaglari.webp';
import sapanXray from '../../assets/projects/sapanbaglari-xray.webp';

const tiles = [
  { name: 'Ali Apartmanı', base: ali, xray: aliXray },
  { name: 'El Ele Apartmanı', base: elele, xray: eleleXray },
  { name: 'Sapanbağları', base: sapan, xray: sapanXray },
];
---

<Base locale="tr" page="home" path="/showcases/xray-lab" title="Röntgen Lab — Tasarım Vitrini" noindex>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Röntgen Lab"
    title="Cephe Röntgeni — imlecin altındaki daire"
    desc="Kapak render'ı ile aynı kadrajdaki kesit ikizi üst üste durur; imleç hangi dairenin üzerindeyse yalnız o bölge iç mekâna açılır. Görsel toptan değişmez. Dokunmatikte parmakla sürüklenir; 'KESİT' düğmesi klavye ve dokunmatik için tam kesiti açar."
  />

  <!-- ─────────────── RÖNTGEN / A — kesit halkası ─────────────── -->
  <Specimen
    id="RÖNTGEN / A"
    name="Mercek — kırmızı kesit halkası"
    why="Keskin dairesel mercek + 1px kırmızı halka + mono 'KESİT' etiketi: bir teknik aletle bakıyormuş hissi. Sınır nettir; neyin render neyin gerçek olduğu karışmaz. Marka dili: guide-line kırmızısı, 2px köşe, mono."
  >
    <section class="container-site section-pad">
      <div class="xh">
        <figure class="xr" data-xray="ring" style="--r: 120px;">
          <Image src={ali} alt="Ali Apartmanı — dış cephe" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img" />
          <Image src={aliXray} alt="" aria-hidden="true" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img xr-top" />
          <span class="xr-ring" aria-hidden="true"><span class="t-tech xr-ring-tag">KESİT</span></span>
          <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
        </figure>
        <div class="xh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">DENE</p>
          <h2 class="t-heading-m">İmleci dairelerin üzerinde gezdir</h2>
          <p class="t-body mt-3 text-graphite-600">
            Mercek imleci izler; hangi dairenin üzerindeysen onun içi görünür.
            Fotoğrafın geri kalanı dış cephe kalır.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── RÖNTGEN / B — yumuşak reveal ─────────────── -->
  <Specimen
    id="RÖNTGEN / B"
    name="Yumuşak geçiş — halkasız, tüylü kenar"
    why="Aynı mekanik, sessiz sunum: kenarı tüylenmiş daha geniş bir alan, çizgisiz. 'Sakin galeri' tonuna en yakın olan; ama kesitin sınırı belirsizleştiği için render/gerçek ayrımı A kadar net okunmaz."
  >
    <section class="container-site section-pad">
      <div class="xh">
        <figure class="xr" data-xray="soft" style="--r: 190px;">
          <Image src={elele} alt="El Ele Apartmanı — dış cephe" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img" />
          <Image src={eleleXray} alt="" aria-hidden="true" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img xr-top" />
          <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
        </figure>
        <div class="xh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">DENE</p>
          <h2 class="t-heading-m">Aynı efekt, çerçevesiz</h2>
          <p class="t-body mt-3 text-graphite-600">
            Kenar tüylü, geçiş yumuşak. Halka ve etiket yok — daha sinematik,
            daha az teknik.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── RÖNTGEN / C — kat bandı ─────────────── -->
  <Specimen
    id="RÖNTGEN / C"
    name="Kat bandı — seviye çizgili yatay kesit"
    why="Mercek yerine mimari kat kesiti: imlecin bulunduğu kat, iki kırmızı seviye çizgisi arasında TÜM genişlikte açılır. Onaylanan 'yükselen kotlar' diliyle aynı aile — çizim gibi okunur; daire daire değil kat kat gezdirir."
  >
    <section class="container-site section-pad">
      <div class="xh">
        <figure class="xr" data-xray="band" style="--band: 9.5%;">
          <Image src={sapan} alt="Sapanbağları — dış cephe" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img" />
          <Image src={sapanXray} alt="" aria-hidden="true" widths={[600, 1086]} sizes="(min-width:900px) 40vw, 100vw" class="xr-img xr-top" />
          <span class="xr-line xr-line-a" aria-hidden="true"><span class="t-tech xr-line-tag">KAT KESİTİ</span></span>
          <span class="xr-line xr-line-b" aria-hidden="true"></span>
          <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
        </figure>
        <div class="xh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">DENE</p>
          <h2 class="t-heading-m">Yukarı-aşağı gezdir: kat kat kesit</h2>
          <p class="t-body mt-3 text-graphite-600">
            İmlecin yüksekliğindeki kat, tüm genişlikte açılır; iki kırmızı
            seviye çizgisi bandı işaretler.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── RÖNTGEN / D — proje kartı ölçeği ─────────────── -->
  <Specimen
    id="RÖNTGEN / D"
    name="Kart ölçeğinde — /projeler ızgarasında mercek"
    why="Aynı A merceği proje kartlarında: liste sayfasında gezinirken bile daireler içten görülebilir. Yarıçap kart ölçeğine indirildi; üç binada da kesit ikizi hazır."
  >
    <section class="container-site section-pad">
      <div class="xd-grid">
        {tiles.map((tl) => (
          <figure class="card xd-tile">
            <div class="xr xd-media" data-xray="ring" style="--r: 80px;">
              <Image src={tl.base} alt={`${tl.name} — dış cephe`} widths={[480, 800]} sizes="(min-width:1024px) 30vw, 100vw" class="xr-img" />
              <Image src={tl.xray} alt="" aria-hidden="true" widths={[480, 800]} sizes="(min-width:1024px) 30vw, 100vw" class="xr-img xr-top" />
              <span class="xr-ring" aria-hidden="true"><span class="t-tech xr-ring-tag">KESİT</span></span>
              <button type="button" class="t-tech xr-toggle" aria-pressed="false" data-open="KESİTİ AÇ" data-close="KESİTİ KAPAT">KESİTİ AÇ</button>
            </div>
            <figcaption class="xd-cap t-heading-s">{tl.name}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  </Specimen>
</Base>

<style>
  /* Demo bağlamı: görsel + açıklama sütunu */
  .xh { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) {
    .xh { grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr); gap: 3.5rem; align-items: start; }
    .xh-info { position: sticky; top: 6rem; }
  }
  .xh-info { padding-inline-start: 1.5rem; }

  /* Çekirdek: iki piksel-hizalı katman; üstteki (kesit) yalnız mercek içinde görünür */
  .xr {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
    max-width: 560px;
    touch-action: none; /* dokunmatikte parmak merceği sürükler */
  }
  .xr :global(.xr-img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  .xr :global(.xr-top) {
    position: absolute;
    inset: 0;
    height: 100%;
  }

  /* A/D — keskin dairesel mercek */
  [data-xray='ring'] :global(.xr-top) {
    clip-path: circle(0px at var(--x, 50%) var(--y, 50%));
  }
  [data-xray='ring'].active :global(.xr-top) {
    clip-path: circle(var(--r, 110px) at var(--x, 50%) var(--y, 50%));
  }
  .xr-ring {
    position: absolute;
    left: var(--x, 50%);
    top: var(--y, 50%);
    width: calc(var(--r, 110px) * 2);
    height: calc(var(--r, 110px) * 2);
    transform: translate(-50%, -50%);
    border: 1px solid var(--color-mey-red);
    border-radius: 9999px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }
  .xr.active .xr-ring { opacity: 1; }
  .xr.open .xr-ring { opacity: 0; }
  .xr-ring-tag {
    position: absolute;
    bottom: -0.4rem;
    left: 50%;
    transform: translate(-50%, 100%);
    background: rgb(14 15 17 / 0.85);
    color: var(--color-red-on-dark);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-brand);
    white-space: nowrap;
  }

  /* B — tüylü kenarlı yumuşak reveal */
  [data-xray='soft'] :global(.xr-top) {
    -webkit-mask-image: radial-gradient(circle var(--r, 190px) at var(--x, 50%) var(--y, 50%), #000 58%, transparent 100%);
    mask-image: radial-gradient(circle var(--r, 190px) at var(--x, 50%) var(--y, 50%), #000 58%, transparent 100%);
    opacity: 0;
  }
  [data-xray='soft'].active :global(.xr-top) { opacity: 1; }

  /* C — kat bandı: imleç yüksekliğinde tam genişlik yatay kesit */
  [data-xray='band'] :global(.xr-top) {
    clip-path: inset(50% 0 50% 0);
  }
  [data-xray='band'].active :global(.xr-top) {
    clip-path: inset(
      clamp(0%, calc(var(--y, 50%) - var(--band, 9.5%)), 100%) 0
      clamp(0%, calc(100% - var(--y, 50%) - var(--band, 9.5%)), 100%) 0
    );
  }
  .xr-line {
    position: absolute;
    inset-inline: 0;
    height: 1px;
    background: var(--color-mey-red);
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease-out;
  }
  .xr-line-a { top: clamp(0%, calc(var(--y, 50%) - var(--band, 9.5%)), 100%); }
  .xr-line-b { top: clamp(0%, calc(var(--y, 50%) + var(--band, 9.5%)), 100%); }
  .xr.active .xr-line { opacity: 1; }
  .xr.open .xr-line { opacity: 0; }
  .xr-line-tag {
    position: absolute;
    inset-inline-end: 0.75rem;
    top: 0;
    transform: translateY(-100%);
    background: rgb(14 15 17 / 0.85);
    color: var(--color-red-on-dark);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-brand);
  }

  /* Tam kesit (klavye + dokunmatik garantisi): düğme her katmanı açar */
  .xr.open :global(.xr-top) {
    clip-path: inset(0) !important;
    -webkit-mask-image: none !important;
    mask-image: none !important;
    opacity: 1 !important;
  }
  .xr-toggle {
    position: absolute;
    bottom: 0.75rem;
    inset-inline-start: 0.75rem;
    z-index: 2;
    background: rgb(14 15 17 / 0.85);
    color: #fff;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-brand);
    cursor: pointer;
  }
  .xr-toggle:hover { color: var(--color-red-on-dark); }

  /* D — kart ızgarası: dış kart çerçeveyi taşır, .xr yalnız medya kutusudur */
  .xd-grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .xd-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .xd-grid { grid-template-columns: repeat(3, 1fr); } }
  .xd-tile { overflow: hidden; }
  .xd-media { max-width: none; border: 0; border-radius: 0; }
  .xd-cap {
    padding: 0.9rem 1rem;
    border-top: 1px solid var(--color-line);
    background: #fff;
  }
</style>

<script>
  /*
    Mercek takibi: imleç konumu iki CSS değişkenine (%) yazılır; hangi varyantın
    nasıl açılacağı tamamen CSS'te. Fare: hover. Dokunmatik: parmak sürükler
    (touch-action: none). Düğme: tam kesit aç/kapat (klavye erişimi).
  */
  for (const el of document.querySelectorAll<HTMLElement>('[data-xray]')) {
    const track = (e: PointerEvent) => {
      const r = el.getBoundingClientRect();
      const x = Math.min(100, Math.max(0, ((e.clientX - r.left) / r.width) * 100));
      const y = Math.min(100, Math.max(0, ((e.clientY - r.top) / r.height) * 100));
      el.style.setProperty('--x', x.toFixed(2) + '%');
      el.style.setProperty('--y', y.toFixed(2) + '%');
    };
    el.addEventListener('pointermove', (e) => {
      if (el.classList.contains('open')) return;
      el.classList.add('active');
      track(e);
    });
    el.addEventListener('pointerdown', (e) => {
      if (el.classList.contains('open') || (e.target as HTMLElement).closest('.xr-toggle')) return;
      el.classList.add('active');
      track(e);
    });
    el.addEventListener('pointerleave', () => el.classList.remove('active'));

    const btn = el.querySelector<HTMLButtonElement>('.xr-toggle');
    btn?.addEventListener('click', () => {
      const open = el.classList.toggle('open');
      el.classList.remove('active');
      btn.setAttribute('aria-pressed', String(open));
      btn.textContent = open ? btn.dataset.close! : btn.dataset.open!;
    });
  }
</script>
