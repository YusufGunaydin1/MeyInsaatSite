---
/*
  KÜNYE & SÜREÇ LAB — /showcases/kunye-surec-lab.
  İki kalıbın yeniden tasarımı: (1) proje detay künyesi (beyaz hücre ızgarası +
  tekrar eden kesikli "Bilgi bekleniyor" çipleri jenerik okunuyor), (2) numaralı
  süreç kartları (4 beyaz kutu + sol-üst numara = varsayılan şablon görünümü).
  Varyantlar gerçek içerik ve gerçek token'larla; eksik bilgi TEK dipnotla,
  bağıra bağıra değil. noindex.
*/
import Base from '../../layouts/Base.astro';
import LabIntro from '../../components/showcase/LabIntro.astro';
import Specimen from '../../components/showcase/Specimen.astro';
import { pageContent, project, ui } from '../../lib/content';
import { Image } from 'astro:assets';
import aliCover from '../../assets/projects/ali.webp';

const t = ui('tr');
const ali = project('ali', 'tr');
const aliName = ali?.md?.frontmatter?.name ?? 'Ali Apartmanı';
const aliSummary = ali?.md?.frontmatter?.summary ?? '';
const d = ali?.data ?? {};

// Gerçek künye satırları: null → "—" (tek dipnot açıklar, çip tekrarı yok)
const specs = [
  { label: t.projects.specs.location, value: d.location },
  { label: t.projects.specs.type, value: t.projects.types?.[d.type] ?? d.type },
  { label: t.projects.specs.status, value: t.projects.status?.[d.status] ?? d.status },
  { label: t.projects.specs.year, value: d.year },
  { label: t.projects.specs.units, value: d.units },
];
const missingNote =
  '— işaretli alanlar: bilgi MEY tarafından doğrulandığında eklenecek.';

const steps: { name: string; desc: string }[] =
  pageContent('hizmetler', 'tr')?.frontmatter?.process?.steps ?? [];
---

<Base locale="tr" page="home" path="/showcases/kunye-surec-lab" title="Künye & Süreç Lab — Tasarım Vitrini" noindex>
  <LabIntro
    kicker="MEY İnşaat · Dahili · Künye & Süreç Lab"
    title="Künye & Süreç — Tasarım Varyantları"
    desc="Proje künyesi (spec tablosu) ve 'Nasıl çalışırız' adımları için jenerik-olmayan alternatifler. 2. tur: SÜREÇ/A onaylanıp canlıya alındı; künye için D/E/F, beğenilen kot-çizgisi dilinde ve detay-hero bağlamında eklendi. Eksik gerçek bilgi görünür kalır ama tek dipnota iner."
  />

  <!-- ─────────────── KÜNYE / A — çizim anteti ─────────────── -->
  <Specimen
    id="KÜNYE / A"
    name="Antet — çizim künyesi"
    why="Her teknik çizimin köşesinde bir antet vardır: mono etiket, noktalı kılavuz, hizalı değer. Eksik alan '—' olur ve TEK dipnot açıklar — üç kesikli çip yerine bir sessiz blok."
  >
    <section class="container-site section-pad">
      <div class="ka-ctx">
        <p class="t-tech text-mey-red mb-3">PROJELER</p>
        <h2 class="t-display-l">{aliName}</h2>
        <p class="t-body-l mt-4 max-w-xl">{aliSummary}</p>

        <div class="ka-antet mt-8">
          <div class="ka-antet-head">
            <span class="t-tech">PROJE KÜNYESİ</span>
            <span class="t-tech ka-antet-brand">MEY İNŞAAT</span>
          </div>
          {specs.map((s) => (
            <div class="ka-row">
              <span class="t-tech ka-label">{s.label}</span>
              <span class="ka-leader" aria-hidden="true"></span>
              <span class:list={['t-tech ka-value', !s.value && 'ka-missing']}>
                {s.value ?? '—'}
              </span>
            </div>
          ))}
          <p class="t-caption ka-note">{missingNote}</p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── KÜNYE / B — tek satır teknik ray ─────────────── -->
  <Specimen
    id="KÜNYE / B"
    name="Künye rayı — yatay teknik şerit"
    why="Kutu ızgarası yerine tek nefeste okunan yatay bir şerit: ince hairline'larla ayrılmış beş alan, mono etiket üstte, değer altta. Boş hücre kalmaz, ölü gri kutu kalmaz."
  >
    <section class="container-site section-pad">
      <div class="ka-ctx">
        <p class="t-tech text-mey-red mb-3">PROJELER</p>
        <h2 class="t-display-l">{aliName}</h2>
        <p class="t-body-l mt-4 max-w-xl">{aliSummary}</p>

        <div class="kb-rail mt-8">
          {specs.map((s) => (
            <div class="kb-cell">
              <span class="t-tech ka-label">{s.label}</span>
              <span class:list={['kb-value', !s.value && 'kb-missing']}>
                {s.value ?? '—'}
              </span>
            </div>
          ))}
        </div>
        <p class="t-caption ka-note-plain mt-3">{missingNote}</p>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── KÜNYE / C — guide-line seviye listesi ─────────────── -->
  <Specimen
    id="KÜNYE / C"
    name="Seviye listesi — kırmızı guide-line"
    why="Sitenin yapısal motifi (§7 guide-line) künyeye taşınır: kırmızı düşey çizgi üzerinde satır satır seviye okuması. Dikey ritim, sıfır kutu; detay sayfasının yan sütununa doğal oturur."
  >
    <section class="container-site section-pad">
      <div class="ka-ctx">
        <p class="t-tech text-mey-red mb-3">PROJELER</p>
        <h2 class="t-display-l">{aliName}</h2>
        <p class="t-body-l mt-4 max-w-xl">{aliSummary}</p>

        <dl class="kc-list mt-8">
          {specs.map((s) => (
            <div class="kc-row">
              <dt class="t-tech ka-label">{s.label}</dt>
              <dd class:list={['kc-value', !s.value && 'kc-missing']}>
                {s.value ?? '—'}
              </dd>
            </div>
          ))}
        </dl>
        <p class="t-caption ka-note-plain mt-3">{missingNote}</p>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── KÜNYE / D — kot çizgileri (SÜREÇ/A dili) ─────────────── -->
  <Specimen
    id="KÜNYE / D"
    name="Kot çizgileri — seviye künyesi (tam sayfa bağlamında)"
    why="Onaylanan 'yükselen kotlar' dili künyeye taşınır: her alan bir kırmızı seviye çizgisi, mono etiket çizginin üstünde süzülür, değer altta güçlü. Kutu yok, çip yok; detay hero'sunun yanında gerçek bağlamıyla."
  >
    <section class="container-site section-pad">
      <div class="kh">
        <figure class="kh-media">
          <Image src={aliCover} alt={aliName} widths={[480, 800]} sizes="(min-width:900px) 40vw, 100vw" class="kh-img" />
        </figure>
        <div class="kh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">PROJELER</p>
          <h2 class="t-display-l">{aliName}</h2>
          <p class="t-body-l mt-4">{aliSummary}</p>

          <div class="kd-grid mt-10">
            {specs.map((s) => (
              <div class="kd-item">
                <span class="kd-line"><span class="t-tech kd-label">{s.label}</span></span>
                <p class:list={['kd-value', !s.value && 'kd-missing']}>{s.value ?? '—'}</p>
              </div>
            ))}
          </div>
          <p class="t-caption ka-note-plain mt-4">{missingNote}</p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── KÜNYE / E — foto üstü survey etiketleri ─────────────── -->
  <Specimen
    id="KÜNYE / E"
    name="Cephe etiketi — künye fotoğrafın üzerinde"
    why="Bina yıldızsa künye onun üzerinde okunmalı: fotoğrafın kenarında kırmızı bir nivo direği, bilinen gerçekler şantiye etiketi gibi asılır (hero'daki 'TESLİM EDİLDİ · 6 KAT' diliyle). Bilinmeyenler tek soluk etikete iner; yan sütun nefes alır."
  >
    <section class="container-site section-pad">
      <div class="kh">
        <figure class="kh-media ke-media">
          <Image src={aliCover} alt={aliName} widths={[480, 800]} sizes="(min-width:900px) 40vw, 100vw" class="kh-img" />
          <span class="ke-pole" aria-hidden="true"></span>
          <span class="ke-tag t-tech" style="--kt: 14%;">{(t.projects.types?.[d.type] ?? d.type).toUpperCase()}</span>
          <span class="ke-tag t-tech" style="--kt: 38%;">{(t.projects.status?.[d.status] ?? d.status).toUpperCase()}</span>
          <span class="ke-tag ke-tag-pending t-tech" style="--kt: 62%;">KONUM · YIL · DAİRE — DOĞRULANIYOR</span>
        </figure>
        <div class="kh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">PROJELER</p>
          <h2 class="t-display-l">{aliName}</h2>
          <p class="t-body-l mt-4">{aliSummary}</p>
          <p class="t-caption ka-note-plain mt-6">Künye fotoğrafın üzerinde; bu sütun hikâyeye kalır.</p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── KÜNYE / F — sadece bilinenler ─────────────── -->
  <Specimen
    id="KÜNYE / F"
    name="Sadece bilinenler — tek mono satır"
    why="En sakin dürüstlük: boş alan hiç çizilmez. Bilinen iki gerçek tek mono satırda (kırmızı ara noktayla), eksikler tek cümlelik notta. Veri geldikçe satır uzar; sayfa hiçbir gün 'eksik şablon' gibi görünmez."
  >
    <section class="container-site section-pad">
      <div class="kh">
        <figure class="kh-media">
          <Image src={aliCover} alt={aliName} widths={[480, 800]} sizes="(min-width:900px) 40vw, 100vw" class="kh-img" />
        </figure>
        <div class="kh-info guide-line-v">
          <p class="t-tech text-mey-red mb-3">PROJELER</p>
          <h2 class="t-display-l">{aliName}</h2>
          <p class="t-body-l mt-4">{aliSummary}</p>

          <p class="kf-line mt-8">
            <span>{t.projects.types?.[d.type] ?? d.type}</span>
            <span class="kf-dot" aria-hidden="true">·</span>
            <span>{t.projects.status?.[d.status] ?? d.status}</span>
          </p>
          <p class="t-caption ka-note-plain mt-3">
            Konum, teslim yılı ve daire sayısı MEY tarafından doğrulandığında eklenecek.
          </p>
        </div>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── SÜREÇ / A — yükselen kotlar (CANLIDA) ─────────────── -->
  <Specimen
    id="SÜREÇ / A"
    name="Yükselen kotlar — CANLIDA (ana sayfa 03 + hizmetler)"
    why="Onaylandı ve production'a alındı (ProcessSteps.astro). Dört adım, dört kot: her adım bir öncekinden yukarıda biter, kırmızı seviye çizgisi katı işaretler — süreç bir binanın yükselişi gibi okunur."
  >
    <section class="bg-concrete-100 border-y border-line">
      <div class="container-site section-pad">
        <p class="t-tech text-mey-red">03 — HİZMETLER</p>
        <h2 class="t-display-l mt-2 mb-12">Nasıl çalışırız</h2>
        <ol class="pa">
          {steps.map((s, i) => (
            <li class="pa-step">
              <span class="pa-level">
                <span class="t-tech pa-no">{String(i + 1).padStart(2, '0')}</span>
              </span>
              <h3 class="t-heading-s mt-3">{s.name}</h3>
              <p class="t-caption text-graphite-600 mt-2">{s.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>
  </Specimen>

  <!-- ─────────────── SÜREÇ / B — kesintisiz ray ─────────────── -->
  <Specimen
    id="SÜREÇ / B"
    name="Kesintisiz ray — çentikli zaman çizgisi"
    why="Tek bir hairline dört adımı birbirine bağlar; her adım kırmızı bir çentikle başlar (şantiye şeridindeki metre işaretleri gibi). Numara başlığın içinde akar, ayrı bir rozet değildir."
  >
    <section class="container-site section-pad">
      <p class="t-tech text-mey-red">03 — HİZMETLER</p>
      <h2 class="t-display-l mt-2 mb-12">Nasıl çalışırız</h2>
      <ol class="pb">
        {steps.map((s, i) => (
          <li class="pb-step">
            <h3 class="pb-name">
              <span class="t-tech pb-no">{String(i + 1).padStart(2, '0')}</span>
              {s.name}
            </h3>
            <p class="t-caption text-graphite-600 mt-2">{s.desc}</p>
          </li>
        ))}
      </ol>
    </section>
  </Specimen>

  <!-- ─────────────── SÜREÇ / C — devasa numara ─────────────── -->
  <Specimen
    id="SÜREÇ / C"
    name="Devasa numara — editoryal endeks"
    why="Numara utangaç bir köşe rozeti olmaktan çıkar, soluk devasa bir Oswald rakamına dönüşür; ad ve açıklama üzerine biner. Tipografi taşır, kart taşımaz — dergi endeksi sükûneti."
  >
    <section class="container-site section-pad">
      <p class="t-tech text-mey-red">03 — HİZMETLER</p>
      <h2 class="t-display-l mt-2 mb-10">Nasıl çalışırız</h2>
      <ol class="pc">
        {steps.map((s, i) => (
          <li class="pc-step">
            <span class="pc-big" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="t-heading-s pc-name">{s.name}</h3>
            <p class="t-caption text-graphite-600 mt-2">{s.desc}</p>
          </li>
        ))}
      </ol>
    </section>
  </Specimen>
</Base>

<style>
  .ka-ctx { max-width: 40rem; }

  /* Paylaşılan künye parçaları */
  .ka-label { color: var(--color-graphite-400); }
  .ka-note-plain { color: var(--color-graphite-400); }

  /* A — antet (çizim künyesi) */
  .ka-antet {
    border: 1px solid var(--color-graphite-900);
    border-radius: var(--radius-brand);
    background: #fff;
  }
  .ka-antet-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--color-graphite-900);
    color: var(--color-graphite-900);
  }
  .ka-antet-brand { color: var(--color-mey-red); }
  .ka-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
  }
  .ka-row + .ka-row { border-top: 1px solid var(--color-line); }
  .ka-leader { flex: 1; border-bottom: 1px dotted var(--color-graphite-400); opacity: 0.55; }
  .ka-value { color: var(--color-graphite-900); }
  .ka-missing { color: var(--color-graphite-400); }
  .ka-note {
    color: var(--color-graphite-400);
    padding: 0.6rem 1rem;
    border-top: 1px dashed var(--color-line);
  }

  /* B — yatay künye rayı */
  .kb-rail {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    row-gap: 1.25rem;
    border-block: 1px solid var(--color-graphite-900);
    padding-block: 1rem;
  }
  @media (min-width: 640px) {
    .kb-rail { grid-template-columns: repeat(5, auto); justify-content: space-between; }
    .kb-cell + .kb-cell { border-inline-start: 1px solid var(--color-line); padding-inline-start: 1.5rem; }
  }
  .kb-cell { display: flex; flex-direction: column; gap: 0.35rem; }
  .kb-value {
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-graphite-900);
    font-variant-numeric: tabular-nums;
  }
  .kb-missing { color: var(--color-graphite-400); font-weight: 400; }

  /* C — guide-line seviye listesi */
  .kc-list { border-inline-start: 2px solid var(--color-mey-red); padding-inline-start: 1.5rem; }
  .kc-row {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.75rem;
    position: relative;
  }
  .kc-row + .kc-row { border-top: 1px solid var(--color-line); }
  /* seviye çentiği: guide-line'dan içeri kısa kırmızı tik */
  .kc-row::before {
    content: "";
    position: absolute;
    inset-inline-start: -1.5rem;
    top: 50%;
    width: 0.6rem;
    height: 1px;
    background: var(--color-mey-red);
  }
  .kc-value { font-weight: 600; color: var(--color-graphite-900); font-variant-numeric: tabular-nums; }
  .kc-missing { color: var(--color-graphite-400); font-weight: 400; }

  /* D/E/F ortak bağlam: detay-hero düzeni (foto + bilgi sütunu) */
  .kh { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) {
    .kh { grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr); gap: 3.5rem; align-items: start; }
  }
  .kh-media {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-brand);
    background: var(--color-concrete-100);
  }
  .kh-img { width: 100%; height: auto; display: block; aspect-ratio: 3 / 4; object-fit: cover; }
  .kh-info { padding-inline-start: 1.5rem; }

  /* D — kot çizgileri künyesi */
  .kd-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.25rem 2rem;
    padding-top: 1.4rem;
  }
  .kd-line { display: block; border-top: 2px solid var(--color-mey-red); position: relative; }
  .kd-label { position: absolute; top: -1.5rem; inset-inline-start: 0; color: var(--color-graphite-400); }
  .kd-value {
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-graphite-900);
    margin-top: 0.5rem;
    font-variant-numeric: tabular-nums;
  }
  .kd-missing { color: var(--color-graphite-400); font-weight: 400; }

  /* E — foto üstü survey etiketleri */
  .ke-pole {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 1.25rem;
    width: 2px;
    background: var(--color-mey-red);
    opacity: 0.9;
  }
  .ke-tag {
    position: absolute;
    top: var(--kt);
    inset-inline-start: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgb(14 15 17 / 0.85);
    color: #fff;
    padding: 0.3rem 0.6rem 0.3rem 1rem;
    border-radius: var(--radius-brand);
    white-space: nowrap;
  }
  /* nivo çentiği: direkten etikete kısa kırmızı tik */
  .ke-tag::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 50%;
    width: 0.65rem;
    height: 2px;
    background: var(--color-mey-red);
  }
  .ke-tag-pending { color: rgb(244 244 242 / 0.55); border: 1px dashed rgb(244 244 242 / 0.25); background: rgb(14 15 17 / 0.7); }

  /* F — sadece bilinenler, tek mono satır */
  .kf-line {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-graphite-900);
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    border-block: 1px solid var(--color-line);
    padding-block: 0.85rem;
  }
  .kf-dot { color: var(--color-mey-red); }

  /* SÜREÇ A — yükselen kotlar */
  .pa { list-style: none; display: grid; grid-template-columns: 1fr; gap: 2rem; }
  .pa-level { display: block; border-top: 2px solid var(--color-mey-red); position: relative; }
  .pa-no {
    position: absolute;
    top: -1.6rem;
    inset-inline-start: 0;
    color: var(--color-mey-red);
  }
  @media (min-width: 900px) {
    .pa {
      grid-template-columns: repeat(4, 1fr);
      gap: 0 2rem;
      align-items: end;
      border-bottom: 1px solid var(--color-graphite-400);
    }
    /* her adım bir kot yukarıda biter — yükselen bina silüeti */
    .pa-step:nth-child(1) { padding-bottom: 1.5rem; }
    .pa-step:nth-child(2) { padding-bottom: 4rem; }
    .pa-step:nth-child(3) { padding-bottom: 6.5rem; }
    .pa-step:nth-child(4) { padding-bottom: 9rem; }
  }

  /* SÜREÇ B — kesintisiz ray */
  .pb { list-style: none; position: relative; display: grid; grid-template-columns: 1fr; gap: 2rem; }
  .pb::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-line);
  }
  .pb-step { position: relative; padding-inline-start: 1.5rem; }
  .pb-step::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 0.35rem;
    width: 0.9rem;
    height: 2px;
    background: var(--color-mey-red);
  }
  .pb-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--color-graphite-900);
  }
  .pb-no { color: var(--color-mey-red); margin-inline-end: 0.6rem; }
  @media (min-width: 900px) {
    .pb { grid-template-columns: repeat(4, 1fr); gap: 2rem; }
    .pb::before { inset-inline: 0; top: 0; bottom: auto; width: auto; height: 1px; }
    .pb-step { padding-inline-start: 0; padding-top: 1.5rem; }
    .pb-step::before { top: -0.5px; width: 2px; height: 0.9rem; }
  }

  /* SÜREÇ C — devasa numara */
